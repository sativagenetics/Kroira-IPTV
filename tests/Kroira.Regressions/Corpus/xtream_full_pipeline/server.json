{
  "routes": [
    {
      "path": "/xtream/xmltv.php",
      "query": { "username": "demo", "password": "demo" },
      "bodyFile": "guide.xml"
    },
    {
      "path": "/xtream/player_api.php",
      "query": { "username": "demo", "password": "demo", "action": "get_live_categories" },
      "bodyFile": "live_categories.json"
    },
    {
      "path": "/xtream/player_api.php",
      "query": { "username": "demo", "password": "demo", "action": "get_live_streams" },
      "bodyFile": "live_streams.json"
    },
    {
      "path": "/xtream/player_api.php",
      "query": { "username": "demo", "password": "demo", "action": "get_vod_categories" },
      "bodyFile": "vod_categories.json"
    },
    {
      "path": "/xtream/player_api.php",
      "query": { "username": "demo", "password": "demo", "action": "get_series_categories" },
      "bodyFile": "series_categories.json"
    },
    {
      "path": "/xtream/player_api.php",
      "query": { "username": "demo", "password": "demo", "action": "get_vod_streams" },
      "bodyFile": "vod_streams.json"
    },
    {
      "path": "/xtream/player_api.php",
      "query": { "username": "demo", "password": "demo", "action": "get_series" },
      "bodyFile": "series.json"
    },
    {
      "path": "/xtream/player_api.php",
      "query": { "username": "demo", "password": "demo", "action": "get_series_info", "series_id": "5001" },
