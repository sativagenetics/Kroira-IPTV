<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Typography ramp. Segoe UI Variable Display is used as the system-safe
        substitute for Manrope on Windows 11. Inter is kept as a fallback
        token in case it gets installed / bundled later.
    -->
    <x:String x:Key="KroiraDisplayFontFamily">Segoe UI Variable Display, Segoe UI Variable, Segoe UI</x:String>
    <x:String x:Key="KroiraTextFontFamily">Segoe UI Variable Text, Segoe UI Variable, Segoe UI</x:String>

    <!-- Display / hero -->
    <Style x:Key="KroiraDisplayLgStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource KroiraDisplayFontFamily}" />
        <Setter Property="FontSize" Value="44" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="52" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!-- Page title (retuned to be smaller / calmer) -->
    <Style x:Key="KroiraPageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource KroiraDisplayFontFamily}" />
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="KroiraPageSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource KroiraTextFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!-- Section header (e.g. "Continue Watching") -->
    <Style x:Key="KroiraSectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource KroiraDisplayFontFamily}" />
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
    </Style>

    <Style x:Key="KroiraSectionHeaderStyle" TargetType="TextBlock" BasedOn="{StaticResource KroiraSectionTitleStyle}">
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <!-- Card title -->
    <Style x:Key="KroiraTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource KroiraTextFontFamily}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
    </Style>

    <!-- Body -->
    <Style x:Key="KroiraBodyStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource KroiraTextFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!-- Small metadata / label -->
    <Style x:Key="KroiraLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource KroiraTextFontFamily}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="60" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextTertiaryBrush}" />
    </Style>

</ResourceDictionary>
