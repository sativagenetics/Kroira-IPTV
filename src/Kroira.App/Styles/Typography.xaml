<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <x:String x:Key="KroiraDisplayFontFamily">Segoe UI Variable Display, Segoe UI Variable, Segoe UI</x:String>
    <x:String x:Key="KroiraTextFontFamily">Segoe UI Variable Text, Segoe UI Variable, Segoe UI</x:String>

    <Style x:Key="KroiraDisplayXlStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource KroiraDisplayFontFamily}" />
        <Setter Property="FontSize" Value="58" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="64" />
        <Setter Property="CharacterSpacing" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="KroiraDisplayLgStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource KroiraDisplayFontFamily}" />
        <Setter Property="FontSize" Value="46" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="54" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="KroiraPageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource KroiraDisplayFontFamily}" />
        <Setter Property="FontSize" Value="34" />
        <Setter Property="LineHeight" Value="40" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="KroiraH1Style" TargetType="TextBlock" BasedOn="{StaticResource KroiraPageTitleStyle}" />

    <Style x:Key="KroiraPageSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource KroiraTextFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="LineHeight" Value="20" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="KroiraSectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource KroiraDisplayFontFamily}" />
        <Setter Property="FontSize" Value="19" />
        <Setter Property="LineHeight" Value="25" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
    </Style>

    <Style x:Key="KroiraSectionHeaderStyle" TargetType="TextBlock" BasedOn="{StaticResource KroiraSectionTitleStyle}">
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <Style x:Key="KroiraTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource KroiraTextFontFamily}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="LineHeight" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
    </Style>

    <Style x:Key="KroiraBodyStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource KroiraTextFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="LineHeight" Value="19" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="KroiraLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource KroiraTextFontFamily}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="LineHeight" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="120" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextTertiaryBrush}" />
    </Style>

    <Style x:Key="KroiraEyebrowStyle" TargetType="TextBlock" BasedOn="{StaticResource KroiraLabelStyle}" />

    <Style x:Key="KroiraMetaStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource KroiraTextFontFamily}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="LineHeight" Value="16" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextTertiaryBrush}" />
    </Style>

    <Style x:Key="KroiraMonoStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, Segoe UI Mono" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="LineHeight" Value="16" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextSecondaryBrush}" />
    </Style>

</ResourceDictionary>
