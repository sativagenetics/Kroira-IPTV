<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Premium media palette: black glass, warm cinema chrome, cold broadcast accent. -->

    <SolidColorBrush x:Key="KroiraPageBackgroundBrush" Color="#090A0D" />
    <SolidColorBrush x:Key="KroiraGlassBrush" Color="#6613181F" />
    <SolidColorBrush x:Key="KroiraGlassStrongBrush" Color="#8A171C23" />
    <SolidColorBrush x:Key="KroiraSurfaceSoftBrush" Color="#10141A" />
    <SolidColorBrush x:Key="KroiraSurfaceBrush" Color="#151A22" />
    <SolidColorBrush x:Key="KroiraSurfaceElevatedBrush" Color="#1B212A" />

    <SolidColorBrush x:Key="KroiraBorderBrush" Color="#29313C" />
    <SolidColorBrush x:Key="KroiraBorderStrongBrush" Color="#47515F" />
    <SolidColorBrush x:Key="KroiraGhostBorderBrush" Color="#FFFFFF" Opacity="0.13" />
    <SolidColorBrush x:Key="KroiraGlassBorderBrush" Color="#FFFFFF" Opacity="0.18" />
    <SolidColorBrush x:Key="KroiraChromeLineBrush" Color="#C8A86A" Opacity="0.34" />

    <SolidColorBrush x:Key="KroiraTextPrimaryBrush" Color="#F6F3EA" />
    <SolidColorBrush x:Key="KroiraTextSecondaryBrush" Color="#C7C1B6" />
    <SolidColorBrush x:Key="KroiraTextTertiaryBrush" Color="#817C74" />

    <SolidColorBrush x:Key="KroiraAccentBrush" Color="#E7C46E" />
    <SolidColorBrush x:Key="KroiraAccentStrongBrush" Color="#F1A63E" />
    <SolidColorBrush x:Key="KroiraAccentContainerBrush" Color="#342716" />
    <SolidColorBrush x:Key="KroiraGoldBrush" Color="#E7C46E" />
    <SolidColorBrush x:Key="KroiraLiveDotBrush" Color="#FF4E4E" />

    <SolidColorBrush x:Key="KroiraStateSuccessBrush" Color="#5AC178" />
    <SolidColorBrush x:Key="KroiraStateSuccessSoftBrush" Color="#5AC178" Opacity="0.16" />
    <SolidColorBrush x:Key="KroiraStateWarningBrush" Color="#F3BA55" />
    <SolidColorBrush x:Key="KroiraStateWarningSoftBrush" Color="#F3BA55" Opacity="0.16" />
    <SolidColorBrush x:Key="KroiraStateDangerBrush" Color="#E85C66" />
    <SolidColorBrush x:Key="KroiraStateDangerSoftBrush" Color="#E85C66" Opacity="0.16" />
    <SolidColorBrush x:Key="KroiraStateInfoBrush" Color="#78D7E8" />
    <SolidColorBrush x:Key="KroiraStateInfoSoftBrush" Color="#78D7E8" Opacity="0.16" />
    <SolidColorBrush x:Key="KroiraStateNeutralBrush" Color="#AEB6C3" />
    <SolidColorBrush x:Key="KroiraStateNeutralSoftBrush" Color="#AEB6C3" Opacity="0.10" />

    <SolidColorBrush x:Key="KroiraControlBrush" Color="#F6F3EA" Opacity="0.075" />
    <SolidColorBrush x:Key="KroiraControlBorderBrush" Color="#FFFFFF" Opacity="0.16" />

    <LinearGradientBrush x:Key="KroiraPageAtmosphereBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#171A1F" Offset="0" />
        <GradientStop Color="#090A0D" Offset="0.48" />
        <GradientStop Color="#050607" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="KroiraShellGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#17100A" Offset="0" />
        <GradientStop Color="#090A0D" Offset="0.48" />
        <GradientStop Color="#030405" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="KroiraSurfaceGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#242A33" Offset="0" />
        <GradientStop Color="#10141A" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="KroiraMediaGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#362514" Offset="0" />
        <GradientStop Color="#161B22" Offset="0.46" />
        <GradientStop Color="#090A0D" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="KroiraAccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F0C568" Offset="0" />
        <GradientStop Color="#A95B25" Offset="1" />
    </LinearGradientBrush>

</ResourceDictionary>
