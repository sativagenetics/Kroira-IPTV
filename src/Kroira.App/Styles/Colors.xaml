<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Premium media palette: ink canvas, smoky glass surfaces, restrained blue accent. -->

    <SolidColorBrush x:Key="KroiraPageBackgroundBrush" Color="#120F1D" />
    <SolidColorBrush x:Key="KroiraShellBackgroundBrush" Color="#0C0A15" />
    <SolidColorBrush x:Key="KroiraGlassBrush" Color="#5A211E33" />
    <SolidColorBrush x:Key="KroiraGlassStrongBrush" Color="#74272240" />
    <SolidColorBrush x:Key="KroiraSurfaceSoftBrush" Color="#1A1728" />
    <SolidColorBrush x:Key="KroiraSurfaceBrush" Color="#211D33" />
    <SolidColorBrush x:Key="KroiraSurfaceElevatedBrush" Color="#2A2540" />
    <SolidColorBrush x:Key="KroiraSurfaceHighBrush" Color="#352F4E" />

    <SolidColorBrush x:Key="KroiraBorderBrush" Color="#3A3451" />
    <SolidColorBrush x:Key="KroiraBorderStrongBrush" Color="#554C73" />
    <SolidColorBrush x:Key="KroiraGhostBorderBrush" Color="#FFFFFF" Opacity="0.16" />
    <SolidColorBrush x:Key="KroiraGlassBorderBrush" Color="#FFFFFF" Opacity="0.22" />

    <SolidColorBrush x:Key="KroiraTextPrimaryBrush" Color="#F4F6FA" />
    <SolidColorBrush x:Key="KroiraTextSecondaryBrush" Color="#C5CBD5" />
    <SolidColorBrush x:Key="KroiraTextTertiaryBrush" Color="#8B93A1" />

    <SolidColorBrush x:Key="KroiraAccentBrush" Color="#AEBBFF" />
    <SolidColorBrush x:Key="KroiraAccentStrongBrush" Color="#768BFF" />
    <SolidColorBrush x:Key="KroiraAccentContainerBrush" Color="#312D59" />
    <SolidColorBrush x:Key="KroiraGoldBrush" Color="#E8C987" />
    <SolidColorBrush x:Key="KroiraLiveDotBrush" Color="#E85C66" />

    <SolidColorBrush x:Key="KroiraStateSuccessBrush" Color="#5AC178" />
    <SolidColorBrush x:Key="KroiraStateSuccessSoftBrush" Color="#5AC178" Opacity="0.16" />
    <SolidColorBrush x:Key="KroiraStateWarningBrush" Color="#F3BA55" />
    <SolidColorBrush x:Key="KroiraStateWarningSoftBrush" Color="#F3BA55" Opacity="0.16" />
    <SolidColorBrush x:Key="KroiraStateDangerBrush" Color="#E85C66" />
    <SolidColorBrush x:Key="KroiraStateDangerSoftBrush" Color="#E85C66" Opacity="0.16" />
    <SolidColorBrush x:Key="KroiraStateInfoBrush" Color="#91B6FF" />
    <SolidColorBrush x:Key="KroiraStateInfoSoftBrush" Color="#91B6FF" Opacity="0.16" />
    <SolidColorBrush x:Key="KroiraStateNeutralBrush" Color="#AEB6C3" />
    <SolidColorBrush x:Key="KroiraStateNeutralSoftBrush" Color="#AEB6C3" Opacity="0.10" />

    <SolidColorBrush x:Key="KroiraMagentaBrush" Color="#8EA0E8" />

    <SolidColorBrush x:Key="KroiraControlBrush" Color="#EAF0F8" Opacity="0.08" />
    <SolidColorBrush x:Key="KroiraControlBorderBrush" Color="#FFFFFF" Opacity="0.18" />

    <LinearGradientBrush x:Key="KroiraPageAtmosphereBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#201B34" Offset="0" />
        <GradientStop Color="#120F1D" Offset="0.52" />
        <GradientStop Color="#0B0913" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="KroiraShellGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#211D31" Offset="0" />
        <GradientStop Color="#121020" Offset="0.48" />
        <GradientStop Color="#080712" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="KroiraSurfaceGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#302A47" Offset="0" />
        <GradientStop Color="#1B1729" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="KroiraMediaGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#302A47" Offset="0" />
        <GradientStop Color="#191525" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="KroiraAccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#5F66C5" Offset="0" />
        <GradientStop Color="#3A376D" Offset="1" />
    </LinearGradientBrush>

</ResourceDictionary>
