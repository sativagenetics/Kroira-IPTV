<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="KroiraPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="#620B101A" />
        <Setter Property="BorderBrush" Value="{StaticResource KroiraGhostBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource KroiraRadiusPanel}" />
        <Setter Property="Padding" Value="22" />
    </Style>

    <Style x:Key="KroiraCardStyle" TargetType="Border">
        <Setter Property="Background" Value="#5C101827" />
        <Setter Property="BorderBrush" Value="{StaticResource KroiraGhostBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource KroiraRadiusCard}" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style x:Key="KroiraPosterCardStyle" TargetType="Border">
        <Setter Property="Background" Value="#30101827" />
        <Setter Property="BorderBrush" Value="{StaticResource KroiraHaloBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource KroiraRadiusCard}" />
    </Style>

    <Style x:Key="KroiraRowStyle" TargetType="Border">
        <Setter Property="Background" Value="#4D101827" />
        <Setter Property="BorderBrush" Value="{StaticResource KroiraGhostBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource KroiraRadiusRow}" />
        <Setter Property="Padding" Value="16,12" />
    </Style>

    <Style x:Key="KroiraSettingsGroupStyle" TargetType="Border">
        <Setter Property="Background" Value="#66101827" />
        <Setter Property="BorderBrush" Value="{StaticResource KroiraGhostBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource KroiraRadiusPanel}" />
        <Setter Property="Padding" Value="20,18" />
    </Style>

    <Style x:Key="KroiraSettingsRowStyle" TargetType="Border">
        <Setter Property="Background" Value="#440B101A" />
        <Setter Property="BorderBrush" Value="{StaticResource KroiraGhostBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource KroiraRadiusRow}" />
        <Setter Property="Padding" Value="14,12" />
    </Style>

    <Style x:Key="KroiraMediaRowContainerStyle" TargetType="ListViewItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="CornerRadius" Value="{StaticResource KroiraRadiusRow}" />
    </Style>

    <Style x:Key="KroiraTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="#9A070B12" />
        <Setter Property="BorderBrush" Value="{StaticResource KroiraControlBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
        <Setter Property="PlaceholderForeground" Value="{StaticResource KroiraTextTertiaryBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource KroiraRadiusInput}" />
        <Setter Property="Padding" Value="15,10" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
    </Style>

    <Style x:Key="KroiraComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Background" Value="#9A070B12" />
        <Setter Property="BorderBrush" Value="{StaticResource KroiraControlBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource KroiraRadiusInput}" />
        <Setter Property="Padding" Value="15,8" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
    </Style>

    <Style x:Key="KroiraButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#66101827" />
        <Setter Property="BorderBrush" Value="{StaticResource KroiraControlBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource KroiraRadiusInput}" />
        <Setter Property="Padding" Value="15,9" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
    </Style>

    <Style x:Key="KroiraGhostButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#32101827" />
        <Setter Property="BorderBrush" Value="{StaticResource KroiraControlBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource KroiraRadiusInput}" />
        <Setter Property="Padding" Value="15,9" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
    </Style>

    <Style x:Key="KroiraPrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource KroiraAccentGradientBrush}" />
        <Setter Property="BorderBrush" Value="#77DDB8FF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="#080A12" />
        <Setter Property="CornerRadius" Value="{StaticResource KroiraRadiusInput}" />
        <Setter Property="Padding" Value="18,10" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="MinHeight" Value="42" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
    </Style>

    <Style x:Key="KroiraDangerButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource KroiraStateDangerSoftBrush}" />
        <Setter Property="BorderBrush" Value="#55E85C66" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="#FFD6DA" />
        <Setter Property="CornerRadius" Value="{StaticResource KroiraRadiusInput}" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
    </Style>

    <Style x:Key="KroiraChromePanelStyle" TargetType="Border">
        <Setter Property="Background" Value="#7A070B12" />
        <Setter Property="BorderBrush" Value="{StaticResource KroiraGhostBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource KroiraRadiusPanel}" />
        <Setter Property="Padding" Value="22" />
    </Style>

    <Style x:Key="KroiraFilterStripStyle" TargetType="Border">
        <Setter Property="Background" Value="#78070B12" />
        <Setter Property="BorderBrush" Value="{StaticResource KroiraGhostBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="12" />
    </Style>

    <Style x:Key="KroiraLibraryToolbarStyle" TargetType="Border">
        <Setter Property="Background" Value="#72070B12" />
        <Setter Property="BorderBrush" Value="{StaticResource KroiraGhostBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="MinHeight" Value="66" />
    </Style>

    <Style x:Key="KroiraCategoryRailPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="#4A070B12" />
        <Setter Property="BorderBrush" Value="{StaticResource KroiraChromeLineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Padding" Value="8" />
    </Style>

    <Style x:Key="KroiraCategoryRailItemContainerStyle" TargetType="ListViewItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,0,6" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="CornerRadius" Value="13" />
        <Setter Property="UseSystemFocusVisuals" Value="True" />
    </Style>

    <DataTemplate x:Key="KroiraCategoryRailItemTemplate">
        <Grid MinHeight="44"
              ToolTipService.ToolTip="{Binding Name}">
            <Border Background="{StaticResource KroiraAccentContainerBrush}"
                    BorderBrush="{StaticResource KroiraChromeLineBrush}"
                    BorderThickness="1"
                    CornerRadius="13"
                    Opacity="{Binding SelectionBackgroundOpacity}" />
            <Border BorderBrush="{StaticResource KroiraAccentBrush}"
                    BorderThickness="1"
                    CornerRadius="13"
                    Opacity="{Binding SelectionChromeOpacity}" />
            <Border Width="3"
                    HorizontalAlignment="Left"
                    Margin="0,7,0,7"
                    CornerRadius="2"
                    Background="{StaticResource KroiraAccentBrush}"
                    Opacity="{Binding SelectionAccentOpacity}" />
            <Grid Padding="11,8,9,8" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <FontIcon Glyph="{Binding IconGlyph}"
                          FontSize="12"
                          Foreground="{StaticResource KroiraAccentBrush}"
                          Opacity="0.82"
                          VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"
                            Spacing="1"
                            MinWidth="0"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding Name}"
                               Foreground="{StaticResource KroiraTextPrimaryBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               MaxLines="1"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Description}"
                               Visibility="{Binding DescriptionVisibility}"
                               Foreground="{StaticResource KroiraTextTertiaryBrush}"
                               FontSize="10"
                               MaxLines="1"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <Border Grid.Column="2"
                        Background="#1AFFFFFF"
                        BorderBrush="{StaticResource KroiraChromeLineBrush}"
                        BorderThickness="1"
                        CornerRadius="9"
                        Padding="6,2"
                        MinWidth="28"
                        VerticalAlignment="Center"
                        Visibility="{Binding CountVisibility}">
                    <TextBlock Text="{Binding CountText}"
                               Foreground="{StaticResource KroiraTextSecondaryBrush}"
                               FontSize="10"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                </Border>
            </Grid>
        </Grid>
    </DataTemplate>

    <Style x:Key="KroiraLaneColumnStyle" TargetType="Border">
        <Setter Property="Background" Value="#36070B12" />
        <Setter Property="BorderBrush" Value="{StaticResource KroiraGhostBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style x:Key="KroiraLaneHeaderStyle" TargetType="Border">
        <Setter Property="Background" Value="#54111827" />
        <Setter Property="BorderBrush" Value="{StaticResource KroiraChromeLineBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="CornerRadius" Value="16,16,0,0" />
        <Setter Property="Padding" Value="16,14,16,12" />
        <Setter Property="MinHeight" Value="76" />
    </Style>

    <Style x:Key="KroiraLaneCountBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="#24251235" />
        <Setter Property="BorderBrush" Value="{StaticResource KroiraChromeLineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="MinWidth" Value="42" />
    </Style>

    <Style x:Key="KroiraLaneClearButtonStyle" TargetType="Button" BasedOn="{StaticResource KroiraGhostButtonStyle}">
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource KroiraChromeLineBrush}" />
        <Setter Property="Background" Value="#22111827" />
        <Setter Property="CornerRadius" Value="12" />
    </Style>

    <Style x:Key="KroiraCountBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="#2E251235" />
        <Setter Property="BorderBrush" Value="{StaticResource KroiraChromeLineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="13,9" />
    </Style>

</ResourceDictionary>
