<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Canonical poster treatment for Movies, Series, and Home Continue
        Watching. Consumers compose their own DataTemplate but should bind
        against these tokens for sizing and style so all three screens stay
        visually aligned.

        Aspect ratio is the cinema standard 2:3.
    -->

    <x:Double x:Key="KroiraPosterWidth">180</x:Double>
    <x:Double x:Key="KroiraPosterHeight">270</x:Double>
    <x:Double x:Key="KroiraPosterCornerRadius">10</x:Double>

    <!-- Landscape variant (16:9) for channels / live / CW episodes -->
    <x:Double x:Key="KroiraLandscapeWidth">300</x:Double>
    <x:Double x:Key="KroiraLandscapeHeight">169</x:Double>

    <!-- The image container itself. No border; tonal surface as fallback. -->
    <Style x:Key="KroiraPosterFrameStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource KroiraSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="{StaticResource KroiraPosterCornerRadius}" />
        <Setter Property="Width" Value="{StaticResource KroiraPosterWidth}" />
        <Setter Property="Height" Value="{StaticResource KroiraPosterHeight}" />
    </Style>

    <!-- GridViewItem container — removes default Fluent chrome and spacing -->
    <Style x:Key="KroiraPosterItemContainerStyle" TargetType="GridViewItem">
        <Setter Property="Margin" Value="0,0,20,24" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Top" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="{StaticResource KroiraPosterCornerRadius}" />
    </Style>

    <!-- Title under poster -->
    <Style x:Key="KroiraPosterTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource KroiraTextFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="MaxLines" Value="2" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="LineHeight" Value="17" />
    </Style>

    <!-- Secondary metadata under poster (category, year) -->
    <Style x:Key="KroiraPosterMetaStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource KroiraTextFontFamily}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextSecondaryBrush}" />
        <Setter Property="MaxLines" Value="1" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="KroiraResultCountStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource KroiraTextFontFamily}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextTertiaryBrush}" />
    </Style>

    <!-- Small floating badge for in-poster overlays (e.g. LIVE, seasons count) -->
    <Style x:Key="KroiraPosterBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="#B30B0C10" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Margin" Value="8" />
    </Style>

    <Style x:Key="KroiraPosterBadgeTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource KroiraTextFontFamily}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="60" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
    </Style>

    <!-- Fallback placeholder background (used when no poster URL) -->
    <LinearGradientBrush x:Key="KroiraPosterPlaceholderBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1F242E" Offset="0" />
        <GradientStop Color="#14161C" Offset="1" />
    </LinearGradientBrush>

    <!-- Filter/search bar (flat, not inside a panel) -->
    <Style x:Key="KroiraFilterTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource KroiraTextBoxStyle}">
        <Setter Property="Background" Value="{StaticResource KroiraSurfaceSoftBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="14,8" />
    </Style>

    <Style x:Key="KroiraFilterComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource KroiraComboBoxStyle}">
        <Setter Property="Background" Value="{StaticResource KroiraSurfaceSoftBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="14,6" />
    </Style>

</ResourceDictionary>
