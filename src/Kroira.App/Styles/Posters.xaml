<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <x:Double x:Key="KroiraPosterWidth">184</x:Double>
    <x:Double x:Key="KroiraPosterHeight">276</x:Double>
    <x:Double x:Key="KroiraPosterCornerRadius">10</x:Double>

    <x:Double x:Key="KroiraLandscapeWidth">320</x:Double>
    <x:Double x:Key="KroiraLandscapeHeight">180</x:Double>

    <Style x:Key="KroiraPosterFrameStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource KroiraPosterPlaceholderBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource KroiraGlassBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource KroiraPosterCornerRadius}" />
        <Setter Property="Width" Value="{StaticResource KroiraPosterWidth}" />
        <Setter Property="Height" Value="{StaticResource KroiraPosterHeight}" />
    </Style>

    <Style x:Key="KroiraPosterItemContainerStyle" TargetType="GridViewItem">
        <Setter Property="Margin" Value="0,0,22,26" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Top" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="{StaticResource KroiraPosterCornerRadius}" />
    </Style>

    <Style x:Key="KroiraPosterTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource KroiraTextFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="LineHeight" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="MaxLines" Value="2" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="KroiraPosterMetaStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource KroiraTextFontFamily}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="LineHeight" Value="16" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextTertiaryBrush}" />
        <Setter Property="MaxLines" Value="1" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="KroiraResultCountStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource KroiraTextFontFamily}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextTertiaryBrush}" />
    </Style>

    <Style x:Key="KroiraPosterBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="#C2111720" />
        <Setter Property="BorderBrush" Value="{StaticResource KroiraGlassBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="7,3" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Margin" Value="9" />
    </Style>

    <Style x:Key="KroiraPosterBadgeTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource KroiraTextFontFamily}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="70" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
    </Style>

    <LinearGradientBrush x:Key="KroiraPosterPlaceholderBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#372717" Offset="0" />
        <GradientStop Color="#172129" Offset="0.46" />
        <GradientStop Color="#0A0C10" Offset="1" />
    </LinearGradientBrush>

    <Style x:Key="KroiraFilterTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource KroiraTextBoxStyle}">
        <Setter Property="Background" Value="#E80A0D11" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
        <Setter Property="PlaceholderForeground" Value="{StaticResource KroiraTextTertiaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource KroiraGlassBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="Padding" Value="16,10" />
    </Style>

    <Style x:Key="KroiraFilterComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource KroiraComboBoxStyle}">
        <Setter Property="Background" Value="#E80A0D11" />
        <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource KroiraGlassBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="Padding" Value="16,8" />
    </Style>

</ResourceDictionary>
