<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Structural design tokens. Colors live in Colors.xaml, type in
        Typography.xaml. This dictionary only holds scalar primitives so
        layout values stop being hardcoded across pages.

        Naming: Kroira{Kind}{Size}. Kinds: Space, Radius, Duration.
        Sizes: 1=4px, 2=8, 3=12, 4=16, 5=20, 6=24, 7=32, 8=40, 9=56, 10=72.
    -->

    <!-- Spacing (px) -->
    <x:Double x:Key="KroiraSpace1">4</x:Double>
    <x:Double x:Key="KroiraSpace2">8</x:Double>
    <x:Double x:Key="KroiraSpace3">12</x:Double>
    <x:Double x:Key="KroiraSpace4">16</x:Double>
    <x:Double x:Key="KroiraSpace5">20</x:Double>
    <x:Double x:Key="KroiraSpace6">24</x:Double>
    <x:Double x:Key="KroiraSpace7">32</x:Double>
    <x:Double x:Key="KroiraSpace8">40</x:Double>
    <x:Double x:Key="KroiraSpace9">56</x:Double>
    <x:Double x:Key="KroiraSpace10">72</x:Double>

    <!-- Page margins and content caps -->
    <Thickness x:Key="KroiraPagePadding">40,28,40,40</Thickness>
    <Thickness x:Key="KroiraPagePaddingCompact">24,20,24,28</Thickness>
    <x:Double x:Key="KroiraPageMaxWidth">1440</x:Double>
    <x:Double x:Key="KroiraPageContentMaxWidth">1200</x:Double>
    <x:Double x:Key="KroiraReadableMaxWidth">720</x:Double>

    <!-- Corner radii -->
    <CornerRadius x:Key="KroiraRadiusInput">4</CornerRadius>
    <CornerRadius x:Key="KroiraRadiusChip">999</CornerRadius>
    <CornerRadius x:Key="KroiraRadiusRow">8</CornerRadius>
    <CornerRadius x:Key="KroiraRadiusCard">10</CornerRadius>
    <CornerRadius x:Key="KroiraRadiusPanel">12</CornerRadius>
    <CornerRadius x:Key="KroiraRadiusSheet">14</CornerRadius>

    <!-- Durations (ms) -->
    <x:Double x:Key="KroiraDurationFast">120</x:Double>
    <x:Double x:Key="KroiraDurationBase">200</x:Double>
    <x:Double x:Key="KroiraDurationSlow">240</x:Double>

    <!-- Focus ring -->
    <x:Double x:Key="KroiraFocusRingThickness">2</x:Double>

    <!--
        Poster / card slot sizes defined here as a layout reference.
        Canonical sizing (including KroiraPosterWidth/Height) lives in
        Posters.xaml and is authoritative. These channel/live sizes are
        additive and do not duplicate Posters.xaml keys.
    -->
    <x:Double x:Key="KroiraChannelCardWidth">176</x:Double>
    <x:Double x:Key="KroiraChannelCardHeight">160</x:Double>
    <x:Double x:Key="KroiraLiveCardWidth">280</x:Double>
    <x:Double x:Key="KroiraLiveCardHeight">168</x:Double>
    <x:Double x:Key="KroiraContinueCardWidth">280</x:Double>
    <x:Double x:Key="KroiraQuickActionCardWidth">192</x:Double>
    <x:Double x:Key="KroiraQuickActionCardHeight">104</x:Double>

</ResourceDictionary>
