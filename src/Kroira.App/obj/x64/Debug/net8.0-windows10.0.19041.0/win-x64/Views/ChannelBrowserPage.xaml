<Page x:ConnectionId='1'
    x:Class="Kroira.App.Views.ChannelBrowserPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16" Spacing="16">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:ConnectionId='6' Content="Back"                    />
                <TextBlock Text="Browser" Style="{ThemeResource TitleTextBlockStyle}" VerticalAlignment="Center"/>
            </StackPanel>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ComboBox x:ConnectionId='4' Grid.Column="0"                                                                                                                          DisplayMemberPath="Name" HorizontalAlignment="Stretch" />
                <TextBox x:ConnectionId='5' Grid.Column="1" PlaceholderText="Search Channels..."                                                                                         />
            </Grid>
        </StackPanel>

        <GridView x:ConnectionId='2' Grid.Row="1"                                                                 SelectionMode="Single"                                                >
            <GridView.ItemTemplate>
                <DataTemplate>
                    <Grid Width="200" Height="80" Padding="12" Background="#11FFFFFF" CornerRadius="4" Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0" Source="{Binding LogoUrl}" Stretch="Uniform" Margin="0,0,8,0" />
                        <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" TextWrapping="Wrap" MaxLines="2" FontWeight="SemiBold" FontSize="14" />
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Page>

