<Page
    x:Class="Kroira.App.Views.DevPlaybackPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvs="using:LibVLCSharp.Platforms.Windows"
    Background="Black">
    
    <Grid>
        <lvs:VideoView x:ConnectionId='2' x:Name="PlayerView" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
        
        <Button x:ConnectionId='3' Content="← Back"                    
                VerticalAlignment="Top" HorizontalAlignment="Left" Margin="20" 
                Background="#88000000" Foreground="White" Padding="12,8" CornerRadius="4" />
        
        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Orientation="Horizontal" Spacing="10" Margin="20" Background="#88000000" Padding="10" CornerRadius="8">
            <TextBlock x:ConnectionId='4' x:Name="StateText" Foreground="White" VerticalAlignment="Center" Text="Idle" Width="70" FontWeight="SemiBold" />
            <Button x:ConnectionId='5' Content="Pause"                     />
            <Button x:ConnectionId='6' Content="Stop"                    />
        </StackPanel>
    </Grid>
</Page>

