<Page x:ConnectionId='1'
    x:Class="Kroira.App.Views.SourceListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <RelativePanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Saved Sources" Style="{ThemeResource TitleTextBlockStyle}" RelativePanel.AlignLeftWithPanel="True" RelativePanel.AlignVerticalCenterWithPanel="True"/>
            <StackPanel Orientation="Horizontal" Spacing="8" RelativePanel.AlignRightWithPanel="True" RelativePanel.AlignVerticalCenterWithPanel="True">
                <Button x:ConnectionId='8' Content="Refresh"                                                 />
                <Button x:ConnectionId='9' Content="Add New Source"                            Style="{ThemeResource AccentButtonStyle}" />
            </StackPanel>
        </RelativePanel>

        <ListView x:ConnectionId='2' Grid.Row="1"                                                       SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="12" Background="#11FFFFFF" CornerRadius="4" Margin="0,0,0,8" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="16" />
                            <TextBlock Text="{Binding Type}" Foreground="Gray" FontSize="12" />
                            <TextBlock Text="{Binding Status}" Foreground="LimeGreen" FontSize="12" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button x:ConnectionId='4' Content="Browse" Tag="{Binding Id}"                            Visibility="{Binding BrowseVisibility}" />
                            <Button x:ConnectionId='5' Content="Import / Parse" Tag="{Binding Id}"                           Visibility="{Binding ParseVisibility}" />
                            <Button x:ConnectionId='6' Content="Sync EPG" Tag="{Binding Id}"                             Visibility="{Binding SyncEpgVisibility}" />
                            <Button x:ConnectionId='7' Content="Delete" Tag="{Binding Id}"                            />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Margin" Value="0,0,0,4" />
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>
    </Grid>
</Page>

