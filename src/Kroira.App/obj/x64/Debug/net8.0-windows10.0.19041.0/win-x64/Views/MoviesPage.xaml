<Page x:ConnectionId='1'
    x:Class="Kroira.App.Views.MoviesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16" Spacing="16">
            <TextBlock Text="Movies" Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBox x:ConnectionId='5'                                                                                         PlaceholderText="Search movies..." MaxWidth="400" HorizontalAlignment="Left" />
        </StackPanel>

        <TextBlock x:ConnectionId='2' Grid.Row="1" x:Name="EmptyMoviesText" Text="No movies imported yet. Sync an Xtream VOD source to get started."
                                                                       
                   Style="{ThemeResource BodyTextBlockStyle}" Foreground="Gray"
                   HorizontalAlignment="Center" VerticalAlignment="Center" />
        <GridView x:ConnectionId='3' Grid.Row="1"                                                              SelectionMode="Single"                                             >
            <GridView.ItemTemplate>
                <DataTemplate>
                    <Grid Width="160" Height="260" Margin="4" CornerRadius="4" Background="#11FFFFFF">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        
                        <Image Grid.Row="0" Source="{Binding PosterUrl}" Stretch="UniformToFill" />
                        
                        <StackPanel Grid.Row="1" Padding="8" Background="#CC000000">
                            <TextBlock Text="{Binding Title}" TextWrapping="Wrap" MaxLines="2" FontWeight="SemiBold" FontSize="12" />
                            <TextBlock Text="{Binding CategoryName}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="10" Margin="0,4,0,0" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Page>

