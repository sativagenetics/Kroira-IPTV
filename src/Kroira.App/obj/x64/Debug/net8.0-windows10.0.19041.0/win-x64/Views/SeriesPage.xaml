<Page x:ConnectionId='1'
    x:Class="Kroira.App.Views.SeriesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Kroira.App.Views"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <local:NullToCollapsedConverter x:Key="NullToCollapsedConverter" />
        <local:SeasonPrefixConverter x:Key="SeasonPrefixConverter" />
        <local:EpisodePrefixConverter x:Key="EpisodePrefixConverter" />
    </Page.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16" Spacing="16">
            <TextBlock Text="Series" Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBox x:ConnectionId='11'                                                                                         PlaceholderText="Search series..." MaxWidth="400" HorizontalAlignment="Left" />
        </StackPanel>

        <TextBlock x:ConnectionId='2' Grid.Row="1" Text="No series imported yet. Sync an Xtream VOD source to get started."
                                                                       
                   Style="{ThemeResource BodyTextBlockStyle}" Foreground="Gray"
                   HorizontalAlignment="Center" VerticalAlignment="Center" />

        <Grid Grid.Row="1" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="380" />
            </Grid.ColumnDefinitions>

            <!-- Left: Series Grid -->
            <GridView x:ConnectionId='3' Grid.Column="0"                                                                                                                            SelectionMode="Single">
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="140" Height="220" Margin="4" CornerRadius="4" Background="#11FFFFFF">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            
                            <Image Grid.Row="0" Source="{Binding PosterUrl}" Stretch="UniformToFill" />
                            
                            <StackPanel Grid.Row="1" Padding="8" Background="#CC000000">
                                <TextBlock Text="{Binding Title}" TextWrapping="Wrap" MaxLines="2" FontWeight="SemiBold" FontSize="11" />
                                <TextBlock Text="{Binding CategoryName}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="9" Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <!-- Right: Details Panel -->
            <Border x:ConnectionId='4' Grid.Column="1" Background="#0AFFFFFF" CornerRadius="8" Padding="16"                                                                                                                 >
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Spacing="8">
                        <TextBlock x:ConnectionId='7'                                                             Style="{ThemeResource SubtitleTextBlockStyle}" TextWrapping="Wrap" />
                        <TextBlock Text="Seasons" FontWeight="SemiBold" Margin="0,16,0,0" />
                        
                        <ComboBox x:ConnectionId='8'                                                                      
                                                                                                
                                  HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SeasonNumber, Converter={StaticResource SeasonPrefixConverter}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Text="Episodes" FontWeight="SemiBold" Margin="0,16,0,8" />
                    
                    <ListView x:ConnectionId='5' Grid.Row="2"                                                                       SelectionMode="Single"                                                >
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Padding="8,4">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding EpisodeNumber, Converter={StaticResource EpisodePrefixConverter}}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>

