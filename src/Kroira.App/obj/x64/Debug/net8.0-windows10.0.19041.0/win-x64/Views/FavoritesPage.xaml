<Page x:ConnectionId='1'
    x:Class="Kroira.App.Views.FavoritesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Favorites" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,16"/>

        <GridView x:ConnectionId='2' Grid.Row="1"                                                                SelectionMode="Single"                                                >
            <GridView.ItemTemplate>
                <DataTemplate>
                    <Grid Width="200" Height="80" Padding="12" Background="#11FFFFFF" CornerRadius="4" Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0" Source="{Binding LogoUrl}" Stretch="Uniform" Margin="0,0,8,0" />
                        <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" TextWrapping="Wrap" MaxLines="2" FontWeight="SemiBold" FontSize="14" />
                        <Button x:ConnectionId='4' Grid.Column="2" Content="✕" Tag="{Binding Id}"                              Background="Transparent" BorderThickness="0" Padding="0,0,0,0" VerticalAlignment="Top" />
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Page>

