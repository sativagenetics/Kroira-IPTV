<Page x:ConnectionId='1'
    x:Class="Kroira.App.Views.SourceOnboardingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <StackPanel Margin="24" Spacing="16" MaxWidth="600" HorizontalAlignment="Left">
        <TextBlock Text="Add New Source" Style="{ThemeResource TitleTextBlockStyle}" />

        <TextBox x:ConnectionId='2' Header="Source Name"                                                                                        PlaceholderText="e.g. My Custom List" />

        <RadioButtons x:ConnectionId='3' Header="Source Format"                                                                                                         >
            <RadioButton Content="M3U (URL or Local File)" />
            <RadioButton Content="Xtream Codes (Live TV Only)" />
        </RadioButtons>

        <StackPanel x:ConnectionId='4'                                                            Spacing="8">
            <TextBlock Text="M3U Connection (URL or Local Path)"/>
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:ConnectionId='12' Grid.Column="0"                                                                                          PlaceholderText="http://... or C:\..." />
                <Button x:ConnectionId='13' Grid.Column="1" Content="Browse File..."                                                     />
            </Grid>

            <TextBlock Text="XMLTV EPG URL (Optional)" Margin="0,8,0,0"/>
            <TextBox x:ConnectionId='11'                                                                                    PlaceholderText="http://.../epg.xml" />
        </StackPanel>

        <StackPanel x:ConnectionId='5'                                                               Spacing="8">
            <TextBlock Text="Xtream Codes Connection" />
            <TextBox x:ConnectionId='8' Header="Server URL"                                                                                       PlaceholderText="http://domain.com:8080" />
            <TextBox x:ConnectionId='9' Header="Username"                                                                                            />
            <PasswordBox x:ConnectionId='10' Header="Password"                                                                                                />
        </StackPanel>

        <Button x:ConnectionId='6' Content="Save Source"                                                Style="{ThemeResource AccentButtonStyle}" Margin="0,16,0,0" />

        <TextBlock x:ConnectionId='7'                                                      
                   Foreground="LimeGreen" 
                                                                                 
                   TextWrapping="WrapWholeWords" />
    </StackPanel>
</Page>

