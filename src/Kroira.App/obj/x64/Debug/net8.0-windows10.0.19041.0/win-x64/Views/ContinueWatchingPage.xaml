<Page x:ConnectionId='1'
    x:Class="Kroira.App.Views.ContinueWatchingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Continue Watching" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,16"/>

        <GridView x:ConnectionId='2' Grid.Row="1"                                                             SelectionMode="Single"                                             >
            <GridView.ItemTemplate>
                <DataTemplate>
                    <Grid Width="220" Height="90" Padding="12" Background="#11FFFFFF" CornerRadius="4" Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0" Source="{Binding LogoUrl}" Stretch="Uniform" Margin="0,0,8,0" />
                        
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}" VerticalAlignment="Center" TextWrapping="Wrap" MaxLines="2" FontWeight="SemiBold" FontSize="14" />
                            <TextBlock Text="{Binding ProgressText}" Foreground="LimeGreen" FontSize="11" Margin="0,4,0,0" />
                        </StackPanel>

                        <Button x:ConnectionId='4' Grid.Column="2" Content="✕" Tag="{Binding Id}"                              Background="Transparent" BorderThickness="0" Padding="0,0,0,0" VerticalAlignment="Top" />
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Page>

