<Page
    x:Class="Kroira.App.Views.MediaLibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Kroira.App.Views"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Page.Resources>
        <local:BoolToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <local:StringToCollapsedConverter x:Key="StringNullOrWhiteSpaceToCollapsedConverter" />
    </Page.Resources>

    <Grid Padding="40,32,40,36"
          MaxWidth="1360"
          HorizontalAlignment="Center"
          RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="24,22">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#172B2F" Offset="0" />
                    <GradientStop Color="#141A20" Offset="0.52" />
                    <GradientStop Color="#080A0E" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="8">
                    <TextBlock Text="CAPTURE LIBRARY"
                               Style="{StaticResource KroiraLabelStyle}"
                               Foreground="{StaticResource KroiraAccentBrush}" />
                    <TextBlock Text="Recordings &amp; Downloads"
                               Style="{StaticResource KroiraPageTitleStyle}" />
                    <TextBlock Text="Monitor scheduled live recordings, queued VOD downloads, and completed files from one place."
                               Style="{StaticResource KroiraPageSubtitleStyle}"
                               MaxWidth="700" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Spacing="4"
                            VerticalAlignment="Bottom"
                            HorizontalAlignment="Right">
                    <TextBlock Text="{x:Bind ViewModel.StorageSummary, Mode=OneWay}"
                               Foreground="{StaticResource KroiraTextPrimaryBrush}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Right" />
                    <TextBlock Text="{x:Bind ViewModel.ActivitySummary, Mode=OneWay}"
                               Foreground="{StaticResource KroiraTextSecondaryBrush}"
                               FontSize="12"
                               HorizontalAlignment="Right" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource KroiraFilterStripStyle}">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="4">
                    <TextBlock Text="Storage path"
                               Style="{StaticResource KroiraLabelStyle}"
                               Foreground="{StaticResource KroiraAccentBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.RootPath, Mode=OneWay}"
                               Foreground="{StaticResource KroiraTextPrimaryBrush}"
                               TextWrapping="WrapWholeWords" />
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Refresh"
                        Click="Refresh_Click"
                        Style="{StaticResource KroiraGhostButtonStyle}"
                        VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Grid Grid.Row="2"
              ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Visibility="{x:Bind ViewModel.EmptyVisibility, Mode=OneWay}"
                        Grid.ColumnSpan="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="10"
                        MaxWidth="460">
                <FontIcon Glyph="&#xE7C3;"
                          Foreground="{StaticResource KroiraTextTertiaryBrush}"
                          FontSize="28"
                          HorizontalAlignment="Center" />
                <TextBlock Text="No recordings or downloads yet"
                           Style="{StaticResource KroiraSectionTitleStyle}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Schedule a live recording from Live TV or queue a VOD download from Movies or Series."
                           Style="{StaticResource KroiraBodyStyle}"
                           TextAlignment="Center" />
            </StackPanel>

            <Border Grid.Column="0"
                    Visibility="{x:Bind ViewModel.RecordingsVisibility, Mode=OneWay}"
                    Background="#D00A0D11"
                    BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="LIVE RECORDINGS"
                               Style="{StaticResource KroiraLabelStyle}"
                               Foreground="{StaticResource KroiraAccentBrush}" />
                    <ListView Grid.Row="1"
                              ItemsSource="{x:Bind ViewModel.Recordings, Mode=OneWay}"
                              SelectionMode="None"
                              Background="Transparent"
                              BorderThickness="0"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              Padding="0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="14,12"
                                        Background="#B011161E"
                                        BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding Title}"
                                                       Style="{StaticResource KroiraTitleStyle}"
                                                       FontSize="14"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Status}"
                                                       Style="{StaticResource KroiraMetaStyle}"
                                                       Foreground="{StaticResource KroiraAccentBrush}" />
                                            <TextBlock Text="{Binding Detail}"
                                                       Style="{StaticResource KroiraBodyStyle}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    Spacing="8"
                                                    VerticalAlignment="Center">
                                            <Button Content="Play"
                                                    Click="PlayRecording_Click"
                                                    Visibility="{Binding CanPlay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <Button Content="Retry"
                                                    Click="RetryRecording_Click"
                                                    Visibility="{Binding CanRetry, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <Button Content="Cancel"
                                                    Click="CancelRecording_Click"
                                                    Visibility="{Binding CanCancel, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <Button Content="Delete"
                                                    Click="DeleteRecording_Click"
                                                    Visibility="{Binding CanDelete, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Visibility="{x:Bind ViewModel.DownloadsVisibility, Mode=OneWay}"
                    Background="#D00A0D11"
                    BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="VOD DOWNLOADS"
                               Style="{StaticResource KroiraLabelStyle}"
                               Foreground="{StaticResource KroiraAccentBrush}" />
                    <ListView Grid.Row="1"
                              ItemsSource="{x:Bind ViewModel.Downloads, Mode=OneWay}"
                              SelectionMode="None"
                              Background="Transparent"
                              BorderThickness="0"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              Padding="0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="14,12"
                                        Background="#B011161E"
                                        BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding Title}"
                                                       Style="{StaticResource KroiraTitleStyle}"
                                                       FontSize="14"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Subtitle}"
                                                       Style="{StaticResource KroiraMetaStyle}"
                                                       Visibility="{Binding Subtitle, Converter={StaticResource StringNullOrWhiteSpaceToCollapsedConverter}}" />
                                            <TextBlock Text="{Binding Status}"
                                                       Style="{StaticResource KroiraMetaStyle}"
                                                       Foreground="{StaticResource KroiraAccentBrush}" />
                                            <TextBlock Text="{Binding Detail}"
                                                       Style="{StaticResource KroiraBodyStyle}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    Spacing="8"
                                                    VerticalAlignment="Center">
                                            <Button Content="Play"
                                                    Click="PlayDownload_Click"
                                                    Visibility="{Binding CanPlay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <Button Content="Retry"
                                                    Click="RetryDownload_Click"
                                                    Visibility="{Binding CanRetry, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <Button Content="Cancel"
                                                    Click="CancelDownload_Click"
                                                    Visibility="{Binding CanCancel, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <Button Content="Delete"
                                                    Click="DeleteDownload_Click"
                                                    Visibility="{Binding CanDelete, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
