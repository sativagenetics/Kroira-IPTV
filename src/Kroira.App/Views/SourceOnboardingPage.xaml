<Page
    x:Class="Kroira.App.Views.SourceOnboardingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <ScrollViewer>
        <Grid Padding="28" RowSpacing="18" MaxWidth="760" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource KroiraPanelStyle}">
                <StackPanel>
                    <TextBlock Text="Add Source" Style="{StaticResource KroiraPageTitleStyle}" />
                    <TextBlock Text="Connect your own M3U playlist or Xtream provider for live TV, movies, series, and guide data." Style="{StaticResource KroiraPageSubtitleStyle}" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource KroiraPanelStyle}">
                <StackPanel Spacing="16">
                    <TextBox Header="Source Name" Style="{StaticResource KroiraTextBoxStyle}" Text="{x:Bind ViewModel.SourceName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="e.g. My Custom List" />

                    <RadioButtons Header="Source Format" SelectedIndex="{x:Bind ViewModel.SelectedFormatIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <RadioButton Content="M3U (URL or Local File)" />
                        <RadioButton Content="Xtream Codes" />
                    </RadioButtons>

                    <StackPanel Visibility="{x:Bind ViewModel.M3UVisibility, Mode=OneWay}" Spacing="8">
                        <TextBlock Text="M3U playlist" Style="{StaticResource KroiraSectionTitleStyle}" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource KroiraTextBoxStyle}" Text="{x:Bind ViewModel.M3uUrlOrPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="http://... or C:\..." />
                            <Button Grid.Column="1" Content="Browse File..." Command="{x:Bind ViewModel.BrowseLocalFileCommand}" Style="{StaticResource KroiraButtonStyle}" />
                        </Grid>

                    </StackPanel>

                    <StackPanel Visibility="{x:Bind ViewModel.XtreamVisibility, Mode=OneWay}" Spacing="8">
                        <TextBlock Text="Xtream provider" Style="{StaticResource KroiraSectionTitleStyle}" />
                        <TextBox Header="Server URL" Style="{StaticResource KroiraTextBoxStyle}" Text="{x:Bind ViewModel.XtreamUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="http://domain.com:8080" />
                        <TextBox Header="Username" Style="{StaticResource KroiraTextBoxStyle}" Text="{x:Bind ViewModel.XtreamUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <PasswordBox Header="Password" Password="{x:Bind ViewModel.XtreamPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Guide mode" Style="{StaticResource KroiraSectionTitleStyle}" />
                        <RadioButtons SelectedIndex="{x:Bind ViewModel.SelectedEpgModeIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <RadioButton Content="Detected from provider" />
                            <RadioButton Content="Manual XMLTV override" />
                            <RadioButton Content="No guide" />
                        </RadioButtons>
                        <TextBlock Text="{x:Bind ViewModel.GuideModeSummaryText, Mode=OneWay}"
                                   Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                   TextWrapping="WrapWholeWords" />
                        <TextBox Visibility="{x:Bind ViewModel.ManualEpgVisibility, Mode=OneWay}"
                                 Header="Manual XMLTV URL"
                                 Style="{StaticResource KroiraTextBoxStyle}"
                                 Text="{x:Bind ViewModel.ManualEpgUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="http://.../epg.xml or C:\guide.xml" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Routing" Style="{StaticResource KroiraSectionTitleStyle}" />
                        <RadioButtons SelectedIndex="{x:Bind ViewModel.SelectedProxyModeIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <RadioButton Content="Direct routing" />
                            <RadioButton Content="Playback only" />
                            <RadioButton Content="Playback + probes" />
                            <RadioButton Content="All requests" />
                        </RadioButtons>
                        <TextBlock Text="{x:Bind ViewModel.ProxySummaryText, Mode=OneWay}"
                                   Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                   TextWrapping="WrapWholeWords" />
                        <TextBox Visibility="{x:Bind ViewModel.ProxyUrlVisibility, Mode=OneWay}"
                                 Header="Proxy URL"
                                 Style="{StaticResource KroiraTextBoxStyle}"
                                 Text="{x:Bind ViewModel.ProxyUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="http://proxy-host:port or socks5://proxy-host:port" />
                    </StackPanel>

                    <Button Content="Save and sync"
                            Command="{x:Bind ViewModel.SaveSourceCommand}"
                            IsEnabled="{x:Bind ViewModel.CanSaveSource, Mode=OneWay}"
                            Style="{StaticResource KroiraPrimaryButtonStyle}"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0" />

                    <Border Visibility="{x:Bind ViewModel.StatusVisibility, Mode=OneWay}" BorderBrush="{StaticResource KroiraBorderStrongBrush}" BorderThickness="1" CornerRadius="12" Padding="12" Background="#1B2134">
                        <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" Foreground="{StaticResource KroiraAccentBrush}" TextWrapping="WrapWholeWords" />
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
