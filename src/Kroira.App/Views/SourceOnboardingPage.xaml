<Page
    x:Class="Kroira.App.Views.SourceOnboardingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Kroira.App.Controls"
    xmlns:viewModels="using:Kroira.App.ViewModels"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Page.Resources>
        <Style x:Key="SetupPreviewChipStyle" TargetType="Border">
            <Setter Property="Background" Value="#8611161E" />
            <Setter Property="BorderBrush" Value="{StaticResource KroiraChromeLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14,12" />
        </Style>
    </Page.Resources>

    <ScrollViewer>
        <Grid Padding="28" RowSpacing="18" MaxWidth="760" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource KroiraPanelStyle}">
                <StackPanel>
                    <TextBlock Text="Add Source" Style="{StaticResource KroiraPageTitleStyle}" />
                    <TextBlock Text="Connect your own M3U playlist, Xtream provider, or Stalker portal for live TV, movies, series, and guide data." Style="{StaticResource KroiraPageSubtitleStyle}" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource KroiraPanelStyle}">
                <StackPanel Spacing="16">
                    <TextBox Header="Source Name" Style="{StaticResource KroiraTextBoxStyle}" Text="{x:Bind ViewModel.SourceName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="e.g. My Custom List" />

                    <RadioButtons Header="Source Format" SelectedIndex="{x:Bind ViewModel.SelectedFormatIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <RadioButton Content="M3U (URL or Local File)" />
                        <RadioButton Content="Xtream Codes" />
                        <RadioButton Content="Stalker Portal" />
                    </RadioButtons>

                    <StackPanel Visibility="{x:Bind ViewModel.M3UVisibility, Mode=OneWay}" Spacing="8">
                        <TextBlock Text="M3U playlist" Style="{StaticResource KroiraSectionTitleStyle}" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource KroiraTextBoxStyle}" Text="{x:Bind ViewModel.M3uUrlOrPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="http://... or C:\..." />
                            <Button Grid.Column="1" Content="Browse File..." Command="{x:Bind ViewModel.BrowseLocalFileCommand}" Style="{StaticResource KroiraButtonStyle}" />
                        </Grid>

                    </StackPanel>

                    <StackPanel Visibility="{x:Bind ViewModel.XtreamVisibility, Mode=OneWay}" Spacing="8">
                        <TextBlock Text="Xtream provider" Style="{StaticResource KroiraSectionTitleStyle}" />
                        <TextBox Header="Server URL" Style="{StaticResource KroiraTextBoxStyle}" Text="{x:Bind ViewModel.XtreamUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="http://domain.com:8080" />
                        <TextBox Header="Username" Style="{StaticResource KroiraTextBoxStyle}" Text="{x:Bind ViewModel.XtreamUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <PasswordBox Header="Password" Password="{x:Bind ViewModel.XtreamPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Visibility="{x:Bind ViewModel.StalkerVisibility, Mode=OneWay}" Spacing="8">
                        <TextBlock Text="Stalker portal" Style="{StaticResource KroiraSectionTitleStyle}" />
                        <TextBox Header="Portal URL" Style="{StaticResource KroiraTextBoxStyle}" Text="{x:Bind ViewModel.StalkerPortalUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="http://portal.example.com/c/" />
                        <TextBox Header="MAC Address" Style="{StaticResource KroiraTextBoxStyle}" Text="{x:Bind ViewModel.StalkerMacAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="00:1A:79:00:00:01" />
                        <TextBox Header="Device ID (Optional)" Style="{StaticResource KroiraTextBoxStyle}" Text="{x:Bind ViewModel.StalkerDeviceId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Leave blank to derive from the MAC address" />
                        <TextBox Header="Serial Number (Optional)" Style="{StaticResource KroiraTextBoxStyle}" Text="{x:Bind ViewModel.StalkerSerialNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Leave blank to derive from the MAC address" />
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Header="Timezone" Style="{StaticResource KroiraTextBoxStyle}" Text="{x:Bind ViewModel.StalkerTimezone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox Grid.Column="1" Header="Locale" Style="{StaticResource KroiraTextBoxStyle}" Text="{x:Bind ViewModel.StalkerLocale, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Guide mode" Style="{StaticResource KroiraSectionTitleStyle}" />
                        <RadioButtons SelectedIndex="{x:Bind ViewModel.SelectedEpgModeIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <RadioButton Content="Detected from provider" />
                            <RadioButton Content="Manual XMLTV override" />
                            <RadioButton Content="No guide" />
                        </RadioButtons>
                        <TextBlock Text="{x:Bind ViewModel.GuideModeSummaryText, Mode=OneWay}"
                                   Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                   TextWrapping="WrapWholeWords" />
                        <TextBox Visibility="{x:Bind ViewModel.ManualEpgVisibility, Mode=OneWay}"
                                 Header="Manual XMLTV URL"
                                 Style="{StaticResource KroiraTextBoxStyle}"
                                 Text="{x:Bind ViewModel.ManualEpgUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="http://.../epg.xml or C:\guide.xml" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Routing" Style="{StaticResource KroiraSectionTitleStyle}" />
                        <RadioButtons SelectedIndex="{x:Bind ViewModel.SelectedProxyModeIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <RadioButton Content="Direct routing" />
                            <RadioButton Content="Playback only" />
                            <RadioButton Content="Playback + probes" />
                            <RadioButton Content="All requests" />
                        </RadioButtons>
                        <TextBlock Text="{x:Bind ViewModel.ProxySummaryText, Mode=OneWay}"
                                   Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                   TextWrapping="WrapWholeWords" />
                        <TextBox Visibility="{x:Bind ViewModel.ProxyUrlVisibility, Mode=OneWay}"
                                 Header="Proxy URL"
                                 Style="{StaticResource KroiraTextBoxStyle}"
                                 Text="{x:Bind ViewModel.ProxyUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="http://proxy-host:port or socks5://proxy-host:port" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Local companion relay" Style="{StaticResource KroiraSectionTitleStyle}" />
                        <RadioButtons SelectedIndex="{x:Bind ViewModel.SelectedCompanionScopeIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <RadioButton Content="Disabled" />
                            <RadioButton Content="Playback only" />
                            <RadioButton Content="Playback + probes" />
                        </RadioButtons>
                        <TextBlock Text="{x:Bind ViewModel.CompanionSummaryText, Mode=OneWay}"
                                   Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                   TextWrapping="WrapWholeWords" />
                        <RadioButtons Visibility="{x:Bind ViewModel.CompanionModeVisibility, Mode=OneWay}"
                                      SelectedIndex="{x:Bind ViewModel.SelectedCompanionModeIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <RadioButton Content="Pass-through relay" />
                            <RadioButton Content="Buffered relay" />
                        </RadioButtons>
                        <TextBox Visibility="{x:Bind ViewModel.CompanionUrlVisibility, Mode=OneWay}"
                                 Header="Companion endpoint"
                                 Style="{StaticResource KroiraTextBoxStyle}"
                                 Text="{x:Bind ViewModel.CompanionUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="http://127.0.0.1:9318/kroira-companion" />
                    </StackPanel>

                    <Border Visibility="{x:Bind ViewModel.ValidationVisibility, Mode=OneWay}"
                            BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="16"
                            Background="#8611161E">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <controls:StatusPill Label="{x:Bind ViewModel.ValidationHeadlineText, Mode=OneWay}"
                                                     Kind="{x:Bind ViewModel.ValidationStatusKind, Mode=OneWay}" />
                                <Button Content="Copy Safe Report"
                                        Click="CopyValidationReport_Click"
                                        Visibility="{x:Bind ViewModel.ValidationVisibility, Mode=OneWay}"
                                        Style="{StaticResource KroiraGhostButtonStyle}"
                                        Padding="12,8" />
                            </StackPanel>

                            <TextBlock Text="{x:Bind ViewModel.ValidationSummaryText, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       TextWrapping="WrapWholeWords" />
                            <TextBlock Text="{x:Bind ViewModel.ValidationConnectionText, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                       TextWrapping="WrapWholeWords" />
                            <TextBlock Text="{x:Bind ViewModel.ValidationTypeHintText, Mode=OneWay}"
                                       Visibility="{x:Bind ViewModel.ValidationTypeHintVisibility, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                       TextWrapping="WrapWholeWords" />
                            <TextBlock Text="{x:Bind ViewModel.ValidationCapabilitySummaryText, Mode=OneWay}"
                                       Style="{StaticResource KroiraLabelStyle}"
                                       Foreground="{StaticResource KroiraAccentBrush}"
                                       TextWrapping="WrapWholeWords" />

                            <ItemsControl ItemsSource="{x:Bind ViewModel.ValidationCapabilities, Mode=OneWay}"
                                          Visibility="{x:Bind ViewModel.ValidationCapabilitiesVisibility, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:SourceSetupCapabilityItemViewModel">
                                        <Border Style="{StaticResource SetupPreviewChipStyle}" Margin="0,0,10,10">
                                            <StackPanel Spacing="6" Width="210">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{x:Bind Label}" Style="{StaticResource KroiraLabelStyle}" />
                                                    <controls:StatusPill Label="{x:Bind Value}" Kind="{x:Bind Kind}" />
                                                </StackPanel>
                                                <TextBlock Text="{x:Bind Detail}"
                                                           Style="{StaticResource KroiraBodyStyle}"
                                                           TextWrapping="WrapWholeWords" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ItemsControl ItemsSource="{x:Bind ViewModel.ValidationIssues, Mode=OneWay}"
                                          Visibility="{x:Bind ViewModel.ValidationIssuesVisibility, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:SourceSetupIssueItemViewModel">
                                        <Border Style="{StaticResource SetupPreviewChipStyle}" Margin="0,0,0,10">
                                            <StackPanel Spacing="6">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <controls:StatusPill Label="{x:Bind Title}" Kind="{x:Bind Kind}" />
                                                </StackPanel>
                                                <TextBlock Text="{x:Bind Detail}"
                                                           Style="{StaticResource KroiraBodyStyle}"
                                                           TextWrapping="WrapWholeWords" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal"
                                Spacing="10"
                                Margin="0,8,0,0">
                        <Button Content="Test Source"
                                Command="{x:Bind ViewModel.ValidateSourceCommand}"
                                IsEnabled="{x:Bind ViewModel.CanTestSource, Mode=OneWay}"
                                Style="{StaticResource KroiraGhostButtonStyle}"
                                Padding="16,10" />
                        <Button Content="Save and sync"
                                Command="{x:Bind ViewModel.SaveSourceCommand}"
                                IsEnabled="{x:Bind ViewModel.CanSaveSource, Mode=OneWay}"
                                Style="{StaticResource KroiraPrimaryButtonStyle}"
                                Padding="18,10" />
                    </StackPanel>

                    <Border Visibility="{x:Bind ViewModel.StatusVisibility, Mode=OneWay}" BorderBrush="{StaticResource KroiraBorderStrongBrush}" BorderThickness="1" CornerRadius="12" Padding="12" Background="#1B2134">
                        <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" Foreground="{StaticResource KroiraAccentBrush}" TextWrapping="WrapWholeWords" />
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
