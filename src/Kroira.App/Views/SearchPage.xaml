<Page
    x:Class="Kroira.App.Views.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Kroira.App.Controls"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Page.Resources>
        <Style x:Key="SearchResultButtonStyle" TargetType="Button" BasedOn="{StaticResource KroiraGhostButtonStyle}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Background" Value="#40111827" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="SearchBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#241B2637" />
            <Setter Property="BorderBrush" Value="{StaticResource KroiraGhostBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
    </Page.Resources>

    <Grid XYFocusKeyboardNavigation="Enabled">
        <controls:AmbientPageBackground />

        <Grid Padding="34,28,36,34"
              RowSpacing="18"
              MaxWidth="1160"
              HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="8">
                    <Border Width="54"
                            Height="5"
                            Background="{StaticResource KroiraAccentGradientBrush}"
                            CornerRadius="3"
                            HorizontalAlignment="Left" />
                    <TextBlock x:Uid="SearchPageTitle" Text="Search" Style="{StaticResource KroiraPageTitleStyle}" />
                    <TextBlock x:Uid="SearchPageSubtitle" Text="Find synced live channels, movies, series, and playable episodes."
                               Style="{StaticResource KroiraPageSubtitleStyle}"
                               MaxWidth="720" />
                </StackPanel>
                <Border Grid.Column="1"
                        Background="#42111827"
                        BorderBrush="{StaticResource KroiraGhostBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14,10"
                        VerticalAlignment="Bottom"
                        Visibility="{x:Bind ViewModel.ResultsVisibility, Mode=OneWay}">
                    <TextBlock Text="{x:Bind ViewModel.ResultCountText, Mode=OneWay}"
                               Foreground="{StaticResource KroiraAccentBrush}"
                               FontSize="12"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>

            <Grid Grid.Row="1" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid>
                        <TextBox x:Name="SearchBox"
                                 x:Uid="SearchMediaBox"
                             Style="{StaticResource KroiraFilterTextBoxStyle}"
                             Text="{x:Bind ViewModel.Query, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="SearchBox_KeyDown"
                             PlaceholderText="Search media"
                             Padding="42,11,12,11" />
                    <FontIcon Glyph="&#xE721;"
                              FontSize="15"
                              Foreground="{StaticResource KroiraTextTertiaryBrush}"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Center"
                              Margin="15,0,0,0" />
                </Grid>
                <ProgressRing Grid.Column="1"
                              IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                              Visibility="{x:Bind ViewModel.LoadingVisibility, Mode=OneWay}"
                              Width="28"
                              Height="28"
                              VerticalAlignment="Center" />
            </Grid>

            <Grid Grid.Row="2">
                <Border Visibility="{x:Bind ViewModel.StatusVisibility, Mode=OneWay}"
                        Background="#76070B12"
                        BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="24"
                        MaxWidth="560"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel Spacing="10">
                        <FontIcon Glyph="&#xE721;"
                                  FontSize="28"
                                  Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                  HorizontalAlignment="Left" />
                        <TextBlock Text="{x:Bind ViewModel.StatusTitle, Mode=OneWay}"
                                   Style="{StaticResource KroiraSectionTitleStyle}" />
                        <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                                   Style="{StaticResource KroiraBodyStyle}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <ListView x:Name="GroupList"
                          Visibility="{x:Bind ViewModel.ResultsVisibility, Mode=OneWay}"
                          ItemsSource="{x:Bind ViewModel.ResultGroups, Mode=OneWay}"
                          SelectionMode="None"
                          Padding="0"
                          ScrollViewer.VerticalScrollMode="Enabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Spacing="10" Margin="0,0,0,22">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Heading}"
                                               Style="{StaticResource KroiraSectionTitleStyle}" />
                                    <Border Grid.Column="1"
                                            Style="{StaticResource SearchBadgeStyle}">
                                        <TextBlock Text="{Binding CountText}"
                                                   Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                </Grid>

                                <ItemsControl ItemsSource="{Binding Results}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Click="ResultAction_Click"
                                                    Style="{StaticResource SearchResultButtonStyle}">
                                                <Grid Padding="12" ColumnSpacing="13">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="58" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <Border Width="54"
                                                            Height="54"
                                                            CornerRadius="10"
                                                            Background="{StaticResource KroiraMediaGradientBrush}"
                                                            BorderBrush="{StaticResource KroiraGhostBorderBrush}"
                                                            BorderThickness="1">
                                                        <Grid>
                                                            <FontIcon Glyph="{Binding Glyph}"
                                                                      FontSize="17"
                                                                      Foreground="{StaticResource KroiraAccentBrush}"
                                                                      Opacity="0.6" />
                                                            <Image Source="{Binding ArtworkUrl, Converter={StaticResource UrlToImageSourceConverter}}"
                                                                   Stretch="UniformToFill"
                                                                   Visibility="{Binding ArtworkVisibility}" />
                                                        </Grid>
                                                    </Border>

                                                    <StackPanel Grid.Column="1"
                                                                Spacing="5"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Title}"
                                                                   Style="{StaticResource KroiraTitleStyle}"
                                                                   MaxLines="2"
                                                                   TextWrapping="Wrap"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding Subtitle}"
                                                                   Style="{StaticResource KroiraMetaStyle}"
                                                                   MaxLines="1"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <Border Style="{StaticResource SearchBadgeStyle}">
                                                                <TextBlock Text="{Binding TypeLabel}"
                                                                           Foreground="{StaticResource KroiraAccentBrush}"
                                                                           FontSize="10"
                                                                           FontWeight="SemiBold" />
                                                            </Border>
                                                            <Border Style="{StaticResource SearchBadgeStyle}">
                                                                <TextBlock Text="{Binding BadgeLine}"
                                                                           Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                                           FontSize="10"
                                                                           FontWeight="SemiBold" />
                                                            </Border>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2"
                                                                Orientation="Horizontal"
                                                                Spacing="8"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding ActionLabel}"
                                                                   Foreground="{StaticResource KroiraAccentBrush}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   VerticalAlignment="Center" />
                                                        <FontIcon Glyph="&#xE72A;"
                                                                  FontSize="11"
                                                                  Foreground="{StaticResource KroiraAccentBrush}"
                                                                  VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</Page>
