<Page
    x:Class="Kroira.App.Views.EmbeddedPlaybackPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Black">

    <Grid PointerMoved="PlayerRoot_PointerMoved"
          DoubleTapped="PlayerRoot_DoubleTapped"
          Background="Black">
        <Grid x:Name="ChromeOverlay"
              VerticalAlignment="Stretch"
              HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border x:Name="TopChrome"
                    Grid.Row="0"
                    Background="#99000000"
                    Padding="18,14">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="BackButton"
                            Content="Back"
                            Click="Back_Click"
                            Background="#22000000"
                            Foreground="White"
                            BorderBrush="#44FFFFFF"
                            BorderThickness="1"
                            Padding="14,8" />

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Kroira Player"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="15" />
                        <TextBlock x:Name="PlaybackInfoText"
                                   Text="Preparing stream"
                                   Foreground="#B8FFFFFF"
                                   FontSize="12" />
                    </StackPanel>

                    <Button Grid.Column="2"
                            Content="Fullscreen"
                            Click="Fullscreen_Click"
                            Background="#22000000"
                            Foreground="White"
                            BorderBrush="#44FFFFFF"
                            BorderThickness="1"
                            Padding="14,8" />
                </Grid>
            </Border>

            <Grid x:Name="VideoHost"
                  Grid.Row="1"
                  Background="Black"
                  SizeChanged="VideoHost_SizeChanged"
                  Loaded="VideoHost_Loaded"
                  Unloaded="VideoHost_Unloaded">
                <Border x:Name="StatusOverlay"
                        Background="#B0000000"
                        CornerRadius="10"
                        Padding="16,12"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <ProgressRing x:Name="LoadingRing"
                                      IsActive="True"
                                      Width="36"
                                      Height="36" />
                        <TextBlock x:Name="StatusText"
                                   Text="Loading stream..."
                                   Foreground="White"
                                   FontSize="14"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="460" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border x:Name="BottomChrome"
                    Grid.Row="2"
                    Background="#CC05070C"
                    Padding="18,14">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="PositionText"
                                   Text="00:00"
                                   Foreground="#E8FFFFFF"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Width="62" />

                        <Slider x:Name="SeekSlider"
                                Grid.Column="1"
                                Minimum="0"
                                Maximum="1"
                                Value="0"
                                IsEnabled="False"
                                PointerPressed="SeekSlider_PointerPressed"
                                PointerReleased="SeekSlider_PointerReleased"
                                KeyUp="SeekSlider_KeyUp"
                                LostFocus="SeekSlider_LostFocus" />

                        <TextBlock x:Name="DurationText"
                                   Grid.Column="2"
                                   Text="Live"
                                   Foreground="#E8FFFFFF"
                                   FontSize="12"
                                   TextAlignment="Right"
                                   VerticalAlignment="Center"
                                   Width="62" />
                    </Grid>

                    <Grid Grid.Row="1" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button x:Name="PlayPauseButton"
                                Content="Pause"
                                Click="PlayPause_Click"
                                Background="#2D6B63FF"
                                Foreground="White"
                                Padding="16,8" />
                        <Button Grid.Column="1"
                                Content="-10s"
                                Click="SkipBack_Click"
                                Background="#22FFFFFF"
                                Foreground="White"
                                Padding="12,8" />
                        <Button Grid.Column="2"
                                Content="+30s"
                                Click="SkipForward_Click"
                                Background="#22FFFFFF"
                                Foreground="White"
                                Padding="12,8" />
                        <Button Grid.Column="3"
                                Content="Stop"
                                Click="Stop_Click"
                                Background="#22FFFFFF"
                                Foreground="White"
                                Padding="12,8" />

                        <TextBlock Grid.Column="4"
                                   Text="Double-click video for fullscreen"
                                   Foreground="#88FFFFFF"
                                   FontSize="12"
                                   VerticalAlignment="Center" />

                        <ComboBox x:Name="SpeedComboBox"
                                  Grid.Column="5"
                                  Header="Speed"
                                  SelectionChanged="SpeedComboBox_SelectionChanged"
                                  SelectedIndex="2">
                            <ComboBoxItem Content="0.5x" Tag="0.5" />
                            <ComboBoxItem Content="0.75x" Tag="0.75" />
                            <ComboBoxItem Content="1x" Tag="1" />
                            <ComboBoxItem Content="1.25x" Tag="1.25" />
                            <ComboBoxItem Content="1.5x" Tag="1.5" />
                            <ComboBoxItem Content="2x" Tag="2" />
                        </ComboBox>

                        <ComboBox x:Name="AudioTrackComboBox"
                                  Grid.Column="6"
                                  Header="Audio"
                                  DisplayMemberPath="Name"
                                  SelectionChanged="AudioTrackComboBox_SelectionChanged" />

                        <ComboBox x:Name="SubtitleTrackComboBox"
                                  Grid.Column="7"
                                  Header="Subtitles"
                                  DisplayMemberPath="Name"
                                  SelectionChanged="SubtitleTrackComboBox_SelectionChanged" />

                        <Button Grid.Column="8"
                                Content="Load subtitles"
                                Click="LoadSubtitles_Click"
                                Background="#22FFFFFF"
                                Foreground="White"
                                Padding="12,8" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
