<Page
    x:Class="Kroira.App.Views.EmbeddedPlaybackPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Black"
    NavigationCacheMode="Disabled"
    PointerMoved="Page_PointerMoved">

    <Grid x:Name="RootGrid" Background="Black">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="TopRow" Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition x:Name="BottomRow" Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top control bar -->
        <Border x:Name="TopBar" Grid.Row="0"
                Background="#CC000000"
                BorderBrush="#2F344E" BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Click="Back_Click"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{StaticResource KroiraTextPrimaryBrush}"
                        ToolTipService.ToolTip="Back"
                        Padding="8">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72B;" />
                </Button>
                <TextBlock Grid.Column="1" x:Name="TitleText"
                           VerticalAlignment="Center" Margin="12,0,0,0"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource KroiraTextPrimaryBrush}"
                           TextTrimming="CharacterEllipsis" />
                <Border Grid.Column="2" x:Name="LivePill"
                        Visibility="Collapsed"
                        Background="#B7B2FF" CornerRadius="4"
                        Padding="8,2" VerticalAlignment="Center">
                    <TextBlock Text="LIVE" FontSize="11" FontWeight="Bold" Foreground="#090B13" />
                </Border>
            </Grid>
        </Border>

        <!-- Video surface host. The Win32 child HWND is sized to match this element. -->
        <Grid x:Name="VideoHost" Grid.Row="1" Background="Black" />

        <!-- Bottom control bar -->
        <Border x:Name="BottomBar" Grid.Row="2"
                Background="#CC000000"
                BorderBrush="#2F344E" BorderThickness="0,1,0,0"
                Padding="16,8,16,12">
            <Grid RowSpacing="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="PositionText" Text="0:00"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource KroiraTextSecondaryBrush}"
                               FontSize="12" />
                    <Slider Grid.Column="1" x:Name="TimelineSlider"
                            Minimum="0" Maximum="1000" StepFrequency="1"
                            Margin="12,0"
                            IsThumbToolTipEnabled="False"
                            VerticalAlignment="Center"
                            PointerPressed="TimelineSlider_PointerPressed"
                            PointerReleased="TimelineSlider_PointerReleased"
                            PointerCaptureLost="TimelineSlider_PointerCaptureLost"
                            LostFocus="TimelineSlider_LostFocus"
                            KeyUp="TimelineSlider_KeyUp" />
                    <TextBlock Grid.Column="2" x:Name="DurationText" Text="0:00"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource KroiraTextSecondaryBrush}"
                               FontSize="12" />
                </Grid>

                <StackPanel Grid.Row="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" Spacing="8">
                    <Button x:Name="GoLiveButton" Click="GoLive_Click"
                            Visibility="Collapsed"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource KroiraTextPrimaryBrush}"
                            ToolTipService.ToolTip="Go to live"
                            Padding="10,6">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Ellipse Width="7" Height="7" Fill="#FF4D5F" VerticalAlignment="Center" />
                            <TextBlock Text="LIVE" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="PlayPauseButton" Click="PlayPause_Click"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource KroiraTextPrimaryBrush}"
                            ToolTipService.ToolTip="Play / Pause"
                            Padding="10">
                        <FontIcon x:Name="PlayPauseIcon" FontFamily="Segoe MDL2 Assets" Glyph="&#xE769;" />
                    </Button>
                    <Button x:Name="StopButton" Click="Stop_Click"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource KroiraTextPrimaryBrush}"
                            ToolTipService.ToolTip="Stop"
                            Padding="10">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE71A;" />
                    </Button>
                    <Button x:Name="AudioTrackButton"
                            Visibility="Collapsed"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource KroiraTextPrimaryBrush}"
                            Padding="10,6"
                            ToolTipService.ToolTip="Audio track">
                        <Button.Flyout>
                            <MenuFlyout x:Name="AudioTrackFlyout" />
                        </Button.Flyout>
                        <TextBlock Text="Audio" FontSize="12" FontWeight="SemiBold" />
                    </Button>
                    <Button x:Name="SubtitleTrackButton"
                            Visibility="Collapsed"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource KroiraTextPrimaryBrush}"
                            Padding="10,6"
                            ToolTipService.ToolTip="Subtitles">
                        <Button.Flyout>
                            <MenuFlyout x:Name="SubtitleTrackFlyout" />
                        </Button.Flyout>
                        <TextBlock Text="Subs" FontSize="12" FontWeight="SemiBold" />
                    </Button>
                    <Button x:Name="AspectButton"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource KroiraTextPrimaryBrush}"
                            Padding="10,6"
                            ToolTipService.ToolTip="Aspect">
                        <Button.Flyout>
                            <MenuFlyout x:Name="AspectFlyout" />
                        </Button.Flyout>
                        <TextBlock Text="Aspect" FontSize="12" FontWeight="SemiBold" />
                    </Button>
                    <Button x:Name="FullscreenButton" Click="Fullscreen_Click"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource KroiraTextPrimaryBrush}"
                            ToolTipService.ToolTip="Fullscreen"
                            Padding="10">
                        <FontIcon x:Name="FullscreenIcon" FontFamily="Segoe MDL2 Assets" Glyph="&#xE740;" />
                    </Button>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Spacing="6"
                                Margin="16,0,0,0">
                        <Button x:Name="MuteButton" Click="Mute_Click"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource KroiraTextPrimaryBrush}"
                                ToolTipService.ToolTip="Mute"
                                Padding="8">
                            <FontIcon x:Name="MuteIcon" FontFamily="Segoe MDL2 Assets" Glyph="&#xE767;" />
                        </Button>
                        <Slider x:Name="VolumeSlider"
                                Minimum="0" Maximum="100" Value="100"
                                Width="120"
                                StepFrequency="1"
                                IsThumbToolTipEnabled="False"
                                VerticalAlignment="Center"
                                ValueChanged="VolumeSlider_ValueChanged" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="StatusOverlay" Grid.RowSpan="3"
                Background="#96090B13"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12" MaxWidth="420" Padding="24">
                <ProgressRing x:Name="StatusRing" Width="34" Height="34" IsActive="False" HorizontalAlignment="Center" />
                <TextBlock x:Name="StatusTitle"
                           FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource KroiraTextPrimaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock x:Name="StatusMessage"
                           Foreground="{StaticResource KroiraTextSecondaryBrush}"
                           TextWrapping="Wrap" HorizontalAlignment="Center"
                           TextAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Error overlay -->
        <Border x:Name="ErrorOverlay" Grid.RowSpan="3"
                Background="#E6090B13"
                Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10" MaxWidth="520" Padding="24">
                <TextBlock Text="Playback error" FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource KroiraTextPrimaryBrush}" HorizontalAlignment="Center" />
                <TextBlock x:Name="ErrorMessage"
                           Foreground="{StaticResource KroiraTextSecondaryBrush}"
                           TextWrapping="Wrap" HorizontalAlignment="Center" />
                <Button Click="Back_Click" Style="{StaticResource KroiraPrimaryButtonStyle}"
                        HorizontalAlignment="Center" Margin="0,12,0,0" Content="Go back" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
