<Page
    x:Class="Kroira.App.Views.EmbeddedPlaybackPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:runtime="using:Kroira.App.Services"
    Background="Black"
    NavigationCacheMode="Disabled"
    PointerMoved="Page_PointerMoved"
    PointerExited="Page_PointerExited"
    PointerWheelChanged="Page_PointerWheelChanged">

    <Page.Resources>
        <Style x:Key="PlayerHeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#18FFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="IsTabStop" Value="True" />
            <Setter Property="UseSystemFocusVisuals" Value="True" />
        </Style>

        <Style x:Key="PlayerHeaderTextButtonStyle" TargetType="Button" BasedOn="{StaticResource PlayerHeaderButtonStyle}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Height" Value="30" />
        </Style>

        <Style x:Key="PlayerIconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1AFFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="MinWidth" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="IsTabStop" Value="True" />
            <Setter Property="UseSystemFocusVisuals" Value="True" />
        </Style>

        <Style x:Key="PlayerPillButtonStyle" TargetType="Button" BasedOn="{StaticResource PlayerIconButtonStyle}">
            <Setter Property="MinWidth" Value="48" />
            <Setter Property="Padding" Value="12,0" />
        </Style>

        <Style x:Key="PlayerTransportButtonStyle" TargetType="Button" BasedOn="{StaticResource PlayerIconButtonStyle}">
            <Setter Property="Background" Value="#14FFFFFF" />
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="CornerRadius" Value="20" />
        </Style>

        <Style x:Key="PlayerPrimaryTransportButtonStyle" TargetType="Button" BasedOn="{StaticResource PlayerTransportButtonStyle}">
            <Setter Property="Background" Value="{StaticResource KroiraAccentGradientBrush}" />
            <Setter Property="Foreground" Value="#05060A" />
            <Setter Property="MinWidth" Value="50" />
            <Setter Property="Height" Value="50" />
            <Setter Property="CornerRadius" Value="25" />
        </Style>

        <Style x:Key="PlayerToolsChipButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#12FFFFFF" />
            <Setter Property="BorderBrush" Value="#16FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="CornerRadius" Value="11" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Height" Value="28" />
            <Setter Property="UseSystemFocusVisuals" Value="True" />
        </Style>

        <Style x:Key="PlayerToolsSectionBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#0CFFFFFF" />
            <Setter Property="BorderBrush" Value="#14FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="13" />
            <Setter Property="Padding" Value="11,9" />
        </Style>
    </Page.Resources>

    <Grid x:Name="RootGrid"
          Background="Black"
          FlowDirection="LeftToRight"
          IsTabStop="True"
          UseSystemFocusVisuals="False"
          XYFocusKeyboardNavigation="Enabled">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="TopRow" Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition x:Name="BottomRow" Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="VideoHost"
              Grid.Row="1"
              Background="Black"
              Canvas.ZIndex="0" />

        <Border x:Name="TopBar" Grid.Row="0" Margin="18,16,18,0" Background="#5605060A" BorderBrush="#12FFFFFF" BorderThickness="1" CornerRadius="22" Padding="14,10" Canvas.ZIndex="2">
            <StackPanel Spacing="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button x:Uid="GeneralBackButton" runtime:RuntimeLocalizer.Uid="GeneralBackButton" Grid.Column="0" Style="{StaticResource PlayerHeaderButtonStyle}" Click="Back_Click" ToolTipService.ToolTip="Back">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72B;" />
                    </Button>

                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Spacing="2">
                        <TextBlock x:Name="TitleText" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource KroiraTextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="ContextText" FontSize="12" Foreground="{StaticResource KroiraTextSecondaryBrush}" TextTrimming="CharacterEllipsis" Visibility="Collapsed" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="8">
                        <Button x:Name="FavoriteButton" x:Uid="GeneralSaveButton" runtime:RuntimeLocalizer.Uid="GeneralSaveButton" Click="FavoriteButton_Click" Style="{StaticResource PlayerHeaderButtonStyle}" Foreground="{StaticResource KroiraGoldBrush}" ToolTipService.ToolTip="Save">
                            <FontIcon x:Name="FavoriteIcon" FontFamily="Segoe MDL2 Assets" Glyph="&#xE734;" />
                        </Button>
                        <Border Background="#12FFFFFF" BorderBrush="#14FFFFFF" BorderThickness="1" CornerRadius="18" Padding="4">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Button x:Name="GuidePanelButton" Click="GuidePanelToggle_Click" Style="{StaticResource PlayerHeaderTextButtonStyle}" Visibility="Collapsed">
                                    <TextBlock x:Uid="GeneralGuideText" runtime:RuntimeLocalizer.Uid="GeneralGuideText" Text="Guide" FontSize="11" FontWeight="SemiBold" />
                                </Button>
                                <Button x:Name="ChannelPanelButton" Click="ChannelPanelToggle_Click" Style="{StaticResource PlayerHeaderTextButtonStyle}" Visibility="Collapsed">
                                    <TextBlock x:Uid="GeneralChannelsText" runtime:RuntimeLocalizer.Uid="GeneralChannelsText" Text="Channels" FontSize="11" FontWeight="SemiBold" />
                                </Button>
                                <Button x:Name="EpisodePanelButton" Click="EpisodePanelToggle_Click" Style="{StaticResource PlayerHeaderTextButtonStyle}" Visibility="Collapsed">
                                    <TextBlock x:Uid="GeneralEpisodesText" runtime:RuntimeLocalizer.Uid="GeneralEpisodesText" Text="Episodes" FontSize="11" FontWeight="SemiBold" />
                                </Button>
                                <Button x:Name="InfoPanelButton" Click="InfoPanelToggle_Click" Style="{StaticResource PlayerHeaderTextButtonStyle}">
                                    <TextBlock x:Uid="GeneralInfoText" runtime:RuntimeLocalizer.Uid="GeneralInfoText" Text="Info" FontSize="11" FontWeight="SemiBold" />
                                </Button>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" x:Name="LivePill" Visibility="Collapsed" Background="#D6E1FF" CornerRadius="10" Padding="8,3" VerticalAlignment="Center">
                            <TextBlock x:Uid="GeneralLiveBadge" runtime:RuntimeLocalizer.Uid="GeneralLiveBadge" Text="LIVE" FontSize="10" FontWeight="Bold" Foreground="#090B13" />
                        </Border>
                        <Border Grid.Column="2" x:Name="CatchupPill" Visibility="Collapsed" Background="#C167FF" CornerRadius="10" Padding="8,3" VerticalAlignment="Center">
                            <TextBlock x:Uid="GeneralCatchupBadge" runtime:RuntimeLocalizer.Uid="GeneralCatchupBadge" Text="CATCHUP" FontSize="10" FontWeight="Bold" Foreground="#090B13" />
                        </Border>
                    </StackPanel>
                </Grid>

                <Border x:Name="ZapBanner" Visibility="Collapsed" Background="#161D2C" BorderBrush="#2F344E" BorderThickness="1" CornerRadius="10" Padding="12,10">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="ZapBannerTitleText" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                        <TextBlock x:Name="ZapBannerMessageText" FontSize="12" Foreground="{StaticResource KroiraTextSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border x:Name="MiniGuidePanel" Visibility="Collapsed" Background="#C00A1020" BorderBrush="{StaticResource KroiraHaloBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="14,12">
                    <StackPanel Spacing="8">
                        <TextBlock x:Uid="PlayerNowNextTitle" runtime:RuntimeLocalizer.Uid="PlayerNowNextTitle" Text="Now / Next" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                        <TextBlock x:Name="GuideCurrentTitleText" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource KroiraTextPrimaryBrush}" TextWrapping="Wrap" />
                        <TextBlock x:Name="GuideCurrentTimeText" FontSize="12" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                        <TextBlock x:Name="GuideNextTitleText" FontSize="13" Foreground="{StaticResource KroiraTextPrimaryBrush}" TextWrapping="Wrap" />
                        <TextBlock x:Name="GuideNextTimeText" FontSize="12" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                        <TextBlock x:Name="GuideCatchupStatusText" FontSize="12" Foreground="{StaticResource KroiraAccentBrush}" TextWrapping="Wrap" />
                        <TextBlock x:Name="GuideConfidenceText" FontSize="12" Foreground="{StaticResource KroiraTextSecondaryBrush}" TextWrapping="Wrap" />
                        <Border Height="1" Background="#24FFFFFF" />
                        <ListView x:Name="GuideProgramList"
                                  MaxHeight="260"
                                  SelectionMode="None"
                                  IsItemClickEnabled="False">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="0,6" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="{StaticResource KroiraTextPrimaryBrush}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding TimeText}"
                                                       Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                                       FontSize="12" />
                                            <TextBlock Text="{Binding StatusText}"
                                                       Visibility="{Binding StatusVisibility}"
                                                       Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="{Binding ActionLabel}"
                                                Click="GuideProgramAction_Click"
                                                Visibility="{Binding ActionVisibility}"
                                                Style="{StaticResource PlayerToolsChipButtonStyle}"
                                                VerticalAlignment="Center"
                                                MinWidth="96" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border x:Name="ChannelSwitchPanel" Visibility="Collapsed" Background="#C00A1020" BorderBrush="{StaticResource KroiraHaloBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="14,12">
                    <StackPanel Spacing="8">
                        <TextBlock x:Uid="PlayerChannelSurfTitle" runtime:RuntimeLocalizer.Uid="PlayerChannelSurfTitle" Text="Channel surf" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                        <TextBox x:Name="ChannelSearchBox" x:Uid="ChannelsSearchBox" runtime:RuntimeLocalizer.Uid="ChannelsSearchBox" PlaceholderText="Search channels" TextChanged="ChannelSearchBox_TextChanged" />
                        <TextBlock x:Name="ChannelSearchStatusText" FontSize="12" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                        <ListView x:Name="ChannelSwitchList" MaxHeight="240" IsItemClickEnabled="True" SelectionMode="None" ItemClick="ChannelSwitchList_ItemClick">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource KroiraTextPrimaryBrush}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding MetaText}" Foreground="{StaticResource KroiraTextSecondaryBrush}" FontSize="12" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding SourceName}" Foreground="{StaticResource KroiraTextSecondaryBrush}" FontSize="11" Margin="12,0,0,0" VerticalAlignment="Top" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border x:Name="EpisodePanel" Visibility="Collapsed" Background="#C00A1020" BorderBrush="{StaticResource KroiraHaloBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="14,12">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="EpisodePanelHeaderText" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                        <TextBlock x:Name="EpisodePanelStatusText" FontSize="12" Foreground="{StaticResource KroiraTextSecondaryBrush}" TextWrapping="Wrap" />
                        <ListView x:Name="EpisodeSwitchList" MaxHeight="240" IsItemClickEnabled="True" SelectionMode="None" ItemClick="EpisodeSwitchList_ItemClick">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Padding="0,6" Spacing="2">
                                        <TextBlock Text="{Binding EpisodeLabel}" Foreground="{StaticResource KroiraTextPrimaryBrush}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Title}" Foreground="{StaticResource KroiraTextSecondaryBrush}" FontSize="12" TextWrapping="Wrap" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border x:Name="InfoPanel" Visibility="Collapsed" Background="#C00A1020" BorderBrush="{StaticResource KroiraHaloBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="14,12">
                    <StackPanel Spacing="8">
                        <TextBlock x:Uid="PlayerPlaybackInfoTitle" runtime:RuntimeLocalizer.Uid="PlayerPlaybackInfoTitle" Text="Playback info" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                        <TextBlock x:Name="InfoSummaryText" FontSize="12" Foreground="{StaticResource KroiraTextSecondaryBrush}" TextWrapping="Wrap" />
                        <Grid ColumnSpacing="18" RowSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock x:Uid="PlayerResolutionLabel" runtime:RuntimeLocalizer.Uid="PlayerResolutionLabel" Grid.Row="0" Grid.Column="0" Text="Resolution" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                            <TextBlock x:Name="InfoResolutionText" Grid.Row="0" Grid.Column="1" Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                            <TextBlock x:Uid="PlayerFpsLabel" runtime:RuntimeLocalizer.Uid="PlayerFpsLabel" Grid.Row="0" Grid.Column="2" Text="FPS" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                            <TextBlock x:Name="InfoFpsText" Grid.Row="0" Grid.Column="3" Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                            <TextBlock x:Uid="PlayerVideoLabel" runtime:RuntimeLocalizer.Uid="PlayerVideoLabel" Grid.Row="1" Grid.Column="0" Text="Video" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                            <TextBlock x:Name="InfoVideoCodecText" Grid.Row="1" Grid.Column="1" Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                            <TextBlock x:Uid="PlayerAudioLabel" runtime:RuntimeLocalizer.Uid="PlayerAudioLabel" Grid.Row="1" Grid.Column="2" Text="Audio" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                            <TextBlock x:Name="InfoAudioCodecText" Grid.Row="1" Grid.Column="3" Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                            <TextBlock x:Uid="GeneralSourceLabel" runtime:RuntimeLocalizer.Uid="GeneralSourceLabel" Grid.Row="2" Grid.Column="0" Text="Source" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                            <TextBlock x:Name="InfoSourceText" Grid.Row="2" Grid.Column="1" Foreground="{StaticResource KroiraTextPrimaryBrush}" TextWrapping="Wrap" />
                            <TextBlock x:Uid="PlayerSpeedLabel" runtime:RuntimeLocalizer.Uid="PlayerSpeedLabel" Grid.Row="2" Grid.Column="2" Text="Speed" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                            <TextBlock x:Name="InfoSpeedText" Grid.Row="2" Grid.Column="3" Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                            <TextBlock x:Uid="PlayerSeekLabel" runtime:RuntimeLocalizer.Uid="PlayerSeekLabel" Grid.Row="3" Grid.Column="0" Text="Seek" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                            <TextBlock x:Name="InfoSeekText" Grid.Row="3" Grid.Column="1" Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                            <TextBlock x:Uid="GeneralGuideLabel" runtime:RuntimeLocalizer.Uid="GeneralGuideLabel" Grid.Row="3" Grid.Column="2" Text="Guide" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                            <TextBlock x:Name="InfoGuideText" Grid.Row="3" Grid.Column="3" Foreground="{StaticResource KroiraTextPrimaryBrush}" TextWrapping="Wrap" />
                        </Grid>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="InspectCurrentItemButton"
                                    x:Uid="GeneralDetailsButton" runtime:RuntimeLocalizer.Uid="GeneralDetailsButton"
                                    Content="Details"
                                    Click="InspectCurrentItem_Click"
                                    Style="{StaticResource PlayerToolsChipButtonStyle}" />
                            <Button x:Name="OpenExternalPlayerButton"
                                    x:Uid="PlayerOpenExternalButton" runtime:RuntimeLocalizer.Uid="PlayerOpenExternalButton"
                                    Content="Open external"
                                    Click="OpenInExternalPlayer_Click"
                                    Style="{StaticResource PlayerToolsChipButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Grid x:Name="BottomChromeHost"
              Grid.Row="2"
              Margin="18,0,18,18"
              Canvas.ZIndex="2">
        <Border x:Name="BottomBar" Margin="0" Background="#5A05060A" BorderBrush="#12FFFFFF" BorderThickness="1" CornerRadius="24" Padding="16,8,16,10" Canvas.ZIndex="1">
            <Grid RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="PlaybackHintText" Grid.Row="0" Foreground="{StaticResource KroiraTextSecondaryBrush}" FontSize="11" Opacity="0.82" TextWrapping="Wrap" Visibility="Collapsed" />

                <Grid x:Name="SeekTimelineContainer" Grid.Row="1" Visibility="Collapsed" ColumnSpacing="10" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="PositionText" Text="0:00" VerticalAlignment="Center" Foreground="{StaticResource KroiraTextPrimaryBrush}" FontSize="13" FontWeight="SemiBold" Opacity="0.96" />
                    <Slider Grid.Column="1" x:Name="TimelineSlider" Minimum="0" Maximum="1000" StepFrequency="1" Height="32" Margin="0" IsTabStop="False" IsThumbToolTipEnabled="False" VerticalAlignment="Center" PointerPressed="TimelineSlider_PointerPressed" PointerReleased="TimelineSlider_PointerReleased" PointerCaptureLost="TimelineSlider_PointerCaptureLost" LostFocus="TimelineSlider_LostFocus" KeyUp="TimelineSlider_KeyUp" Foreground="{StaticResource KroiraAccentStrongBrush}" Background="#26FFFFFF" />
                    <TextBlock Grid.Column="2" x:Name="DurationText" Text="0:00" VerticalAlignment="Center" Foreground="{StaticResource KroiraTextSecondaryBrush}" FontSize="13" Opacity="0.88" />
                </Grid>

                <Grid Grid.Row="2" ColumnSpacing="14" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" x:Name="LiveSummaryPanel" Spacing="2" Visibility="Collapsed" MaxWidth="320" VerticalAlignment="Center">
                        <TextBlock x:Uid="PlayerLiveNowLabel" runtime:RuntimeLocalizer.Uid="PlayerLiveNowLabel" Text="Live now" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource KroiraTextSecondaryBrush}" Opacity="0.8" />
                        <TextBlock x:Name="BottomLiveTitleText" Foreground="{StaticResource KroiraTextPrimaryBrush}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="BottomLiveMetaText" Foreground="{StaticResource KroiraTextSecondaryBrush}" FontSize="11" Opacity="0.86" TextTrimming="CharacterEllipsis" Visibility="Collapsed" />
                    </StackPanel>

                    <Border Grid.Column="1" Background="#08FFFFFF" BorderThickness="0" CornerRadius="22" Padding="10,6" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                            <Button x:Name="PreviousChannelButton" x:Uid="PlayerPreviousChannelButton" runtime:RuntimeLocalizer.Uid="PlayerPreviousChannelButton" Style="{StaticResource PlayerTransportButtonStyle}" Click="PreviousChannel_Click" Visibility="Collapsed" ToolTipService.ToolTip="Previous channel">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE892;" />
                            </Button>
                            <Button x:Name="LastChannelButton" x:Uid="PlayerLastChannelButton" runtime:RuntimeLocalizer.Uid="PlayerLastChannelButton" Style="{StaticResource PlayerTransportButtonStyle}" Click="LastChannel_Click" Visibility="Collapsed" ToolTipService.ToolTip="Last channel">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE1D3;" />
                            </Button>
                            <Button x:Name="Back30Button" x:Uid="PlayerBack30Button" runtime:RuntimeLocalizer.Uid="PlayerBack30Button" Style="{StaticResource PlayerTransportButtonStyle}" Click="Back30_Click" Visibility="Collapsed" ToolTipService.ToolTip="Back 30 seconds">
                                <TextBlock Text="-30" FontSize="12" FontWeight="SemiBold" />
                            </Button>
                            <Button x:Name="Back10Button" x:Uid="PlayerBack10Button" runtime:RuntimeLocalizer.Uid="PlayerBack10Button" Style="{StaticResource PlayerTransportButtonStyle}" Click="Back10_Click" Visibility="Collapsed" ToolTipService.ToolTip="Back 10 seconds">
                                <TextBlock Text="-10" FontSize="12" FontWeight="SemiBold" />
                            </Button>
                            <Button x:Name="RestartButton" x:Uid="PlayerRestartButton" runtime:RuntimeLocalizer.Uid="PlayerRestartButton" Style="{StaticResource PlayerTransportButtonStyle}" Click="Restart_Click" Visibility="Collapsed" ToolTipService.ToolTip="Restart from beginning">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72C;" />
                            </Button>
                            <Button x:Name="PlayPauseButton" x:Uid="PlayerPlayPauseButton" runtime:RuntimeLocalizer.Uid="PlayerPlayPauseButton" Style="{StaticResource PlayerPrimaryTransportButtonStyle}" Click="PlayPause_Click" ToolTipService.ToolTip="Play or pause">
                                <FontIcon x:Name="PlayPauseIcon" FontFamily="Segoe MDL2 Assets" Glyph="&#xE769;" />
                            </Button>
                            <Button x:Name="StopButton" x:Uid="PlayerStopButton" runtime:RuntimeLocalizer.Uid="PlayerStopButton" Style="{StaticResource PlayerTransportButtonStyle}" Click="Stop_Click" Visibility="Collapsed" ToolTipService.ToolTip="Stop playback">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE71A;" />
                            </Button>
                            <Button x:Name="Forward10Button" x:Uid="PlayerForward10Button" runtime:RuntimeLocalizer.Uid="PlayerForward10Button" Style="{StaticResource PlayerTransportButtonStyle}" Click="Forward10_Click" Visibility="Collapsed" ToolTipService.ToolTip="Forward 10 seconds">
                                <TextBlock Text="+10" FontSize="12" FontWeight="SemiBold" />
                            </Button>
                            <Button x:Name="Forward30Button" x:Uid="PlayerForward30Button" runtime:RuntimeLocalizer.Uid="PlayerForward30Button" Style="{StaticResource PlayerTransportButtonStyle}" Click="Forward30_Click" Visibility="Collapsed" ToolTipService.ToolTip="Forward 30 seconds">
                                <TextBlock Text="+30" FontSize="12" FontWeight="SemiBold" />
                            </Button>
                            <Button x:Name="NextChannelButton" x:Uid="PlayerNextChannelButton" runtime:RuntimeLocalizer.Uid="PlayerNextChannelButton" Style="{StaticResource PlayerTransportButtonStyle}" Click="NextChannel_Click" Visibility="Collapsed" ToolTipService.ToolTip="Next channel">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE893;" />
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="Transparent" BorderThickness="0" CornerRadius="20" Padding="4,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                        <Button x:Name="BottomGuideButton" x:Uid="PlayerMiniGuideButton" runtime:RuntimeLocalizer.Uid="PlayerMiniGuideButton" Style="{StaticResource PlayerIconButtonStyle}" Click="GuidePanelToggle_Click" Visibility="Collapsed" ToolTipService.ToolTip="Mini guide">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE787;" />
                        </Button>
                        <Button x:Name="BottomChannelListButton" x:Uid="PlayerChannelListButton" runtime:RuntimeLocalizer.Uid="PlayerChannelListButton" Style="{StaticResource PlayerIconButtonStyle}" Click="ChannelPanelToggle_Click" Visibility="Collapsed" ToolTipService.ToolTip="Channel list">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8FD;" />
                        </Button>
                        <Button x:Name="GoLiveButton" x:Uid="PlayerGoLiveButton" runtime:RuntimeLocalizer.Uid="PlayerGoLiveButton" Style="{StaticResource PlayerPillButtonStyle}" Click="GoLive_Click" Visibility="Collapsed" ToolTipService.ToolTip="Jump to live">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Ellipse Width="7" Height="7" Fill="#FF4D5F" VerticalAlignment="Center" />
                                <TextBlock x:Uid="GeneralLiveBadge" runtime:RuntimeLocalizer.Uid="GeneralLiveBadge" Text="LIVE" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="SpeedButton" x:Uid="PlayerSpeedButton" runtime:RuntimeLocalizer.Uid="PlayerSpeedButton" Style="{StaticResource PlayerPillButtonStyle}" Visibility="Collapsed" ToolTipService.ToolTip="Playback speed">
                            <Button.Flyout><MenuFlyout x:Name="SpeedFlyout" /></Button.Flyout>
                            <TextBlock x:Name="SpeedButtonText" Text="1.0x" FontSize="11" FontWeight="SemiBold" />
                        </Button>
                        <Button x:Name="TracksButton" x:Uid="PlayerTracksButton" runtime:RuntimeLocalizer.Uid="PlayerTracksButton" Style="{StaticResource PlayerIconButtonStyle}" Visibility="Collapsed" ToolTipService.ToolTip="Audio and subtitles">
                            <Button.Flyout><MenuFlyout x:Name="TracksFlyout" /></Button.Flyout>
                            <TextBlock Text="A/V" FontSize="11" FontWeight="SemiBold" />
                        </Button>
                        <Button x:Name="ToolsButton" x:Uid="PlayerMoreButton" runtime:RuntimeLocalizer.Uid="PlayerMoreButton" Style="{StaticResource PlayerIconButtonStyle}" Click="ToolsButton_Click" ToolTipService.ToolTip="More">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE712;" />
                        </Button>
                        <Button x:Name="FullscreenButton" x:Uid="PlayerFullscreenButton" runtime:RuntimeLocalizer.Uid="PlayerFullscreenButton" Style="{StaticResource PlayerIconButtonStyle}" Click="Fullscreen_Click" ToolTipService.ToolTip="Fullscreen">
                            <FontIcon x:Name="FullscreenIcon" FontFamily="Segoe MDL2 Assets" Glyph="&#xE740;" />
                        </Button>
                        <Border Background="#10FFFFFF" BorderThickness="0" CornerRadius="16" Padding="4,2">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="6">
                                <Button x:Name="MuteButton" x:Uid="PlayerMuteButton" runtime:RuntimeLocalizer.Uid="PlayerMuteButton" Style="{StaticResource PlayerIconButtonStyle}" Click="Mute_Click" MinWidth="32" Height="32" ToolTipService.ToolTip="Mute">
                                    <FontIcon x:Name="MuteIcon" FontFamily="Segoe MDL2 Assets" Glyph="&#xE767;" />
                                </Button>
                                <Slider x:Name="VolumeSlider" Minimum="0" Maximum="100" Value="100" Width="72" Height="32" StepFrequency="1" IsTabStop="True" IsThumbToolTipEnabled="False" VerticalAlignment="Center" ValueChanged="VolumeSlider_ValueChanged" Foreground="{StaticResource KroiraAccentStrongBrush}" Background="#26FFFFFF" />
                            </StackPanel>
                        </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <StackPanel Visibility="Collapsed">
                    <Button x:Name="AudioTrackButton">
                        <Button.Flyout><MenuFlyout x:Name="AudioTrackFlyout" /></Button.Flyout>
                    </Button>
                    <Button x:Name="SubtitleTrackButton">
                        <Button.Flyout><MenuFlyout x:Name="SubtitleTrackFlyout" /></Button.Flyout>
                    </Button>
                    <Button x:Name="AspectButton">
                        <Button.Flyout><MenuFlyout x:Name="AspectFlyout" /></Button.Flyout>
                    </Button>
                    <Button x:Name="AudioDelayFlyoutButton">
                        <Button.Flyout><MenuFlyout x:Name="AudioDelayFlyout" /></Button.Flyout>
                    </Button>
                    <Button x:Name="SubtitleDelayFlyoutButton">
                        <Button.Flyout><MenuFlyout x:Name="SubtitleDelayFlyout" /></Button.Flyout>
                    </Button>
                    <Button x:Name="SubtitleStyleFlyoutButton">
                        <Button.Flyout><MenuFlyout x:Name="SubtitleStyleFlyout" /></Button.Flyout>
                    </Button>
                    <Button x:Name="ZoomFlyoutButton">
                        <Button.Flyout><MenuFlyout x:Name="ZoomFlyout" /></Button.Flyout>
                    </Button>
                    <Button x:Name="RotationFlyoutButton">
                        <Button.Flyout><MenuFlyout x:Name="RotationFlyout" /></Button.Flyout>
                    </Button>
                    <Button x:Name="SleepTimerFlyoutButton">
                        <Button.Flyout><MenuFlyout x:Name="SleepTimerFlyout" /></Button.Flyout>
                    </Button>
                    <Button x:Name="PictureInPictureButton" Click="PictureInPicture_Click">
                        <TextBlock x:Name="PictureInPictureButtonText" x:Uid="PlayerPipText" runtime:RuntimeLocalizer.Uid="PlayerPipText" Text="PIP" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        </Grid>

        <Border x:Name="ToolsPanel" Visibility="Collapsed" Width="360" Background="#B005060A" BorderBrush="{StaticResource KroiraGhostBorderBrush}" BorderThickness="1" CornerRadius="18" Padding="12,10" Margin="0" MaxHeight="360">
            <ScrollViewer MaxHeight="340" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Width="336" MaxWidth="336" Spacing="9">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="1">
                            <TextBlock x:Uid="PlayerPlaybackToolsTitle" runtime:RuntimeLocalizer.Uid="PlayerPlaybackToolsTitle" Text="Playback tools" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                            <TextBlock x:Name="ToolsPanelSummaryText" x:Uid="PlayerPlaybackToolsSummary" runtime:RuntimeLocalizer.Uid="PlayerPlaybackToolsSummary" FontSize="11" Foreground="{StaticResource KroiraTextSecondaryBrush}" Text="Compact live controls for display, subtitles, and session actions." TextWrapping="Wrap" />
                        </StackPanel>

                        <Button x:Name="ToolsPanelCloseButton" x:Uid="PlayerCloseToolsButton" runtime:RuntimeLocalizer.Uid="PlayerCloseToolsButton" Grid.Column="1" Style="{StaticResource PlayerIconButtonStyle}" Click="ToolsButton_Click" ToolTipService.ToolTip="Close tools" MinWidth="32" Height="32">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE711;" />
                        </Button>
                    </Grid>

                    <StackPanel Spacing="8">
                        <Border Style="{StaticResource PlayerToolsSectionBorderStyle}">
                            <StackPanel Spacing="8">
                                <StackPanel Spacing="2">
                                    <TextBlock x:Uid="PlayerQuickActionsTitle" runtime:RuntimeLocalizer.Uid="PlayerQuickActionsTitle" Text="Quick actions" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                                    <TextBlock x:Uid="PlayerQuickActionsSummary" runtime:RuntimeLocalizer.Uid="PlayerQuickActionsSummary" Text="Panels, recovery, capture, and picture-in-picture." FontSize="10" Foreground="{StaticResource KroiraTextSecondaryBrush}" Opacity="0.82" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Button x:Name="ToolsInfoButton" x:Uid="GeneralInfoButton" runtime:RuntimeLocalizer.Uid="GeneralInfoButton" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="InfoPanelToggle_Click" Content="Info" />
                                    <Button x:Name="ToolsRetryButton" x:Uid="GeneralRetryButton" runtime:RuntimeLocalizer.Uid="GeneralRetryButton" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="RetryPlayback_Click" Content="Retry" />
                                    <Button x:Name="ToolsRestartButton" x:Uid="PlayerRestartContentButton" runtime:RuntimeLocalizer.Uid="PlayerRestartContentButton" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="Restart_Click" Content="Restart" Visibility="Collapsed" />
                                    <Button x:Name="ToolsJumpLiveButton" x:Uid="PlayerLiveButton" runtime:RuntimeLocalizer.Uid="PlayerLiveButton" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="GoLive_Click" Content="Live" Visibility="Collapsed" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Button x:Name="ToolsPictureInPictureButton" x:Uid="PlayerPipButton" runtime:RuntimeLocalizer.Uid="PlayerPipButton" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="PictureInPicture_Click" Content="PiP" Visibility="Collapsed" />
                                    <Button x:Name="ToolsScreenshotButton" x:Uid="PlayerShotButton" runtime:RuntimeLocalizer.Uid="PlayerShotButton" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="CaptureScreenshot_Click" Content="Shot" />
                                    <Button x:Name="ToolsGuideButton" x:Uid="GeneralGuideButton" runtime:RuntimeLocalizer.Uid="GeneralGuideButton" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="GuidePanelToggle_Click" Content="Guide" Visibility="Collapsed" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Button x:Name="ToolsChannelsButton" x:Uid="PlayerChannelsButton" runtime:RuntimeLocalizer.Uid="PlayerChannelsButton" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="ChannelPanelToggle_Click" Content="Channels" Visibility="Collapsed" />
                                    <Button x:Name="ToolsEpisodesButton" x:Uid="PlayerEpisodesButton" runtime:RuntimeLocalizer.Uid="PlayerEpisodesButton" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="EpisodePanelToggle_Click" Content="Episodes" Visibility="Collapsed" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PlayerToolsSectionBorderStyle}">
                            <StackPanel Spacing="8">
                                <StackPanel Spacing="2">
                                    <TextBlock x:Uid="PlayerSessionTitle" runtime:RuntimeLocalizer.Uid="PlayerSessionTitle" Text="Session" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                                    <TextBlock x:Name="ToolsSessionSummaryText" x:Uid="PlayerSessionSummary" runtime:RuntimeLocalizer.Uid="PlayerSessionSummary" FontSize="10" Foreground="{StaticResource KroiraTextSecondaryBrush}" Opacity="0.82" TextWrapping="Wrap" Text="Sleep timer off. Window follows normal stacking." />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Button x:Name="SleepTimer30Button" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="SleepTimerTool_Click" Tag="30" Content="30m" />
                                    <Button x:Name="SleepTimer60Button" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="SleepTimerTool_Click" Tag="60" Content="60m" />
                                    <Button x:Name="SleepTimer90Button" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="SleepTimerTool_Click" Tag="90" Content="90m" />
                                    <Button x:Name="SleepTimerCancelButton" x:Uid="GeneralOffButton" runtime:RuntimeLocalizer.Uid="GeneralOffButton" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="SleepTimerTool_Click" Tag="cancel" Content="Off" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Button x:Name="ToolsAlwaysOnTopButton" x:Uid="PlayerAlwaysOnTopButton" runtime:RuntimeLocalizer.Uid="PlayerAlwaysOnTopButton" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="ToggleAlwaysOnTop_Click" Content="Always on top" />
                                    <Button x:Name="ToolsStopButton" x:Uid="PlayerStopContentButton" runtime:RuntimeLocalizer.Uid="PlayerStopContentButton" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="Stop_Click" Content="Stop" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PlayerToolsSectionBorderStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock x:Uid="PlayerDisplayTitle" runtime:RuntimeLocalizer.Uid="PlayerDisplayTitle" Text="Display" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                                <TextBlock x:Name="ToolsDisplaySummaryText" x:Uid="PlayerDisplaySummary" runtime:RuntimeLocalizer.Uid="PlayerDisplaySummary" FontSize="10" Foreground="{StaticResource KroiraTextSecondaryBrush}" Opacity="0.82" TextWrapping="Wrap" Text="Auto framing, neutral zoom, and standard rotation." />
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Button x:Name="AspectAutoButton" x:Uid="PlayerAutoButton" runtime:RuntimeLocalizer.Uid="PlayerAutoButton" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="AspectToolButton_Click" Tag="Automatic" Content="Auto" />
                                    <Button x:Name="AspectFillButton" x:Uid="PlayerFillButton" runtime:RuntimeLocalizer.Uid="PlayerFillButton" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="AspectToolButton_Click" Tag="FillWindow" Content="Fill" />
                                    <Button x:Name="Aspect169Button" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="AspectToolButton_Click" Tag="Ratio16x9" Content="16:9" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Button x:Name="Aspect43Button" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="AspectToolButton_Click" Tag="Ratio4x3" Content="4:3" />
                                    <Button x:Name="Aspect185Button" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="AspectToolButton_Click" Tag="Ratio185x1" Content="1.85" />
                                    <Button x:Name="Aspect235Button" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="AspectToolButton_Click" Tag="Ratio235x1" Content="2.35" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Button x:Name="ZoomOutButton" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="ZoomTool_Click" Tag="-0.15" Content="-" />
                                    <Button x:Name="ZoomResetButton" x:Uid="GeneralResetButton" runtime:RuntimeLocalizer.Uid="GeneralResetButton" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="ZoomTool_Click" Tag="reset" Content="Reset" />
                                    <Button x:Name="ZoomInButton" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="ZoomTool_Click" Tag="0.15" Content="+" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Button x:Name="Rotation0Button" x:Uid="PlayerRotation0Button" runtime:RuntimeLocalizer.Uid="PlayerRotation0Button" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="RotationTool_Click" Tag="0" Content="0 deg" />
                                    <Button x:Name="Rotation90Button" x:Uid="PlayerRotation90Button" runtime:RuntimeLocalizer.Uid="PlayerRotation90Button" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="RotationTool_Click" Tag="90" Content="90 deg" />
                                    <Button x:Name="Rotation180Button" x:Uid="PlayerRotation180Button" runtime:RuntimeLocalizer.Uid="PlayerRotation180Button" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="RotationTool_Click" Tag="180" Content="180 deg" />
                                    <Button x:Name="Rotation270Button" x:Uid="PlayerRotation270Button" runtime:RuntimeLocalizer.Uid="PlayerRotation270Button" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="RotationTool_Click" Tag="270" Content="270 deg" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Button x:Name="ToolsDeinterlaceButton" x:Uid="PlayerDeinterlaceButton" runtime:RuntimeLocalizer.Uid="PlayerDeinterlaceButton" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="ToggleDeinterlace_Click" Content="Deinterlace" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PlayerToolsSectionBorderStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock x:Uid="PlayerAudioSubtitlesTitle" runtime:RuntimeLocalizer.Uid="PlayerAudioSubtitlesTitle" Text="Audio &amp; subtitles" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                                <TextBlock x:Name="ToolsSubtitleSummaryText" x:Uid="PlayerSubtitleSummary" runtime:RuntimeLocalizer.Uid="PlayerSubtitleSummary" FontSize="10" Foreground="{StaticResource KroiraTextSecondaryBrush}" Opacity="0.82" TextWrapping="Wrap" Text="Subtitle scale and placement follow the active player state." />
                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="ToolsAudioDelayValueText" x:Uid="PlayerAudioDelayValueText" runtime:RuntimeLocalizer.Uid="PlayerAudioDelayValueText" FontSize="10" Foreground="{StaticResource KroiraTextSecondaryBrush}" Text="Audio delay 0.0s" />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Button x:Name="AudioDelayMinusButton" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="AudioDelayTool_Click" Tag="-0.1" Content="-0.1s" />
                                        <Button x:Name="AudioDelayResetButton" x:Uid="GeneralResetButton2" runtime:RuntimeLocalizer.Uid="GeneralResetButton2" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="AudioDelayTool_Click" Tag="reset" Content="Reset" />
                                        <Button x:Name="AudioDelayPlusButton" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="AudioDelayTool_Click" Tag="0.1" Content="+0.1s" />
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="ToolsSubtitleDelayValueText" x:Uid="PlayerSubtitleDelayValueText" runtime:RuntimeLocalizer.Uid="PlayerSubtitleDelayValueText" FontSize="10" Foreground="{StaticResource KroiraTextSecondaryBrush}" Text="Subtitle delay 0.0s" />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Button x:Name="SubtitleDelayMinusButton" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="SubtitleDelayTool_Click" Tag="-0.1" Content="-0.1s" />
                                        <Button x:Name="SubtitleDelayResetButton" x:Uid="GeneralResetButton3" runtime:RuntimeLocalizer.Uid="GeneralResetButton3" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="SubtitleDelayTool_Click" Tag="reset" Content="Reset" />
                                        <Button x:Name="SubtitleDelayPlusButton" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="SubtitleDelayTool_Click" Tag="0.1" Content="+0.1s" />
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Button x:Name="SubtitleSizeSmallButton" x:Uid="PlayerSmallButton" runtime:RuntimeLocalizer.Uid="PlayerSmallButton" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="SubtitleStyleTool_Click" Tag="scale:0.85" Content="Small" />
                                    <Button x:Name="SubtitleSizeMediumButton" x:Uid="PlayerMediumButton" runtime:RuntimeLocalizer.Uid="PlayerMediumButton" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="SubtitleStyleTool_Click" Tag="scale:1.0" Content="Medium" />
                                    <Button x:Name="SubtitleSizeLargeButton" x:Uid="PlayerLargeButton" runtime:RuntimeLocalizer.Uid="PlayerLargeButton" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="SubtitleStyleTool_Click" Tag="scale:1.2" Content="Large" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Button x:Name="SubtitlePositionHighButton" x:Uid="PlayerHighButton" runtime:RuntimeLocalizer.Uid="PlayerHighButton" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="SubtitleStyleTool_Click" Tag="position:84" Content="High" />
                                    <Button x:Name="SubtitlePositionCenterButton" x:Uid="PlayerMidButton" runtime:RuntimeLocalizer.Uid="PlayerMidButton" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="SubtitleStyleTool_Click" Tag="position:92" Content="Mid" />
                                    <Button x:Name="SubtitlePositionLowButton" x:Uid="PlayerLowButton" runtime:RuntimeLocalizer.Uid="PlayerLowButton" Style="{StaticResource PlayerToolsChipButtonStyle}" Click="SubtitleStyleTool_Click" Tag="position:100" Content="Low" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border x:Name="StatusOverlay" Grid.RowSpan="3" Background="#96090B13" Visibility="Collapsed" IsHitTestVisible="False">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12" MaxWidth="420" Padding="24">
                <ProgressRing x:Name="StatusRing" Width="34" Height="34" IsActive="False" HorizontalAlignment="Center" />
                <TextBlock x:Name="StatusTitle" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource KroiraTextPrimaryBrush}" HorizontalAlignment="Center" />
                <TextBlock x:Name="StatusMessage" Foreground="{StaticResource KroiraTextSecondaryBrush}" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" />
            </StackPanel>
        </Border>

        <Border x:Name="ErrorOverlay" Grid.RowSpan="3" Background="#E6090B13" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10" MaxWidth="520" Padding="24">
                <TextBlock x:Uid="PlayerPlaybackErrorTitle" runtime:RuntimeLocalizer.Uid="PlayerPlaybackErrorTitle" Text="Playback error" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource KroiraTextPrimaryBrush}" HorizontalAlignment="Center" />
                <TextBlock x:Name="ErrorMessage" Foreground="{StaticResource KroiraTextSecondaryBrush}" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10" Margin="0,12,0,0">
                    <Button x:Uid="GeneralRetryButton2" runtime:RuntimeLocalizer.Uid="GeneralRetryButton2" Click="RetryPlayback_Click" Style="{StaticResource KroiraPrimaryButtonStyle}" Content="Retry" />
                    <Button x:Uid="GeneralGoBackButton" runtime:RuntimeLocalizer.Uid="GeneralGoBackButton" Click="Back_Click" Content="Go back" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
