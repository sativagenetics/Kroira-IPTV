<Page
    x:Class="Kroira.App.Views.DevPlaybackPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Black">

    <Grid>
        <Button Content="← Back" Click="Back_Click"
                VerticalAlignment="Top" HorizontalAlignment="Left" Margin="20"
                Background="#88000000" Foreground="White" Padding="12,8" CornerRadius="4" />

        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center"
                    Orientation="Horizontal" Spacing="10" Margin="20"
                    Background="#88000000" Padding="10" CornerRadius="8">
            <TextBlock x:Name="StateText" Foreground="White" VerticalAlignment="Center"
                       Text="Idle" Width="70" FontWeight="SemiBold" />
            <Button Content="Pause" Click="Pause_Click" />
            <Button Content="Stop" Click="Stop_Click" />
        </StackPanel>
    </Grid>
</Page>
