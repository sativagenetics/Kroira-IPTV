<Page
    x:Class="Kroira.App.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#0B0F14">

    <Page.Resources>
        <SolidColorBrush x:Key="HomeCardBrush" Color="#151A21" />
        <SolidColorBrush x:Key="HomeCardElevatedBrush" Color="#1A2029" />
        <SolidColorBrush x:Key="HomeBorderBrush" Color="#2A3340" />
        <SolidColorBrush x:Key="HomeMutedTextBrush" Color="#A7B0BD" />
        <SolidColorBrush x:Key="HomeAccentBrush" Color="#7CC7FF" />

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource HomeCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource HomeBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
    </Page.Resources>

    <ScrollViewer>
        <Grid Padding="28" RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="20" BorderThickness="1" BorderBrush="#334256" Padding="28">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#202936" Offset="0" />
                        <GradientStop Color="#151A22" Offset="0.55" />
                        <GradientStop Color="#10141A" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="12" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Background="#223A4C" BorderBrush="#40627B" BorderThickness="1" CornerRadius="999" Padding="10,5">
                                <TextBlock Text="{x:Bind ViewModel.LicenseStatusMessage, Mode=OneWay}" Foreground="{StaticResource HomeAccentBrush}" FontSize="12" FontWeight="SemiBold" />
                            </Border>
                            <Border Background="#1C2631" BorderBrush="#2F3F50" BorderThickness="1" CornerRadius="999" Padding="10,5">
                                <TextBlock Text="{x:Bind ViewModel.SourceStatusMessage, Mode=OneWay}" Foreground="{StaticResource HomeMutedTextBrush}" FontSize="12" />
                            </Border>
                        </StackPanel>

                        <TextBlock Text="Welcome to Kroira IPTV" FontSize="34" FontWeight="SemiBold" TextWrapping="Wrap" />
                        <TextBlock Text="{x:Bind ViewModel.HeroSubtitle, Mode=OneWay}" Foreground="{StaticResource HomeMutedTextBrush}" FontSize="15" TextWrapping="Wrap" MaxWidth="760" />

                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,8,0,0">
                            <Button Style="{ThemeResource AccentButtonStyle}" Click="AddSource_Click" Padding="16,8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE710;" FontSize="14" />
                                    <TextBlock Text="Add Source" />
                                </StackPanel>
                            </Button>
                            <Button Click="ContinueWatching_Click" Padding="16,8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE768;" FontSize="14" />
                                    <TextBlock Text="Continue Watching" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1" Width="180" MinHeight="150" Background="#18222D" BorderBrush="#2F4357" BorderThickness="1" CornerRadius="18" Padding="18" VerticalAlignment="Stretch">
                        <StackPanel Spacing="10" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE7F4;" FontSize="30" Foreground="{StaticResource HomeAccentBrush}" HorizontalAlignment="Left" />
                            <TextBlock Text="{x:Bind ViewModel.LibraryStatusMessage, Mode=OneWay}" TextWrapping="Wrap" FontWeight="SemiBold" />
                            <TextBlock Text="{x:Bind ViewModel.LastSyncMessage, Mode=OneWay}" Foreground="{StaticResource HomeMutedTextBrush}" FontSize="12" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <GridView Grid.Row="1" ItemsSource="{x:Bind ViewModel.SummaryItems, Mode=OneWay}" SelectionMode="None" IsItemClickEnabled="False">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="4" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem">
                        <Setter Property="Margin" Value="0,0,12,12" />
                    </Style>
                </GridView.ItemContainerStyle>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border Width="210" Style="{StaticResource CardBorderStyle}">
                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="42" Height="42" Background="#202C38" CornerRadius="12">
                                    <FontIcon Glyph="{Binding Glyph}" FontSize="18" Foreground="{StaticResource HomeAccentBrush}" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="{Binding Label}" Foreground="{StaticResource HomeMutedTextBrush}" FontSize="12" />
                                    <TextBlock Text="{Binding Value}" FontSize="25" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Detail}" Foreground="{StaticResource HomeMutedTextBrush}" FontSize="12" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <Grid Grid.Row="2" ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Background="{StaticResource HomeCardElevatedBrush}">
                    <StackPanel>
                        <TextBlock Text="Quick Actions" Style="{StaticResource SectionTitleStyle}" />
                        <GridView ItemsSource="{x:Bind ViewModel.QuickActions, Mode=OneWay}" SelectionMode="None" IsItemClickEnabled="True" ItemClick="QuickAction_ItemClick">
                            <GridView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="3" />
                                </ItemsPanelTemplate>
                            </GridView.ItemsPanel>
                            <GridView.ItemContainerStyle>
                                <Style TargetType="GridViewItem">
                                    <Setter Property="Margin" Value="0,0,10,10" />
                                </Style>
                            </GridView.ItemContainerStyle>
                            <GridView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="230" MinHeight="82" Padding="14" Background="#121821" BorderBrush="#26313D" BorderThickness="1" CornerRadius="12" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="38" Height="38" Background="#1D2A36" CornerRadius="10" VerticalAlignment="Top">
                                            <FontIcon Glyph="{Binding Glyph}" FontSize="16" Foreground="{StaticResource HomeAccentBrush}" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="3">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Detail}" Foreground="{StaticResource HomeMutedTextBrush}" FontSize="12" TextWrapping="Wrap" MaxLines="2" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Continue Watching" Style="{StaticResource SectionTitleStyle}" Margin="0" />
                            <Button Content="View all" HorizontalAlignment="Right" Click="ContinueWatching_Click" />
                        </Grid>

                        <ListView ItemsSource="{x:Bind ViewModel.ContinueItems, Mode=OneWay}" SelectionMode="Single" SelectionChanged="ContinueList_SelectionChanged" Visibility="{x:Bind ViewModel.ContinueItemsVisibility, Mode=OneWay}">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Margin" Value="0,0,0,8" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid MinHeight="72" Padding="12" Background="#121821" BorderBrush="#26313D" BorderThickness="1" CornerRadius="12" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="48" Height="48" Background="#1D2A36" CornerRadius="12">
                                            <FontIcon Glyph="&#xE768;" Foreground="{StaticResource HomeAccentBrush}" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" MaxLines="1" />
                                            <TextBlock Text="{Binding Detail}" Foreground="{StaticResource HomeMutedTextBrush}" FontSize="12" />
                                        </StackPanel>
                                        <FontIcon Grid.Column="2" Glyph="&#xE76C;" Foreground="{StaticResource HomeMutedTextBrush}" FontSize="12" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Border Visibility="{x:Bind ViewModel.ContinueEmptyVisibility, Mode=OneWay}" Background="#111821" BorderBrush="#26313D" BorderThickness="1" CornerRadius="12" Padding="18">
                            <StackPanel Spacing="8">
                                <FontIcon Glyph="&#xE768;" Foreground="{StaticResource HomeAccentBrush}" FontSize="24" HorizontalAlignment="Left" />
                                <TextBlock Text="Nothing to resume yet" FontWeight="SemiBold" />
                                <TextBlock Text="Start watching a channel, movie, or episode and it will appear here." Foreground="{StaticResource HomeMutedTextBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}" Padding="16">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="36" Height="36" Background="#1D2A36" CornerRadius="10">
                        <FontIcon Glyph="&#xE946;" Foreground="{StaticResource HomeAccentBrush}" FontSize="16" />
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.SourceStatusMessage, Mode=OneWay}" FontWeight="SemiBold" />
                        <TextBlock Text="{x:Bind ViewModel.LastSyncMessage, Mode=OneWay}" Foreground="{StaticResource HomeMutedTextBrush}" FontSize="12" />
                    </StackPanel>
                    <Border Grid.Column="2" Visibility="{x:Bind ViewModel.SourceIssueVisibility, Mode=OneWay}" Background="#3B211F" BorderBrush="#6A3832" BorderThickness="1" CornerRadius="999" Padding="10,5" VerticalAlignment="Center">
                        <TextBlock Text="Source attention needed" Foreground="#FFB5AA" FontSize="12" FontWeight="SemiBold" />
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
