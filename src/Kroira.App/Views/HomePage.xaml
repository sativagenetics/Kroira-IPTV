<Page
    x:Class="Kroira.App.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <ScrollViewer>
        <Grid Padding="40,28,40,40"
              RowSpacing="28"
              MaxWidth="1200"
              HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="10" MaxWidth="760">
                    <TextBlock Text="KROIRA · DESKTOP MEDIA HUB"
                               Style="{StaticResource KroiraLabelStyle}"
                               Foreground="{StaticResource KroiraAccentBrush}" />
                    <TextBlock Text="Welcome back"
                               Style="{StaticResource KroiraDisplayLgStyle}" />
                    <TextBlock Text="{x:Bind ViewModel.HeroSubtitle, Mode=OneWay}"
                               Style="{StaticResource KroiraBodyStyle}"
                               FontSize="14"
                               MaxWidth="680" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="10"
                            VerticalAlignment="Center">
                    <Button Click="ContinueWatching_Click"
                            Style="{StaticResource KroiraPrimaryButtonStyle}"
                            Padding="18,10"
                            MinWidth="160"
                            Content="Continue watching" />
                    <Button Click="AddSource_Click"
                            Style="{StaticResource KroiraGhostButtonStyle}"
                            Padding="18,10"
                            MinWidth="140"
                            Content="Add source" />
                </StackPanel>
            </Grid>

            <!-- Library strip -->
            <Border Grid.Row="1"
                    Background="{StaticResource KroiraSurfaceSoftBrush}"
                    CornerRadius="12"
                    Padding="20,14">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ItemsControl ItemsSource="{x:Bind ViewModel.SummaryItems, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,28,0">
                                    <FontIcon Glyph="{Binding Glyph}"
                                              FontSize="13"
                                              Foreground="{StaticResource KroiraTextTertiaryBrush}" />
                                    <TextBlock Text="{Binding Value}"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                                    <TextBlock Text="{Binding Label}"
                                               FontSize="13"
                                               Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Grid.Column="1"
                               Text="{x:Bind ViewModel.LibraryStatusMessage, Mode=OneWay}"
                               Style="{StaticResource KroiraBodyStyle}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               TextAlignment="Right" />
                </Grid>
            </Border>

            <!-- Continue watching safe block -->
            <StackPanel Grid.Row="2" Spacing="14">
                <Grid>
                    <TextBlock Text="Continue watching"
                               Style="{StaticResource KroiraSectionTitleStyle}"
                               VerticalAlignment="Center" />
                    <Button Content="View all"
                            HorizontalAlignment="Right"
                            Click="ContinueWatching_Click"
                            Style="{StaticResource KroiraGhostButtonStyle}" />
                </Grid>

                <Border Visibility="{x:Bind ViewModel.ContinueItemsVisibility, Mode=OneWay}"
                        Background="{StaticResource KroiraSurfaceBrush}"
                        CornerRadius="12"
                        Padding="20">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Resume queue is ready"
                                   Style="{StaticResource KroiraTitleStyle}" />
                        <TextBlock Text="Use View all to continue movies, episodes, and live playback from your saved positions."
                                   Style="{StaticResource KroiraBodyStyle}"
                                   MaxWidth="700" />
                    </StackPanel>
                </Border>

                <Border Visibility="{x:Bind ViewModel.ContinueEmptyVisibility, Mode=OneWay}"
                        Background="{StaticResource KroiraSurfaceBrush}"
                        CornerRadius="12"
                        Padding="20">
                    <StackPanel Spacing="8" MaxWidth="560">
                        <FontIcon Glyph="&#xE768;"
                                  FontSize="18"
                                  Foreground="{StaticResource KroiraTextTertiaryBrush}" />
                        <TextBlock Text="Nothing to resume yet"
                                   Style="{StaticResource KroiraTitleStyle}" />
                        <TextBlock Text="Start watching a channel, movie, or episode and it will appear here."
                                   Style="{StaticResource KroiraBodyStyle}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Source status -->
            <Border Grid.Row="3"
                    Background="{StaticResource KroiraSurfaceSoftBrush}"
                    CornerRadius="10"
                    Padding="16,12">
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <FontIcon Glyph="&#xE946;"
                              FontSize="13"
                              Foreground="{StaticResource KroiraTextTertiaryBrush}"
                              VerticalAlignment="Center" />

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="12"
                                VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.SourceStatusMessage, Mode=OneWay}"
                                   Style="{StaticResource KroiraTitleStyle}"
                                   FontSize="13" />
                        <TextBlock Text="·"
                                   Foreground="{StaticResource KroiraTextTertiaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.LastSyncMessage, Mode=OneWay}"
                                   Style="{StaticResource KroiraBodyStyle}"
                                   FontSize="12" />
                        <TextBlock Text="·"
                                   Foreground="{StaticResource KroiraTextTertiaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.LicenseStatusMessage, Mode=OneWay}"
                                   Style="{StaticResource KroiraBodyStyle}"
                                   FontSize="12" />
                    </StackPanel>

                    <Border Grid.Column="2"
                            Visibility="{x:Bind ViewModel.SourceIssueVisibility, Mode=OneWay}"
                            Background="Transparent"
                            BorderBrush="{StaticResource KroiraGoldBrush}"
                            BorderThickness="1"
                            CornerRadius="999"
                            Padding="10,4"
                            VerticalAlignment="Center">
                        <TextBlock Text="Source attention needed"
                                   Foreground="{StaticResource KroiraGoldBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold" />
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>