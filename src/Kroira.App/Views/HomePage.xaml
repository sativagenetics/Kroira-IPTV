<Page
    x:Class="Kroira.App.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Kroira.App.Controls"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Page.Resources>
        <Style x:Key="HomeCardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>

        <DataTemplate x:Key="SummaryStatTemplate">
            <Border MinWidth="118"
                    Padding="14,10"
                    Background="#7A090B0F"
                    BorderBrush="#18FFFFFF"
                    BorderThickness="1"
                    CornerRadius="10">
                <StackPanel Spacing="1">
                    <TextBlock Text="{Binding Value}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                    <TextBlock Text="{Binding Label}"
                               Style="{StaticResource KroiraMetaStyle}"
                               FontSize="11" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ContinueItemCardTemplate">
            <Button Click="ContinueItem_Click"
                    Style="{StaticResource HomeCardButtonStyle}">
                <Border Width="372"
                        Height="218"
                        BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                    <Grid>
                        <Border Background="{StaticResource KroiraMediaGradientBrush}"
                                CornerRadius="12" />
                        <Image Source="{Binding BackdropUrl, Converter={StaticResource UrlToImageSourceConverter}}"
                               Stretch="UniformToFill"
                               Opacity="0.82" />
                        <Border>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#E0090B0F" Offset="0" />
                                    <GradientStop Color="#8610141A" Offset="0.46" />
                                    <GradientStop Color="#F0090B0F" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <Grid Padding="16" ColumnSpacing="15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="112" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Width="112"
                                    Height="158"
                                    CornerRadius="9"
                                    Background="{StaticResource KroiraPosterPlaceholderBrush}"
                                    BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                    BorderThickness="1">
                                <Grid>
                                    <FontIcon Glyph="&#xE8B2;"
                                              Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                              FontSize="22"
                                              Opacity="0.55" />
                                    <Image Source="{Binding PosterUrl, Converter={StaticResource UrlToImageSourceConverter}}"
                                           Stretch="UniformToFill" />
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="1"
                                        Spacing="8"
                                        VerticalAlignment="Top">
                                <Border Background="#B30A0D11"
                                        BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="8,3"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="RESUME"
                                               Foreground="{StaticResource KroiraAccentBrush}"
                                               FontSize="10"
                                               FontWeight="SemiBold" />
                                </Border>
                                <TextBlock Text="{Binding Title}"
                                           Style="{StaticResource KroiraTitleStyle}"
                                           FontSize="17"
                                           MaxLines="2"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Overview}"
                                           Style="{StaticResource KroiraBodyStyle}"
                                           FontSize="12"
                                           LineHeight="17"
                                           MaxLines="2"
                                           TextTrimming="CharacterEllipsis" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding Detail}"
                                               Style="{StaticResource KroiraMetaStyle}"
                                               MaxLines="1"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding VoteAverage}"
                                               Foreground="{StaticResource KroiraAccentBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </StackPanel>

                            <Grid Grid.Row="1"
                                  Grid.ColumnSpan="2"
                                  ColumnSpacing="10"
                                  Margin="0,13,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ProgressBar Value="{Binding ProgressValue}"
                                             Maximum="100"
                                             Height="3"
                                             Foreground="{StaticResource KroiraAccentBrush}"
                                             Background="#4AFFFFFF"
                                             VerticalAlignment="Center" />
                                <FontIcon Grid.Column="1"
                                          Glyph="&#xE768;"
                                          FontSize="16"
                                          Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="MediaPosterCardTemplate">
            <Button Click="MediaItem_Click"
                    Style="{StaticResource HomeCardButtonStyle}">
                <Border Width="188"
                        Height="300"
                        BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="10,10,10,12">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#252016" Offset="0" />
                            <GradientStop Color="#10151C" Offset="0.54" />
                            <GradientStop Color="#080A0D" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="206" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Border CornerRadius="9"
                                    Background="{StaticResource KroiraPosterPlaceholderBrush}"
                                    BorderBrush="#1EFFFFFF"
                                    BorderThickness="1">
                                <FontIcon Glyph="&#xE8B2;"
                                          Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                          FontSize="26"
                                          Opacity="0.55" />
                            </Border>
                            <Border CornerRadius="9">
                                <Image Source="{Binding PosterUrl, Converter={StaticResource UrlToImageSourceConverter}}"
                                       Stretch="UniformToFill" />
                            </Border>
                            <Border Height="72"
                                    VerticalAlignment="Bottom"
                                    CornerRadius="0,0,9,9">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#0010141A" Offset="0" />
                                        <GradientStop Color="#D8080A0D" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <Border Background="#C8090B0F"
                                    BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="7,3"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="8">
                                <TextBlock Text="{Binding RatingText}"
                                           Foreground="{StaticResource KroiraAccentBrush}"
                                           FontSize="11"
                                           FontWeight="SemiBold" />
                            </Border>
                        </Grid>

                        <StackPanel Grid.Row="1" Spacing="4" Margin="1,10,1,4">
                            <TextBlock Text="{Binding Title}"
                                       Style="{StaticResource KroiraTitleStyle}"
                                       FontSize="14"
                                       MaxLines="2"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Detail}"
                                       Style="{StaticResource KroiraMetaStyle}"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <Border Grid.Row="2"
                                HorizontalAlignment="Left"
                                Background="#1B231A10"
                                BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="9,4">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE768;"
                                          FontSize="11"
                                          Foreground="{StaticResource KroiraAccentBrush}" />
                                <TextBlock Text="Open"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource KroiraAccentBrush}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="LiveNowCardTemplate">
            <Button Click="LiveNow_Click"
                    Style="{StaticResource HomeCardButtonStyle}">
                <Border Width="248"
                        Height="138"
                        BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1B2830" Offset="0" />
                            <GradientStop Color="#10151C" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Border Width="64"
                                    Height="52"
                                    CornerRadius="9"
                                    Background="#5810141A"
                                    BorderBrush="#18FFFFFF"
                                    BorderThickness="1"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top">
                                <Grid>
                                    <FontIcon Glyph="&#xE714;"
                                              FontSize="20"
                                              Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                              Opacity="0.48" />
                                    <Image Source="{Binding LogoUrl, Converter={StaticResource UrlToImageSourceConverter}}"
                                           Stretch="Uniform"
                                           Margin="7" />
                                </Grid>
                            </Border>
                            <Border Background="{StaticResource KroiraStateDangerSoftBrush}"
                                    BorderBrush="#33FF5A5F"
                                    BorderThickness="1"
                                    CornerRadius="9"
                                    Padding="8,3"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <Ellipse Width="6" Height="6" Fill="{StaticResource KroiraLiveDotBrush}" />
                                    <TextBlock Text="LIVE"
                                               Foreground="{StaticResource KroiraLiveDotBrush}"
                                               FontSize="10"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <StackPanel Grid.Row="1" Spacing="3">
                            <TextBlock Text="{Binding Title}"
                                       Style="{StaticResource KroiraTitleStyle}"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Detail}"
                                       Style="{StaticResource KroiraMetaStyle}"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Button>
        </DataTemplate>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  VerticalScrollMode="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  HorizontalScrollMode="Disabled">
        <StackPanel Padding="44,32,44,46" Spacing="30">
            <Border MinHeight="288"
                    MaxHeight="344"
                    CornerRadius="18"
                    BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Border Background="{StaticResource KroiraMediaGradientBrush}"
                            CornerRadius="18" />
                    <Image Source="{x:Bind ViewModel.FeaturedItem.HeroArtworkUrl, Mode=OneWay, Converter={StaticResource UrlToImageSourceConverter}}"
                           Stretch="UniformToFill"
                           Opacity="0.88" />
                    <Image Source="{x:Bind ViewModel.FeaturedItem.HeroPosterUrl, Mode=OneWay, Converter={StaticResource UrlToImageSourceConverter}}"
                           Width="440"
                           HorizontalAlignment="Right"
                           Stretch="UniformToFill"
                           Opacity="0.20" />
                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#F006080A" Offset="0" />
                                <GradientStop Color="#D1090B0F" Offset="0.38" />
                                <GradientStop Color="#5910141A" Offset="0.68" />
                                <GradientStop Color="#D0080A0D" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#26000000" Offset="0" />
                                <GradientStop Color="#08000000" Offset="0.44" />
                                <GradientStop Color="#B8080A0D" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Border Width="5"
                            HorizontalAlignment="Left"
                            Background="{StaticResource KroiraAccentGradientBrush}"
                            CornerRadius="18,0,0,18" />

                    <Grid Padding="36,24" ColumnSpacing="26">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="188" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Spacing="10"
                                    VerticalAlignment="Bottom"
                                    MaxWidth="760">
                            <TextBlock Text="FEATURED"
                                       Style="{StaticResource KroiraEyebrowStyle}"
                                       Foreground="{StaticResource KroiraAccentBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.FeaturedItem.Title, Mode=OneWay}"
                                       Style="{StaticResource KroiraDisplayLgStyle}"
                                       FontSize="44"
                                       LineHeight="50"
                                       MaxLines="2"
                                       TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border Background="#B40A0D11"
                                        BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="9,4">
                                    <TextBlock Text="{x:Bind ViewModel.FeaturedItem.RatingText, Mode=OneWay}"
                                               Foreground="{StaticResource KroiraAccentBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold" />
                                </Border>
                                <TextBlock Text="{x:Bind ViewModel.FeaturedItem.Detail, Mode=OneWay}"
                                           Style="{StaticResource KroiraMetaStyle}"
                                           VerticalAlignment="Center"
                                           MaxLines="1"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.FeaturedItem.Overview, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       FontSize="13"
                                       LineHeight="19"
                                       MaxWidth="580"
                                       MaxLines="2"
                                       TextTrimming="CharacterEllipsis" />
                            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,5,0,0">
                                <Button Click="FeaturedPrimary_Click"
                                        Style="{StaticResource KroiraPrimaryButtonStyle}"
                                        Padding="18,10"
                                        MinWidth="132">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE768;" FontSize="13" />
                                        <TextBlock Text="{x:Bind ViewModel.FeaturedItem.PrimaryActionLabel, Mode=OneWay}" />
                                    </StackPanel>
                                </Button>
                                <Button Click="LiveTv_Click"
                                        Style="{StaticResource KroiraGhostButtonStyle}"
                                        Padding="16,10"
                                        MinWidth="104"
                                        Content="Live TV" />
                            </StackPanel>
                            <Border Margin="0,5,0,0"
                                    Padding="7"
                                    Background="#5E090B0F"
                                    BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    HorizontalAlignment="Left">
                                <ItemsControl ItemsSource="{x:Bind ViewModel.SummaryItems, Mode=OneWay}"
                                              ItemTemplate="{StaticResource SummaryStatTemplate}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <ItemsStackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Spacing="10"
                                    VerticalAlignment="Bottom">
                            <Border Width="164"
                                    Height="244"
                                    CornerRadius="12"
                                    BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                    BorderThickness="1"
                                    Background="{StaticResource KroiraPosterPlaceholderBrush}">
                                <Grid>
                                    <FontIcon Glyph="&#xE8B2;"
                                          Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                          FontSize="28"
                                          Opacity="0.55" />
                                    <Image Source="{x:Bind ViewModel.FeaturedItem.HeroPosterUrl, Mode=OneWay, Converter={StaticResource UrlToImageSourceConverter}}"
                                           Stretch="UniformToFill" />
                                    <Border Height="72"
                                            VerticalAlignment="Bottom">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#0010141A" Offset="0" />
                                                <GradientStop Color="#D8080A0D" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                </Grid>
                            </Border>
                            <Border Width="164"
                                    Padding="11,9"
                                    Background="#9A090B0F"
                                    BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Now featured"
                                               Style="{StaticResource KroiraLabelStyle}"
                                               Foreground="{StaticResource KroiraAccentBrush}" />
                                    <TextBlock Text="{x:Bind ViewModel.FeaturedItem.Detail, Mode=OneWay}"
                                               Style="{StaticResource KroiraMetaStyle}"
                                               MaxLines="1"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <StackPanel Spacing="16">
                <Grid>
                    <TextBlock Text="Continue Watching"
                               Style="{StaticResource KroiraSectionTitleStyle}"
                               VerticalAlignment="Center" />
                    <Button Content="View all"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Click="ContinueWatching_Click"
                            Style="{StaticResource KroiraGhostButtonStyle}" />
                </Grid>

                <controls:Rail x:Name="ContinueWatchingRail"
                               Visibility="{x:Bind ViewModel.ContinueItemsVisibility, Mode=OneWay}"
                               ItemsSource="{x:Bind ViewModel.ContinueItems, Mode=OneWay}"
                               ItemTemplate="{StaticResource ContinueItemCardTemplate}"
                               RailHeight="224"
                               ItemSpacing="16"
                               ScrollAmount="404" />

                <Border Visibility="{x:Bind ViewModel.ContinueEmptyVisibility, Mode=OneWay}"
                        Background="#A00B0E13"
                        BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="24,20">
                    <StackPanel Spacing="8" MaxWidth="500">
                        <FontIcon Glyph="&#xE768;"
                                  FontSize="18"
                                  Foreground="{StaticResource KroiraTextTertiaryBrush}" />
                        <TextBlock Text="Nothing to resume yet"
                                   Style="{StaticResource KroiraTitleStyle}" />
                        <TextBlock Text="Start watching a channel, movie, or episode and it will appear here."
                                   Style="{StaticResource KroiraBodyStyle}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="16" Visibility="{x:Bind ViewModel.PopularItemsVisibility, Mode=OneWay}">
                <Grid>
                    <TextBlock Text="Recommended For You"
                               Style="{StaticResource KroiraSectionTitleStyle}"
                               VerticalAlignment="Center" />
                    <Button Content="Browse catalog"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Click="BrowseCatalog_Click"
                            Style="{StaticResource KroiraGhostButtonStyle}" />
                </Grid>
                <controls:Rail x:Name="RecommendedRail"
                               ItemsSource="{x:Bind ViewModel.PopularItems, Mode=OneWay}"
                               ItemTemplate="{StaticResource MediaPosterCardTemplate}"
                               RailHeight="306"
                               ItemSpacing="16"
                               ScrollAmount="420" />
            </StackPanel>

            <StackPanel Spacing="16" Visibility="{x:Bind ViewModel.RecentlyAddedItemsVisibility, Mode=OneWay}">
                <TextBlock Text="Recently Added"
                           Style="{StaticResource KroiraSectionTitleStyle}" />
                <controls:Rail x:Name="RecentlyAddedRail"
                               ItemsSource="{x:Bind ViewModel.RecentlyAddedItems, Mode=OneWay}"
                               ItemTemplate="{StaticResource MediaPosterCardTemplate}"
                               RailHeight="306"
                               ItemSpacing="16"
                               ScrollAmount="420" />
            </StackPanel>

            <StackPanel Spacing="16" Visibility="{x:Bind ViewModel.TopRatedItemsVisibility, Mode=OneWay}">
                <TextBlock Text="Top Rated"
                           Style="{StaticResource KroiraSectionTitleStyle}" />
                <controls:Rail x:Name="TopRatedRail"
                               ItemsSource="{x:Bind ViewModel.TopRatedItems, Mode=OneWay}"
                               ItemTemplate="{StaticResource MediaPosterCardTemplate}"
                               RailHeight="306"
                               ItemSpacing="16"
                               ScrollAmount="420" />
            </StackPanel>

            <StackPanel Spacing="16" Visibility="{x:Bind ViewModel.LiveItemsVisibility, Mode=OneWay}">
                <Grid>
                    <TextBlock Text="Live Now"
                               Style="{StaticResource KroiraSectionTitleStyle}"
                               VerticalAlignment="Center" />
                    <Button Content="All live TV"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Click="LiveTv_Click"
                            Style="{StaticResource KroiraGhostButtonStyle}" />
                </Grid>

                <controls:Rail x:Name="LiveNowRail"
                               ItemsSource="{x:Bind ViewModel.LiveItems, Mode=OneWay}"
                               ItemTemplate="{StaticResource LiveNowCardTemplate}"
                               RailHeight="144"
                               ItemSpacing="16"
                               ScrollAmount="360" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
