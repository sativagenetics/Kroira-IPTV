<Page
    x:Class="Kroira.App.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Kroira.App.Controls"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Page.Resources>
        <Style x:Key="HomeCardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>

        <DataTemplate x:Key="SummaryStatTemplate">
            <Border MinWidth="118"
                    Padding="10,5"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    CornerRadius="8">
                <StackPanel Spacing="1">
                    <TextBlock Text="{Binding Value}"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                    <TextBlock Text="{Binding Label}"
                               Style="{StaticResource KroiraMetaStyle}"
                               FontSize="11" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ContinueItemCardTemplate">
            <Button Click="ContinueItem_Click"
                    Style="{StaticResource HomeCardButtonStyle}">
                <Border Width="372"
                        Height="218"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        CornerRadius="16">
                    <Grid>
                        <Border Background="{StaticResource KroiraMediaGradientBrush}"
                                CornerRadius="12" />
                        <Image Source="{Binding BackdropUrl, Converter={StaticResource UrlToImageSourceConverter}}"
                               Stretch="UniformToFill"
                               Opacity="0.82" />
                        <Border>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#E0090B0F" Offset="0" />
                                    <GradientStop Color="#7010141A" Offset="0.46" />
                                    <GradientStop Color="#F0090B0F" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <Grid Padding="16" ColumnSpacing="15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="112" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Width="112"
                                    Height="158"
                                    CornerRadius="9"
                                    Background="{StaticResource KroiraPosterPlaceholderBrush}"
                                    BorderBrush="Transparent"
                                    BorderThickness="0">
                                <Grid>
                                    <FontIcon Glyph="&#xE8B2;"
                                              Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                              FontSize="22"
                                              Opacity="0.55" />
                                    <Image Source="{Binding PosterUrl, Converter={StaticResource UrlToImageSourceConverter}}"
                                           Stretch="UniformToFill" />
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="1"
                                        Spacing="8"
                                        VerticalAlignment="Top">
                                <Border Background="#B30A0D11"
                                        BorderBrush="Transparent"
                                        BorderThickness="0"
                                        CornerRadius="8"
                                        Padding="8,3"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="RESUME"
                                               Foreground="{StaticResource KroiraAccentBrush}"
                                               FontSize="10"
                                               FontWeight="SemiBold" />
                                </Border>
                                <TextBlock Text="{Binding Title}"
                                           Style="{StaticResource KroiraTitleStyle}"
                                           FontSize="17"
                                           MaxLines="2"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Overview}"
                                           Style="{StaticResource KroiraBodyStyle}"
                                           FontSize="12"
                                           LineHeight="17"
                                           MaxLines="2"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Detail}"
                                           Style="{StaticResource KroiraMetaStyle}"
                                           MaxLines="1"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>

                            <Grid Grid.Row="1"
                                  Grid.ColumnSpan="2"
                                  ColumnSpacing="10"
                                  Margin="0,13,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ProgressBar Value="{Binding ProgressValue}"
                                             Maximum="100"
                                             Height="3"
                                             Foreground="{StaticResource KroiraAccentBrush}"
                                             Background="#4AFFFFFF"
                                             VerticalAlignment="Center" />
                                <FontIcon Grid.Column="1"
                                          Glyph="&#xE768;"
                                          FontSize="16"
                                          Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="MediaPosterCardTemplate">
            <Button Click="MediaItem_Click"
                    Style="{StaticResource HomeCardButtonStyle}">
                <Border Width="188"
                        Height="300"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        CornerRadius="12"
                        Padding="10,10,10,12">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#111827" Offset="0" />
                            <GradientStop Color="#090E18" Offset="0.54" />
                            <GradientStop Color="#00000000" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="206" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Border CornerRadius="9"
                                    Background="{StaticResource KroiraPosterPlaceholderBrush}"
                                    BorderBrush="#1EFFFFFF"
                                    BorderThickness="1">
                                <FontIcon Glyph="&#xE8B2;"
                                          Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                          FontSize="26"
                                          Opacity="0.55" />
                            </Border>
                            <Border CornerRadius="9">
                                <Image Source="{Binding PosterUrl, Converter={StaticResource UrlToImageSourceConverter}}"
                                       Stretch="UniformToFill" />
                            </Border>
                            <Border Height="72"
                                    VerticalAlignment="Bottom"
                                    CornerRadius="0,0,9,9">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#0010141A" Offset="0" />
                                        <GradientStop Color="#D8080A0D" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>

                        <StackPanel Grid.Row="1" Spacing="4" Margin="1,10,1,4">
                            <TextBlock Text="{Binding Title}"
                                       Style="{StaticResource KroiraTitleStyle}"
                                       FontSize="14"
                                       MaxLines="2"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Detail}"
                                       Style="{StaticResource KroiraMetaStyle}"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="LiveNowCardTemplate">
            <Button Click="LiveNow_Click"
                    Style="{StaticResource HomeCardButtonStyle}">
                <Border Width="248"
                        Height="138"
                        BorderBrush="{StaticResource KroiraGhostBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1B2830" Offset="0" />
                            <GradientStop Color="#10151C" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Border Width="64"
                                    Height="52"
                                    CornerRadius="9"
                                    Background="#5810141A"
                                    BorderBrush="#18FFFFFF"
                                    BorderThickness="1"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top">
                                <Grid>
                                    <FontIcon Glyph="&#xE714;"
                                              FontSize="20"
                                              Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                              Opacity="0.48" />
                                    <Image Source="{Binding LogoUrl, Converter={StaticResource UrlToImageSourceConverter}}"
                                           Stretch="Uniform"
                                           Margin="7" />
                                </Grid>
                            </Border>
                            <Border Background="{StaticResource KroiraStateDangerSoftBrush}"
                                    BorderBrush="#33FF5A5F"
                                    BorderThickness="1"
                                    CornerRadius="9"
                                    Padding="8,3"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <Ellipse Width="6" Height="6" Fill="{StaticResource KroiraLiveDotBrush}" />
                                    <TextBlock Text="LIVE"
                                               Foreground="{StaticResource KroiraLiveDotBrush}"
                                               FontSize="10"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <StackPanel Grid.Row="1" Spacing="3">
                            <TextBlock Text="{Binding Title}"
                                       Style="{StaticResource KroiraTitleStyle}"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Detail}"
                                       Style="{StaticResource KroiraMetaStyle}"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="LiveSportsNowCardTemplate">
            <Button Click="LiveSportsNow_Click"
                    Style="{StaticResource HomeCardButtonStyle}">
                <Border Width="288"
                        Height="126"
                        Padding="14"
                        Background="#66070B12"
                        BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14">
                    <Grid RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="58" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Width="58"
                                    Height="46"
                                    CornerRadius="10"
                                    Background="#5810141A"
                                    BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                    BorderThickness="1">
                                <Grid>
                                    <FontIcon Glyph="&#xE714;"
                                              FontSize="18"
                                              Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                              Opacity="0.55" />
                                    <Image Source="{Binding LogoUrl, Converter={StaticResource UrlToImageSourceConverter}}"
                                           Stretch="Uniform"
                                           Margin="7" />
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="1"
                                        Spacing="3"
                                        VerticalAlignment="Center">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Title}"
                                               Style="{StaticResource KroiraTitleStyle}"
                                               MaxLines="1"
                                               TextTrimming="CharacterEllipsis" />
                                    <Border Grid.Column="1"
                                            Background="{StaticResource KroiraStateDangerSoftBrush}"
                                            BorderBrush="#33FF5A5F"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="7,2">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <Ellipse Width="5"
                                                     Height="5"
                                                     Fill="{StaticResource KroiraLiveDotBrush}"
                                                     VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding BadgeText}"
                                                       Foreground="{StaticResource KroiraLiveDotBrush}"
                                                       FontSize="9"
                                                       FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <TextBlock Text="{Binding Detail}"
                                           Style="{StaticResource KroiraMetaStyle}"
                                           MaxLines="1"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Grid.Row="1"
                                   Text="{Binding ProgramLine}"
                                   Style="{StaticResource KroiraBodyStyle}"
                                   FontSize="12"
                                   LineHeight="17"
                                   MaxLines="1"
                                   TextTrimming="CharacterEllipsis"
                                   Visibility="{Binding ProgramVisibility}" />
                    </Grid>
                </Border>
            </Button>
        </DataTemplate>
    </Page.Resources>

    <Grid XYFocusKeyboardNavigation="Enabled">
        <controls:AmbientPageBackground />

        <ScrollViewer x:Name="HomeScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      VerticalScrollMode="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      HorizontalScrollMode="Disabled"
                      Visibility="{x:Bind ViewModel.SurfaceState.ContentVisibility, Mode=OneWay}">
        <StackPanel Padding="28,16,44,46" Spacing="28">
            <Border MinHeight="330"
                    MaxHeight="380"
                    Margin="-28,-20,-44,0"
                    CornerRadius="0,0,28,28"
                    BorderBrush="{StaticResource KroiraGhostBorderBrush}"
                    BorderThickness="0">
                <Grid>
                    <Border Background="{StaticResource KroiraMediaGradientBrush}"
                            CornerRadius="0,0,28,28" />
                    <Image Source="ms-appx:///Assets/Home/match-center-hero.png"
                           Stretch="UniformToFill"
                           Opacity="0.92" />
                    <Border Background="{StaticResource KroiraHeroScrimBrush}" />
                    <Border Background="{StaticResource KroiraVerticalScrimBrush}" />
                    <Border HorizontalAlignment="Right"
                            Width="520"
                            Background="{StaticResource KroiraPlumWashBrush}"
                            Opacity="0.55" />

                    <Grid Padding="54,34,52,34"
                          ColumnSpacing="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="260" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="12"
                                    VerticalAlignment="Center"
                                    MaxWidth="650">
                            <Border Background="#B40A0D11"
                                    BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="9"
                                    Padding="10,5"
                                    HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal" Spacing="7">
                                    <Ellipse Width="7"
                                             Height="7"
                                             Fill="{StaticResource KroiraLiveDotBrush}"
                                             VerticalAlignment="Center" />
                                    <TextBlock Text="LIVE SPORTS"
                                               Foreground="{StaticResource KroiraAccentBrush}"
                                               FontSize="11"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <TextBlock Text="Match Center"
                                       Style="{StaticResource KroiraDisplayLgStyle}"
                                       FontSize="48"
                                       LineHeight="54"
                                       MaxLines="1" />
                            <TextBlock Text="Jump into live sports instantly."
                                       Style="{StaticResource KroiraBodyStyle}"
                                       FontSize="16"
                                       LineHeight="23"
                                       MaxWidth="460"
                                       Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                            <Button x:Name="FeaturedPrimaryButton"
                                    Click="LiveTv_Click"
                                    Style="{StaticResource KroiraPrimaryButtonStyle}"
                                    Padding="20,11"
                                    MinWidth="154"
                                    Margin="0,8,0,0"
                                    HorizontalAlignment="Left"
                                    AutomationProperties.Name="Watch Live TV">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE768;" FontSize="14" />
                                    <TextBlock Text="Watch Live TV" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Width="224"
                                Padding="18"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right"
                                Background="#82070B12"
                                BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="18">
                            <StackPanel Spacing="12">
                                <Grid Width="48"
                                      Height="48"
                                      HorizontalAlignment="Left">
                                    <Ellipse Fill="{StaticResource KroiraStateDangerSoftBrush}" />
                                    <FontIcon Glyph="&#xE7FC;"
                                              FontSize="21"
                                              Foreground="{StaticResource KroiraLiveDotBrush}" />
                                </Grid>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Live TV"
                                               Style="{StaticResource KroiraTitleStyle}"
                                               FontSize="17" />
                                    <TextBlock Text="Sports channels, live events, and match-night viewing in one jump."
                                               Style="{StaticResource KroiraBodyStyle}"
                                               MaxLines="3"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <Border Height="1"
                                        Background="{StaticResource KroiraGlassBorderBrush}" />
                                <TextBlock Text="Ready when the match starts"
                                           Style="{StaticResource KroiraMetaStyle}"
                                           Foreground="{StaticResource KroiraAccentBrush}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <StackPanel Spacing="12">
                <TextBlock Text="Live TV Shortcuts"
                           Style="{StaticResource KroiraSectionTitleStyle}" />

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Click="LiveTv_Click"
                            Style="{StaticResource HomeCardButtonStyle}"
                            AutomationProperties.Name="All Channels">
                        <Border Height="88"
                                Padding="14"
                                Background="#66070B12"
                                BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="36"
                                        Height="36"
                                        Background="{StaticResource KroiraControlBrush}"
                                        BorderBrush="{StaticResource KroiraControlBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <FontIcon Glyph="&#xE714;"
                                              FontSize="17"
                                              Foreground="{StaticResource KroiraAccentBrush}" />
                                </Border>
                                <StackPanel Grid.Column="1"
                                            Spacing="2"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="All Channels"
                                               Style="{StaticResource KroiraTitleStyle}"
                                               MaxLines="1"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="Browse the full live lineup"
                                               Style="{StaticResource KroiraMetaStyle}"
                                               MaxLines="1"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Button>

                    <Button Grid.Column="1"
                            Click="LiveTv_Click"
                            Style="{StaticResource HomeCardButtonStyle}"
                            AutomationProperties.Name="Sports">
                        <Border Height="88"
                                Padding="14"
                                Background="#66070B12"
                                BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="36"
                                        Height="36"
                                        Background="{StaticResource KroiraStateDangerSoftBrush}"
                                        BorderBrush="#33FF5A5F"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <FontIcon Glyph="&#xE7FC;"
                                              FontSize="17"
                                              Foreground="{StaticResource KroiraLiveDotBrush}" />
                                </Border>
                                <StackPanel Grid.Column="1"
                                            Spacing="2"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Sports"
                                               Style="{StaticResource KroiraTitleStyle}"
                                               MaxLines="1"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="Jump to sports viewing"
                                               Style="{StaticResource KroiraMetaStyle}"
                                               MaxLines="1"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Button>

                    <Button Grid.Column="2"
                            Click="Favorites_Click"
                            Style="{StaticResource HomeCardButtonStyle}"
                            AutomationProperties.Name="Favorites">
                        <Border Height="88"
                                Padding="14"
                                Background="#66070B12"
                                BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="36"
                                        Height="36"
                                        Background="{StaticResource KroiraControlBrush}"
                                        BorderBrush="{StaticResource KroiraControlBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <FontIcon Glyph="&#xE734;"
                                              FontSize="17"
                                              Foreground="{StaticResource KroiraAccentBrush}" />
                                </Border>
                                <StackPanel Grid.Column="1"
                                            Spacing="2"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Favorites"
                                               Style="{StaticResource KroiraTitleStyle}"
                                               MaxLines="1"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="Open saved channels"
                                               Style="{StaticResource KroiraMetaStyle}"
                                               MaxLines="1"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Button>

                    <Button Grid.Column="3"
                            Click="ContinueWatching_Click"
                            Style="{StaticResource HomeCardButtonStyle}"
                            AutomationProperties.Name="Recently Watched">
                        <Border Height="88"
                                Padding="14"
                                Background="#66070B12"
                                BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="36"
                                        Height="36"
                                        Background="{StaticResource KroiraControlBrush}"
                                        BorderBrush="{StaticResource KroiraControlBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <FontIcon Glyph="&#xE916;"
                                              FontSize="17"
                                              Foreground="{StaticResource KroiraAccentBrush}" />
                                </Border>
                                <StackPanel Grid.Column="1"
                                            Spacing="2"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Recently Watched"
                                               Style="{StaticResource KroiraTitleStyle}"
                                               MaxLines="1"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="Return to recent viewing"
                                               Style="{StaticResource KroiraMetaStyle}"
                                               MaxLines="1"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Button>
                </Grid>
            </StackPanel>

            <StackPanel Spacing="12"
                        Visibility="{x:Bind ViewModel.LiveSportsItemsVisibility, Mode=OneWay}">
                <Grid>
                    <TextBlock Text="Live Sports Now"
                               Style="{StaticResource KroiraSectionTitleStyle}"
                               VerticalAlignment="Center" />
                    <Button Content="All live TV"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Click="LiveTv_Click"
                            Style="{StaticResource KroiraGhostButtonStyle}" />
                </Grid>

                <controls:Rail x:Name="LiveSportsNowRail"
                               ItemsSource="{x:Bind ViewModel.LiveSportsItems, Mode=OneWay}"
                               ItemTemplate="{StaticResource LiveSportsNowCardTemplate}"
                               RailHeight="132"
                               ItemSpacing="12"
                               ScrollAmount="360" />
            </StackPanel>

            <StackPanel Spacing="16">
                <Grid>
                    <TextBlock Text="Continue Watching"
                               Style="{StaticResource KroiraSectionTitleStyle}"
                               VerticalAlignment="Center" />
                    <Button Content="View all"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Click="ContinueWatching_Click"
                            Style="{StaticResource KroiraGhostButtonStyle}" />
                </Grid>

                <controls:Rail x:Name="ContinueWatchingRail"
                               Visibility="{x:Bind ViewModel.ContinueItemsVisibility, Mode=OneWay}"
                               ItemsSource="{x:Bind ViewModel.ContinueItems, Mode=OneWay}"
                               ItemTemplate="{StaticResource ContinueItemCardTemplate}"
                               RailHeight="224"
                               ItemSpacing="16"
                               ScrollAmount="404" />

                <Border Visibility="{x:Bind ViewModel.ContinueEmptyVisibility, Mode=OneWay}"
                        Background="#A00B0E13"
                        BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="24,20">
                    <StackPanel Spacing="8" MaxWidth="500">
                        <FontIcon Glyph="&#xE768;"
                                  FontSize="18"
                                  Foreground="{StaticResource KroiraTextTertiaryBrush}" />
                        <TextBlock Text="Nothing to resume yet"
                                   Style="{StaticResource KroiraTitleStyle}" />
                        <TextBlock Text="Start watching a channel, movie, or episode and it will appear here."
                                   Style="{StaticResource KroiraBodyStyle}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="16" Visibility="{x:Bind ViewModel.PopularItemsVisibility, Mode=OneWay}">
                <Grid>
                    <TextBlock Text="Recommended For You"
                               Style="{StaticResource KroiraSectionTitleStyle}"
                               VerticalAlignment="Center" />
                    <Button Content="Browse catalog"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Click="BrowseCatalog_Click"
                            Style="{StaticResource KroiraGhostButtonStyle}" />
                </Grid>
                <controls:Rail x:Name="RecommendedRail"
                               ItemsSource="{x:Bind ViewModel.PopularItems, Mode=OneWay}"
                               ItemTemplate="{StaticResource MediaPosterCardTemplate}"
                               RailHeight="306"
                               ItemSpacing="16"
                               ScrollAmount="420" />
            </StackPanel>

            <StackPanel Spacing="16" Visibility="{x:Bind ViewModel.RecentlyAddedItemsVisibility, Mode=OneWay}">
                <TextBlock Text="Recently Added"
                           Style="{StaticResource KroiraSectionTitleStyle}" />
                <controls:Rail x:Name="RecentlyAddedRail"
                               ItemsSource="{x:Bind ViewModel.RecentlyAddedItems, Mode=OneWay}"
                               ItemTemplate="{StaticResource MediaPosterCardTemplate}"
                               RailHeight="306"
                               ItemSpacing="16"
                               ScrollAmount="420" />
            </StackPanel>

            <StackPanel Spacing="16" Visibility="{x:Bind ViewModel.TopRatedItemsVisibility, Mode=OneWay}">
                <TextBlock Text="Top Rated"
                           Style="{StaticResource KroiraSectionTitleStyle}" />
                <controls:Rail x:Name="TopRatedRail"
                               ItemsSource="{x:Bind ViewModel.TopRatedItems, Mode=OneWay}"
                               ItemTemplate="{StaticResource MediaPosterCardTemplate}"
                               RailHeight="306"
                               ItemSpacing="16"
                               ScrollAmount="420" />
            </StackPanel>

            <StackPanel Spacing="16" Visibility="{x:Bind ViewModel.LiveItemsVisibility, Mode=OneWay}">
                <Grid>
                    <TextBlock Text="Live Now"
                               Style="{StaticResource KroiraSectionTitleStyle}"
                               VerticalAlignment="Center" />
                    <Button Content="All live TV"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Click="LiveTv_Click"
                            Style="{StaticResource KroiraGhostButtonStyle}" />
                </Grid>

                <controls:Rail x:Name="LiveNowRail"
                               ItemsSource="{x:Bind ViewModel.LiveItems, Mode=OneWay}"
                               ItemTemplate="{StaticResource LiveNowCardTemplate}"
                               RailHeight="144"
                               ItemSpacing="16"
                               ScrollAmount="360" />
            </StackPanel>

            <StackPanel Spacing="8"
                        Opacity="0.72"
                        Margin="0,2,0,0">
                <TextBlock Text="Library at a glance"
                           Style="{StaticResource KroiraLabelStyle}"
                           Foreground="{StaticResource KroiraTextTertiaryBrush}" />
                <ItemsControl ItemsSource="{x:Bind ViewModel.SummaryItems, Mode=OneWay}"
                              ItemTemplate="{StaticResource SummaryStatTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
        </ScrollViewer>

        <Border Visibility="{x:Bind ViewModel.SurfaceState.StateVisibility, Mode=OneWay}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="560"
                Margin="32"
                Background="#76070B12"
                BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="28,24">
            <StackPanel Spacing="12">
                <Grid Width="32" Height="32">
                    <ProgressRing IsActive="True"
                                  Width="28"
                                  Height="28"
                                  Visibility="{x:Bind ViewModel.SurfaceState.ProgressVisibility, Mode=OneWay}" />
                    <FontIcon Glyph="{x:Bind ViewModel.SurfaceState.Glyph, Mode=OneWay}"
                              FontSize="28"
                              Foreground="{StaticResource KroiraTextTertiaryBrush}"
                              Visibility="{x:Bind ViewModel.SurfaceState.IconVisibility, Mode=OneWay}" />
                </Grid>
                <TextBlock Text="{x:Bind ViewModel.SurfaceState.Title, Mode=OneWay}"
                           Style="{StaticResource KroiraSectionTitleStyle}" />
                <TextBlock Text="{x:Bind ViewModel.SurfaceState.Message, Mode=OneWay}"
                           Style="{StaticResource KroiraBodyStyle}"
                           TextWrapping="Wrap" />
                <Button Content="{x:Bind ViewModel.SurfaceState.ActionLabel, Mode=OneWay}"
                        Click="OpenSources_Click"
                        Visibility="{x:Bind ViewModel.SurfaceState.ActionVisibility, Mode=OneWay}"
                        Style="{StaticResource KroiraPrimaryButtonStyle}"
                        HorizontalAlignment="Left" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
