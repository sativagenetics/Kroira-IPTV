<Page
    x:Class="Kroira.App.Views.MoviesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Kroira.App.Controls"
    xmlns:viewModels="using:Kroira.App.ViewModels"
    x:Name="MoviesPageRoot"
    NavigationCacheMode="Required"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Page.Resources>
        <Style x:Key="MovieTileContainerStyle" TargetType="GridViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,10,22" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="UseSystemFocusVisuals" Value="True" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="CategoryRailItemContainerStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="FavoritePillButtonStyle" TargetType="Button" BasedOn="{StaticResource KroiraGhostButtonStyle}">
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>
    </Page.Resources>

    <Grid XYFocusKeyboardNavigation="Enabled">
        <controls:AmbientPageBackground />

        <Grid Padding="34,26,34,38"
              MaxWidth="1660"
              HorizontalAlignment="Center"
              RowSpacing="14"
              Visibility="{x:Bind ViewModel.ContentShellVisibility, Mode=OneWay}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="5">
                <TextBlock Text="MOVIES LIBRARY"
                           Style="{StaticResource KroiraLabelStyle}"
                           Foreground="{StaticResource KroiraAccentBrush}" />
                <TextBlock Text="Movies"
                           Style="{StaticResource KroiraPageTitleStyle}" />
                <TextBlock Text="Search, filter, and pick a film from your sources."
                           Style="{StaticResource KroiraPageSubtitleStyle}"
                           MaxWidth="720" />
            </StackPanel>
        </Grid>

        <!--
            FEATURED HERO
            ─────────────────────────────────────────────────────────────
            The outer Border is Height-clamped AND MaxHeight-clamped so
            the unbounded <Image Stretch="UniformToFill" .. /> children
            below can never dictate the layout height from their natural
            pixel dimensions. The CornerRadius on this Border clips any
            overflow to the rounded rectangle. Row 0 of the outer Grid is
            now a fixed 326px row so the hero can never push the browse
            area off-screen even if the hero Border is ever re-templated.
        -->
        <Border Grid.Row="0"
                Height="326"
                MaxHeight="326"
                Visibility="Collapsed"
                VerticalAlignment="Top"
                BorderBrush="{StaticResource KroiraGhostBorderBrush}"
                BorderThickness="0"
                CornerRadius="{StaticResource KroiraRadiusHero}">
            <Grid>
                <Border Background="{StaticResource KroiraMediaGradientBrush}"
                        CornerRadius="{StaticResource KroiraRadiusHero}" />
                <!--
                    Hero backdrop image. Width/Height explicitly set to
                    the hero size so the image cannot request its own
                    natural pixel size during measure. UniformToFill
                    crops to the hero frame.
                -->
                <Image Source="{x:Bind ViewModel.FeaturedMovie.DisplayHeroArtworkUrl, Mode=OneWay, Converter={StaticResource UrlToImageSourceConverter}}"
                       Stretch="UniformToFill"
                       Opacity="0.92"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"
                       MaxHeight="324" />
                <!--
                    Right-aligned poster accent. Width bounded AND height
                    bounded so UniformToFill crops rather than requesting
                    a natural height (otherwise a 2:3 poster would ask
                    for ~645px and blow out Row 0).
                -->
                <Image Source="{x:Bind ViewModel.FeaturedMovie.DisplayPosterUrl, Mode=OneWay, Converter={StaticResource UrlToImageSourceConverter}}"
                       Width="430"
                       MaxHeight="324"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Stretch"
                       Stretch="UniformToFill"
                       Opacity="0.16" />
                <Border>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#F205060A" Offset="0" />
                            <GradientStop Color="#D9070912" Offset="0.44" />
                            <GradientStop Color="#52151B2A" Offset="0.72" />
                            <GradientStop Color="#D605060A" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <Border>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#26000000" Offset="0" />
                            <GradientStop Color="#08000000" Offset="0.44" />
                            <GradientStop Color="#B8080A0D" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <Border Width="3"
                        HorizontalAlignment="Left"
                        Background="{StaticResource KroiraAccentGradientBrush}"
                        CornerRadius="24,0,0,24"
                        Opacity="0.72" />

                <Grid Padding="34,28" ColumnSpacing="28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="174" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Spacing="11"
                                VerticalAlignment="Bottom"
                                MaxWidth="760">
                        <TextBlock Text="FEATURED FILM"
                                   Style="{StaticResource KroiraLabelStyle}"
                                   Foreground="{StaticResource KroiraAccentBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.FeaturedMovie.Title, Mode=OneWay}"
                                   Style="{StaticResource KroiraDisplayLgStyle}"
                                   FontSize="38"
                                   LineHeight="44"
                                   MaxLines="2"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Background="#B40A0D11"
                                    BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="9,4"
                                    Visibility="{x:Bind ViewModel.FeaturedMovie.RatingVisibility, Mode=OneWay}">
                                <TextBlock Text="{x:Bind ViewModel.FeaturedMovie.RatingText, Mode=OneWay}"
                                           Foreground="{StaticResource KroiraAccentBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                            </Border>
                            <TextBlock Text="{x:Bind ViewModel.FeaturedMovie.MetadataLine, Mode=OneWay}"
                                       Style="{StaticResource KroiraMetaStyle}"
                                       VerticalAlignment="Center"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.FeaturedMovie.Overview, Mode=OneWay}"
                                   Style="{StaticResource KroiraBodyStyle}"
                                   FontSize="14"
                                   LineHeight="21"
                                   MaxWidth="620"
                                   MaxLines="2"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal"
                                    Spacing="10"
                                    Margin="0,6,0,0">
                            <Button x:Name="FeaturedPlayButton"
                                    Click="FeaturedPlay_Click"
                                    IsEnabled="{x:Bind ViewModel.FeaturedMovieCanPlay, Mode=OneWay}"
                                    Style="{StaticResource KroiraPrimaryButtonStyle}"
                                    Padding="20,11"
                                    MinWidth="136">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE102;" FontSize="13" />
                                    <TextBlock Text="Play movie" />
                                </StackPanel>
                            </Button>
                            <Button Click="FeaturedInspect_Click"
                                    Style="{StaticResource FavoritePillButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE946;"
                                              FontSize="13"
                                              Foreground="{StaticResource KroiraAccentBrush}" />
                                    <TextBlock Text="Details" />
                                </StackPanel>
                            </Button>
                            <Button Click="FavoriteToggle_Click"
                                    Tag="{x:Bind ViewModel.FeaturedMovie.Id, Mode=OneWay}"
                                    Style="{StaticResource FavoritePillButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="{x:Bind ViewModel.FeaturedMovie.FavoriteGlyph, Mode=OneWay}"
                                              FontSize="13"
                                              Foreground="{StaticResource KroiraAccentBrush}" />
                                    <TextBlock Text="{x:Bind ViewModel.FeaturedMovie.FavoriteLabel, Mode=OneWay}" />
                                </StackPanel>
                            </Button>
                            <Button Click="FeaturedDownload_Click"
                                    Visibility="{x:Bind DownloadActionsVisibility, Mode=OneWay}"
                                    IsEnabled="{x:Bind ViewModel.FeaturedMovieCanPlay, Mode=OneWay}"
                                    Style="{StaticResource FavoritePillButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE896;"
                                              FontSize="13"
                                              Foreground="{StaticResource KroiraAccentBrush}" />
                                    <TextBlock Text="Download" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Width="158"
                            Height="238"
                            CornerRadius="14"
                            BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                            BorderThickness="1"
                            Background="{StaticResource KroiraPosterPlaceholderBrush}"
                            VerticalAlignment="Bottom">
                        <Grid>
                            <FontIcon Glyph="&#xE8B2;"
                                      Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                      FontSize="28"
                                      Opacity="0.55" />
                            <Image Source="{x:Bind ViewModel.FeaturedMovie.DisplayPosterUrl, Mode=OneWay, Converter={StaticResource UrlToImageSourceConverter}}"
                                   Stretch="UniformToFill" />
                            <Border Height="72"
                                    VerticalAlignment="Bottom">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#0010141A" Offset="0" />
                                        <GradientStop Color="#D8080A0D" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1" RowSpacing="12" ColumnSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="0" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="186" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0"
                    Grid.ColumnSpan="2"
                    Background="#42070B12"
                    BorderBrush="{StaticResource KroiraGhostBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="10">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.2*" MaxWidth="520" />
                            <ColumnDefinition Width="190" />
                            <ColumnDefinition Width="190" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                             <TextBox x:Name="SearchBox"
                                      Style="{StaticResource KroiraFilterTextBoxStyle}"
                                      Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      KeyDown="SearchBox_KeyDown"
                                      PlaceholderText="Search movies"
                                      AutomationProperties.Name="Search movies" />
                            <FontIcon Glyph="&#xE721;"
                                      FontSize="14"
                                      Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                      HorizontalAlignment="Right"
                                      Margin="0,0,16,0"
                                      VerticalAlignment="Center" />
                        </Grid>

                         <ComboBox Grid.Column="1"
                                   Style="{StaticResource KroiraFilterComboBoxStyle}"
                                   ItemsSource="{x:Bind ViewModel.SourceOptions, Mode=OneWay}"
                                   SelectedItem="{x:Bind ViewModel.SelectedSourceOption, Mode=TwoWay}"
                                   DisplayMemberPath="DisplayName"
                                   AutomationProperties.Name="Movie provider" />

                         <ComboBox Grid.Column="2"
                                   Style="{StaticResource KroiraFilterComboBoxStyle}"
                                   ItemsSource="{x:Bind ViewModel.SortOptions, Mode=OneWay}"
                                   SelectedItem="{x:Bind ViewModel.SelectedSortOption, Mode=TwoWay}"
                                   DisplayMemberPath="Label"
                                   AutomationProperties.Name="Movie sort" />

                        <StackPanel Grid.Column="3"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                             <CheckBox Content="Favorites"
                                       IsChecked="{x:Bind ViewModel.FavoritesOnly, Mode=TwoWay}"
                                       AutomationProperties.Name="Show favorite movies only" />
                             <CheckBox Content="Primary only"
                                       IsChecked="{x:Bind ViewModel.HideSecondaryContent, Mode=TwoWay}"
                                       AutomationProperties.Name="Show primary movie entries only" />
                        </StackPanel>
                    </Grid>
            </Border>

            <ListView x:Name="CategoryList"
                      Grid.Row="1"
                      Grid.Column="0"
                      ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                      SelectionMode="Single"
                      ItemContainerStyle="{StaticResource CategoryRailItemContainerStyle}"
                      Background="Transparent"
                      BorderThickness="0"
                      Padding="0"
                      ScrollViewer.HorizontalScrollMode="Disabled"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollMode="Enabled"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      AutomationProperties.Name="Movie categories">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:BrowserCategoryViewModel">
                        <Grid MinHeight="44">
                            <Border Background="{StaticResource KroiraAccentContainerBrush}"
                                    BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Opacity="{x:Bind SelectionBackgroundOpacity, Mode=OneWay}" />
                            <Border BorderBrush="{StaticResource KroiraAccentBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Opacity="{x:Bind SelectionChromeOpacity, Mode=OneWay}" />
                            <Border Width="3"
                                    HorizontalAlignment="Left"
                                    Margin="0,7,0,7"
                                    CornerRadius="2"
                                    Background="{StaticResource KroiraAccentBrush}"
                                    Opacity="{x:Bind SelectionAccentOpacity, Mode=OneWay}" />
                            <Grid Padding="12,8,10,8" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="1">
                                    <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                               Foreground="{StaticResource KroiraTextPrimaryBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{x:Bind Description, Mode=OneWay}"
                                               Visibility="{x:Bind DescriptionVisibility, Mode=OneWay}"
                                               Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                               FontSize="10"
                                               MaxLines="1"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Background="#1AFFFFFF"
                                        BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="9"
                                        Padding="6,2"
                                        VerticalAlignment="Center"
                                        Visibility="{x:Bind CountVisibility, Mode=OneWay}">
                                    <TextBlock Text="{x:Bind CountText, Mode=OneWay}"
                                               Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                               FontSize="10"
                                               FontWeight="SemiBold" />
                                </Border>
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Grid Grid.Row="1" Grid.Column="1">
                    <controls:EmptyStateView IconGlyph="&#xE8B2;"
                                             Title="{x:Bind ViewModel.EmptyStateTitle, Mode=OneWay}"
                                             Message="{x:Bind ViewModel.EmptyStateMessage, Mode=OneWay}"
                                             Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center" />

                <GridView x:Name="MovieGrid"
                          ItemsSource="{x:Bind ViewModel.DisplayMovieSlots, Mode=OneWay}"
                          SelectionMode="None"
                          IsItemClickEnabled="True"
                          ItemClick="GridView_ItemClick"
                          KeyDown="MovieGrid_KeyDown"
                          ItemContainerStyle="{StaticResource MovieTileContainerStyle}"
                          HorizontalAlignment="Stretch"
                          ScrollViewer.HorizontalScrollMode="Disabled"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollMode="Enabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          Padding="0,4,0,24">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"
                                           ItemWidth="176"
                                           ItemHeight="306"
                                           MaximumRowsOrColumns="7" />
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="170"
                                  Height="294"
                                  Loaded="RevealCardRoot_Loaded">
                                <Border Visibility="{Binding MovieVisibility}"
                                        BorderBrush="Transparent"
                                        BorderThickness="0"
                                        CornerRadius="14"
                                        Padding="8,8,8,10">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#0A111A" Offset="0" />
                                            <GradientStop Color="#05080E" Offset="0.58" />
                                            <GradientStop Color="#00000000" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="214" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Border CornerRadius="9"
                                                    Background="{StaticResource KroiraPosterPlaceholderBrush}"
                                                    BorderBrush="#1EFFFFFF"
                                                    BorderThickness="1">
                                                <FontIcon Glyph="&#xE8B2;"
                                                          Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                          FontSize="28"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Opacity="0.55" />
                                            </Border>
                                            <Border CornerRadius="9">
                                                <Image Source="{Binding DisplayPosterUrl, Converter={StaticResource UrlToImageSourceConverter}}"
                                                       Stretch="UniformToFill" />
                                            </Border>
                                            <Border Height="96"
                                                    VerticalAlignment="Bottom"
                                                    CornerRadius="0,0,9,9">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#0010141A" Offset="0" />
                                                        <GradientStop Color="#D8080A0D" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <Border Tag="MediaActionOverlay"
                                                    Visibility="Collapsed"
                                                    Opacity="0"
                                                    IsHitTestVisible="False"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Bottom"
                                                    Margin="10"
                                                    CornerRadius="18"
                                                    Padding="6"
                                                    Background="#A805070B">
                                                <Grid ColumnSpacing="6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border HorizontalAlignment="Left"
                                                            Background="{StaticResource KroiraAccentContainerBrush}"
                                                            BorderBrush="{StaticResource KroiraAccentBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="14"
                                                            Padding="8,5">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <FontIcon Glyph="&#xE768;"
                                                                      FontSize="12"
                                                                      Foreground="{StaticResource KroiraAccentBrush}" />
                                                            <TextBlock Text="Play"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                                                        </StackPanel>
                                                    </Border>
                                                     <Button Grid.Column="1"
                                                             Click="FavoriteToggle_Click"
                                                             Tag="{Binding Id}"
                                                             ToolTipService.ToolTip="{Binding FavoriteLabel}"
                                                             AutomationProperties.Name="{Binding FavoriteLabel}"
                                                             Width="28"
                                                            Height="28"
                                                            Padding="0"
                                                            MinWidth="0"
                                                            MinHeight="0"
                                                            Background="#201A2030"
                                                            BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="14">
                                                        <FontIcon Glyph="{Binding FavoriteGlyph}"
                                                                  FontSize="12"
                                                                  Foreground="{StaticResource KroiraAccentBrush}" />
                                                    </Button>
                                                    <Button Grid.Column="2"
                                                            Click="MovieInspect_Click"
                                                            Width="28"
                                                            Height="28"
                                                            Padding="0"
                                                            MinWidth="0"
                                                            MinHeight="0"
                                                            Style="{StaticResource KroiraGhostButtonStyle}"
                                                            AutomationProperties.Name="Details"
                                                            ToolTipService.ToolTip="Details">
                                                        <FontIcon Glyph="&#xE946;"
                                                                  FontSize="11"
                                                                  Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                                                    </Button>
                                                    <Button Grid.Column="3"
                                                            Click="MovieDownload_Click"
                                                            Visibility="{Binding ElementName=MoviesPageRoot, Path=DownloadActionsVisibility}"
                                                            Width="28"
                                                            Height="28"
                                                            Margin="0"
                                                            Padding="0"
                                                            MinWidth="0"
                                                            MinHeight="0"
                                                            Style="{StaticResource KroiraGhostButtonStyle}"
                                                            AutomationProperties.Name="Download"
                                                            ToolTipService.ToolTip="Download">
                                                        <FontIcon Glyph="&#xE896;"
                                                                  FontSize="11"
                                                                  Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </Grid>

                                        <StackPanel Grid.Row="1" Spacing="3" Margin="2,10,2,0">
                                            <TextBlock Text="{Binding Title}"
                                                       Style="{StaticResource KroiraTitleStyle}"
                                                       FontSize="13"
                                                       MaxLines="2"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding MetadataLine}"
                                                       Style="{StaticResource KroiraMetaStyle}"
                                                       MaxLines="1"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Visibility="{Binding PlaceholderVisibility}"
                                        BorderBrush="#14FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Background="#220A0D11"
                                        Opacity="0.72">
                                    <Grid>
                                        <Border Margin="10"
                                                CornerRadius="9"
                                                BorderBrush="#0FFFFFFF"
                                                BorderThickness="1"
                                                Background="#18000000" />
                                        <FontIcon Glyph="&#xE8B2;"
                                                  FontSize="24"
                                                  Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                  Opacity="0.16" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </Grid>
        </Grid>
        </Grid>

        <Grid Visibility="{x:Bind ViewModel.BlockingSurfaceVisibility, Mode=OneWay}"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Margin="32">
            <controls:LoadingStateView Title="{x:Bind ViewModel.SurfaceState.Title, Mode=OneWay}"
                                       Message="{x:Bind ViewModel.SurfaceState.Message, Mode=OneWay}"
                                       Visibility="{x:Bind ViewModel.SurfaceState.LoadingStateVisibility, Mode=OneWay}" />
            <controls:EmptyStateView IconGlyph="{x:Bind ViewModel.SurfaceState.Glyph, Mode=OneWay}"
                                     Title="{x:Bind ViewModel.SurfaceState.Title, Mode=OneWay}"
                                     Message="{x:Bind ViewModel.SurfaceState.Message, Mode=OneWay}"
                                     PrimaryActionLabel="{x:Bind ViewModel.SurfaceState.ActionLabel, Mode=OneWay}"
                                     PrimaryActionVisibility="{x:Bind ViewModel.SurfaceState.ActionVisibility, Mode=OneWay}"
                                     Visibility="{x:Bind ViewModel.SurfaceState.EmptyStateVisibility, Mode=OneWay}"
                                     PrimaryActionClick="OpenSources_Click" />
            <controls:ErrorStateView IconGlyph="{x:Bind ViewModel.SurfaceState.Glyph, Mode=OneWay}"
                                     Title="{x:Bind ViewModel.SurfaceState.Title, Mode=OneWay}"
                                     Message="{x:Bind ViewModel.SurfaceState.Message, Mode=OneWay}"
                                     RetryActionLabel="Retry"
                                     DiagnosticsActionLabel="{x:Bind ViewModel.SurfaceState.ActionLabel, Mode=OneWay}"
                                     DiagnosticsActionVisibility="{x:Bind ViewModel.SurfaceState.DiagnosticsActionVisibility, Mode=OneWay}"
                                     Visibility="{x:Bind ViewModel.SurfaceState.ErrorStateVisibility, Mode=OneWay}"
                                     RetryClick="RetrySurface_Click"
                                     DiagnosticsClick="OpenSources_Click" />
        </Grid>
    </Grid>
</Page>
