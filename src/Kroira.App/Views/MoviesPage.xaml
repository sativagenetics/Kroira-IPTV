<Page
    x:Class="Kroira.App.Views.MoviesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Grid Padding="40,24,40,32"
          MaxWidth="1400"
          HorizontalAlignment="Center"
          RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock Text="VOD LIBRARY"
                       Style="{StaticResource KroiraLabelStyle}"
                       Foreground="{StaticResource KroiraAccentBrush}" />
            <TextBlock Text="Movies"
                       Style="{StaticResource KroiraPageTitleStyle}" />
        </StackPanel>

        <!-- Filter bar -->
        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MaxWidth="460" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Style="{StaticResource KroiraFilterTextBoxStyle}"
                     Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="Search movies"
                     HorizontalAlignment="Stretch" />

            <ComboBox Grid.Column="1"
                      Style="{StaticResource KroiraFilterComboBoxStyle}"
                      ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                      DisplayMemberPath="Name"
                      MinWidth="220" />
        </Grid>

        <!-- Result count -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Spacing="5"
                    Margin="2,0,0,0">
            <TextBlock Text="{x:Bind ViewModel.FilteredMovies.Count, Mode=OneWay, Converter={StaticResource NumberFormatConverter}}"
                       Style="{StaticResource KroiraResultCountStyle}" />
            <TextBlock Text="titles"
                       Style="{StaticResource KroiraResultCountStyle}" />
        </StackPanel>

        <!-- Empty state -->
        <StackPanel Grid.Row="3"
                    Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="10"
                    MaxWidth="460">
            <FontIcon Glyph="&#xE8B2;"
                      Foreground="{StaticResource KroiraTextTertiaryBrush}"
                      FontSize="28"
                      HorizontalAlignment="Center" />
            <TextBlock Text="No movies to show"
                       Style="{StaticResource KroiraSectionTitleStyle}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Sync an Xtream VOD source, or clear your search and category filters."
                       Style="{StaticResource KroiraBodyStyle}"
                       TextAlignment="Center"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Safe movie list -->
       <ListView Grid.Row="3"
          ItemsSource="{x:Bind ViewModel.FilteredMovies, Mode=OneWay}"
          SelectionMode="Single"
          SelectionChanged="GridView_SelectionChanged"
          ScrollViewer.HorizontalScrollMode="Disabled"
          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
          ScrollViewer.VerticalScrollMode="Enabled"
          ScrollViewer.VerticalScrollBarVisibility="Auto"
          Padding="0,4,0,20">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,12" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="{StaticResource KroiraSurfaceBrush}"
                            CornerRadius="12"
                            Padding="14">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="88" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Poster -->
                            <Grid Width="88" Height="132">
                                <Border CornerRadius="10"
                                        Background="{StaticResource KroiraPosterPlaceholderBrush}">
                                    <FontIcon Glyph="&#xE8B2;"
                                              Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                              FontSize="24"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                </Border>

                                <Border CornerRadius="10">
                                    <Image Source="{Binding PosterUrl, Converter={StaticResource UrlToImageSourceConverter}}"
                                           Stretch="UniformToFill" />
                                </Border>
                            </Grid>

                            <!-- Metadata -->
                            <StackPanel Grid.Column="1"
                                        Spacing="6"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}"
                                           Style="{StaticResource KroiraTitleStyle}"
                                           FontSize="18"
                                           TextWrapping="WrapWholeWords"
                                           MaxLines="2" />
                                <TextBlock Text="{Binding CategoryName}"
                                           Style="{StaticResource KroiraBodyStyle}"
                                           FontSize="13"
                                           Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                                <TextBlock Text="Select to start playback"
                                           Style="{StaticResource KroiraBodyStyle}"
                                           FontSize="12"
                                           Foreground="{StaticResource KroiraTextTertiaryBrush}" />
                            </StackPanel>

                            <!-- Action affordance -->
                            <StackPanel Grid.Column="2"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Right"
                                        Spacing="6">
                                <Border Background="{StaticResource KroiraSurfaceSoftBrush}"
                                        CornerRadius="999"
                                        Padding="10,5">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE768;"
                                                  FontSize="12"
                                                  Foreground="{StaticResource KroiraAccentBrush}" />
                                        <TextBlock Text="Play"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>