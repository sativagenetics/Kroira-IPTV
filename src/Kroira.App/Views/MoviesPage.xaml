<Page
    x:Class="Kroira.App.Views.MoviesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Page.Resources>
        <Style x:Key="MovieTileContainerStyle" TargetType="GridViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>
    </Page.Resources>

    <Grid Padding="28,26,28,32"
          MaxWidth="1280"
          HorizontalAlignment="Center"
          RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="6">
                <TextBlock Text="VOD LIBRARY"
                           Style="{StaticResource KroiraLabelStyle}"
                           Foreground="{StaticResource KroiraAccentBrush}" />
                <TextBlock Text="Movies"
                           Style="{StaticResource KroiraPageTitleStyle}" />
                <TextBlock Text="Compact six-column browsing for faster scanning."
                           Style="{StaticResource KroiraPageSubtitleStyle}"
                           MaxWidth="620" />
            </StackPanel>

            <Border Grid.Column="1"
                    Background="#99161B24"
                    BorderBrush="#24FFFFFF"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14,10"
                    VerticalAlignment="Bottom">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{x:Bind ViewModel.FilteredMovies.Count, Mode=OneWay, Converter={StaticResource NumberFormatConverter}}"
                               Style="{StaticResource KroiraTitleStyle}"
                               FontSize="13" />
                    <TextBlock Text="titles" Style="{StaticResource KroiraMetaStyle}" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MaxWidth="520" />
                <ColumnDefinition Width="220" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Style="{StaticResource KroiraFilterTextBoxStyle}"
                     Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="Search movies" />

            <ComboBox Grid.Column="1"
                      Style="{StaticResource KroiraFilterComboBoxStyle}"
                      ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                      DisplayMemberPath="Name" />
        </Grid>

        <Grid Grid.Row="2">
            <StackPanel Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="10"
                        MaxWidth="460">
                <FontIcon Glyph="&#xE8B2;"
                          Foreground="{StaticResource KroiraTextTertiaryBrush}"
                          FontSize="28"
                          HorizontalAlignment="Center" />
                <TextBlock Text="No movies to show"
                           Style="{StaticResource KroiraSectionTitleStyle}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Sync an Xtream VOD source, or clear your search and category filters."
                           Style="{StaticResource KroiraBodyStyle}"
                           TextAlignment="Center" />
            </StackPanel>

            <GridView ItemsSource="{x:Bind ViewModel.FilteredMovies, Mode=OneWay}"
                      SelectionMode="Single"
                      SelectionChanged="GridView_SelectionChanged"
                      ItemContainerStyle="{StaticResource MovieTileContainerStyle}"
                      ScrollViewer.HorizontalScrollMode="Disabled"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollMode="Enabled"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      Padding="0,2,0,22">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"
                                       ItemWidth="184"
                                       ItemHeight="236"
                                       MaximumRowsOrColumns="6" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border Width="176"
                                Height="226"
                                Background="#99161B24"
                                BorderBrush="#24FFFFFF"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="138" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Border CornerRadius="10"
                                            Background="{StaticResource KroiraPosterPlaceholderBrush}">
                                        <FontIcon Glyph="&#xE8B2;"
                                                  Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                  FontSize="24"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                    </Border>
                                    <Border CornerRadius="10">
                                        <Image Source="{Binding PosterUrl, Converter={StaticResource UrlToImageSourceConverter}}"
                                               Stretch="UniformToFill" />
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Row="1" Spacing="4" Margin="2,10,2,4">
                                    <TextBlock Text="{Binding Title}"
                                               Style="{StaticResource KroiraTitleStyle}"
                                               MaxLines="2"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding CategoryName}"
                                               Style="{StaticResource KroiraMetaStyle}"
                                               MaxLines="1"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <Border Grid.Row="2"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource KroiraSurfaceSoftBrush}"
                                        CornerRadius="10"
                                        Padding="9,4">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE768;"
                                                  FontSize="11"
                                                  Foreground="{StaticResource KroiraAccentBrush}" />
                                        <TextBlock Text="Play"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </Grid>
    </Grid>
</Page>
