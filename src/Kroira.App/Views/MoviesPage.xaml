<Page
    x:Class="Kroira.App.Views.MoviesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Grid Padding="28" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource KroiraPanelStyle}">
            <StackPanel Spacing="16">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Movies" Style="{StaticResource KroiraPageTitleStyle}" />
                        <TextBlock Text="Browse imported VOD titles with a poster-first desktop library." Style="{StaticResource KroiraPageSubtitleStyle}" Margin="0,4,0,0" />
                    </StackPanel>
                    <Border HorizontalAlignment="Right" VerticalAlignment="Center" Background="#221F42" BorderBrush="{StaticResource KroiraBorderStrongBrush}" BorderThickness="1" CornerRadius="999" Padding="12,5">
                        <TextBlock Text="VOD Library" Foreground="{StaticResource KroiraAccentBrush}" FontSize="12" FontWeight="SemiBold" />
                    </Border>
                </Grid>
                <TextBox Style="{StaticResource KroiraTextBoxStyle}" Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Search movies..." MaxWidth="420" HorizontalAlignment="Left" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}" Style="{StaticResource KroiraPanelStyle}" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="460">
            <StackPanel Spacing="10">
                <FontIcon Glyph="&#xE8B2;" Foreground="{StaticResource KroiraAccentBrush}" FontSize="30" HorizontalAlignment="Left" />
                <TextBlock Text="No movies imported yet" Style="{StaticResource KroiraSectionTitleStyle}" />
                <TextBlock Text="Sync an Xtream VOD source to build your movie library." Style="{StaticResource KroiraPageSubtitleStyle}" />
            </StackPanel>
        </Border>
        <GridView Grid.Row="1" ItemsSource="{x:Bind ViewModel.FilteredMovies, Mode=OneWay}" SelectionMode="Single" SelectionChanged="GridView_SelectionChanged">
            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="Margin" Value="0,0,12,14" />
                </Style>
            </GridView.ItemContainerStyle>
            <GridView.ItemTemplate>
                <DataTemplate>
                    <Grid Width="166" Height="268" CornerRadius="18" BorderBrush="{StaticResource KroiraBorderBrush}" BorderThickness="1">
                        <Grid.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1A1F35" Offset="0" />
                                <GradientStop Color="#0F151F" Offset="1" />
                            </LinearGradientBrush>
                        </Grid.Background>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        
                        <Grid Grid.Row="0" Background="{StaticResource KroiraMediaGradientBrush}">
                            <FontIcon Glyph="&#xE8B2;" Foreground="{StaticResource KroiraAccentBrush}" FontSize="30" Opacity="0.45" />
                            <Image Source="{Binding PosterUrl}" Stretch="UniformToFill" />
                        </Grid>

                        <StackPanel Grid.Row="1" Padding="10" Background="#E00F141D">
                            <TextBlock Text="{Binding Title}" TextWrapping="Wrap" MaxLines="2" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                            <TextBlock Text="{Binding CategoryName}" Foreground="{StaticResource KroiraTextSecondaryBrush}" FontSize="10" Margin="0,4,0,0" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Page>
