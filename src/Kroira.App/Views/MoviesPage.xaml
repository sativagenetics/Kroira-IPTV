<Page
    x:Class="Kroira.App.Views.MoviesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Page.Resources>
        <Style x:Key="MovieTileContainerStyle" TargetType="GridViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,14,22" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="UseSystemFocusVisuals" Value="True" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>
    </Page.Resources>

    <Grid Padding="42,36,42,40"
          MaxWidth="1440"
          HorizontalAlignment="Center"
          RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                MinHeight="174"
                BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="26,24">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#342515" Offset="0" />
                    <GradientStop Color="#151B22" Offset="0.48" />
                    <GradientStop Color="#080A0E" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid ColumnSpacing="28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="VOD COLLECTION"
                               Style="{StaticResource KroiraLabelStyle}"
                               Foreground="{StaticResource KroiraAccentBrush}" />
                    <TextBlock Text="Movies"
                               Style="{StaticResource KroiraDisplayLgStyle}"
                               FontSize="44"
                               LineHeight="50" />
                    <TextBlock Text="A dense cinema browser with poster-led scanning, category control, and fast selection."
                               Style="{StaticResource KroiraPageSubtitleStyle}"
                               MaxWidth="620" />
                </StackPanel>

                <Border Grid.Column="1"
                        Style="{StaticResource KroiraCountBadgeStyle}"
                        VerticalAlignment="Bottom"
                        MinWidth="148">
                    <StackPanel Spacing="2">
                        <TextBlock Text="{x:Bind ViewModel.FilteredMovies.Count, Mode=OneWay, Converter={StaticResource NumberFormatConverter}}"
                                   Foreground="{StaticResource KroiraTextPrimaryBrush}"
                                   FontSize="24"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="TITLES AVAILABLE"
                                   Style="{StaticResource KroiraLabelStyle}"
                                   FontSize="10" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource KroiraFilterStripStyle}">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MaxWidth="620" />
                    <ColumnDefinition Width="244" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <TextBox Style="{StaticResource KroiraFilterTextBoxStyle}"
                             Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="Search movies" />
                    <FontIcon Glyph="&#xE721;"
                              FontSize="14"
                              Foreground="{StaticResource KroiraTextTertiaryBrush}"
                              HorizontalAlignment="Right"
                              Margin="0,0,16,0"
                              VerticalAlignment="Center" />
                </Grid>

                <ComboBox Grid.Column="1"
                          Style="{StaticResource KroiraFilterComboBoxStyle}"
                          ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                          DisplayMemberPath="Name" />

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="8"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Border Width="7"
                            Height="7"
                            CornerRadius="4"
                            Background="{StaticResource KroiraAccentBrush}" />
                    <TextBlock Text="POSTER GRID"
                               Style="{StaticResource KroiraLabelStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <StackPanel Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="10"
                        MaxWidth="460">
                <FontIcon Glyph="&#xE8B2;"
                          Foreground="{StaticResource KroiraTextTertiaryBrush}"
                          FontSize="28"
                          HorizontalAlignment="Center" />
                <TextBlock Text="No movies to show"
                           Style="{StaticResource KroiraSectionTitleStyle}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Sync an Xtream VOD source, or clear your search and category filters."
                           Style="{StaticResource KroiraBodyStyle}"
                           TextAlignment="Center" />
            </StackPanel>

            <GridView ItemsSource="{x:Bind ViewModel.FilteredMovies, Mode=OneWay}"
                      SelectionMode="Single"
                      SelectionChanged="GridView_SelectionChanged"
                      ItemContainerStyle="{StaticResource MovieTileContainerStyle}"
                      ScrollViewer.HorizontalScrollMode="Disabled"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollMode="Enabled"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      Padding="0,4,0,24">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"
                                       ItemWidth="204"
                                       ItemHeight="304"
                                       MaximumRowsOrColumns="6" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border Width="190"
                                Height="292"
                                BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="10,10,10,12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#252016" Offset="0" />
                                    <GradientStop Color="#11161D" Offset="0.48" />
                                    <GradientStop Color="#090B0F" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="204" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Border CornerRadius="9"
                                            Background="{StaticResource KroiraPosterPlaceholderBrush}"
                                            BorderBrush="#1EFFFFFF"
                                            BorderThickness="1">
                                        <Grid>
                                            <FontIcon Glyph="&#xE8B2;"
                                                      Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                      FontSize="28"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                    <Border CornerRadius="9">
                                        <Image Source="{Binding PosterUrl, Converter={StaticResource UrlToImageSourceConverter}}"
                                               Stretch="UniformToFill" />
                                    </Border>
                                    <Border Height="64"
                                            VerticalAlignment="Bottom"
                                            CornerRadius="0,0,9,9">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#0010141A" Offset="0" />
                                                <GradientStop Color="#D0080A0D" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Row="1" Spacing="4" Margin="2,11,2,5">
                                    <TextBlock Text="{Binding Title}"
                                               Style="{StaticResource KroiraTitleStyle}"
                                               FontSize="14"
                                               MaxLines="2"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding CategoryName}"
                                               Style="{StaticResource KroiraMetaStyle}"
                                               MaxLines="1"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <Border Grid.Row="2"
                                        HorizontalAlignment="Left"
                                        Background="#1B231A10"
                                        BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="9,4">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE768;"
                                                  FontSize="11"
                                                  Foreground="{StaticResource KroiraAccentBrush}" />
                                        <TextBlock Text="Play"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource KroiraAccentBrush}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </Grid>
    </Grid>
</Page>
