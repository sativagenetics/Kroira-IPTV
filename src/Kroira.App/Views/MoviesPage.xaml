<Page
    x:Class="Kroira.App.Views.MoviesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Page.Resources>
        <Style x:Key="MovieTileContainerStyle" TargetType="GridViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,16,24" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="UseSystemFocusVisuals" Value="True" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="CategoryRailItemContainerStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,7" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style x:Key="FavoritePillButtonStyle" TargetType="Button" BasedOn="{StaticResource KroiraGhostButtonStyle}">
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>
    </Page.Resources>

    <Grid Padding="42,32,42,40"
          MaxWidth="1480"
          HorizontalAlignment="Center"
          RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                MinHeight="326"
                BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <Grid>
                <Border Background="{StaticResource KroiraMediaGradientBrush}"
                        CornerRadius="18" />
                <Image Source="{x:Bind ViewModel.FeaturedMovie.DisplayHeroArtworkUrl, Mode=OneWay, Converter={StaticResource UrlToImageSourceConverter}}"
                       Stretch="UniformToFill"
                       Opacity="0.92" />
                <Image Source="{x:Bind ViewModel.FeaturedMovie.DisplayPosterUrl, Mode=OneWay, Converter={StaticResource UrlToImageSourceConverter}}"
                       Width="430"
                       HorizontalAlignment="Right"
                       Stretch="UniformToFill"
                       Opacity="0.16" />
                <Border>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#F006080A" Offset="0" />
                            <GradientStop Color="#D0090B0F" Offset="0.44" />
                            <GradientStop Color="#5410141A" Offset="0.72" />
                            <GradientStop Color="#D0080A0D" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <Border>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#26000000" Offset="0" />
                            <GradientStop Color="#08000000" Offset="0.44" />
                            <GradientStop Color="#B8080A0D" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <Border Width="5"
                        HorizontalAlignment="Left"
                        Background="{StaticResource KroiraAccentGradientBrush}"
                        CornerRadius="18,0,0,18" />

                <Grid Padding="34,28" ColumnSpacing="28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="174" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Spacing="11"
                                VerticalAlignment="Bottom"
                                MaxWidth="760">
                        <TextBlock Text="FEATURED FILM"
                                   Style="{StaticResource KroiraLabelStyle}"
                                   Foreground="{StaticResource KroiraAccentBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.FeaturedMovie.Title, Mode=OneWay}"
                                   Style="{StaticResource KroiraDisplayLgStyle}"
                                   FontSize="46"
                                   LineHeight="52"
                                   MaxLines="2"
                                   TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Background="#B40A0D11"
                                    BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="9,4">
                                <TextBlock Text="{x:Bind ViewModel.FeaturedMovie.RatingText, Mode=OneWay}"
                                           Foreground="{StaticResource KroiraAccentBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                            </Border>
                            <TextBlock Text="{x:Bind ViewModel.FeaturedMovie.MetadataLine, Mode=OneWay}"
                                       Style="{StaticResource KroiraMetaStyle}"
                                       VerticalAlignment="Center"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.FeaturedMovie.Overview, Mode=OneWay}"
                                   Style="{StaticResource KroiraBodyStyle}"
                                   FontSize="14"
                                   LineHeight="21"
                                   MaxWidth="620"
                                   MaxLines="3"
                                   TextTrimming="CharacterEllipsis" />
                        <StackPanel Orientation="Horizontal"
                                    Spacing="10"
                                    Margin="0,6,0,0">
                            <Button Click="FeaturedPlay_Click"
                                    IsEnabled="{x:Bind ViewModel.FeaturedMovieCanPlay, Mode=OneWay}"
                                    Style="{StaticResource KroiraPrimaryButtonStyle}"
                                    Padding="20,11"
                                    MinWidth="136">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE102;" FontSize="13" />
                                    <TextBlock Text="Play movie" />
                                </StackPanel>
                            </Button>
                            <Button Click="FavoriteToggle_Click"
                                    Tag="{x:Bind ViewModel.FeaturedMovie.Id, Mode=OneWay}"
                                    Style="{StaticResource FavoritePillButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="{x:Bind ViewModel.FeaturedMovie.FavoriteGlyph, Mode=OneWay}"
                                              FontSize="13"
                                              Foreground="{StaticResource KroiraAccentBrush}" />
                                    <TextBlock Text="{x:Bind ViewModel.FeaturedMovie.FavoriteLabel, Mode=OneWay}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Width="158"
                            Height="238"
                            CornerRadius="14"
                            BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                            BorderThickness="1"
                            Background="{StaticResource KroiraPosterPlaceholderBrush}"
                            VerticalAlignment="Bottom">
                        <Grid>
                            <FontIcon Glyph="&#xE8B2;"
                                      Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                      FontSize="28"
                                      Opacity="0.55" />
                            <Image Source="{x:Bind ViewModel.FeaturedMovie.DisplayPosterUrl, Mode=OneWay, Converter={StaticResource UrlToImageSourceConverter}}"
                                   Stretch="UniformToFill" />
                            <Border Height="72"
                                    VerticalAlignment="Bottom">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#0010141A" Offset="0" />
                                        <GradientStop Color="#D8080A0D" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource KroiraCountBadgeStyle}"
                            VerticalAlignment="Bottom"
                            MinWidth="128">
                        <StackPanel Spacing="1">
                            <TextBlock Text="{x:Bind ViewModel.FilteredMovies.Count, Mode=OneWay, Converter={StaticResource NumberFormatConverter}}"
                                       Foreground="{StaticResource KroiraTextPrimaryBrush}"
                                       FontSize="28"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="TITLES"
                                       Style="{StaticResource KroiraLabelStyle}"
                                       FontSize="10" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Column="0"
                    Grid.RowSpan="2"
                    Background="#D00A0D11"
                    BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="12">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Spacing="4">
                        <TextBlock Text="BROWSE BY"
                                   Style="{StaticResource KroiraLabelStyle}"
                                   Foreground="{StaticResource KroiraAccentBrush}" />
                        <TextBlock Text="Categories"
                                   Style="{StaticResource KroiraTitleStyle}"
                                   FontSize="15" />
                    </StackPanel>
                    <ListView Grid.Row="1"
                              ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                              SelectionMode="Single"
                              ItemContainerStyle="{StaticResource CategoryRailItemContainerStyle}"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="0"
                              ScrollViewer.VerticalScrollMode="Enabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="11,9" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="4"
                                            CornerRadius="2"
                                            Background="{StaticResource KroiraAccentBrush}"
                                            Opacity="0.72" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Name}"
                                               Style="{StaticResource KroiraMetaStyle}"
                                               Foreground="{StaticResource KroiraTextPrimaryBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Grid.Row="0"
                    Style="{StaticResource KroiraFilterStripStyle}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MaxWidth="640" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <TextBox Style="{StaticResource KroiraFilterTextBoxStyle}"
                                 Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Search movies" />
                        <FontIcon Glyph="&#xE721;"
                                  FontSize="14"
                                  Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                  HorizontalAlignment="Right"
                                  Margin="0,0,16,0"
                                  VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Border Width="7"
                                Height="7"
                                CornerRadius="4"
                                Background="{StaticResource KroiraAccentBrush}" />
                        <TextBlock Text="POSTERS"
                                   Style="{StaticResource KroiraLabelStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Grid.Row="1">
                <StackPanel Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="10"
                            MaxWidth="460">
                    <FontIcon Glyph="&#xE8B2;"
                              Foreground="{StaticResource KroiraTextTertiaryBrush}"
                              FontSize="28"
                              HorizontalAlignment="Center" />
                    <TextBlock Text="No movies to show"
                               Style="{StaticResource KroiraSectionTitleStyle}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Sync an Xtream VOD source, or clear your search and category filters."
                               Style="{StaticResource KroiraBodyStyle}"
                               TextAlignment="Center" />
                </StackPanel>

                <GridView ItemsSource="{x:Bind ViewModel.FilteredMovies, Mode=OneWay}"
                          SelectionMode="Single"
                          SelectionChanged="GridView_SelectionChanged"
                          ItemContainerStyle="{StaticResource MovieTileContainerStyle}"
                          ScrollViewer.HorizontalScrollMode="Disabled"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollMode="Enabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          Padding="0,4,0,24">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal"
                                           ItemWidth="206"
                                           ItemHeight="334"
                                           MaximumRowsOrColumns="6" />
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Border Width="194"
                                    Height="322"
                                    BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="10,10,10,12">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#252016" Offset="0" />
                                        <GradientStop Color="#10151C" Offset="0.54" />
                                        <GradientStop Color="#080A0D" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="230" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid>
                                        <Border CornerRadius="9"
                                                Background="{StaticResource KroiraPosterPlaceholderBrush}"
                                                BorderBrush="#1EFFFFFF"
                                                BorderThickness="1">
                                            <FontIcon Glyph="&#xE8B2;"
                                                      Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                      FontSize="28"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Opacity="0.55" />
                                        </Border>
                                        <Border CornerRadius="9">
                                            <Image Source="{Binding DisplayPosterUrl, Converter={StaticResource UrlToImageSourceConverter}}"
                                                   Stretch="UniformToFill" />
                                        </Border>
                                        <Border Height="76"
                                                VerticalAlignment="Bottom"
                                                CornerRadius="0,0,9,9">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#0010141A" Offset="0" />
                                                    <GradientStop Color="#D8080A0D" Offset="1" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <Button Click="FavoriteToggle_Click"
                                                Tag="{Binding Id}"
                                                ToolTipService.ToolTip="{Binding FavoriteLabel}"
                                                Width="36"
                                                Height="36"
                                                Padding="0"
                                                MinWidth="0"
                                                MinHeight="0"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Margin="8"
                                                Background="#D0090B0F"
                                                BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                                BorderThickness="1"
                                                CornerRadius="18">
                                            <FontIcon Glyph="{Binding FavoriteGlyph}"
                                                      FontSize="13"
                                                      Foreground="{StaticResource KroiraAccentBrush}" />
                                        </Button>
                                        <Border Background="#D0090B0F"
                                                BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="8,4"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Margin="8">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE7BA;"
                                                          FontSize="10"
                                                          Foreground="{StaticResource KroiraAccentBrush}" />
                                                <TextBlock Text="{Binding RatingText}"
                                                           Foreground="{StaticResource KroiraAccentBrush}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <StackPanel Grid.Row="1" Spacing="3" Margin="2,9,2,4">
                                        <TextBlock Text="{Binding Title}"
                                                   Style="{StaticResource KroiraTitleStyle}"
                                                   FontSize="13"
                                                   MaxLines="2"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding MetadataLine}"
                                                   Style="{StaticResource KroiraMetaStyle}"
                                                   MaxLines="1"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <Border Grid.Row="2"
                                            HorizontalAlignment="Left"
                                            Background="#26231A10"
                                            BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="9,4">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE768;"
                                                      FontSize="11"
                                                      Foreground="{StaticResource KroiraAccentBrush}" />
                                            <TextBlock Text="Play"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource KroiraAccentBrush}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </Grid>
        </Grid>
    </Grid>
</Page>
