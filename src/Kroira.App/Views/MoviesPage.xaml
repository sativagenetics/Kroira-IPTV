<Page
    x:Class="Kroira.App.Views.MoviesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Page.Resources>
        <Style x:Key="MovieTileContainerStyle" TargetType="GridViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,16,24" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="UseSystemFocusVisuals" Value="True" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>
    </Page.Resources>

    <Grid Padding="42,36,42,40"
          MaxWidth="1480"
          HorizontalAlignment="Center"
          RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                MinHeight="270"
                BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="14">
            <Grid>
                <Border Background="{StaticResource KroiraMediaGradientBrush}"
                        CornerRadius="14" />
                <Image Source="{x:Bind ViewModel.FeaturedMovie.BackdropUrl, Mode=OneWay, Converter={StaticResource UrlToImageSourceConverter}}"
                       Stretch="UniformToFill"
                       Opacity="0.72" />
                <Border>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#F006080A" Offset="0" />
                            <GradientStop Color="#C8090B0F" Offset="0.42" />
                            <GradientStop Color="#5410141A" Offset="0.72" />
                            <GradientStop Color="#D0080A0D" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <Border>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#18000000" Offset="0" />
                            <GradientStop Color="#A8080A0D" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <Grid Padding="28,26" ColumnSpacing="26">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Spacing="12"
                                VerticalAlignment="Bottom"
                                MaxWidth="760">
                        <TextBlock Text="VOD COLLECTION"
                                   Style="{StaticResource KroiraLabelStyle}"
                                   Foreground="{StaticResource KroiraAccentBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.FeaturedMovie.Title, Mode=OneWay}"
                                   Style="{StaticResource KroiraDisplayLgStyle}"
                                   FontSize="44"
                                   LineHeight="50"
                                   MaxLines="2"
                                   TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Background="#B40A0D11"
                                    BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="9,4">
                                <TextBlock Text="{x:Bind ViewModel.FeaturedMovie.RatingText, Mode=OneWay}"
                                           Foreground="{StaticResource KroiraAccentBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                            </Border>
                            <TextBlock Text="{x:Bind ViewModel.FeaturedMovie.MetadataLine, Mode=OneWay}"
                                       Style="{StaticResource KroiraMetaStyle}"
                                       VerticalAlignment="Center"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.FeaturedMovie.Overview, Mode=OneWay}"
                                   Style="{StaticResource KroiraBodyStyle}"
                                   FontSize="14"
                                   LineHeight="21"
                                   MaxWidth="650"
                                   MaxLines="3"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Width="154"
                            Height="220"
                            CornerRadius="12"
                            BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                            BorderThickness="1"
                            Background="{StaticResource KroiraPosterPlaceholderBrush}"
                            VerticalAlignment="Bottom">
                        <Grid>
                            <FontIcon Glyph="&#xE8B2;"
                                      Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                      FontSize="30"
                                      Opacity="0.55" />
                            <Image Source="{x:Bind ViewModel.FeaturedMovie.PosterUrl, Mode=OneWay, Converter={StaticResource UrlToImageSourceConverter}}"
                                   Stretch="UniformToFill" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource KroiraCountBadgeStyle}"
                            VerticalAlignment="Bottom"
                            MinWidth="150">
                        <StackPanel Spacing="2">
                            <TextBlock Text="{x:Bind ViewModel.FilteredMovies.Count, Mode=OneWay, Converter={StaticResource NumberFormatConverter}}"
                                       Foreground="{StaticResource KroiraTextPrimaryBrush}"
                                       FontSize="24"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="TITLES"
                                       Style="{StaticResource KroiraLabelStyle}"
                                       FontSize="10" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource KroiraFilterStripStyle}">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MaxWidth="640" />
                    <ColumnDefinition Width="252" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <TextBox Style="{StaticResource KroiraFilterTextBoxStyle}"
                             Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="Search movies" />
                    <FontIcon Glyph="&#xE721;"
                              FontSize="14"
                              Foreground="{StaticResource KroiraTextTertiaryBrush}"
                              HorizontalAlignment="Right"
                              Margin="0,0,16,0"
                              VerticalAlignment="Center" />
                </Grid>

                <ComboBox Grid.Column="1"
                          Style="{StaticResource KroiraFilterComboBoxStyle}"
                          ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                          DisplayMemberPath="Name" />

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="8"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Border Width="7"
                            Height="7"
                            CornerRadius="4"
                            Background="{StaticResource KroiraAccentBrush}" />
                    <TextBlock Text="POSTER LIBRARY"
                               Style="{StaticResource KroiraLabelStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <StackPanel Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="10"
                        MaxWidth="460">
                <FontIcon Glyph="&#xE8B2;"
                          Foreground="{StaticResource KroiraTextTertiaryBrush}"
                          FontSize="28"
                          HorizontalAlignment="Center" />
                <TextBlock Text="No movies to show"
                           Style="{StaticResource KroiraSectionTitleStyle}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Sync an Xtream VOD source, or clear your search and category filters."
                           Style="{StaticResource KroiraBodyStyle}"
                           TextAlignment="Center" />
            </StackPanel>

            <GridView ItemsSource="{x:Bind ViewModel.FilteredMovies, Mode=OneWay}"
                      SelectionMode="Single"
                      SelectionChanged="GridView_SelectionChanged"
                      ItemContainerStyle="{StaticResource MovieTileContainerStyle}"
                      ScrollViewer.HorizontalScrollMode="Disabled"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollMode="Enabled"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      Padding="0,4,0,24">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"
                                       ItemWidth="204"
                                       ItemHeight="316"
                                       MaximumRowsOrColumns="6" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border Width="190"
                                Height="304"
                                BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="10,10,10,12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#252016" Offset="0" />
                                    <GradientStop Color="#10151C" Offset="0.54" />
                                    <GradientStop Color="#080A0D" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="212" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Border CornerRadius="9"
                                            Background="{StaticResource KroiraPosterPlaceholderBrush}"
                                            BorderBrush="#1EFFFFFF"
                                            BorderThickness="1">
                                        <FontIcon Glyph="&#xE8B2;"
                                                  Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                  FontSize="28"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Opacity="0.55" />
                                    </Border>
                                    <Border CornerRadius="9">
                                        <Image Source="{Binding PosterUrl, Converter={StaticResource UrlToImageSourceConverter}}"
                                               Stretch="UniformToFill" />
                                    </Border>
                                    <Border Height="76"
                                            VerticalAlignment="Bottom"
                                            CornerRadius="0,0,9,9">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#0010141A" Offset="0" />
                                                <GradientStop Color="#D8080A0D" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <Border Background="#C8090B0F"
                                            BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="7,3"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Margin="8">
                                        <TextBlock Text="{Binding RatingText}"
                                                   Foreground="{StaticResource KroiraAccentBrush}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Row="1" Spacing="4" Margin="2,10,2,4">
                                    <TextBlock Text="{Binding Title}"
                                               Style="{StaticResource KroiraTitleStyle}"
                                               FontSize="14"
                                               MaxLines="2"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding MetadataLine}"
                                               Style="{StaticResource KroiraMetaStyle}"
                                               MaxLines="1"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <Border Grid.Row="2"
                                        HorizontalAlignment="Left"
                                        Background="#1B231A10"
                                        BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="9,4">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE768;"
                                                  FontSize="11"
                                                  Foreground="{StaticResource KroiraAccentBrush}" />
                                        <TextBlock Text="Play"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource KroiraAccentBrush}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </Grid>
    </Grid>
</Page>
