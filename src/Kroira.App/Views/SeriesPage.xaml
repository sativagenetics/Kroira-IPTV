<Page
    x:Class="Kroira.App.Views.SeriesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Kroira.App.Views"
    xmlns:viewModels="using:Kroira.App.ViewModels"
    x:Name="SeriesPageRoot"
    NavigationCacheMode="Required"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Page.Resources>
        <local:NullToCollapsedConverter x:Key="NullToCollapsedConverter" />
        <local:NullToVisibleConverter x:Key="NullToVisibleConverter" />
        <local:SeasonPrefixConverter x:Key="SeasonPrefixConverter" />

        <Style x:Key="SeriesTileContainerStyle" TargetType="GridViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="SeriesEpisodeRowStyle" TargetType="ListViewItem">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="CategoryRailItemContainerStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,7" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style x:Key="FavoritePillButtonStyle" TargetType="Button" BasedOn="{StaticResource KroiraGhostButtonStyle}">
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>
    </Page.Resources>

    <Grid>
        <Grid Padding="30,28,30,34"
              MaxWidth="1360"
              HorizontalAlignment="Center"
              RowSpacing="16"
              Visibility="{x:Bind ViewModel.ContentShellVisibility, Mode=OneWay}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="6">
                <TextBlock Text="SHOWS LIBRARY"
                           Style="{StaticResource KroiraLabelStyle}"
                           Foreground="{StaticResource KroiraAccentBrush}" />
                <TextBlock Text="Series"
                           Style="{StaticResource KroiraPageTitleStyle}" />
                <TextBlock Text="Pick a show, then inspect seasons and episodes in the side panel."
                           Style="{StaticResource KroiraPageSubtitleStyle}"
                           MaxWidth="680" />
            </StackPanel>

            <Border Grid.Column="1"
                    Background="#99161B24"
                    BorderBrush="#24FFFFFF"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14,10"
                    VerticalAlignment="Bottom">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{x:Bind ViewModel.FilteredSeriesCount, Mode=OneWay, Converter={StaticResource NumberFormatConverter}}"
                               Style="{StaticResource KroiraTitleStyle}"
                               FontSize="13" />
                    <TextBlock Text="shows" Style="{StaticResource KroiraMetaStyle}" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource KroiraFilterStripStyle}">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.2*" />
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <TextBox Style="{StaticResource KroiraFilterTextBoxStyle}"
                                 Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Search series" />
                        <FontIcon Glyph="&#xE721;"
                                  FontSize="14"
                                  Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                  HorizontalAlignment="Right"
                                  Margin="0,0,16,0"
                                  VerticalAlignment="Center" />
                    </Grid>

                    <ComboBox Grid.Column="1"
                              Style="{StaticResource KroiraFilterComboBoxStyle}"
                              ItemsSource="{x:Bind ViewModel.SourceOptions, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedSourceOption, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName" />

                    <ComboBox Grid.Column="2"
                              Style="{StaticResource KroiraFilterComboBoxStyle}"
                              ItemsSource="{x:Bind ViewModel.SortOptions, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedSortOption, Mode=TwoWay}"
                              DisplayMemberPath="Label" />

                    <StackPanel Grid.Column="3"
                                Orientation="Horizontal"
                                Spacing="10"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <CheckBox Content="Favorites"
                                  IsChecked="{x:Bind ViewModel.FavoritesOnly, Mode=TwoWay}" />
                        <CheckBox Content="Primary only"
                                  IsChecked="{x:Bind ViewModel.HideSecondaryContent, Mode=TwoWay}" />
                        <Border Width="7"
                                Height="7"
                                CornerRadius="4"
                                Background="{StaticResource KroiraAccentBrush}" />
                        <TextBlock Text="SERIES GRID"
                                   Style="{StaticResource KroiraLabelStyle}" />
                    </StackPanel>
                </Grid>

                <Expander Grid.Row="1"
                          Header="Advanced browse controls"
                          IsExpanded="{x:Bind ViewModel.HasAdvancedFilters, Mode=OneWay}">
                    <Grid Margin="0,12,0,0" ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="1.2*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="10">
                            <TextBlock Text="Visible providers"
                                       Style="{StaticResource KroiraLabelStyle}"
                                       Foreground="{StaticResource KroiraAccentBrush}" />
                            <ItemsControl ItemsSource="{x:Bind ViewModel.SourceVisibilityOptions, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsVisible, Mode=TwoWay}" Margin="0,2,0,2">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" />
                                                <TextBlock Text="{Binding Detail}"
                                                           Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                           FontSize="11" />
                                            </StackPanel>
                                        </CheckBox>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="10">
                            <TextBlock Text="Category alias / hide"
                                       Style="{StaticResource KroiraLabelStyle}"
                                       Foreground="{StaticResource KroiraAccentBrush}" />
                            <ComboBox Style="{StaticResource KroiraFilterComboBoxStyle}"
                                      ItemsSource="{x:Bind ViewModel.ManageCategoryOptions, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedManageCategory, Mode=TwoWay}"
                                      DisplayMemberPath="DisplayName" />
                            <TextBox Style="{StaticResource KroiraFilterTextBoxStyle}"
                                     IsEnabled="{x:Bind ViewModel.HasManageCategorySelection, Mode=OneWay}"
                                     Text="{x:Bind ViewModel.ManageCategoryAliasDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="Rename selected category for browsing" />
                            <ToggleSwitch Header="Hide selected category"
                                          IsEnabled="{x:Bind ViewModel.HasManageCategorySelection, Mode=OneWay}"
                                          IsOn="{x:Bind ViewModel.IsManageCategoryHidden, Mode=TwoWay}" />
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button Content="Save category rule"
                                        Command="{x:Bind ViewModel.SaveCategoryPreferenceCommand}"
                                        IsEnabled="{x:Bind ViewModel.HasManageCategorySelection, Mode=OneWay}" />
                                <Button Content="Clear rule"
                                        Command="{x:Bind ViewModel.ClearCategoryPreferenceCommand}"
                                        IsEnabled="{x:Bind ViewModel.HasManageCategorySelection, Mode=OneWay}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Expander>
            </Grid>
        </Border>

        <Grid Grid.Row="2" ColumnSpacing="22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="206" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="430" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#D00A0D11"
                    BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="12">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Spacing="4">
                        <TextBlock Text="BROWSE BY"
                                   Style="{StaticResource KroiraLabelStyle}"
                                   Foreground="{StaticResource KroiraAccentBrush}" />
                        <TextBlock Text="Categories"
                                   Style="{StaticResource KroiraTitleStyle}"
                                   FontSize="15" />
                    </StackPanel>
                    <ListView x:Name="CategoryList"
                              Grid.Row="1"
                              ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                              SelectionMode="Single"
                              ItemContainerStyle="{StaticResource CategoryRailItemContainerStyle}"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="0"
                              ScrollViewer.VerticalScrollMode="Enabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:BrowserCategoryViewModel">
                                <Grid>
                                    <Border Background="{StaticResource KroiraAccentContainerBrush}"
                                            BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Opacity="{x:Bind SelectionBackgroundOpacity, Mode=OneWay}" />
                                    <Border BorderBrush="{StaticResource KroiraAccentBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Opacity="{x:Bind SelectionChromeOpacity, Mode=OneWay}" />
                                    <Grid Padding="11,9" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="4"
                                                CornerRadius="2"
                                                Background="{StaticResource KroiraAccentBrush}"
                                                Opacity="{x:Bind SelectionAccentOpacity, Mode=OneWay}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind Name, Mode=OneWay}"
                                                   Style="{StaticResource KroiraMetaStyle}"
                                                   Foreground="{StaticResource KroiraTextPrimaryBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <StackPanel Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="10"
                            MaxWidth="460">
                    <FontIcon Glyph="&#xE8A9;"
                              Foreground="{StaticResource KroiraTextTertiaryBrush}"
                              FontSize="28"
                              HorizontalAlignment="Center" />
                    <TextBlock Text="No series to show"
                               Style="{StaticResource KroiraSectionTitleStyle}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Sync an Xtream VOD source, or clear your filters."
                               Style="{StaticResource KroiraBodyStyle}"
                               TextAlignment="Center" />
                </StackPanel>

                <GridView ItemsSource="{x:Bind ViewModel.DisplaySeriesSlots, Mode=OneWay}"
                          SelectionChanged="SeriesGrid_SelectionChanged"
                          SelectionMode="Single"
                          ItemContainerStyle="{StaticResource SeriesTileContainerStyle}"
                          HorizontalAlignment="Left"
                          Width="546"
                          ScrollViewer.HorizontalScrollMode="Disabled"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollMode="Enabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          Padding="0,2,0,22">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal"
                                           ItemWidth="182"
                                           ItemHeight="248"
                                           MaximumRowsOrColumns="3" />
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="174" Height="238">
                                <Border Visibility="{Binding SeriesVisibility}"
                                        Background="#AA11161E"
                                        BorderBrush="#24FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="148" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Border CornerRadius="10"
                                                    Background="{StaticResource KroiraPosterPlaceholderBrush}">
                                                <FontIcon Glyph="&#xE8A9;"
                                                          Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                          FontSize="24"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                            </Border>
                                            <Border CornerRadius="10">
                                                <Image Source="{Binding DisplayPosterUrl, Converter={StaticResource UrlToImageSourceConverter}}"
                                                       Stretch="UniformToFill" />
                                            </Border>
                                            <Border Height="54"
                                                    VerticalAlignment="Bottom"
                                                    CornerRadius="0,0,10,10">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#0010141A" Offset="0" />
                                                        <GradientStop Color="#C8080A0D" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <Button Click="FavoriteToggle_Click"
                                                    Tag="{Binding Id}"
                                                    ToolTipService.ToolTip="{Binding FavoriteLabel}"
                                                    Width="34"
                                                    Height="34"
                                                    Padding="0"
                                                    MinWidth="0"
                                                    MinHeight="0"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    Margin="8"
                                                    Background="#D0090B0F"
                                                    BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="17">
                                                <FontIcon Glyph="{Binding FavoriteGlyph}"
                                                          FontSize="12"
                                                          Foreground="{StaticResource KroiraAccentBrush}" />
                                            </Button>
                                        </Grid>

                                        <StackPanel Grid.Row="1" Spacing="4" Margin="2,10,2,4">
                                            <TextBlock Text="{Binding Title}"
                                                       Style="{StaticResource KroiraTitleStyle}"
                                                       MaxLines="2"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding CategoryName}"
                                                       Style="{StaticResource KroiraMetaStyle}"
                                                       MaxLines="1"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>

                                        <Border Grid.Row="2"
                                                HorizontalAlignment="Left"
                                                Background="#24231A10"
                                                BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="9,4">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE7C3;"
                                                          FontSize="11"
                                                          Foreground="{StaticResource KroiraAccentBrush}" />
                                                <TextBlock Text="Inspect"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border Visibility="{Binding PlaceholderVisibility}"
                                        Background="#220A0D11"
                                        BorderBrush="#14FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Opacity="0.72">
                                    <Grid>
                                        <Border Margin="10"
                                                CornerRadius="10"
                                                BorderBrush="#0FFFFFFF"
                                                BorderThickness="1"
                                                Background="#18000000" />
                                        <FontIcon Glyph="&#xE8A9;"
                                                  FontSize="22"
                                                  Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                  Opacity="0.16" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </Grid>

            <Border Grid.Column="2"
                    Background="#D00B0E13"
                    BorderBrush="#24FFFFFF"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="0"
                    VerticalAlignment="Stretch">
                <Grid>
                    <!-- No-selection placeholder -->
                    <StackPanel Visibility="{x:Bind ViewModel.SelectedSeries, Mode=OneWay, Converter={StaticResource NullToVisibleConverter}}"
                                Spacing="18"
                                Padding="24"
                                VerticalAlignment="Center">
                        <Border Height="172"
                                CornerRadius="14"
                                Background="{StaticResource KroiraMediaGradientBrush}"
                                BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                BorderThickness="1">
                            <Grid>
                                <FontIcon Glyph="&#xE8A9;"
                                          FontSize="34"
                                          Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                          Opacity="0.35" />
                                <Border>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#3327150A" Offset="0" />
                                            <GradientStop Color="#141A22" Offset="0.52" />
                                            <GradientStop Color="#090A0D" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Border Width="4"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource KroiraAccentGradientBrush}"
                                        CornerRadius="14,0,0,14" />
                            </Grid>
                        </Border>
                        <StackPanel Spacing="8">
                            <TextBlock Text="Pick a show"
                                       Style="{StaticResource KroiraSectionTitleStyle}" />
                            <TextBlock Text="Select a title from the library to load artwork, seasons, and episode playback here."
                                       Style="{StaticResource KroiraBodyStyle}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Detail panel: scrollable stack, visible when a series is selected -->
                    <ScrollViewer Visibility="{x:Bind ViewModel.SelectedSeries, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}"
                                  VerticalScrollMode="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollMode="Disabled"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="12" Padding="16">

                            <!-- Hero artwork + title block -->
                            <Border MinHeight="286"
                                    CornerRadius="14"
                                    BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                    BorderThickness="1"
                                    Background="{StaticResource KroiraMediaGradientBrush}">
                                <Grid>
                                    <Image Source="{x:Bind ViewModel.SelectedSeries.DisplayHeroArtworkUrl, Mode=OneWay, Converter={StaticResource UrlToImageSourceConverter}}"
                                           Stretch="UniformToFill"
                                           Opacity="0.88" />
                                    <Border>
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#20000000" Offset="0" />
                                                <GradientStop Color="#B0090B0F" Offset="0.56" />
                                                <GradientStop Color="#F0090B0F" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <Border Width="4"
                                            HorizontalAlignment="Left"
                                            Background="{StaticResource KroiraAccentGradientBrush}"
                                            CornerRadius="14,0,0,14" />
                                    <Grid Padding="16" ColumnSpacing="15" VerticalAlignment="Bottom">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="108" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="108"
                                                Height="160"
                                                CornerRadius="10"
                                                Background="{StaticResource KroiraPosterPlaceholderBrush}"
                                                BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                                BorderThickness="1">
                                            <Grid>
                                                <FontIcon Glyph="&#xE8A9;"
                                                          FontSize="22"
                                                          Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                          Opacity="0.55" />
                                                <Image Source="{x:Bind ViewModel.SelectedSeries.DisplayPosterUrl, Mode=OneWay, Converter={StaticResource UrlToImageSourceConverter}}"
                                                       Stretch="UniformToFill" />
                                            </Grid>
                                        </Border>
                                        <StackPanel Grid.Column="1"
                                                    Spacing="6"
                                                    VerticalAlignment="Bottom">
                                            <TextBlock Text="SHOW"
                                                       Style="{StaticResource KroiraLabelStyle}"
                                                       Foreground="{StaticResource KroiraAccentBrush}" />
                                            <TextBlock Text="{x:Bind ViewModel.SelectedSeries.Title, Mode=OneWay}"
                                                       Style="{StaticResource KroiraSectionTitleStyle}"
                                                       FontSize="22"
                                                       MaxLines="2"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{x:Bind ViewModel.SelectedSeries.MetadataLine, Mode=OneWay}"
                                                       Style="{StaticResource KroiraBodyStyle}"
                                                       Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                                       MaxLines="1"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{x:Bind ViewModel.SelectedSeries.Overview, Mode=OneWay}"
                                                       Style="{StaticResource KroiraBodyStyle}"
                                                       FontSize="12"
                                                       LineHeight="17"
                                                       MaxLines="3"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Button Click="FavoriteToggle_Click"
                                                    Tag="{x:Bind ViewModel.SelectedSeries.Id, Mode=OneWay}"
                                                    Style="{StaticResource FavoritePillButtonStyle}"
                                                    HorizontalAlignment="Left"
                                                    Margin="0,2,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <FontIcon Glyph="{x:Bind ViewModel.SelectedSeries.FavoriteGlyph, Mode=OneWay}"
                                                              FontSize="13"
                                                              Foreground="{StaticResource KroiraAccentBrush}" />
                                                    <TextBlock Text="{x:Bind ViewModel.SelectedSeries.FavoriteLabel, Mode=OneWay}" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Season picker + play button -->
                            <Border Background="#9611161E"
                                    BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="13">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="10">
                                        <StackPanel Spacing="7"
                                                    Visibility="{x:Bind ViewModel.SelectedSeries.SourceSelectionVisibility, Mode=OneWay}">
                                            <TextBlock Text="SOURCE"
                                                       Style="{StaticResource KroiraLabelStyle}"
                                                       Foreground="{StaticResource KroiraAccentBrush}" />
                                            <ComboBox Style="{StaticResource KroiraFilterComboBoxStyle}"
                                                      ItemsSource="{x:Bind ViewModel.SelectedSeries.SourceOptions, Mode=OneWay}"
                                                      SelectedItem="{x:Bind ViewModel.SelectedSeries.SelectedSourceOption, Mode=TwoWay}"
                                                      DisplayMemberPath="Label"
                                                      HorizontalAlignment="Stretch" />
                                        </StackPanel>
                                        <TextBlock Text="SEASON"
                                                   Style="{StaticResource KroiraLabelStyle}"
                                                   Foreground="{StaticResource KroiraAccentBrush}" />
                                        <ComboBox Style="{StaticResource KroiraFilterComboBoxStyle}"
                                                  ItemsSource="{x:Bind ViewModel.SeasonOptions, Mode=OneWay}"
                                                  SelectedItem="{x:Bind ViewModel.SelectedSeason, Mode=TwoWay}"
                                                  HorizontalAlignment="Stretch">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DisplayName}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <ToggleSwitch Header="Hide watched episodes"
                                                      IsOn="{x:Bind ViewModel.HideWatchedEpisodes, Mode=TwoWay}"
                                                      OnContent=""
                                                      OffContent=""
                                                      HorizontalAlignment="Left" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                Spacing="8"
                                                VerticalAlignment="Bottom"
                                                Visibility="{x:Bind ViewModel.SelectedEpisodePlayVisibility, Mode=OneWay}">
                                        <Button Content="Play"
                                                Click="PlaySelectedEpisode_Click"
                                                Style="{StaticResource KroiraPrimaryButtonStyle}"
                                                Padding="18,11" />
                                        <Button Content="Download"
                                                Click="DownloadSelectedEpisode_Click"
                                                Visibility="{x:Bind DownloadActionsVisibility, Mode=OneWay}"
                                                Style="{StaticResource KroiraGhostButtonStyle}"
                                                Padding="18,11" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Async status message -->
                            <TextBlock Text="{x:Bind ViewModel.SelectedSeriesStatus, Mode=OneWay}"
                                       Visibility="{x:Bind ViewModel.SelectedSeriesStatusVisibility, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="2,0" />

                            <!-- Episodes section header -->
                            <Grid ColumnSpacing="8" Margin="2,2,2,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="EPISODES"
                                           Style="{StaticResource KroiraLabelStyle}"
                                           Foreground="{StaticResource KroiraAccentBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind ViewModel.EpisodeItems.Count, Mode=OneWay}"
                                           Visibility="{x:Bind ViewModel.EpisodesListVisibility, Mode=OneWay}"
                                           Style="{StaticResource KroiraMetaStyle}"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <!-- Empty state when season exists but has no playable episodes -->
                            <Border Visibility="{x:Bind ViewModel.EpisodesEmptyVisibility, Mode=OneWay}"
                                    Background="#7A0B0E14"
                                    BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="20,18">
                                <StackPanel Spacing="8">
                                    <FontIcon Glyph="&#xE8A9;"
                                              FontSize="22"
                                              Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                              HorizontalAlignment="Left" />
                                    <TextBlock Text="No playable episodes"
                                               Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock Text="Episode stream data is not available for this season yet. Re-sync the VOD source or select a different season."
                                               Style="{StaticResource KroiraBodyStyle}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <!-- Episodes list with constrained max height so it scrolls within the panel -->
                            <ListView Visibility="{x:Bind ViewModel.EpisodesListVisibility, Mode=OneWay}"
                                      ItemsSource="{x:Bind ViewModel.EpisodeItems, Mode=OneWay}"
                                      MaxHeight="380"
                                      SelectionMode="Single"
                                      SelectionChanged="EpisodeList_SelectionChanged"
                                      ItemContainerStyle="{StaticResource SeriesEpisodeRowStyle}"
                                      ScrollViewer.VerticalScrollMode="Enabled"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollMode="Disabled"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      Padding="0,0,0,4">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#B111161E"
                                                BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                                BorderThickness="1"
                                                CornerRadius="9"
                                                Padding="13,11">
                                                <Grid ColumnSpacing="10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0"
                                                        Background="#24FFFFFF"
                                                        CornerRadius="6"
                                                        Padding="5,2"
                                                        MinWidth="26"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding EpisodeNumber}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                               HorizontalAlignment="Center" />
                                                </Border>

                                                    <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Title}"
                                                                   Style="{StaticResource KroiraTitleStyle}"
                                                                   FontSize="13"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding StatusText}"
                                                                   Style="{StaticResource KroiraMetaStyle}" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                        <Button Content="Download"
                                                                Click="DownloadEpisode_Click"
                                                                Visibility="{Binding ElementName=SeriesPageRoot, Path=DownloadActionsVisibility}"
                                                                Style="{StaticResource KroiraGhostButtonStyle}"
                                                                FontSize="11" />
                                                        <Button Content="Watched"
                                                                Click="MarkEpisodeWatched_Click"
                                                                Style="{StaticResource KroiraGhostButtonStyle}"
                                                                FontSize="11"
                                                                Visibility="{Binding MarkWatchedVisibility}" />
                                                        <Button Content="Unwatched"
                                                                Click="MarkEpisodeUnwatched_Click"
                                                                Style="{StaticResource KroiraGhostButtonStyle}"
                                                                FontSize="11"
                                                                Visibility="{Binding MarkUnwatchedVisibility}" />
                                                        <FontIcon Glyph="&#xE102;"
                                                                  FontSize="11"
                                                                  Foreground="{StaticResource KroiraAccentBrush}"
                                                                  VerticalAlignment="Center" />
                                                    </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
        </Grid>

        <Border Visibility="{x:Bind ViewModel.BlockingSurfaceVisibility, Mode=OneWay}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="560"
                Margin="32"
                Background="#D00B0E13"
                BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="28,24">
            <StackPanel Spacing="12">
                <Grid Width="32" Height="32">
                    <ProgressRing IsActive="True"
                                  Width="28"
                                  Height="28"
                                  Visibility="{x:Bind ViewModel.SurfaceState.ProgressVisibility, Mode=OneWay}" />
                    <FontIcon Glyph="{x:Bind ViewModel.SurfaceState.Glyph, Mode=OneWay}"
                              FontSize="28"
                              Foreground="{StaticResource KroiraTextTertiaryBrush}"
                              Visibility="{x:Bind ViewModel.SurfaceState.IconVisibility, Mode=OneWay}" />
                </Grid>
                <TextBlock Text="{x:Bind ViewModel.SurfaceState.Title, Mode=OneWay}"
                           Style="{StaticResource KroiraSectionTitleStyle}" />
                <TextBlock Text="{x:Bind ViewModel.SurfaceState.Message, Mode=OneWay}"
                           Style="{StaticResource KroiraBodyStyle}"
                           TextWrapping="Wrap" />
                <Button Content="{x:Bind ViewModel.SurfaceState.ActionLabel, Mode=OneWay}"
                        Click="OpenSources_Click"
                        Visibility="{x:Bind ViewModel.SurfaceState.ActionVisibility, Mode=OneWay}"
                        Style="{StaticResource KroiraPrimaryButtonStyle}"
                        HorizontalAlignment="Left" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
