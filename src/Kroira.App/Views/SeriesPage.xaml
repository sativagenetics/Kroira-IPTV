<Page
    x:Class="Kroira.App.Views.SeriesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Kroira.App.Views"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Page.Resources>
        <local:NullToCollapsedConverter x:Key="NullToCollapsedConverter" />
        <local:NullToVisibleConverter x:Key="NullToVisibleConverter" />
        <local:SeasonPrefixConverter x:Key="SeasonPrefixConverter" />

        <Style x:Key="SeriesListItemStyle" TargetType="ListViewItem">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="SeriesEpisodeRowStyle" TargetType="ListViewItem">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
    </Page.Resources>

    <Grid Padding="40,24,40,32"
          MaxWidth="1500"
          HorizontalAlignment="Center"
          RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock Text="SHOWS LIBRARY"
                       Style="{StaticResource KroiraLabelStyle}"
                       Foreground="{StaticResource KroiraAccentBrush}" />
            <TextBlock Text="Series"
                       Style="{StaticResource KroiraPageTitleStyle}" />
        </StackPanel>

        <!-- Filter bar -->
        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MaxWidth="460" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Style="{StaticResource KroiraFilterTextBoxStyle}"
                     Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="Search series"
                     HorizontalAlignment="Stretch" />

            <ComboBox Grid.Column="1"
                      Style="{StaticResource KroiraFilterComboBoxStyle}"
                      ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                      DisplayMemberPath="Name"
                      MinWidth="220" />
        </Grid>

        <!-- Result count -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Spacing="5"
                    Margin="2,0,0,0">
            <TextBlock Text="{x:Bind ViewModel.FilteredSeries.Count, Mode=OneWay, Converter={StaticResource NumberFormatConverter}}"
                       Style="{StaticResource KroiraResultCountStyle}" />
            <TextBlock Text="shows"
                       Style="{StaticResource KroiraResultCountStyle}" />
        </StackPanel>

        <!-- Main content -->
        <Grid Grid.Row="3" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="420" />
            </Grid.ColumnDefinitions>

            <!-- Empty state -->
            <StackPanel Grid.Column="0"
                        Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="10"
                        MaxWidth="460">
                <FontIcon Glyph="&#xE8A9;"
                          Foreground="{StaticResource KroiraTextTertiaryBrush}"
                          FontSize="28"
                          HorizontalAlignment="Center" />
                <TextBlock Text="No series to show"
                           Style="{StaticResource KroiraSectionTitleStyle}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Sync an Xtream VOD source, or clear your filters."
                           Style="{StaticResource KroiraBodyStyle}"
                           TextAlignment="Center"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Safe master list -->
            <ListView Grid.Column="0"
                      ItemsSource="{x:Bind ViewModel.FilteredSeries, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedSeries, Mode=TwoWay}"
                      SelectionMode="Single"
                      ItemContainerStyle="{StaticResource SeriesListItemStyle}"
                      ScrollViewer.HorizontalScrollMode="Disabled"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollMode="Enabled"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      Padding="0,4,0,20">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource KroiraSurfaceBrush}"
                                CornerRadius="12"
                                Padding="14">
                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Poster -->
                                <Grid Width="72" Height="108">
                                    <Border CornerRadius="10"
                                            Background="{StaticResource KroiraPosterPlaceholderBrush}">
                                        <FontIcon Glyph="&#xE8A9;"
                                                  Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                  FontSize="22"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                    </Border>
                                    <Border CornerRadius="10">
                                        <Image Source="{Binding PosterUrl, Converter={StaticResource UrlToImageSourceConverter}}"
                                               Stretch="UniformToFill" />
                                    </Border>
                                </Grid>

                                <!-- Metadata -->
                                <StackPanel Grid.Column="1"
                                            Spacing="4"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}"
                                               Style="{StaticResource KroiraTitleStyle}"
                                               FontSize="17"
                                               TextWrapping="WrapWholeWords"
                                               MaxLines="2" />
                                    <TextBlock Text="{Binding CategoryName}"
                                               Style="{StaticResource KroiraBodyStyle}"
                                               FontSize="13"
                                               Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                                    <TextBlock Text="Select to inspect seasons and episodes"
                                               Style="{StaticResource KroiraBodyStyle}"
                                               FontSize="12"
                                               Foreground="{StaticResource KroiraTextTertiaryBrush}" />
                                </StackPanel>

                                <!-- Affordance -->
                                <StackPanel Grid.Column="2"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Right"
                                            Spacing="6">
                                    <Border Background="{StaticResource KroiraSurfaceSoftBrush}"
                                            CornerRadius="999"
                                            Padding="10,5">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE7C3;"
                                                      FontSize="12"
                                                      Foreground="{StaticResource KroiraAccentBrush}" />
                                            <TextBlock Text="Series"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Detail drawer -->
            <Border Grid.Column="1"
                    Background="{StaticResource KroiraSurfaceBrush}"
                    CornerRadius="14"
                    Padding="24"
                    VerticalAlignment="Stretch">
                <Grid>
                    <!-- Nothing selected -->
                    <StackPanel Visibility="{x:Bind ViewModel.SelectedSeries, Mode=OneWay, Converter={StaticResource NullToVisibleConverter}}"
                                Spacing="10"
                                VerticalAlignment="Top">
                        <FontIcon Glyph="&#xE8A9;"
                                  FontSize="24"
                                  Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                  HorizontalAlignment="Left" />
                        <TextBlock Text="Pick a show"
                                   Style="{StaticResource KroiraSectionTitleStyle}" />
                        <TextBlock Text="Select any title on the left to view its seasons and episodes."
                                   Style="{StaticResource KroiraBodyStyle}" />
                    </StackPanel>

                    <!-- Selected series -->
                    <Grid Visibility="{x:Bind ViewModel.SelectedSeries, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}"
                          RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Show info -->
                        <StackPanel Grid.Row="0" Spacing="6">
                            <TextBlock Text="SHOW"
                                       Style="{StaticResource KroiraLabelStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.SelectedSeries.Title, Mode=OneWay}"
                                       Style="{StaticResource KroiraSectionTitleStyle}"
                                       FontSize="20"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{x:Bind ViewModel.SelectedSeries.CategoryName, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                        </StackPanel>

                        <!-- Season picker -->
                        <StackPanel Grid.Row="1" Spacing="8">
                            <TextBlock Text="SEASON"
                                       Style="{StaticResource KroiraLabelStyle}" />
                            <ComboBox Style="{StaticResource KroiraFilterComboBoxStyle}"
                                      ItemsSource="{x:Bind ViewModel.SelectedSeries.Seasons, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedSeason, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SeasonNumber, Converter={StaticResource SeasonPrefixConverter}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <!-- Status / CTA -->
                        <StackPanel Grid.Row="2" Spacing="10">
                            <TextBlock Text="{x:Bind ViewModel.SelectedSeriesStatus, Mode=OneWay}"
                                       Visibility="{x:Bind ViewModel.SelectedSeriesStatusVisibility, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       FontSize="12" />
                            <Button Content="Play selected episode"
                                    Visibility="{x:Bind ViewModel.SelectedEpisodePlayVisibility, Mode=OneWay}"
                                    Click="PlaySelectedEpisode_Click"
                                    Style="{StaticResource KroiraPrimaryButtonStyle}"
                                    HorizontalAlignment="Left" />
                        </StackPanel>

                        <!-- Episodes label -->
                        <TextBlock Grid.Row="3"
                                   Text="EPISODES"
                                   Style="{StaticResource KroiraLabelStyle}"
                                   Margin="0,4,0,0" />

                        <!-- Episodes list -->
                        <ListView Grid.Row="4"
                                  ItemsSource="{x:Bind ViewModel.SelectedSeason.Episodes, Mode=OneWay}"
                                  SelectionMode="Single"
                                  SelectionChanged="EpisodeList_SelectionChanged"
                                  ItemContainerStyle="{StaticResource SeriesEpisodeRowStyle}"
                                  ScrollViewer.VerticalScrollMode="Enabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollMode="Disabled"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource KroiraSurfaceSoftBrush}"
                                            CornerRadius="8"
                                            Padding="14,10">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding EpisodeNumber}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                       VerticalAlignment="Center"
                                                       MinWidth="22" />

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Title}"
                                                       Style="{StaticResource KroiraTitleStyle}"
                                                       FontSize="13"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />

                                            <FontIcon Grid.Column="2"
                                                      Glyph="&#xE768;"
                                                      FontSize="12"
                                                      Foreground="{StaticResource KroiraAccentBrush}"
                                                      VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>