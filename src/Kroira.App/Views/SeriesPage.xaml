<Page
    x:Class="Kroira.App.Views.SeriesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Kroira.App.Controls"
    xmlns:local="using:Kroira.App.Views"
    xmlns:viewModels="using:Kroira.App.ViewModels"
    x:Name="SeriesPageRoot"
    NavigationCacheMode="Required"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Page.Resources>
        <local:NullToCollapsedConverter x:Key="NullToCollapsedConverter" />
        <local:NullToVisibleConverter x:Key="NullToVisibleConverter" />
        <local:SeasonPrefixConverter x:Key="SeasonPrefixConverter" />

        <Style x:Key="SeriesTileContainerStyle" TargetType="GridViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="SeriesEpisodeRowStyle" TargetType="ListViewItem">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="CategoryRailItemContainerStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="FavoritePillButtonStyle" TargetType="Button" BasedOn="{StaticResource KroiraGhostButtonStyle}">
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>
    </Page.Resources>

    <Grid XYFocusKeyboardNavigation="Enabled">
        <controls:AmbientPageBackground />

        <Grid Padding="30,26,30,34"
              MaxWidth="1660"
              HorizontalAlignment="Center"
              RowSpacing="16"
              ColumnSpacing="16"
              Visibility="{x:Bind ViewModel.ContentShellVisibility, Mode=OneWay}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="0" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="186" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0" Grid.ColumnSpan="2" ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="6">
                <TextBlock Text="SHOWS LIBRARY"
                           Style="{StaticResource KroiraLabelStyle}"
                           Foreground="{StaticResource KroiraAccentBrush}" />
                <TextBlock Text="Series"
                           Style="{StaticResource KroiraPageTitleStyle}" />
                <TextBlock Text="Pick a show to browse seasons and episodes."
                           Style="{StaticResource KroiraPageSubtitleStyle}"
                           MaxWidth="680" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Grid.ColumnSpan="2"
                Background="#42070B12"
                BorderBrush="Transparent"
                BorderThickness="0"
                CornerRadius="18"
                Padding="10">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.2*" />
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                         <TextBox x:Name="SearchBox"
                                  Style="{StaticResource KroiraFilterTextBoxStyle}"
                                  Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  KeyDown="SearchBox_KeyDown"
                                  PlaceholderText="Search series"
                                  AutomationProperties.Name="Search series" />
                        <FontIcon Glyph="&#xE721;"
                                  FontSize="14"
                                  Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                  HorizontalAlignment="Right"
                                  Margin="0,0,16,0"
                                  VerticalAlignment="Center" />
                    </Grid>

                     <ComboBox Grid.Column="1"
                               Style="{StaticResource KroiraFilterComboBoxStyle}"
                               ItemsSource="{x:Bind ViewModel.SourceOptions, Mode=OneWay}"
                               SelectedItem="{x:Bind ViewModel.SelectedSourceOption, Mode=TwoWay}"
                               DisplayMemberPath="DisplayName"
                               AutomationProperties.Name="Series provider" />

                     <ComboBox Grid.Column="2"
                               Style="{StaticResource KroiraFilterComboBoxStyle}"
                               ItemsSource="{x:Bind ViewModel.SortOptions, Mode=OneWay}"
                               SelectedItem="{x:Bind ViewModel.SelectedSortOption, Mode=TwoWay}"
                               DisplayMemberPath="Label"
                               AutomationProperties.Name="Series sort" />

                    <StackPanel Grid.Column="3"
                                Orientation="Horizontal"
                                Spacing="10"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                         <CheckBox Content="Favorites"
                                  IsChecked="{x:Bind ViewModel.FavoritesOnly, Mode=TwoWay}"
                                  AutomationProperties.Name="Show favorite series only" />
                         <CheckBox Content="Primary only"
                                  IsChecked="{x:Bind ViewModel.HideSecondaryContent, Mode=TwoWay}"
                                  AutomationProperties.Name="Show primary series entries only" />
                    </StackPanel>
                </Grid>
        </Border>

        <ListView x:Name="CategoryList"
                  Grid.Row="3"
                  Grid.Column="0"
                  ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                  SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                  SelectionMode="Single"
                  ItemContainerStyle="{StaticResource CategoryRailItemContainerStyle}"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="0"
                  ScrollViewer.HorizontalScrollMode="Disabled"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ScrollViewer.VerticalScrollMode="Enabled"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  AutomationProperties.Name="Series categories">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="viewModels:BrowserCategoryViewModel">
                    <Grid MinHeight="44">
                        <Border Background="{StaticResource KroiraAccentContainerBrush}"
                                BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Opacity="{x:Bind SelectionBackgroundOpacity, Mode=OneWay}" />
                        <Border BorderBrush="{StaticResource KroiraAccentBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Opacity="{x:Bind SelectionChromeOpacity, Mode=OneWay}" />
                        <Border Width="3"
                                HorizontalAlignment="Left"
                                Margin="0,7,0,7"
                                CornerRadius="2"
                                Background="{StaticResource KroiraAccentBrush}"
                                Opacity="{x:Bind SelectionAccentOpacity, Mode=OneWay}" />
                        <Grid Padding="12,8,10,8" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="1">
                                <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                           Foreground="{StaticResource KroiraTextPrimaryBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{x:Bind Description, Mode=OneWay}"
                                           Visibility="{x:Bind DescriptionVisibility, Mode=OneWay}"
                                           Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                           FontSize="10"
                                           MaxLines="1"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Background="#1AFFFFFF"
                                    BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="9"
                                    Padding="6,2"
                                    VerticalAlignment="Center"
                                    Visibility="{x:Bind CountVisibility, Mode=OneWay}">
                                <TextBlock Text="{x:Bind CountText, Mode=OneWay}"
                                           Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                           FontSize="10"
                                           FontWeight="SemiBold" />
                            </Border>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Grid Grid.Row="3" Grid.Column="1" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="370" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <controls:EmptyStateView IconGlyph="&#xE8A9;"
                                         Title="{x:Bind ViewModel.EmptyStateTitle, Mode=OneWay}"
                                         Message="{x:Bind ViewModel.EmptyStateMessage, Mode=OneWay}"
                                         Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center" />

                <GridView x:Name="SeriesGrid"
                          ItemsSource="{x:Bind ViewModel.DisplaySeriesSlots, Mode=OneWay}"
                          SelectionChanged="SeriesGrid_SelectionChanged"
                          KeyDown="SeriesGrid_KeyDown"
                          SelectionMode="Single"
                          ItemContainerStyle="{StaticResource SeriesTileContainerStyle}"
                          HorizontalAlignment="Stretch"
                          ScrollViewer.HorizontalScrollMode="Disabled"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollMode="Enabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          Padding="0,2,0,22">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal"
                                           ItemWidth="182"
                                           ItemHeight="248"
                                           MaximumRowsOrColumns="5" />
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="174"
                                  Height="238"
                                  Loaded="RevealCardRoot_Loaded">
                                <Border Visibility="{Binding SeriesVisibility}"
                                        Background="#24070B12"
                                        BorderBrush="Transparent"
                                        BorderThickness="0"
                                        CornerRadius="14"
                                        Padding="8">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="166" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Border CornerRadius="10"
                                                    Background="{StaticResource KroiraPosterPlaceholderBrush}">
                                                <FontIcon Glyph="&#xE8A9;"
                                                          Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                          FontSize="24"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                            </Border>
                                            <Border CornerRadius="10">
                                                <Image Source="{Binding DisplayPosterUrl, Converter={StaticResource UrlToImageSourceConverter}}"
                                                       Stretch="UniformToFill" />
                                            </Border>
                                            <Border Height="54"
                                                    VerticalAlignment="Bottom"
                                                    CornerRadius="0,0,10,10">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#0010141A" Offset="0" />
                                                        <GradientStop Color="#C8080A0D" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <Border Tag="MediaActionOverlay"
                                                    Visibility="Collapsed"
                                                    Opacity="0"
                                                    IsHitTestVisible="False"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Bottom"
                                                    Margin="10"
                                                    CornerRadius="18"
                                                    Padding="6"
                                                    Background="#A805070B">
                                                <Grid ColumnSpacing="6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border HorizontalAlignment="Left"
                                                            Background="#66111827"
                                                            BorderBrush="{StaticResource KroiraAccentBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="13"
                                                            Padding="8,5">
                                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                                            <FontIcon Glyph="&#xE7C3;"
                                                                      FontSize="10"
                                                                      Foreground="{StaticResource KroiraAccentBrush}" />
                                                            <TextBlock Text="Details"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                                                        </StackPanel>
                                                    </Border>
                                                    <Button Grid.Column="1"
                                                            Click="FavoriteToggle_Click"
                                                            Tag="{Binding Id}"
                                                            ToolTipService.ToolTip="{Binding FavoriteLabel}"
                                                            Width="28"
                                                            Height="28"
                                                            Padding="0"
                                                            MinWidth="0"
                                                            MinHeight="0"
                                                            Background="#201A2030"
                                                            BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="14">
                                                        <FontIcon Glyph="{Binding FavoriteGlyph}"
                                                                  FontSize="11"
                                                                  Foreground="{StaticResource KroiraAccentBrush}" />
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </Grid>

                                        <StackPanel Grid.Row="1" Spacing="4" Margin="2,10,2,0">
                                            <TextBlock Text="{Binding Title}"
                                                       Style="{StaticResource KroiraTitleStyle}"
                                                       MaxLines="2"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding CategoryName}"
                                                       Style="{StaticResource KroiraMetaStyle}"
                                                       MaxLines="1"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Visibility="{Binding PlaceholderVisibility}"
                                        Background="#220A0D11"
                                        BorderBrush="#14FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Opacity="0.72">
                                    <Grid>
                                        <Border Margin="10"
                                                CornerRadius="10"
                                                BorderBrush="#0FFFFFFF"
                                                BorderThickness="1"
                                                Background="#18000000" />
                                        <FontIcon Glyph="&#xE8A9;"
                                                  FontSize="22"
                                                  Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                  Opacity="0.16" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </Grid>

            <Border Grid.Column="1"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    CornerRadius="16"
                    Padding="0"
                    VerticalAlignment="Stretch">
                <Grid>
                    <!-- No-selection placeholder -->
                    <StackPanel Visibility="{x:Bind ViewModel.SelectedSeries, Mode=OneWay, Converter={StaticResource NullToVisibleConverter}}"
                                Spacing="14"
                                Padding="18"
                                VerticalAlignment="Top">
                        <Border Height="136"
                                CornerRadius="14"
                                Background="{StaticResource KroiraMediaGradientBrush}"
                                BorderBrush="Transparent"
                                BorderThickness="0">
                            <Grid>
                                <FontIcon Glyph="&#xE8A9;"
                                          FontSize="34"
                                          Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                          Opacity="0.35" />
                                <Border>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#3327150A" Offset="0" />
                                            <GradientStop Color="#141A22" Offset="0.52" />
                                            <GradientStop Color="#090A0D" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Border Width="4"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource KroiraAccentGradientBrush}"
                                        CornerRadius="14,0,0,14" />
                            </Grid>
                        </Border>
                        <StackPanel Spacing="8">
                            <TextBlock Text="Pick a show"
                                       Style="{StaticResource KroiraSectionTitleStyle}" />
                            <TextBlock Text="Select a title from the library to load artwork, seasons, and episode playback here."
                                       Style="{StaticResource KroiraBodyStyle}"
                                       MaxLines="3"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Detail panel: scrollable stack, visible when a series is selected -->
                    <ScrollViewer Visibility="{x:Bind ViewModel.SelectedSeries, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}"
                                  VerticalScrollMode="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollMode="Disabled"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="12" Padding="16">

                            <!-- Hero artwork + title block -->
                            <Border MinHeight="286"
                                    CornerRadius="14"
                                    BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                    BorderThickness="1"
                                    Background="{StaticResource KroiraMediaGradientBrush}">
                                <Grid>
                                    <Image Source="{x:Bind ViewModel.SelectedSeries.DisplayHeroArtworkUrl, Mode=OneWay, Converter={StaticResource UrlToImageSourceConverter}}"
                                           Stretch="UniformToFill"
                                           Opacity="0.88" />
                                    <Border>
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#20000000" Offset="0" />
                                                <GradientStop Color="#B0090B0F" Offset="0.56" />
                                                <GradientStop Color="#F0090B0F" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <Border Width="4"
                                            HorizontalAlignment="Left"
                                            Background="{StaticResource KroiraAccentGradientBrush}"
                                            CornerRadius="14,0,0,14" />
                                    <Grid Padding="16" ColumnSpacing="15" VerticalAlignment="Bottom">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="108" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="108"
                                                Height="160"
                                                CornerRadius="10"
                                                Background="{StaticResource KroiraPosterPlaceholderBrush}"
                                                BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                                BorderThickness="1">
                                            <Grid>
                                                <FontIcon Glyph="&#xE8A9;"
                                                          FontSize="22"
                                                          Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                          Opacity="0.55" />
                                                <Image Source="{x:Bind ViewModel.SelectedSeries.DisplayPosterUrl, Mode=OneWay, Converter={StaticResource UrlToImageSourceConverter}}"
                                                       Stretch="UniformToFill" />
                                            </Grid>
                                        </Border>
                                        <StackPanel Grid.Column="1"
                                                    Spacing="6"
                                                    VerticalAlignment="Bottom">
                                            <TextBlock Text="SHOW"
                                                       Style="{StaticResource KroiraLabelStyle}"
                                                       Foreground="{StaticResource KroiraAccentBrush}" />
                                            <TextBlock Text="{x:Bind ViewModel.SelectedSeries.Title, Mode=OneWay}"
                                                       Style="{StaticResource KroiraSectionTitleStyle}"
                                                       FontSize="22"
                                                       MaxLines="2"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{x:Bind ViewModel.SelectedSeries.MetadataLine, Mode=OneWay}"
                                                       Style="{StaticResource KroiraBodyStyle}"
                                                       Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                                       MaxLines="1"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{x:Bind ViewModel.SelectedSeries.Overview, Mode=OneWay}"
                                                       Style="{StaticResource KroiraBodyStyle}"
                                                       FontSize="12"
                                                       LineHeight="17"
                                                       MaxLines="3"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Button Click="FavoriteToggle_Click"
                                                    Tag="{x:Bind ViewModel.SelectedSeries.Id, Mode=OneWay}"
                                                    Style="{StaticResource FavoritePillButtonStyle}"
                                                    HorizontalAlignment="Left"
                                                    Margin="0,2,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <FontIcon Glyph="{x:Bind ViewModel.SelectedSeries.FavoriteGlyph, Mode=OneWay}"
                                                              FontSize="13"
                                                              Foreground="{StaticResource KroiraAccentBrush}" />
                                                    <TextBlock Text="{x:Bind ViewModel.SelectedSeries.FavoriteLabel, Mode=OneWay}" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Season picker + play button -->
                            <Border Background="#42111827"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="12"
                                    Padding="12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="10">
                                        <StackPanel Spacing="7"
                                                    Visibility="{x:Bind ViewModel.SelectedSeries.SourceSelectionVisibility, Mode=OneWay}">
                                            <TextBlock Text="SOURCE"
                                                       Style="{StaticResource KroiraLabelStyle}"
                                                       Foreground="{StaticResource KroiraAccentBrush}" />
                                         <ComboBox Style="{StaticResource KroiraFilterComboBoxStyle}"
                                                   ItemsSource="{x:Bind ViewModel.SelectedSeries.SourceOptions, Mode=OneWay}"
                                                   SelectedItem="{x:Bind ViewModel.SelectedSeries.SelectedSourceOption, Mode=TwoWay}"
                                                   DisplayMemberPath="Label"
                                                   HorizontalAlignment="Stretch"
                                                   AutomationProperties.Name="Episode source" />
                                        </StackPanel>
                                        <TextBlock Text="SEASON"
                                                   Style="{StaticResource KroiraLabelStyle}"
                                                   Foreground="{StaticResource KroiraAccentBrush}" />
                                         <ComboBox Style="{StaticResource KroiraFilterComboBoxStyle}"
                                                   ItemsSource="{x:Bind ViewModel.SeasonOptions, Mode=OneWay}"
                                                   SelectedItem="{x:Bind ViewModel.SelectedSeason, Mode=TwoWay}"
                                                   HorizontalAlignment="Stretch"
                                                   AutomationProperties.Name="Season">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DisplayName}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                         <ToggleSwitch Header="Hide watched episodes"
                                                       IsOn="{x:Bind ViewModel.HideWatchedEpisodes, Mode=TwoWay}"
                                                       OnContent=""
                                                       OffContent=""
                                                       HorizontalAlignment="Left"
                                                       AutomationProperties.Name="Hide watched episodes" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                Spacing="8"
                                                VerticalAlignment="Bottom"
                                                Visibility="{x:Bind ViewModel.SelectedEpisodePlayVisibility, Mode=OneWay}">
                                         <Button x:Name="PlaySelectedEpisodeButton"
                                                 Content="Play"
                                                 Click="PlaySelectedEpisode_Click"
                                                 Style="{StaticResource KroiraPrimaryButtonStyle}"
                                                 Padding="18,11"
                                                 AutomationProperties.Name="Play selected episode" />
                                        <Button Click="InspectSelectedEpisode_Click"
                                                Style="{StaticResource KroiraGhostButtonStyle}"
                                                Width="38"
                                                Height="38"
                                                Padding="0"
                                                AutomationProperties.Name="Episode details"
                                                ToolTipService.ToolTip="Details">
                                            <FontIcon Glyph="&#xE946;"
                                                      FontSize="12"
                                                      Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                                        </Button>
                                        <Button Click="DownloadSelectedEpisode_Click"
                                                Visibility="{x:Bind DownloadActionsVisibility, Mode=OneWay}"
                                                Style="{StaticResource KroiraGhostButtonStyle}"
                                                Width="38"
                                                Height="38"
                                                Padding="0"
                                                AutomationProperties.Name="Download episode"
                                                ToolTipService.ToolTip="Download">
                                            <FontIcon Glyph="&#xE896;"
                                                      FontSize="12"
                                                      Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Async status message -->
                            <TextBlock Text="{x:Bind ViewModel.SelectedSeriesStatus, Mode=OneWay}"
                                       Visibility="{x:Bind ViewModel.SelectedSeriesStatusVisibility, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="2,0" />

                            <!-- Episodes section header -->
                            <Grid ColumnSpacing="8" Margin="2,2,2,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="EPISODES"
                                           Style="{StaticResource KroiraLabelStyle}"
                                           Foreground="{StaticResource KroiraAccentBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind ViewModel.EpisodeItems.Count, Mode=OneWay}"
                                           Visibility="{x:Bind ViewModel.EpisodesListVisibility, Mode=OneWay}"
                                           Style="{StaticResource KroiraMetaStyle}"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <controls:EmptyStateView IconGlyph="&#xE8A9;"
                                                     Title="No playable episodes"
                                                     Message="Episode stream data is not available for this season yet. Re-sync the VOD source or select a different season."
                                                     Visibility="{x:Bind ViewModel.EpisodesEmptyVisibility, Mode=OneWay}" />

                            <!-- Episodes list with constrained max height so it scrolls within the panel -->
                            <ListView x:Name="EpisodeList"
                                      Visibility="{x:Bind ViewModel.EpisodesListVisibility, Mode=OneWay}"
                                      ItemsSource="{x:Bind ViewModel.EpisodeItems, Mode=OneWay}"
                                      MaxHeight="380"
                                      SelectionMode="None"
                                      IsItemClickEnabled="True"
                                      ItemClick="EpisodeList_ItemClick"
                                      KeyDown="EpisodeList_KeyDown"
                                      ItemContainerStyle="{StaticResource SeriesEpisodeRowStyle}"
                                      ScrollViewer.VerticalScrollMode="Enabled"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollMode="Disabled"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      Padding="0,0,0,4">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#52111827"
                                                BorderBrush="Transparent"
                                                BorderThickness="0"
                                                CornerRadius="9"
                                                Padding="13,11"
                                                Loaded="RevealCardRoot_Loaded">
                                                <Grid ColumnSpacing="10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0"
                                                        Background="#24FFFFFF"
                                                        CornerRadius="6"
                                                        Padding="5,2"
                                                        MinWidth="26"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding EpisodeNumber}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                               HorizontalAlignment="Center" />
                                                </Border>

                                                    <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Title}"
                                                                   Style="{StaticResource KroiraTitleStyle}"
                                                                   FontSize="13"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding StatusText}"
                                                                   Style="{StaticResource KroiraMetaStyle}" />
                                                    </StackPanel>

                                                    <Grid Grid.Column="2"
                                                          VerticalAlignment="Center">
                                                        <FontIcon Glyph="&#xE102;"
                                                                  FontSize="12"
                                                                  Foreground="{StaticResource KroiraAccentBrush}"
                                                                  HorizontalAlignment="Right"
                                                                  VerticalAlignment="Center"
                                                                  Opacity="0.85" />
                                                        <StackPanel Tag="MediaActionOverlay"
                                                                    Visibility="Collapsed"
                                                                    Opacity="0"
                                                                    IsHitTestVisible="False"
                                                                    Orientation="Horizontal"
                                                                    Spacing="6"
                                                                    Background="#B805070B">
                                                            <Button Content="Details"
                                                                    Click="InspectEpisode_Click"
                                                                    Style="{StaticResource KroiraGhostButtonStyle}"
                                                                    FontSize="11"
                                                                    Padding="9,4" />
                                                            <Button Content="Download"
                                                                    Click="DownloadEpisode_Click"
                                                                    Visibility="{Binding ElementName=SeriesPageRoot, Path=DownloadActionsVisibility}"
                                                                    Style="{StaticResource KroiraGhostButtonStyle}"
                                                                    FontSize="11"
                                                                    Padding="9,4" />
                                                            <Button Content="Watched"
                                                                    Click="MarkEpisodeWatched_Click"
                                                                    Style="{StaticResource KroiraGhostButtonStyle}"
                                                                    FontSize="11"
                                                                    Padding="9,4"
                                                                    Visibility="{Binding MarkWatchedVisibility}" />
                                                            <Button Content="Unwatched"
                                                                    Click="MarkEpisodeUnwatched_Click"
                                                                    Style="{StaticResource KroiraGhostButtonStyle}"
                                                                    FontSize="11"
                                                                    Padding="9,4"
                                                                    Visibility="{Binding MarkUnwatchedVisibility}" />
                                                        </StackPanel>
                                                    </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
        </Grid>

        <Grid Visibility="{x:Bind ViewModel.BlockingSurfaceVisibility, Mode=OneWay}"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Margin="32">
            <controls:LoadingStateView Title="{x:Bind ViewModel.SurfaceState.Title, Mode=OneWay}"
                                       Message="{x:Bind ViewModel.SurfaceState.Message, Mode=OneWay}"
                                       Visibility="{x:Bind ViewModel.SurfaceState.LoadingStateVisibility, Mode=OneWay}" />
            <controls:EmptyStateView IconGlyph="{x:Bind ViewModel.SurfaceState.Glyph, Mode=OneWay}"
                                     Title="{x:Bind ViewModel.SurfaceState.Title, Mode=OneWay}"
                                     Message="{x:Bind ViewModel.SurfaceState.Message, Mode=OneWay}"
                                     PrimaryActionLabel="{x:Bind ViewModel.SurfaceState.ActionLabel, Mode=OneWay}"
                                     PrimaryActionVisibility="{x:Bind ViewModel.SurfaceState.ActionVisibility, Mode=OneWay}"
                                     Visibility="{x:Bind ViewModel.SurfaceState.EmptyStateVisibility, Mode=OneWay}"
                                     PrimaryActionClick="OpenSources_Click" />
            <controls:ErrorStateView IconGlyph="{x:Bind ViewModel.SurfaceState.Glyph, Mode=OneWay}"
                                     Title="{x:Bind ViewModel.SurfaceState.Title, Mode=OneWay}"
                                     Message="{x:Bind ViewModel.SurfaceState.Message, Mode=OneWay}"
                                     RetryActionLabel="Retry"
                                     DiagnosticsActionLabel="{x:Bind ViewModel.SurfaceState.ActionLabel, Mode=OneWay}"
                                     DiagnosticsActionVisibility="{x:Bind ViewModel.SurfaceState.DiagnosticsActionVisibility, Mode=OneWay}"
                                     Visibility="{x:Bind ViewModel.SurfaceState.ErrorStateVisibility, Mode=OneWay}"
                                     RetryClick="RetrySurface_Click"
                                     DiagnosticsClick="OpenSources_Click" />
        </Grid>
    </Grid>
</Page>
