<Page
    x:Class="Kroira.App.Views.SeriesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Kroira.App.Views"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <local:NullToCollapsedConverter x:Key="NullToCollapsedConverter" />
        <local:SeasonPrefixConverter x:Key="SeasonPrefixConverter" />
        <local:EpisodePrefixConverter x:Key="EpisodePrefixConverter" />
    </Page.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16" Spacing="16">
            <TextBlock Text="Series" Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBox Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Search series..." MaxWidth="400" HorizontalAlignment="Left" />
        </StackPanel>

        <TextBlock Grid.Row="1" Text="No series imported yet. Sync an Xtream VOD source to get started."
                   Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
                   Style="{ThemeResource BodyTextBlockStyle}" Foreground="Gray"
                   HorizontalAlignment="Center" VerticalAlignment="Center" />

        <Grid Grid.Row="1" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="380" />
            </Grid.ColumnDefinitions>

            <!-- Left: Series Grid -->
            <GridView Grid.Column="0" ItemsSource="{x:Bind ViewModel.FilteredSeries, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedSeries, Mode=TwoWay}" SelectionMode="Single">
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="140" Height="220" Margin="4" CornerRadius="4" Background="#11FFFFFF">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            
                            <Image Grid.Row="0" Source="{Binding PosterUrl}" Stretch="UniformToFill" />
                            
                            <StackPanel Grid.Row="1" Padding="8" Background="#CC000000">
                                <TextBlock Text="{Binding Title}" TextWrapping="Wrap" MaxLines="2" FontWeight="SemiBold" FontSize="11" />
                                <TextBlock Text="{Binding CategoryName}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="9" Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <!-- Right: Details Panel -->
            <Border Grid.Column="1" Background="#0AFFFFFF" CornerRadius="8" Padding="16" Visibility="{x:Bind ViewModel.SelectedSeries, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Spacing="8">
                        <TextBlock Text="{x:Bind ViewModel.SelectedSeries.Title, Mode=OneWay}" Style="{ThemeResource SubtitleTextBlockStyle}" TextWrapping="Wrap" />
                        <TextBlock Text="Seasons" FontWeight="SemiBold" Margin="0,16,0,0" />
                        
                        <ComboBox ItemsSource="{x:Bind ViewModel.SelectedSeries.Seasons, Mode=OneWay}" 
                                  SelectedItem="{x:Bind ViewModel.SelectedSeason, Mode=TwoWay}" 
                                  HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SeasonNumber, Converter={StaticResource SeasonPrefixConverter}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Text="Episodes" FontWeight="SemiBold" Margin="0,16,0,8" />
                    
                    <ListView Grid.Row="2" ItemsSource="{x:Bind ViewModel.SelectedSeason.Episodes, Mode=OneWay}" SelectionMode="Single" SelectionChanged="EpisodeList_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Padding="8,4">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding EpisodeNumber, Converter={StaticResource EpisodePrefixConverter}}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
