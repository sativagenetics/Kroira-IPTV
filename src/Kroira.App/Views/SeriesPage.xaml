<Page
    x:Class="Kroira.App.Views.SeriesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Kroira.App.Views"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Page.Resources>
        <local:NullToCollapsedConverter x:Key="NullToCollapsedConverter" />
        <local:NullToVisibleConverter x:Key="NullToVisibleConverter" />
        <local:SeasonPrefixConverter x:Key="SeasonPrefixConverter" />

        <Style x:Key="SeriesTileContainerStyle" TargetType="GridViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="SeriesEpisodeRowStyle" TargetType="ListViewItem">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
    </Page.Resources>

    <Grid Padding="30,28,30,34"
          MaxWidth="1360"
          HorizontalAlignment="Center"
          RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="6">
                <TextBlock Text="SHOWS LIBRARY"
                           Style="{StaticResource KroiraLabelStyle}"
                           Foreground="{StaticResource KroiraAccentBrush}" />
                <TextBlock Text="Series"
                           Style="{StaticResource KroiraPageTitleStyle}" />
                <TextBlock Text="Pick a show, then inspect seasons and episodes in the side panel."
                           Style="{StaticResource KroiraPageSubtitleStyle}"
                           MaxWidth="680" />
            </StackPanel>

            <Border Grid.Column="1"
                    Background="#99161B24"
                    BorderBrush="#24FFFFFF"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14,10"
                    VerticalAlignment="Bottom">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{x:Bind ViewModel.FilteredSeries.Count, Mode=OneWay, Converter={StaticResource NumberFormatConverter}}"
                               Style="{StaticResource KroiraTitleStyle}"
                               FontSize="13" />
                    <TextBlock Text="shows" Style="{StaticResource KroiraMetaStyle}" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MaxWidth="520" />
                <ColumnDefinition Width="236" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Style="{StaticResource KroiraFilterTextBoxStyle}"
                     Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="Search series" />

            <ComboBox Grid.Column="1"
                      Style="{StaticResource KroiraFilterComboBoxStyle}"
                      ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                      DisplayMemberPath="Name" />
        </Grid>

        <Grid Grid.Row="2" ColumnSpacing="22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="430" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <StackPanel Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="10"
                            MaxWidth="460">
                    <FontIcon Glyph="&#xE8A9;"
                              Foreground="{StaticResource KroiraTextTertiaryBrush}"
                              FontSize="28"
                              HorizontalAlignment="Center" />
                    <TextBlock Text="No series to show"
                               Style="{StaticResource KroiraSectionTitleStyle}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Sync an Xtream VOD source, or clear your filters."
                               Style="{StaticResource KroiraBodyStyle}"
                               TextAlignment="Center" />
                </StackPanel>

                <GridView ItemsSource="{x:Bind ViewModel.FilteredSeries, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedSeries, Mode=TwoWay}"
                          SelectionMode="Single"
                          ItemContainerStyle="{StaticResource SeriesTileContainerStyle}"
                          ScrollViewer.HorizontalScrollMode="Disabled"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollMode="Enabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          Padding="0,2,0,22">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal"
                                           ItemWidth="182"
                                           ItemHeight="248"
                                           MaximumRowsOrColumns="4" />
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Border Width="174"
                                    Height="238"
                                    Background="#AA11161E"
                                    BorderBrush="#24FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="148" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid>
                                        <Border CornerRadius="10"
                                                Background="{StaticResource KroiraPosterPlaceholderBrush}">
                                            <FontIcon Glyph="&#xE8A9;"
                                                      Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                      FontSize="24"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                        </Border>
                                        <Border CornerRadius="10">
                                            <Image Source="{Binding DisplayPosterUrl, Converter={StaticResource UrlToImageSourceConverter}}"
                                                   Stretch="UniformToFill" />
                                        </Border>
                                        <Border Height="54"
                                                VerticalAlignment="Bottom"
                                                CornerRadius="0,0,10,10">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#0010141A" Offset="0" />
                                                    <GradientStop Color="#C8080A0D" Offset="1" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                    </Grid>

                                    <StackPanel Grid.Row="1" Spacing="4" Margin="2,10,2,4">
                                        <TextBlock Text="{Binding Title}"
                                                   Style="{StaticResource KroiraTitleStyle}"
                                                   MaxLines="2"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding CategoryName}"
                                                   Style="{StaticResource KroiraMetaStyle}"
                                                   MaxLines="1"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <Border Grid.Row="2"
                                            HorizontalAlignment="Left"
                                            Background="#24231A10"
                                            BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="9,4">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE7C3;"
                                                      FontSize="11"
                                                      Foreground="{StaticResource KroiraAccentBrush}" />
                                            <TextBlock Text="Inspect"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </Grid>

            <Border Grid.Column="1"
                    Background="#D00B0E13"
                    BorderBrush="#24FFFFFF"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="0"
                    VerticalAlignment="Stretch">
                <Grid>
                    <!-- No-selection placeholder -->
                    <StackPanel Visibility="{x:Bind ViewModel.SelectedSeries, Mode=OneWay, Converter={StaticResource NullToVisibleConverter}}"
                                Spacing="18"
                                Padding="24"
                                VerticalAlignment="Center">
                        <Border Height="172"
                                CornerRadius="14"
                                Background="{StaticResource KroiraMediaGradientBrush}"
                                BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                BorderThickness="1">
                            <Grid>
                                <FontIcon Glyph="&#xE8A9;"
                                          FontSize="34"
                                          Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                          Opacity="0.35" />
                                <Border>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#3327150A" Offset="0" />
                                            <GradientStop Color="#141A22" Offset="0.52" />
                                            <GradientStop Color="#090A0D" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Border Width="4"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource KroiraAccentGradientBrush}"
                                        CornerRadius="14,0,0,14" />
                            </Grid>
                        </Border>
                        <StackPanel Spacing="8">
                            <TextBlock Text="Pick a show"
                                       Style="{StaticResource KroiraSectionTitleStyle}" />
                            <TextBlock Text="Select a title from the library to load artwork, seasons, and episode playback here."
                                       Style="{StaticResource KroiraBodyStyle}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Detail panel: scrollable stack, visible when a series is selected -->
                    <ScrollViewer Visibility="{x:Bind ViewModel.SelectedSeries, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}"
                                  VerticalScrollMode="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollMode="Disabled"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="12" Padding="16">

                            <!-- Hero artwork + title block -->
                            <Border MinHeight="286"
                                    CornerRadius="14"
                                    BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                    BorderThickness="1"
                                    Background="{StaticResource KroiraMediaGradientBrush}">
                                <Grid>
                                    <Image Source="{x:Bind ViewModel.SelectedSeries.DisplayHeroArtworkUrl, Mode=OneWay, Converter={StaticResource UrlToImageSourceConverter}}"
                                           Stretch="UniformToFill"
                                           Opacity="0.88" />
                                    <Border>
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#20000000" Offset="0" />
                                                <GradientStop Color="#B0090B0F" Offset="0.56" />
                                                <GradientStop Color="#F0090B0F" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <Border Width="4"
                                            HorizontalAlignment="Left"
                                            Background="{StaticResource KroiraAccentGradientBrush}"
                                            CornerRadius="14,0,0,14" />
                                    <Grid Padding="16" ColumnSpacing="15" VerticalAlignment="Bottom">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="108" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="108"
                                                Height="160"
                                                CornerRadius="10"
                                                Background="{StaticResource KroiraPosterPlaceholderBrush}"
                                                BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                                BorderThickness="1">
                                            <Grid>
                                                <FontIcon Glyph="&#xE8A9;"
                                                          FontSize="22"
                                                          Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                          Opacity="0.55" />
                                                <Image Source="{x:Bind ViewModel.SelectedSeries.DisplayPosterUrl, Mode=OneWay, Converter={StaticResource UrlToImageSourceConverter}}"
                                                       Stretch="UniformToFill" />
                                            </Grid>
                                        </Border>
                                        <StackPanel Grid.Column="1"
                                                    Spacing="6"
                                                    VerticalAlignment="Bottom">
                                            <TextBlock Text="SHOW"
                                                       Style="{StaticResource KroiraLabelStyle}"
                                                       Foreground="{StaticResource KroiraAccentBrush}" />
                                            <TextBlock Text="{x:Bind ViewModel.SelectedSeries.Title, Mode=OneWay}"
                                                       Style="{StaticResource KroiraSectionTitleStyle}"
                                                       FontSize="22"
                                                       MaxLines="2"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{x:Bind ViewModel.SelectedSeries.MetadataLine, Mode=OneWay}"
                                                       Style="{StaticResource KroiraBodyStyle}"
                                                       Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                                       MaxLines="1"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{x:Bind ViewModel.SelectedSeries.Overview, Mode=OneWay}"
                                                       Style="{StaticResource KroiraBodyStyle}"
                                                       FontSize="12"
                                                       LineHeight="17"
                                                       MaxLines="3"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Season picker + play button -->
                            <Border Background="#9611161E"
                                    BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="13">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="7">
                                        <TextBlock Text="SEASON"
                                                   Style="{StaticResource KroiraLabelStyle}"
                                                   Foreground="{StaticResource KroiraAccentBrush}" />
                                        <ComboBox Style="{StaticResource KroiraFilterComboBoxStyle}"
                                                  ItemsSource="{x:Bind ViewModel.SelectedSeries.Seasons, Mode=OneWay}"
                                                  SelectedItem="{x:Bind ViewModel.SelectedSeason, Mode=TwoWay}"
                                                  HorizontalAlignment="Stretch">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding SeasonNumber, Converter={StaticResource SeasonPrefixConverter}}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Content="Play"
                                            Visibility="{x:Bind ViewModel.SelectedEpisodePlayVisibility, Mode=OneWay}"
                                            Click="PlaySelectedEpisode_Click"
                                            Style="{StaticResource KroiraPrimaryButtonStyle}"
                                            Padding="18,11"
                                            VerticalAlignment="Bottom" />
                                </Grid>
                            </Border>

                            <!-- Async status message -->
                            <TextBlock Text="{x:Bind ViewModel.SelectedSeriesStatus, Mode=OneWay}"
                                       Visibility="{x:Bind ViewModel.SelectedSeriesStatusVisibility, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="2,0" />

                            <!-- Episodes section header -->
                            <Grid ColumnSpacing="8" Margin="2,2,2,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="EPISODES"
                                           Style="{StaticResource KroiraLabelStyle}"
                                           Foreground="{StaticResource KroiraAccentBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind ViewModel.SelectedSeason.Episodes.Count, Mode=OneWay}"
                                           Visibility="{x:Bind ViewModel.EpisodesListVisibility, Mode=OneWay}"
                                           Style="{StaticResource KroiraMetaStyle}"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <!-- Empty state when season exists but has no playable episodes -->
                            <Border Visibility="{x:Bind ViewModel.EpisodesEmptyVisibility, Mode=OneWay}"
                                    Background="#7A0B0E14"
                                    BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="20,18">
                                <StackPanel Spacing="8">
                                    <FontIcon Glyph="&#xE8A9;"
                                              FontSize="22"
                                              Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                              HorizontalAlignment="Left" />
                                    <TextBlock Text="No playable episodes"
                                               Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock Text="Episode stream data is not available for this season yet. Re-sync the VOD source or select a different season."
                                               Style="{StaticResource KroiraBodyStyle}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <!-- Episodes list with constrained max height so it scrolls within the panel -->
                            <ListView Visibility="{x:Bind ViewModel.EpisodesListVisibility, Mode=OneWay}"
                                      ItemsSource="{x:Bind ViewModel.SelectedSeason.Episodes, Mode=OneWay}"
                                      MaxHeight="380"
                                      SelectionMode="Single"
                                      SelectionChanged="EpisodeList_SelectionChanged"
                                      ItemContainerStyle="{StaticResource SeriesEpisodeRowStyle}"
                                      ScrollViewer.VerticalScrollMode="Enabled"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollMode="Disabled"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      Padding="0,0,0,4">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#B111161E"
                                                BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                                BorderThickness="1"
                                                CornerRadius="9"
                                                Padding="13,11">
                                            <Grid ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0"
                                                        Background="#24FFFFFF"
                                                        CornerRadius="6"
                                                        Padding="5,2"
                                                        MinWidth="26"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding EpisodeNumber}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                               HorizontalAlignment="Center" />
                                                </Border>

                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Title}"
                                                           Style="{StaticResource KroiraTitleStyle}"
                                                           FontSize="13"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center" />

                                                <FontIcon Grid.Column="2"
                                                          Glyph="&#xE102;"
                                                          FontSize="11"
                                                          Foreground="{StaticResource KroiraAccentBrush}"
                                                          VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
