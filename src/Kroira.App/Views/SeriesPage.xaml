<Page
    x:Class="Kroira.App.Views.SeriesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Kroira.App.Views"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Page.Resources>
        <local:NullToCollapsedConverter x:Key="NullToCollapsedConverter" />
        <local:NullToVisibleConverter x:Key="NullToVisibleConverter" />
        <local:SeasonPrefixConverter x:Key="SeasonPrefixConverter" />

        <Style x:Key="SeriesTileContainerStyle" TargetType="GridViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="SeriesEpisodeRowStyle" TargetType="ListViewItem">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
    </Page.Resources>

    <Grid Padding="28,26,28,32"
          MaxWidth="1280"
          HorizontalAlignment="Center"
          RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="6">
                <TextBlock Text="SHOWS LIBRARY"
                           Style="{StaticResource KroiraLabelStyle}"
                           Foreground="{StaticResource KroiraAccentBrush}" />
                <TextBlock Text="Series"
                           Style="{StaticResource KroiraPageTitleStyle}" />
                <TextBlock Text="Pick a show, then inspect seasons and episodes in the side panel."
                           Style="{StaticResource KroiraPageSubtitleStyle}"
                           MaxWidth="680" />
            </StackPanel>

            <Border Grid.Column="1"
                    Background="#99161B24"
                    BorderBrush="#24FFFFFF"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14,10"
                    VerticalAlignment="Bottom">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{x:Bind ViewModel.FilteredSeries.Count, Mode=OneWay, Converter={StaticResource NumberFormatConverter}}"
                               Style="{StaticResource KroiraTitleStyle}"
                               FontSize="13" />
                    <TextBlock Text="shows" Style="{StaticResource KroiraMetaStyle}" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MaxWidth="520" />
                <ColumnDefinition Width="220" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Style="{StaticResource KroiraFilterTextBoxStyle}"
                     Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="Search series" />

            <ComboBox Grid.Column="1"
                      Style="{StaticResource KroiraFilterComboBoxStyle}"
                      ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                      DisplayMemberPath="Name" />
        </Grid>

        <Grid Grid.Row="2" ColumnSpacing="22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="390" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <StackPanel Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="10"
                            MaxWidth="460">
                    <FontIcon Glyph="&#xE8A9;"
                              Foreground="{StaticResource KroiraTextTertiaryBrush}"
                              FontSize="28"
                              HorizontalAlignment="Center" />
                    <TextBlock Text="No series to show"
                               Style="{StaticResource KroiraSectionTitleStyle}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Sync an Xtream VOD source, or clear your filters."
                               Style="{StaticResource KroiraBodyStyle}"
                               TextAlignment="Center" />
                </StackPanel>

                <GridView ItemsSource="{x:Bind ViewModel.FilteredSeries, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedSeries, Mode=TwoWay}"
                          SelectionMode="Single"
                          ItemContainerStyle="{StaticResource SeriesTileContainerStyle}"
                          ScrollViewer.HorizontalScrollMode="Disabled"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollMode="Enabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          Padding="0,2,0,22">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal"
                                           ItemWidth="176"
                                           ItemHeight="236"
                                           MaximumRowsOrColumns="4" />
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Border Width="168"
                                    Height="226"
                                    Background="#99161B24"
                                    BorderBrush="#24FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="138" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid>
                                        <Border CornerRadius="10"
                                                Background="{StaticResource KroiraPosterPlaceholderBrush}">
                                            <FontIcon Glyph="&#xE8A9;"
                                                      Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                      FontSize="24"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                        </Border>
                                        <Border CornerRadius="10">
                                            <Image Source="{Binding DisplayPosterUrl, Converter={StaticResource UrlToImageSourceConverter}}"
                                                   Stretch="UniformToFill" />
                                        </Border>
                                    </Grid>

                                    <StackPanel Grid.Row="1" Spacing="4" Margin="2,10,2,4">
                                        <TextBlock Text="{Binding Title}"
                                                   Style="{StaticResource KroiraTitleStyle}"
                                                   MaxLines="2"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding CategoryName}"
                                                   Style="{StaticResource KroiraMetaStyle}"
                                                   MaxLines="1"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <Border Grid.Row="2"
                                            HorizontalAlignment="Left"
                                            Background="{StaticResource KroiraSurfaceSoftBrush}"
                                            CornerRadius="10"
                                            Padding="9,4">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE7C3;"
                                                      FontSize="11"
                                                      Foreground="{StaticResource KroiraAccentBrush}" />
                                            <TextBlock Text="Inspect"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </Grid>

            <Border Grid.Column="1"
                    Background="#B0121620"
                    BorderBrush="#24FFFFFF"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="0"
                    VerticalAlignment="Stretch">
                <Grid>
                    <StackPanel Visibility="{x:Bind ViewModel.SelectedSeries, Mode=OneWay, Converter={StaticResource NullToVisibleConverter}}"
                                Spacing="18"
                                Padding="24"
                                VerticalAlignment="Stretch">
                        <Border Height="190"
                                CornerRadius="14"
                                Background="{StaticResource KroiraMediaGradientBrush}"
                                BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                BorderThickness="1">
                            <Grid>
                                <FontIcon Glyph="&#xE8A9;"
                                          FontSize="34"
                                          Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                          Opacity="0.4" />
                                <Border>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#3327150A" Offset="0" />
                                            <GradientStop Color="#141A22" Offset="0.52" />
                                            <GradientStop Color="#090A0D" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Border Width="5"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource KroiraAccentGradientBrush}"
                                        CornerRadius="14,0,0,14" />
                            </Grid>
                        </Border>
                        <StackPanel Spacing="8">
                            <TextBlock Text="Pick a show"
                                       Style="{StaticResource KroiraSectionTitleStyle}" />
                            <TextBlock Text="Select a title from the browser to load provider artwork, seasons, and episode playback actions here."
                                       Style="{StaticResource KroiraBodyStyle}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>

                    <Grid Visibility="{x:Bind ViewModel.SelectedSeries, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}"
                          RowSpacing="14"
                          Padding="18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                MinHeight="248"
                                CornerRadius="14"
                                BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                BorderThickness="1"
                                Background="{StaticResource KroiraMediaGradientBrush}">
                            <Grid>
                                <Image Source="{x:Bind ViewModel.SelectedSeries.DisplayHeroArtworkUrl, Mode=OneWay, Converter={StaticResource UrlToImageSourceConverter}}"
                                       Stretch="UniformToFill"
                                       Opacity="0.74" />
                                <Border>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#3A000000" Offset="0" />
                                            <GradientStop Color="#E5090B0F" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Grid Padding="16" ColumnSpacing="14" VerticalAlignment="Bottom">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="104" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="104"
                                            Height="150"
                                            CornerRadius="10"
                                            Background="{StaticResource KroiraPosterPlaceholderBrush}"
                                            BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                            BorderThickness="1">
                                        <Grid>
                                            <FontIcon Glyph="&#xE8A9;"
                                                      FontSize="24"
                                                      Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                      Opacity="0.55" />
                                            <Image Source="{x:Bind ViewModel.SelectedSeries.DisplayPosterUrl, Mode=OneWay, Converter={StaticResource UrlToImageSourceConverter}}"
                                                   Stretch="UniformToFill" />
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Column="1"
                                                Spacing="7"
                                                VerticalAlignment="Bottom">
                                        <TextBlock Text="SHOW"
                                                   Style="{StaticResource KroiraLabelStyle}"
                                                   Foreground="{StaticResource KroiraAccentBrush}" />
                                        <TextBlock Text="{x:Bind ViewModel.SelectedSeries.Title, Mode=OneWay}"
                                                   Style="{StaticResource KroiraSectionTitleStyle}"
                                                   FontSize="21"
                                                   MaxLines="2"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{x:Bind ViewModel.SelectedSeries.MetadataLine, Mode=OneWay}"
                                                   Style="{StaticResource KroiraBodyStyle}"
                                                   Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                                   MaxLines="2"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{x:Bind ViewModel.SelectedSeries.Overview, Mode=OneWay}"
                                                   Style="{StaticResource KroiraBodyStyle}"
                                                   FontSize="12"
                                                   MaxLines="3"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="1" Spacing="8">
                            <TextBlock Text="SEASON" Style="{StaticResource KroiraLabelStyle}" />
                            <ComboBox Style="{StaticResource KroiraFilterComboBoxStyle}"
                                      ItemsSource="{x:Bind ViewModel.SelectedSeries.Seasons, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedSeason, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SeasonNumber, Converter={StaticResource SeasonPrefixConverter}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Spacing="10">
                            <TextBlock Text="{x:Bind ViewModel.SelectedSeriesStatus, Mode=OneWay}"
                                       Visibility="{x:Bind ViewModel.SelectedSeriesStatusVisibility, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                            <Button Content="Play selected episode"
                                    Visibility="{x:Bind ViewModel.SelectedEpisodePlayVisibility, Mode=OneWay}"
                                    Click="PlaySelectedEpisode_Click"
                                    Style="{StaticResource KroiraPrimaryButtonStyle}"
                                    HorizontalAlignment="Left" />
                        </StackPanel>

                        <TextBlock Grid.Row="3"
                                   Text="EPISODES"
                                   Style="{StaticResource KroiraLabelStyle}"
                                   Margin="0,4,0,0" />

                        <ListView Grid.Row="4"
                                  ItemsSource="{x:Bind ViewModel.SelectedSeason.Episodes, Mode=OneWay}"
                                  SelectionMode="Single"
                                  SelectionChanged="EpisodeList_SelectionChanged"
                                  ItemContainerStyle="{StaticResource SeriesEpisodeRowStyle}"
                                  ScrollViewer.VerticalScrollMode="Enabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollMode="Disabled"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource KroiraSurfaceSoftBrush}"
                                            CornerRadius="8"
                                            Padding="13,10">
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding EpisodeNumber}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                       VerticalAlignment="Center"
                                                       MinWidth="22" />

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Title}"
                                                       Style="{StaticResource KroiraTitleStyle}"
                                                       FontSize="13"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />

                                            <FontIcon Grid.Column="2"
                                                      Glyph="&#xE768;"
                                                      FontSize="12"
                                                      Foreground="{StaticResource KroiraAccentBrush}"
                                                      VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
