<Page
    x:Class="Kroira.App.Views.SeriesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Kroira.App.Views"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Page.Resources>
        <local:NullToCollapsedConverter x:Key="NullToCollapsedConverter" />
        <local:SeasonPrefixConverter x:Key="SeasonPrefixConverter" />
        <local:EpisodePrefixConverter x:Key="EpisodePrefixConverter" />
    </Page.Resources>
    <Grid Padding="28" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource KroiraPanelStyle}">
            <StackPanel Spacing="16">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Series" Style="{StaticResource KroiraPageTitleStyle}" />
                        <TextBlock Text="Explore shows, seasons, and episodes from your VOD sources." Style="{StaticResource KroiraPageSubtitleStyle}" Margin="0,4,0,0" />
                    </StackPanel>
                    <Border HorizontalAlignment="Right" VerticalAlignment="Center" Background="#221F42" BorderBrush="{StaticResource KroiraBorderStrongBrush}" BorderThickness="1" CornerRadius="999" Padding="12,5">
                        <TextBlock Text="Episodes" Foreground="{StaticResource KroiraAccentBrush}" FontSize="12" FontWeight="SemiBold" />
                    </Border>
                </Grid>
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250" />
                        <ColumnDefinition Width="*" MaxWidth="420" />
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" Style="{StaticResource KroiraComboBoxStyle}" ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}" DisplayMemberPath="Name" HorizontalAlignment="Stretch" />
                    <TextBox Grid.Column="1" Style="{StaticResource KroiraTextBoxStyle}" Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Search series..." HorizontalAlignment="Stretch" />
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}" Style="{StaticResource KroiraPanelStyle}" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="460">
            <StackPanel Spacing="10">
                <FontIcon Glyph="&#xE8A9;" Foreground="{StaticResource KroiraAccentBrush}" FontSize="30" HorizontalAlignment="Left" />
                <TextBlock Text="No series imported yet" Style="{StaticResource KroiraSectionTitleStyle}" />
                <TextBlock Text="Sync an Xtream VOD source to start browsing shows and episodes." Style="{StaticResource KroiraPageSubtitleStyle}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="380" />
            </Grid.ColumnDefinitions>

            <!-- Left: Series Grid -->
            <GridView Grid.Column="0" ItemsSource="{x:Bind ViewModel.FilteredSeries, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedSeries, Mode=TwoWay}" SelectionMode="Single">
                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem">
                        <Setter Property="Margin" Value="0,0,12,14" />
                    </Style>
                </GridView.ItemContainerStyle>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="150" Height="234" CornerRadius="18" BorderBrush="{StaticResource KroiraBorderBrush}" BorderThickness="1">
                            <Grid.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1A1F35" Offset="0" />
                                    <GradientStop Color="#0F151F" Offset="1" />
                                </LinearGradientBrush>
                            </Grid.Background>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            
                            <Grid Grid.Row="0" Background="{StaticResource KroiraMediaGradientBrush}">
                                <Border Margin="11" CornerRadius="15" BorderBrush="#46B7B2FF" BorderThickness="1" Opacity="0.72">
                                    <Grid>
                                        <FontIcon Glyph="&#xE8A9;" Foreground="{StaticResource KroiraAccentBrush}" FontSize="28" Opacity="0.52" />
                                        <Border Width="56" Height="4" Background="{StaticResource KroiraGoldBrush}" CornerRadius="2" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="13,0,0,15" Opacity="0.72" />
                                        <Border Width="94" Height="4" Background="#40FFFFFF" CornerRadius="2" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="13,0,0,15" Opacity="0.22" />
                                    </Grid>
                                </Border>
                                <Image Source="{Binding PosterUrl, Converter={StaticResource UrlToImageSourceConverter}}" Stretch="UniformToFill" />
                            </Grid>

                            <StackPanel Grid.Row="1" Padding="10,9,10,10" Background="#E00F141D" Spacing="5">
                                <TextBlock Text="{Binding Title}" TextWrapping="Wrap" MaxLines="2" FontWeight="SemiBold" FontSize="11" Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                                <Border Background="#241F42" BorderBrush="#38B7B2FF" BorderThickness="1" CornerRadius="999" Padding="7,2" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding CategoryName}" Foreground="{StaticResource KroiraTextSecondaryBrush}" FontSize="9" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <!-- Right: Details Panel -->
            <Border Grid.Column="1" Style="{StaticResource KroiraPanelStyle}" Visibility="{x:Bind ViewModel.SelectedSeries, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Spacing="8">
                        <TextBlock Text="{x:Bind ViewModel.SelectedSeries.Title, Mode=OneWay}" Style="{StaticResource KroiraSectionTitleStyle}" TextWrapping="Wrap" />
                        <TextBlock Text="Seasons" FontWeight="SemiBold" Margin="0,16,0,0" Foreground="{StaticResource KroiraTextPrimaryBrush}" />

                        <ComboBox Style="{StaticResource KroiraComboBoxStyle}" ItemsSource="{x:Bind ViewModel.SelectedSeries.Seasons, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedSeason, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SeasonNumber, Converter={StaticResource SeasonPrefixConverter}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="{x:Bind ViewModel.SelectedSeriesStatus, Mode=OneWay}"
                                   Visibility="{x:Bind ViewModel.SelectedSeriesStatusVisibility, Mode=OneWay}"
                                   Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                        <Button Content="Play selected episode"
                                Visibility="{x:Bind ViewModel.SelectedEpisodePlayVisibility, Mode=OneWay}"
                                Click="PlaySelectedEpisode_Click"
                                Style="{StaticResource KroiraPrimaryButtonStyle}"
                                HorizontalAlignment="Left" />
                    </StackPanel>

                    <TextBlock Grid.Row="1" Text="Episodes" FontWeight="SemiBold" Margin="0,16,0,8" Foreground="{StaticResource KroiraTextPrimaryBrush}" />

                    <ListView Grid.Row="2" ItemsSource="{x:Bind ViewModel.SelectedSeason.Episodes, Mode=OneWay}" SelectionMode="Single" SelectionChanged="EpisodeList_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Padding="10,6">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                                    <TextBlock Text="{Binding EpisodeNumber, Converter={StaticResource EpisodePrefixConverter}}" Foreground="{StaticResource KroiraTextSecondaryBrush}" FontSize="12" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
