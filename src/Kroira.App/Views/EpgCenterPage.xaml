<Page
    x:Class="Kroira.App.Views.EpgCenterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Kroira.App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Kroira.App.ViewModels"
    Background="{StaticResource KroiraPageBackgroundBrush}"
    mc:Ignorable="d">

    <Grid XYFocusKeyboardNavigation="Enabled">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <controls:AmbientPageBackground Grid.RowSpan="2" />

        <Grid Padding="28,24,28,12" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock Text="EPG Center" Style="{StaticResource KroiraPageTitleStyle}" />
                <TextBlock Text="{x:Bind ViewModel.HeadlineText, Mode=OneWay}"
                           Style="{StaticResource KroiraBodyStyle}"
                           Foreground="{StaticResource KroiraTextSecondaryBrush}"
                           TextWrapping="WrapWholeWords" />
                <StackPanel Orientation="Horizontal" Spacing="14">
                    <TextBlock Text="{x:Bind ViewModel.LastSyncText, Mode=OneWay}"
                               Style="{StaticResource KroiraMetaStyle}"
                               Foreground="{StaticResource KroiraTextTertiaryBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.LastSuccessText, Mode=OneWay}"
                               Style="{StaticResource KroiraMetaStyle}"
                               Foreground="{StaticResource KroiraTextTertiaryBrush}" />
                </StackPanel>
            </StackPanel>
            <Button x:Name="RefreshButton"
                    Grid.Column="1"
                    MinWidth="132"
                    VerticalAlignment="Top"
                    Click="Refresh_Click"
                    IsEnabled="{x:Bind ViewModel.IsRefreshEnabled, Mode=OneWay}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                    <TextBlock Text="{x:Bind ViewModel.BusyText, Mode=OneWay}" />
                </StackPanel>
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1" Padding="28,0,28,28">
            <StackPanel Spacing="18">
                <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                           Style="{StaticResource KroiraBodyStyle}"
                           TextWrapping="WrapWholeWords" />
                <TextBlock Text="{x:Bind ViewModel.RefreshProgressText, Mode=OneWay}"
                           Visibility="{x:Bind ViewModel.RefreshProgressVisibility, Mode=OneWay}"
                           Style="{StaticResource KroiraMetaStyle}"
                           Foreground="{StaticResource KroiraTextSecondaryBrush}"
                           TextWrapping="WrapWholeWords" />

                <Border Padding="18"
                        CornerRadius="18"
                        Background="#42101827"
                        BorderBrush="{StaticResource KroiraChromeLineBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="12">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="3">
                                <TextBlock Text="Guide Timeline" Style="{StaticResource KroiraSectionTitleStyle}" />
                                <TextBlock Text="{x:Bind ViewModel.GuideRangeText, Mode=OneWay}"
                                           Style="{StaticResource KroiraMetaStyle}"
                                           Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Button Click="JumpGuideToNow_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE121;" FontSize="14" />
                                        <TextBlock Text="Jump to Now" />
                                    </StackPanel>
                                </Button>
                                <Button Click="RefreshGuideTimeline_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE72C;" FontSize="14" />
                                        <TextBlock Text="Reload" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="1.4*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Header="Source"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{x:Bind ViewModel.GuideSourceFilterOptions, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedGuideSourceFilter, Mode=TwoWay}"
                                      MinWidth="220" />
                            <ComboBox Grid.Column="1"
                                      Header="Category"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{x:Bind ViewModel.GuideCategoryOptions, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedGuideCategoryOption, Mode=TwoWay}"
                                      MinWidth="220" />
                            <TextBox Grid.Column="2"
                                     Header="Search"
                                     PlaceholderText="Filter channels, categories, or sources"
                                     Text="{x:Bind ViewModel.GuideSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <TextBlock Text="{x:Bind ViewModel.GuideStaleWarningText, Mode=OneWay}"
                                   Visibility="{x:Bind ViewModel.GuideStaleWarningVisibility, Mode=OneWay}"
                                   Style="{StaticResource KroiraBodyStyle}"
                                   Foreground="{StaticResource KroiraStateWarningBrush}"
                                   TextWrapping="WrapWholeWords" />
                        <TextBlock Text="Loading guide timeline..."
                                   Visibility="{x:Bind ViewModel.GuideTimelineBusyVisibility, Mode=OneWay}"
                                   Style="{StaticResource KroiraMetaStyle}"
                                   Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                        <TextBlock Text="No guide programmes are available for the selected filters and time range."
                                   Visibility="{x:Bind ViewModel.GuideTimelineEmptyVisibility, Mode=OneWay}"
                                   Style="{StaticResource KroiraBodyStyle}"
                                   Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                   TextWrapping="WrapWholeWords" />

                        <ScrollViewer HorizontalScrollMode="Enabled"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollMode="Enabled"
                                      VerticalScrollBarVisibility="Auto"
                                      MaxHeight="640">
                            <StackPanel Spacing="0">
                                <Grid Height="34">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="230" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Channel"
                                               VerticalAlignment="Center"
                                               Style="{StaticResource KroiraMetaStyle}"
                                               Foreground="{StaticResource KroiraTextTertiaryBrush}" />
                                    <Grid Grid.Column="1" Width="{x:Bind ViewModel.GuideTimelineWidth, Mode=OneWay}">
                                        <ItemsControl ItemsSource="{x:Bind ViewModel.GuideTimelineSlots, Mode=OneWay}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:GuideTimelineSlotViewModel">
                                                    <Border Width="{x:Bind Width}"
                                                            BorderBrush="{StaticResource KroiraBorderBrush}"
                                                            BorderThickness="1,0,0,1"
                                                            Padding="8,0">
                                                        <TextBlock Text="{x:Bind Label}"
                                                                   VerticalAlignment="Center"
                                                                   Style="{StaticResource KroiraMetaStyle}"
                                                                   Foreground="{StaticResource KroiraTextTertiaryBrush}" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Canvas Width="{x:Bind ViewModel.GuideTimelineWidth, Mode=OneWay}"
                                                Height="34"
                                                IsHitTestVisible="False">
                                            <Border Canvas.Left="{x:Bind ViewModel.GuideNowMarkerLeft, Mode=OneWay}"
                                                    Width="2"
                                                    Height="34"
                                                    Background="{StaticResource KroiraAccentBrush}"
                                                    Visibility="{x:Bind ViewModel.GuideNowMarkerVisibility, Mode=OneWay}" />
                                        </Canvas>
                                    </Grid>
                                </Grid>

                                <ItemsControl ItemsSource="{x:Bind ViewModel.GuideTimelineRows, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:GuideTimelineChannelViewModel">
                                            <Border Height="76"
                                                    BorderBrush="{StaticResource KroiraBorderBrush}"
                                                    BorderThickness="0,0,0,1">
                                                <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="230" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Button Padding="0"
                                                        Height="76"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Click="TimelineChannel_Click"
                                                        CommandParameter="{Binding}">
                                                    <Grid Padding="0,8,12,8" ColumnSpacing="10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="42" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border Width="38"
                                                                Height="38"
                                                                CornerRadius="6"
                                                                Background="#2AFFFFFF">
                                                            <Image Source="{Binding LogoUrl, Converter={StaticResource UrlToImageSourceConverter}}" Stretch="UniformToFill" />
                                                        </Border>
                                                        <StackPanel Grid.Column="1" Spacing="2">
                                                            <TextBlock Text="{x:Bind ChannelName}"
                                                                       FontWeight="SemiBold"
                                                                       MaxLines="2"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Text="{x:Bind CategoryName}"
                                                                       Style="{StaticResource KroiraMetaStyle}"
                                                                       Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                                       MaxLines="1"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Text="{x:Bind CurrentText}"
                                                                       Style="{StaticResource KroiraMetaStyle}"
                                                                       Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                                                       MaxLines="1"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Button>

                                                <Grid Grid.Column="1"
                                                      Width="{x:Bind TimelineWidth}"
                                                      Height="76"
                                                      Background="#18000000">
                                                    <TextBlock Text="No guide in this range"
                                                               Visibility="{x:Bind EmptyGuideVisibility}"
                                                               Margin="12,0,0,0"
                                                               VerticalAlignment="Center"
                                                               Style="{StaticResource KroiraMetaStyle}"
                                                               Foreground="{StaticResource KroiraTextTertiaryBrush}" />
                                                    <ItemsControl ItemsSource="{x:Bind Programs}"
                                                                  Width="{x:Bind TimelineWidth}"
                                                                  Height="76">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <Canvas Height="76" />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemContainerStyle>
                                                            <Style TargetType="ContentPresenter">
                                                                <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                                            </Style>
                                                        </ItemsControl.ItemContainerStyle>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:GuideTimelineProgramViewModel">
                                                                <Button Width="{x:Bind Width}"
                                                                        MinWidth="0"
                                                                        Height="54"
                                                                        Margin="0,10,0,10"
                                                                        Padding="6,4"
                                                                        Background="#4E111827"
                                                                        BorderBrush="{StaticResource KroiraChromeLineBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="9"
                                                                        HorizontalContentAlignment="Stretch"
                                                                        VerticalContentAlignment="Stretch"
                                                                        Click="TimelineProgram_Click"
                                                                        CommandParameter="{Binding}"
                                                                        ToolTipService.ToolTip="{x:Bind ToolTipText}">
                                                                    <Grid>
                                                                        <FontIcon Glyph="&#xE121;"
                                                                                  FontSize="9"
                                                                                  Foreground="{StaticResource KroiraAccentBrush}"
                                                                                  HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"
                                                                                  Visibility="{x:Bind CompactGlyphVisibility}" />
                                                                    <StackPanel Spacing="1"
                                                                                Visibility="{x:Bind TitleVisibility}">
                                                                        <TextBlock Text="{x:Bind Title}"
                                                                                   FontWeight="SemiBold"
                                                                                   FontSize="12"
                                                                                   MaxLines="{x:Bind TitleMaxLines}"
                                                                                   TextTrimming="CharacterEllipsis" />
                                                                        <TextBlock Text="{x:Bind TimeText}"
                                                                                   Style="{StaticResource KroiraMetaStyle}"
                                                                                   Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                                                                   MaxLines="1"
                                                                                   Visibility="{x:Bind TimeVisibility}"
                                                                                   TextTrimming="CharacterEllipsis" />
                                                                        <TextBlock Text="{x:Bind DetailText}"
                                                                                   Style="{StaticResource KroiraMetaStyle}"
                                                                                   Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                                                   MaxLines="1"
                                                                                   Visibility="{x:Bind DetailVisibility}"
                                                                                   TextTrimming="CharacterEllipsis" />
                                                                    </StackPanel>
                                                                    </Grid>
                                                                </Button>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <Canvas Width="{x:Bind TimelineWidth}"
                                                            Height="76"
                                                            IsHitTestVisible="False">
                                                        <Border Canvas.Left="{x:Bind NowMarkerLeft}"
                                                                Width="2"
                                                                Height="76"
                                                                Background="{StaticResource KroiraAccentBrush}"
                                                                Visibility="{x:Bind NowMarkerVisibility}" />
                                                    </Canvas>
                                                </Grid>
                                            </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <Border Padding="16"
                        CornerRadius="8"
                        Background="{StaticResource KroiraSurfaceBrush}"
                        BorderBrush="{StaticResource KroiraBorderBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Manual EPG Matching" Style="{StaticResource KroiraSectionTitleStyle}" />
                        <TextBlock Text="{x:Bind ViewModel.ManualMatchStatusText, Mode=OneWay}"
                                   Visibility="{x:Bind ViewModel.ManualMatchStatusVisibility, Mode=OneWay}"
                                   Style="{StaticResource KroiraBodyStyle}"
                                   Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                   TextWrapping="WrapWholeWords" />
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="1.4*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Header="Source"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{x:Bind ViewModel.SourceOptions, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedSourceOption, Mode=TwoWay}"
                                      MinWidth="220" />
                            <ComboBox Grid.Column="1"
                                      Header="Channel"
                                      DisplayMemberPath="DisplayName"
                                      ItemsSource="{x:Bind ViewModel.ManualMatchChannels, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedManualMatchChannel, Mode=TwoWay}"
                                      MinWidth="280" />
                            <TextBox Grid.Column="2"
                                     Header="XMLTV channel search"
                                     PlaceholderText="Search display name or enter an exact XMLTV id"
                                     Text="{x:Bind ViewModel.ManualMatchSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="3"
                                    Margin="0,28,0,0"
                                    Click="ClearManualOverride_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE711;" FontSize="14" />
                                    <TextBlock Text="Clear Override" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <TextBlock Text="Searching matches..."
                                   Visibility="{x:Bind ViewModel.ManualMatchBusyVisibility, Mode=OneWay}"
                                   Style="{StaticResource KroiraMetaStyle}"
                                   Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                        <ListView ItemsSource="{x:Bind ViewModel.ManualMatchCandidates, Mode=OneWay}"
                                  MaxHeight="300"
                                  IsItemClickEnabled="False">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:ManualMatchCandidateViewModel">
                                    <Grid Padding="8" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{x:Bind DisplayName}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="WrapWholeWords" />
                                            <TextBlock Text="{x:Bind XmltvChannelId}"
                                                       Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                                       TextWrapping="WrapWholeWords" />
                                            <TextBlock Text="{x:Bind MatchText}"
                                                       Foreground="{StaticResource KroiraTextTertiaryBrush}" />
                                            <TextBlock Text="{x:Bind DetailText}"
                                                       Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                       TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Click="SetManualOverride_Click"
                                                CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE73E;" FontSize="14" />
                                                <TextBlock Text="Set Override" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border Padding="16"
                        CornerRadius="8"
                        Background="{StaticResource KroiraSurfaceBrush}"
                        BorderBrush="{StaticResource KroiraBorderBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Public Guide Source" Style="{StaticResource KroiraSectionTitleStyle}" />
                        <Grid ColumnSpacing="12" RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="1.3*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Header="Source"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{x:Bind ViewModel.SourceOptions, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedSourceOption, Mode=TwoWay}"
                                      IsEnabled="{x:Bind ViewModel.HasPublicGuideConfigSources, Mode=OneWay}"
                                      MinWidth="220" />
                            <ComboBox Grid.Column="1"
                                      Header="Mode"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{x:Bind ViewModel.PublicGuideAddModes, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedPublicGuideAddMode, Mode=TwoWay}"
                                      IsEnabled="{x:Bind ViewModel.HasPublicGuideConfigSources, Mode=OneWay}"
                                      MinWidth="240" />
                            <Button Grid.Column="2"
                                    Margin="0,28,0,0"
                                    MinWidth="112"
                                    Click="AddPresetGuide_Click"
                                    IsEnabled="{x:Bind ViewModel.CanAddPublicGuidePresetMode, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE710;" FontSize="14" />
                                    <TextBlock Text="{x:Bind ViewModel.PublicGuideActionText, Mode=OneWay}" />
                                </StackPanel>
                            </Button>
                            <ComboBox Grid.Row="1"
                                      Grid.ColumnSpan="2"
                                      Header="IPTV-EPG.org country"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{x:Bind ViewModel.PublicGuidePresets, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedPublicGuidePreset, Mode=TwoWay}"
                                      Visibility="{x:Bind ViewModel.SingleCountryPresetVisibility, Mode=OneWay}"
                                      MinWidth="240" />
                            <StackPanel Grid.Row="2"
                                        Grid.ColumnSpan="3"
                                        Spacing="4">
                                <TextBlock Text="{x:Bind ViewModel.PublicGuideModeDescriptionText, Mode=OneWay}"
                                           Style="{StaticResource KroiraMetaStyle}"
                                           Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                           TextWrapping="WrapWholeWords" />
                                <TextBlock Text="{x:Bind ViewModel.PublicGuidePresetPreviewText, Mode=OneWay}"
                                           Style="{StaticResource KroiraMetaStyle}"
                                           Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                           TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <StackPanel Grid.Row="3"
                                        Grid.ColumnSpan="3"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                <Button Click="ReplaceWithAutoDetected_Click"
                                        IsEnabled="{x:Bind ViewModel.CanManagePublicGuidePresets, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE8B3;" FontSize="14" />
                                        <TextBlock Text="Replace with Auto-Detected" />
                                    </StackPanel>
                                </Button>
                                <Button Click="ClearPublicGuidePresets_Click"
                                        IsEnabled="{x:Bind ViewModel.CanManagePublicGuidePresets, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                        <TextBlock Text="Clear IPTV-EPG.org Presets" />
                                    </StackPanel>
                                </Button>
                                <Button Click="ClearReviewDecisions_Click"
                                        IsEnabled="{x:Bind ViewModel.CanManageReviewDecisions, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE711;" FontSize="14" />
                                        <TextBlock Text="Clear Review Decisions" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                            <TextBox Grid.Row="4"
                                     Grid.ColumnSpan="2"
                                     Header="Public XMLTV URL"
                                     PlaceholderText="https://iptv-epg.org/files/epg-tr.xml"
                                     Text="{x:Bind ViewModel.CustomPublicGuideUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Row="4"
                                    Grid.Column="2"
                                    Margin="0,28,0,0"
                                    MinWidth="112"
                                    Click="AddCustomGuide_Click"
                                    IsEnabled="{x:Bind ViewModel.CanAddCustomPublicGuide, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE710;" FontSize="14" />
                                    <TextBlock Text="Add URL" />
                                </StackPanel>
                            </Button>
                        </Grid>
                        <TextBlock Text="{x:Bind ViewModel.AddPublicGuideStatusText, Mode=OneWay}"
                                   Visibility="{x:Bind ViewModel.AddPublicGuideStatusVisibility, Mode=OneWay}"
                                   Style="{StaticResource KroiraMetaStyle}"
                                   Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                   TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{x:Bind ViewModel.SummaryCards, Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="3" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:EpgSummaryCardViewModel">
                            <Border Width="250"
                                    MinHeight="112"
                                    Margin="0,0,12,12"
                                    Padding="16"
                                    CornerRadius="8"
                                    Background="{StaticResource KroiraSurfaceBrush}"
                                    BorderBrush="{StaticResource KroiraBorderBrush}"
                                    BorderThickness="1">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{x:Bind Label}" Style="{StaticResource KroiraMetaStyle}" Foreground="{StaticResource KroiraTextTertiaryBrush}" />
                                    <TextBlock Text="{x:Bind Value}" FontSize="28" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind Detail}" Style="{StaticResource KroiraBodyStyle}" Foreground="{StaticResource KroiraTextSecondaryBrush}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Spacing="8" Visibility="{x:Bind ViewModel.WarningListVisibility, Mode=OneWay}">
                    <TextBlock Text="Warnings" Style="{StaticResource KroiraSectionTitleStyle}" />
                    <ListView ItemsSource="{x:Bind ViewModel.Warnings, Mode=OneWay}" IsItemClickEnabled="False">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="WrapWholeWords" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Text="Guide Sources" Style="{StaticResource KroiraSectionTitleStyle}" />
                    <TextBlock Text="No EPG sources have been configured or detected yet."
                               Visibility="{x:Bind ViewModel.EmptySourcesVisibility, Mode=OneWay}"
                               Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                    <ListView ItemsSource="{x:Bind ViewModel.GuideSources, Mode=OneWay}" IsItemClickEnabled="False">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:EpgSourceStatusViewModel">
                                <Border Padding="12"
                                        Margin="0,0,0,8"
                                        CornerRadius="8"
                                        Background="{StaticResource KroiraSurfaceBrush}"
                                        BorderBrush="{StaticResource KroiraBorderBrush}"
                                        BorderThickness="1">
                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.25*" />
                                            <ColumnDefinition Width="1.35*" />
                                            <ColumnDefinition Width="2*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="{x:Bind SourceName}" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                                            <TextBlock Text="{x:Bind GuideSourceName}" TextWrapping="WrapWholeWords" />
                                            <TextBlock Text="{x:Bind StatusText}" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                                            <TextBlock Text="{x:Bind CoverageText}" Foreground="{StaticResource KroiraTextTertiaryBrush}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="3">
                                            <TextBlock Text="{x:Bind SyncText}" TextWrapping="WrapWholeWords" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                                            <TextBlock Text="{x:Bind WarningText}" Visibility="{x:Bind WarningVisibility}" TextWrapping="WrapWholeWords" Foreground="{StaticResource KroiraStateWarningBrush}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{x:Bind SourceText}" TextWrapping="WrapWholeWords" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Unmatched Channels" Style="{StaticResource KroiraSectionTitleStyle}" />
                        <TextBox PlaceholderText="Search unmatched channels"
                                 Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="No unmatched channels found."
                                   Visibility="{x:Bind ViewModel.EmptyUnmatchedVisibility, Mode=OneWay}"
                                   Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                        <ListView ItemsSource="{x:Bind ViewModel.UnmatchedChannels, Mode=OneWay}" MaxHeight="420" IsItemClickEnabled="False">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:EpgChannelCoverageViewModel">
                                    <StackPanel Padding="6" Spacing="2">
                                        <TextBlock Text="{x:Bind ChannelName}" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                                        <TextBlock Text="{x:Bind SourceName}" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                                        <TextBlock Text="{x:Bind DetailText}" Foreground="{StaticResource KroiraTextTertiaryBrush}" TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="8">
                        <TextBlock Text="Weak Matches" Style="{StaticResource KroiraSectionTitleStyle}" />
                        <TextBox PlaceholderText="Search weak matches"
                                 Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="No weak matches found."
                                   Visibility="{x:Bind ViewModel.EmptyWeakVisibility, Mode=OneWay}"
                                   Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                        <ListView ItemsSource="{x:Bind ViewModel.WeakMatches, Mode=OneWay}" MaxHeight="420" IsItemClickEnabled="False">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:EpgChannelCoverageViewModel">
                                    <StackPanel Padding="6" Spacing="2">
                                        <TextBlock Text="{x:Bind ChannelName}" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                                        <TextBlock Text="{x:Bind SourceName}" Foreground="{StaticResource KroiraTextSecondaryBrush}" TextWrapping="WrapWholeWords" />
                                        <TextBlock Text="{x:Bind CategoryName}" Foreground="{StaticResource KroiraTextTertiaryBrush}" TextWrapping="WrapWholeWords" />
                                        <TextBlock Text="{x:Bind ProposedGuideText}" Foreground="{StaticResource KroiraTextSecondaryBrush}" TextWrapping="WrapWholeWords" />
                                        <TextBlock Text="{x:Bind MatchText}" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                                        <TextBlock Text="{x:Bind ReviewStatusText}" Foreground="{StaticResource KroiraStateWarningBrush}" TextWrapping="WrapWholeWords" />
                                        <TextBlock Text="{x:Bind WeakReasonText}" Foreground="{StaticResource KroiraTextTertiaryBrush}" TextWrapping="WrapWholeWords" />
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8"
                                                    Margin="0,6,0,0"
                                                    Visibility="{x:Bind ReviewActionsVisibility}">
                                            <Button Content="Approve"
                                                    Click="ApproveWeakMatch_Click"
                                                    CommandParameter="{x:Bind}"
                                                    Visibility="{x:Bind ApproveVisibility}" />
                                            <Button Content="Reject"
                                                    Click="RejectWeakMatch_Click"
                                                    CommandParameter="{x:Bind}"
                                                    Visibility="{x:Bind RejectVisibility}" />
                                            <Button Content="Clear"
                                                    Click="ClearMappingDecision_Click"
                                                    CommandParameter="{x:Bind}"
                                                    Visibility="{x:Bind ClearDecisionVisibility}" />
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
