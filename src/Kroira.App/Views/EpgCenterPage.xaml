<Page
    x:Class="Kroira.App.Views.EpgCenterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Kroira.App.ViewModels"
    mc:Ignorable="d">

    <Grid XYFocusKeyboardNavigation="Enabled">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Padding="28,24,28,12" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock Text="EPG Center" Style="{StaticResource KroiraPageTitleStyle}" />
                <TextBlock Text="{x:Bind ViewModel.HeadlineText, Mode=OneWay}"
                           Style="{StaticResource KroiraBodyStyle}"
                           Foreground="{StaticResource KroiraTextSecondaryBrush}"
                           TextWrapping="WrapWholeWords" />
                <StackPanel Orientation="Horizontal" Spacing="14">
                    <TextBlock Text="{x:Bind ViewModel.LastSyncText, Mode=OneWay}"
                               Style="{StaticResource KroiraMetaStyle}"
                               Foreground="{StaticResource KroiraTextTertiaryBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.LastSuccessText, Mode=OneWay}"
                               Style="{StaticResource KroiraMetaStyle}"
                               Foreground="{StaticResource KroiraTextTertiaryBrush}" />
                </StackPanel>
            </StackPanel>
            <Button x:Name="RefreshButton"
                    Grid.Column="1"
                    MinWidth="132"
                    VerticalAlignment="Top"
                    Click="Refresh_Click"
                    IsEnabled="{x:Bind ViewModel.IsRefreshEnabled, Mode=OneWay}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                    <TextBlock Text="{x:Bind ViewModel.BusyText, Mode=OneWay}" />
                </StackPanel>
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1" Padding="28,0,28,28">
            <StackPanel Spacing="18">
                <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                           Style="{StaticResource KroiraBodyStyle}"
                           TextWrapping="WrapWholeWords" />
                <TextBlock Text="{x:Bind ViewModel.RefreshProgressText, Mode=OneWay}"
                           Visibility="{x:Bind ViewModel.RefreshProgressVisibility, Mode=OneWay}"
                           Style="{StaticResource KroiraMetaStyle}"
                           Foreground="{StaticResource KroiraTextSecondaryBrush}"
                           TextWrapping="WrapWholeWords" />

                <Border Padding="16"
                        CornerRadius="8"
                        Background="{StaticResource KroiraSurfaceBrush}"
                        BorderBrush="{StaticResource KroiraBorderBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Public Guide Source" Style="{StaticResource KroiraSectionTitleStyle}" />
                        <Grid ColumnSpacing="12" RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="1.3*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Header="Source"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{x:Bind ViewModel.SourceOptions, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedSourceOption, Mode=TwoWay}"
                                      IsEnabled="{x:Bind ViewModel.HasPublicGuideConfigSources, Mode=OneWay}"
                                      MinWidth="220" />
                            <ComboBox Grid.Column="1"
                                      Header="Mode"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{x:Bind ViewModel.PublicGuideAddModes, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedPublicGuideAddMode, Mode=TwoWay}"
                                      IsEnabled="{x:Bind ViewModel.HasPublicGuideConfigSources, Mode=OneWay}"
                                      MinWidth="240" />
                            <Button Grid.Column="2"
                                    Margin="0,28,0,0"
                                    MinWidth="112"
                                    Click="AddPresetGuide_Click"
                                    IsEnabled="{x:Bind ViewModel.CanAddPublicGuidePresetMode, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE710;" FontSize="14" />
                                    <TextBlock Text="{x:Bind ViewModel.PublicGuideActionText, Mode=OneWay}" />
                                </StackPanel>
                            </Button>
                            <ComboBox Grid.Row="1"
                                      Grid.ColumnSpan="2"
                                      Header="IPTV-EPG.org country"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{x:Bind ViewModel.PublicGuidePresets, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedPublicGuidePreset, Mode=TwoWay}"
                                      Visibility="{x:Bind ViewModel.SingleCountryPresetVisibility, Mode=OneWay}"
                                      MinWidth="240" />
                            <StackPanel Grid.Row="2"
                                        Grid.ColumnSpan="3"
                                        Spacing="4">
                                <TextBlock Text="{x:Bind ViewModel.PublicGuideModeDescriptionText, Mode=OneWay}"
                                           Style="{StaticResource KroiraMetaStyle}"
                                           Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                           TextWrapping="WrapWholeWords" />
                                <TextBlock Text="{x:Bind ViewModel.PublicGuidePresetPreviewText, Mode=OneWay}"
                                           Style="{StaticResource KroiraMetaStyle}"
                                           Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                           TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <StackPanel Grid.Row="3"
                                        Grid.ColumnSpan="3"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                <Button Click="ReplaceWithAutoDetected_Click"
                                        IsEnabled="{x:Bind ViewModel.CanManagePublicGuidePresets, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE8B3;" FontSize="14" />
                                        <TextBlock Text="Replace with Auto-Detected" />
                                    </StackPanel>
                                </Button>
                                <Button Click="ClearPublicGuidePresets_Click"
                                        IsEnabled="{x:Bind ViewModel.CanManagePublicGuidePresets, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                        <TextBlock Text="Clear IPTV-EPG.org Presets" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                            <TextBox Grid.Row="4"
                                     Grid.ColumnSpan="2"
                                     Header="Public XMLTV URL"
                                     PlaceholderText="https://iptv-epg.org/files/epg-tr.xml"
                                     Text="{x:Bind ViewModel.CustomPublicGuideUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Row="4"
                                    Grid.Column="2"
                                    Margin="0,28,0,0"
                                    MinWidth="112"
                                    Click="AddCustomGuide_Click"
                                    IsEnabled="{x:Bind ViewModel.CanAddCustomPublicGuide, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE710;" FontSize="14" />
                                    <TextBlock Text="Add URL" />
                                </StackPanel>
                            </Button>
                        </Grid>
                        <TextBlock Text="{x:Bind ViewModel.AddPublicGuideStatusText, Mode=OneWay}"
                                   Visibility="{x:Bind ViewModel.AddPublicGuideStatusVisibility, Mode=OneWay}"
                                   Style="{StaticResource KroiraMetaStyle}"
                                   Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                   TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{x:Bind ViewModel.SummaryCards, Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="3" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:EpgSummaryCardViewModel">
                            <Border Width="250"
                                    MinHeight="112"
                                    Margin="0,0,12,12"
                                    Padding="16"
                                    CornerRadius="8"
                                    Background="{StaticResource KroiraSurfaceBrush}"
                                    BorderBrush="{StaticResource KroiraBorderBrush}"
                                    BorderThickness="1">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{x:Bind Label}" Style="{StaticResource KroiraMetaStyle}" Foreground="{StaticResource KroiraTextTertiaryBrush}" />
                                    <TextBlock Text="{x:Bind Value}" FontSize="28" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind Detail}" Style="{StaticResource KroiraBodyStyle}" Foreground="{StaticResource KroiraTextSecondaryBrush}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Spacing="8" Visibility="{x:Bind ViewModel.WarningListVisibility, Mode=OneWay}">
                    <TextBlock Text="Warnings" Style="{StaticResource KroiraSectionTitleStyle}" />
                    <ListView ItemsSource="{x:Bind ViewModel.Warnings, Mode=OneWay}" IsItemClickEnabled="False">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="WrapWholeWords" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Text="Guide Sources" Style="{StaticResource KroiraSectionTitleStyle}" />
                    <TextBlock Text="No EPG sources have been configured or detected yet."
                               Visibility="{x:Bind ViewModel.EmptySourcesVisibility, Mode=OneWay}"
                               Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                    <ListView ItemsSource="{x:Bind ViewModel.GuideSources, Mode=OneWay}" IsItemClickEnabled="False">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:EpgSourceStatusViewModel">
                                <Border Padding="12"
                                        Margin="0,0,0,8"
                                        CornerRadius="8"
                                        Background="{StaticResource KroiraSurfaceBrush}"
                                        BorderBrush="{StaticResource KroiraBorderBrush}"
                                        BorderThickness="1">
                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.25*" />
                                            <ColumnDefinition Width="1.35*" />
                                            <ColumnDefinition Width="2*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="{x:Bind SourceName}" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                                            <TextBlock Text="{x:Bind GuideSourceName}" TextWrapping="WrapWholeWords" />
                                            <TextBlock Text="{x:Bind StatusText}" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                                            <TextBlock Text="{x:Bind CoverageText}" Foreground="{StaticResource KroiraTextTertiaryBrush}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="3">
                                            <TextBlock Text="{x:Bind SyncText}" TextWrapping="WrapWholeWords" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                                            <TextBlock Text="{x:Bind WarningText}" Visibility="{x:Bind WarningVisibility}" TextWrapping="WrapWholeWords" Foreground="{StaticResource KroiraStateWarningBrush}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{x:Bind SourceText}" TextWrapping="WrapWholeWords" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Unmatched Channels" Style="{StaticResource KroiraSectionTitleStyle}" />
                        <TextBox PlaceholderText="Search unmatched channels"
                                 Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="No unmatched channels found."
                                   Visibility="{x:Bind ViewModel.EmptyUnmatchedVisibility, Mode=OneWay}"
                                   Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                        <ListView ItemsSource="{x:Bind ViewModel.UnmatchedChannels, Mode=OneWay}" MaxHeight="420" IsItemClickEnabled="False">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:EpgChannelCoverageViewModel">
                                    <StackPanel Padding="6" Spacing="2">
                                        <TextBlock Text="{x:Bind ChannelName}" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                                        <TextBlock Text="{x:Bind SourceName}" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                                        <TextBlock Text="{x:Bind DetailText}" Foreground="{StaticResource KroiraTextTertiaryBrush}" TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="8">
                        <TextBlock Text="Weak Matches" Style="{StaticResource KroiraSectionTitleStyle}" />
                        <TextBox PlaceholderText="Search weak matches"
                                 Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="No weak matches found."
                                   Visibility="{x:Bind ViewModel.EmptyWeakVisibility, Mode=OneWay}"
                                   Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                        <ListView ItemsSource="{x:Bind ViewModel.WeakMatches, Mode=OneWay}" MaxHeight="420" IsItemClickEnabled="False">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:EpgChannelCoverageViewModel">
                                    <StackPanel Padding="6" Spacing="2">
                                        <TextBlock Text="{x:Bind ChannelName}" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                                        <TextBlock Text="{x:Bind ProposedGuideText}" Foreground="{StaticResource KroiraTextSecondaryBrush}" TextWrapping="WrapWholeWords" />
                                        <TextBlock Text="{x:Bind MatchText}" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                                        <TextBlock Text="{x:Bind ReviewStatusText}" Foreground="{StaticResource KroiraStateWarningBrush}" TextWrapping="WrapWholeWords" />
                                        <TextBlock Text="{x:Bind WeakReasonText}" Foreground="{StaticResource KroiraTextTertiaryBrush}" TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
