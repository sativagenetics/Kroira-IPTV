<Page
    x:Class="Kroira.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <ScrollViewer>
        <Grid Padding="28" RowSpacing="18" MaxWidth="760" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource KroiraPanelStyle}">
                <StackPanel>
                    <TextBlock Text="Settings" Style="{StaticResource KroiraPageTitleStyle}" />
                    <TextBlock Text="Licensing, app information, privacy, and support." Style="{StaticResource KroiraPageSubtitleStyle}" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource KroiraPanelStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Licensing Details" Style="{StaticResource KroiraSectionTitleStyle}" />
                    <TextBlock Text="Current Tier:" FontWeight="SemiBold" Foreground="{StaticResource KroiraTextSecondaryBrush}" />

                    <Grid>
                        <TextBlock Text="KROIRA PRO" Foreground="{StaticResource KroiraGoldBrush}" FontWeight="Bold" FontSize="20" Visibility="{x:Bind ViewModel.ProTierVisibility, Mode=OneWay}" />
                        <TextBlock Text="KROIRA FREE" Foreground="{StaticResource KroiraAccentBrush}" FontWeight="Bold" FontSize="20" Visibility="{x:Bind ViewModel.FreeTierVisibility, Mode=OneWay}" />
                    </Grid>

                    <TextBlock Text="{x:Bind ViewModel.LicenseStatusDescription, Mode=OneWay}" TextWrapping="Wrap" MaxWidth="620" Foreground="{StaticResource KroiraTextSecondaryBrush}" Margin="0,4,0,12" />

                    <Button Content="Upgrade to Pro"
                            Command="{x:Bind ViewModel.UpgradeCommand}"
                            Visibility="{x:Bind ViewModel.FreeTierVisibility, Mode=OneWay}"
                            Style="{StaticResource KroiraPrimaryButtonStyle}"
                            HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource KroiraPanelStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="App Information" Style="{StaticResource KroiraSectionTitleStyle}" />

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Version:" FontWeight="SemiBold" Foreground="{StaticResource KroiraTextSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.AppVersion, Mode=OneTime}" Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                    </StackPanel>

                    <HyperlinkButton Content="Privacy Policy" Command="{x:Bind ViewModel.OpenPrivacyPolicyCommand}" Foreground="{StaticResource KroiraAccentBrush}" />
                    <HyperlinkButton Content="Support &amp; Feedback" Command="{x:Bind ViewModel.OpenSupportCommand}" Foreground="{StaticResource KroiraAccentBrush}" />

                    <TextBlock Text="2026 KROIRA. All rights reserved." Foreground="{StaticResource KroiraTextTertiaryBrush}" FontSize="12" Margin="0,16,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
