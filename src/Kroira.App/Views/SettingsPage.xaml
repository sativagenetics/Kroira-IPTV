<Page
    x:Class="Kroira.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <ScrollViewer>
        <Grid
            Padding="28"
            RowSpacing="22"
            MaxWidth="1040"
            HorizontalAlignment="Left"
            Background="{StaticResource KroiraPageAtmosphereBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="4">
                <TextBlock Text="Settings" Style="{StaticResource KroiraPageTitleStyle}" />
                <TextBlock
                    Text="Manage account status, app language, product information, privacy, and support."
                    Style="{StaticResource KroiraPageSubtitleStyle}"
                    MaxWidth="720" />
            </StackPanel>

            <Grid Grid.Row="1" ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.45*" />
                    <ColumnDefinition Width="0.95*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="16">
                    <Border Style="{StaticResource KroiraSettingsGroupStyle}">
                        <StackPanel Spacing="14">
                            <StackPanel Spacing="3">
                                <TextBlock Text="Account" Style="{StaticResource KroiraSectionTitleStyle}" />
                                <TextBlock
                                    Text="License status and available product tier."
                                    Style="{StaticResource KroiraBodyStyle}" />
                            </StackPanel>

                            <Border Style="{StaticResource KroiraSettingsRowStyle}">
                                <Grid ColumnSpacing="18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Current tier" Style="{StaticResource KroiraTitleStyle}" />
                                        <TextBlock
                                            Text="{x:Bind ViewModel.LicenseStatusDescription, Mode=OneWay}"
                                            Style="{StaticResource KroiraBodyStyle}"
                                            MaxWidth="560" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Spacing="8" MinWidth="150" HorizontalAlignment="Right">
                                        <Border
                                            Visibility="{x:Bind ViewModel.ProTierVisibility, Mode=OneWay}"
                                            Background="{StaticResource KroiraSurfaceHighBrush}"
                                            CornerRadius="8"
                                            Padding="12,8">
                                            <TextBlock
                                                Text="KROIRA PRO"
                                                Foreground="{StaticResource KroiraGoldBrush}"
                                                FontWeight="SemiBold"
                                                FontSize="13"
                                                HorizontalAlignment="Center" />
                                        </Border>

                                        <Border
                                            Visibility="{x:Bind ViewModel.FreeTierVisibility, Mode=OneWay}"
                                            Background="{StaticResource KroiraSurfaceHighBrush}"
                                            CornerRadius="8"
                                            Padding="12,8">
                                            <TextBlock
                                                Text="KROIRA FREE"
                                                Foreground="{StaticResource KroiraAccentBrush}"
                                                FontWeight="SemiBold"
                                                FontSize="13"
                                                HorizontalAlignment="Center" />
                                        </Border>

                                        <Button
                                            Content="Upgrade to Pro"
                                            Command="{x:Bind ViewModel.UpgradeCommand}"
                                            Visibility="{x:Bind ViewModel.FreeTierVisibility, Mode=OneWay}"
                                            Style="{StaticResource KroiraPrimaryButtonStyle}"
                                            HorizontalAlignment="Stretch" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KroiraSettingsGroupStyle}">
                        <StackPanel Spacing="14">
                            <StackPanel Spacing="3">
                                <TextBlock Text="Application" Style="{StaticResource KroiraSectionTitleStyle}" />
                                <TextBlock
                                    Text="Local preferences that affect catalog presentation."
                                    Style="{StaticResource KroiraBodyStyle}" />
                            </StackPanel>

                            <Border Style="{StaticResource KroiraSettingsRowStyle}">
                                <Grid ColumnSpacing="18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="260" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="App language" Style="{StaticResource KroiraTitleStyle}" />
                                        <TextBlock
                                            Text="{x:Bind ViewModel.LanguageStatusText, Mode=OneWay}"
                                            Style="{StaticResource KroiraBodyStyle}"
                                            MaxWidth="520" />
                                    </StackPanel>

                                    <ComboBox
                                        Grid.Column="1"
                                        Style="{StaticResource KroiraComboBoxStyle}"
                                        ItemsSource="{x:Bind ViewModel.Languages, Mode=OneWay}"
                                        SelectedItem="{x:Bind ViewModel.SelectedLanguage, Mode=TwoWay}"
                                        DisplayMemberPath="DisplayName"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="16">
                    <Border Style="{StaticResource KroiraSettingsGroupStyle}">
                        <StackPanel Spacing="14">
                            <StackPanel Spacing="3">
                                <TextBlock Text="Product" Style="{StaticResource KroiraSectionTitleStyle}" />
                                <TextBlock
                                    Text="Installed build and official links."
                                    Style="{StaticResource KroiraBodyStyle}" />
                            </StackPanel>

                            <Border Style="{StaticResource KroiraSettingsRowStyle}">
                                <Grid ColumnSpacing="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="Version" Style="{StaticResource KroiraTitleStyle}" />
                                        <TextBlock
                                            Text="Current installed application package."
                                            Style="{StaticResource KroiraBodyStyle}" />
                                    </StackPanel>
                                    <TextBlock
                                        Grid.Column="1"
                                        Text="{x:Bind ViewModel.AppVersion, Mode=OneTime}"
                                        Foreground="{StaticResource KroiraTextPrimaryBrush}"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        VerticalAlignment="Center" />
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource KroiraSettingsRowStyle}">
                                <StackPanel Spacing="8">
                                    <Grid ColumnSpacing="14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="Privacy" Style="{StaticResource KroiraTitleStyle}" />
                                            <TextBlock
                                                Text="Open the privacy policy in your default browser."
                                                Style="{StaticResource KroiraBodyStyle}" />
                                        </StackPanel>
                                        <HyperlinkButton
                                            Grid.Column="1"
                                            Content="Open"
                                            Command="{x:Bind ViewModel.OpenPrivacyPolicyCommand}"
                                            Foreground="{StaticResource KroiraAccentBrush}"
                                            Padding="0"
                                            VerticalAlignment="Center" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource KroiraSettingsRowStyle}">
                                <Grid ColumnSpacing="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="Support" Style="{StaticResource KroiraTitleStyle}" />
                                        <TextBlock
                                            Text="Open support and feedback resources."
                                            Style="{StaticResource KroiraBodyStyle}" />
                                    </StackPanel>
                                    <HyperlinkButton
                                        Grid.Column="1"
                                        Content="Open"
                                        Command="{x:Bind ViewModel.OpenSupportCommand}"
                                        Foreground="{StaticResource KroiraAccentBrush}"
                                        Padding="0"
                                        VerticalAlignment="Center" />
                                </Grid>
                            </Border>

                            <TextBlock
                                Text="2026 KROIRA. All rights reserved."
                                Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                FontSize="12" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
