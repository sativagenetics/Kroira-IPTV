<Page
    x:Class="Kroira.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Kroira.App.Controls"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Grid>
        <controls:AmbientPageBackground />

    <ScrollViewer x:Name="PageScrollViewer">
        <Grid Padding="34,28,34,34"
              RowSpacing="22"
              XYFocusKeyboardNavigation="Enabled"
              MaxWidth="980"
              HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    BorderBrush="{StaticResource KroiraGhostBorderBrush}"
                    BorderThickness="0"
                    CornerRadius="{StaticResource KroiraRadiusSheet}"
                    Padding="24">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1B1130" Offset="0" />
                        <GradientStop Color="#10141A" Offset="0.58" />
                        <GradientStop Color="#090A0D" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="8">
                        <TextBlock Text="Settings" Style="{StaticResource KroiraPageTitleStyle}" />
                        <TextBlock Text="Playback, library, appearance, and support settings."
                                   Style="{StaticResource KroiraPageSubtitleStyle}"
                                   MaxWidth="680" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Width="70"
                            Height="70"
                            CornerRadius="16"
                            Background="#8010141A"
                            BorderBrush="{StaticResource KroiraChromeLineBrush}"
                            BorderThickness="1"
                            VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE713;"
                                  FontSize="28"
                                  Foreground="{StaticResource KroiraAccentBrush}" />
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnSpacing="22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.35*" />
                    <ColumnDefinition Width="0.9*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="18">
                    <Border Style="{StaticResource KroiraSettingsGroupStyle}">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="3">
                                <TextBlock Text="Application" Style="{StaticResource KroiraSectionTitleStyle}" />
                                <TextBlock Text="Preferences that shape your local library experience."
                                           Style="{StaticResource KroiraBodyStyle}" />
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource KroiraBorderBrush}" Opacity="0.45" />

                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="220" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="5">
                                    <TextBlock Text="Remote-friendly mode" Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock Text="{x:Bind ViewModel.RemoteModeStatusText, Mode=OneWay}"
                                               Style="{StaticResource KroiraBodyStyle}"
                                               MaxWidth="520"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <ToggleSwitch x:Name="RemoteModeToggle"
                                              Grid.Column="1"
                                              IsOn="{x:Bind ViewModel.RemoteModeEnabled, Mode=TwoWay}"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center" />
                            </Grid>

                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="220" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="5">
                                    <TextBlock Text="App language" Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock Text="{x:Bind ViewModel.LanguageStatusText, Mode=OneWay}"
                                               Style="{StaticResource KroiraBodyStyle}"
                                               MaxWidth="520" />
                                </StackPanel>

                                <ComboBox x:Name="LanguageComboBox"
                                          Grid.Column="1"
                                          Style="{StaticResource KroiraComboBoxStyle}"
                                          ItemsSource="{x:Bind ViewModel.Languages, Mode=OneWay}"
                                          SelectedItem="{x:Bind ViewModel.SelectedLanguage, Mode=TwoWay}"
                                          DisplayMemberPath="DisplayName"
                                          MinWidth="180"
                                          MaxWidth="220"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Center" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KroiraSettingsGroupStyle}">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="3">
                                <TextBlock Text="Appearance" Style="{StaticResource KroiraSectionTitleStyle}" />
                                <TextBlock Text="Choose the visual preset and accent combination that fits your setup."
                                           Style="{StaticResource KroiraBodyStyle}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource KroiraBorderBrush}" Opacity="0.45" />

                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="220" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Theme preset" Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock Text="Adjust the page atmosphere and surface gradient family."
                                               Style="{StaticResource KroiraBodyStyle}" />
                                </StackPanel>

                                <ComboBox Grid.Column="1"
                                          Style="{StaticResource KroiraComboBoxStyle}"
                                          ItemsSource="{x:Bind ViewModel.ThemeOptions, Mode=OneWay}"
                                          SelectedItem="{x:Bind ViewModel.SelectedThemeOption, Mode=TwoWay}"
                                          DisplayMemberPath="DisplayName"
                                          IsEnabled="{x:Bind ViewModel.CanUseThemePresets, Mode=OneWay}"
                                          MinWidth="180"
                                          MaxWidth="220"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Center" />
                            </Grid>

                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="220" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Accent pack" Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock Text="Retune action chrome, focus color, and highlight accents across the app."
                                               Style="{StaticResource KroiraBodyStyle}" />
                                </StackPanel>

                                <ComboBox Grid.Column="1"
                                          Style="{StaticResource KroiraComboBoxStyle}"
                                          ItemsSource="{x:Bind ViewModel.AccentOptions, Mode=OneWay}"
                                          SelectedItem="{x:Bind ViewModel.SelectedAccentOption, Mode=TwoWay}"
                                          DisplayMemberPath="DisplayName"
                                          IsEnabled="{x:Bind ViewModel.CanUseAccentPacks, Mode=OneWay}"
                                          MinWidth="180"
                                          MaxWidth="220"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Center" />
                            </Grid>

                            <TextBlock Text="{x:Bind ViewModel.AppearanceStatusText, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource KroiraSettingsGroupStyle}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Media behavior" Style="{StaticResource KroiraSectionTitleStyle}" />
                                <TextBlock Text="Provider data remains the primary source for artwork, titles, and playback routing."
                                           Style="{StaticResource KroiraBodyStyle}"
                                           TextWrapping="Wrap" />
                                <Border Height="1" Background="{StaticResource KroiraBorderBrush}" Opacity="0.45" />
                                <TextBlock Text="Provider metadata first"
                                           Foreground="{StaticResource KroiraAccentBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource KroiraSettingsGroupStyle}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Metadata" Style="{StaticResource KroiraSectionTitleStyle}" />
                                <TextBlock Text="TMDb is used as enrichment and fallback when local provider metadata is incomplete."
                                           Style="{StaticResource KroiraBodyStyle}"
                                           TextWrapping="Wrap" />
                                <Border Height="1" Background="{StaticResource KroiraBorderBrush}" Opacity="0.45" />
                                <TextBlock Text="Fallback enrichment"
                                           Foreground="{StaticResource KroiraAccentBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Style="{StaticResource KroiraSettingsGroupStyle}">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="3">
                                <TextBlock Text="Automatic refresh" Style="{StaticResource KroiraSectionTitleStyle}" />
                                <TextBlock Text="Keep sources current on a bounded cadence while the app is open. Refreshes update guide data, artwork, and library availability."
                                           Style="{StaticResource KroiraBodyStyle}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource KroiraBorderBrush}" Opacity="0.45" />

                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="220" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Enable automatic refresh" Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock Text="{x:Bind ViewModel.AutoRefreshStatusText, Mode=OneWay}"
                                               Style="{StaticResource KroiraBodyStyle}"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <ToggleSwitch Grid.Column="1"
                                              IsOn="{x:Bind ViewModel.AutoRefreshEnabled, Mode=TwoWay}"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center" />
                            </Grid>

                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="220" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Refresh cadence" Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock Text="Choose how often sources become due while the app stays open."
                                               Style="{StaticResource KroiraBodyStyle}" />
                                </StackPanel>

                                <ComboBox Grid.Column="1"
                                          Style="{StaticResource KroiraComboBoxStyle}"
                                          ItemsSource="{x:Bind ViewModel.AutoRefreshIntervalOptions, Mode=OneWay}"
                                          SelectedItem="{x:Bind ViewModel.SelectedAutoRefreshInterval, Mode=TwoWay}"
                                          DisplayMemberPath="DisplayName"
                                          IsEnabled="{x:Bind ViewModel.AutoRefreshEnabled, Mode=OneWay}"
                                          MinWidth="180"
                                          MaxWidth="220"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Center" />
                            </Grid>

                            <ToggleSwitch Header="Run shortly after launch"
                                          IsOn="{x:Bind ViewModel.RunAutoRefreshAfterLaunch, Mode=TwoWay}"
                                          IsEnabled="{x:Bind ViewModel.AutoRefreshEnabled, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="18">
                    <Border Style="{StaticResource KroiraSettingsGroupStyle}">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="3">
                                <TextBlock Text="About" Style="{StaticResource KroiraSectionTitleStyle}" />
                                <TextBlock Text="Installed build and release information."
                                           Style="{StaticResource KroiraBodyStyle}" />
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource KroiraBorderBrush}" Opacity="0.45" />

                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="App" Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock Text="Name" Style="{StaticResource KroiraBodyStyle}" />
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind ViewModel.AppName, Mode=OneWay}"
                                           Foreground="{StaticResource KroiraTextPrimaryBrush}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Version / build" Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock Text="Installed package" Style="{StaticResource KroiraBodyStyle}" />
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind ViewModel.AppVersionBuildText, Mode=OneTime}"
                                           Foreground="{StaticResource KroiraTextPrimaryBrush}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <TextBlock Text="{x:Bind ViewModel.ProductDescription, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KroiraSettingsGroupStyle}">
                        <StackPanel Spacing="14">
                            <StackPanel Spacing="3">
                                <TextBlock Text="{x:Bind BackupSectionTitle, Mode=OneWay}" Style="{StaticResource KroiraSectionTitleStyle}" />
                                <TextBlock Text="{x:Bind BackupSectionDescription, Mode=OneWay}"
                                           Style="{StaticResource KroiraBodyStyle}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource KroiraBorderBrush}" Opacity="0.45" />

                            <TextBlock Text="Restore replaces the current local setup, then rebuilds the library from the restored sources on this device."
                                       Visibility="{x:Bind RestoreBackupVisibility, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       TextWrapping="Wrap" />

                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Button Content="Export"
                                        Click="OnExportBackupClick"
                                        IsEnabled="{x:Bind ViewModel.CanStartBackupAction, Mode=OneWay}" />

                                <Button Content="Restore"
                                        Click="OnRestoreBackupClick"
                                        Visibility="{x:Bind RestoreBackupVisibility, Mode=OneWay}"
                                        IsEnabled="{x:Bind ViewModel.CanStartBackupAction, Mode=OneWay}" />

                                <ProgressRing Width="18"
                                              Height="18"
                                              Margin="8,0,0,0"
                                              IsActive="{x:Bind ViewModel.IsBackupBusy, Mode=OneWay}"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center" />
                            </StackPanel>

                            <TextBlock Text="{x:Bind ViewModel.BackupStatusText, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KroiraSettingsGroupStyle}">
                        <StackPanel Spacing="14">
                            <StackPanel Spacing="3">
                                <TextBlock Text="Help" Style="{StaticResource KroiraSectionTitleStyle}" />
                                <TextBlock Text="Quick start for bringing your own sources."
                                           Style="{StaticResource KroiraBodyStyle}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource KroiraBorderBrush}" Opacity="0.45" />

                            <StackPanel Spacing="8">
                                <TextBlock Text="{x:Bind ViewModel.HelpStepOne, Mode=OneWay}"
                                           Style="{StaticResource KroiraBodyStyle}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{x:Bind ViewModel.HelpStepTwo, Mode=OneWay}"
                                           Style="{StaticResource KroiraBodyStyle}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{x:Bind ViewModel.HelpStepThree, Mode=OneWay}"
                                           Style="{StaticResource KroiraBodyStyle}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{x:Bind ViewModel.HelpStepFour, Mode=OneWay}"
                                           Style="{StaticResource KroiraBodyStyle}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KroiraSettingsGroupStyle}">
                        <StackPanel Spacing="14">
                            <StackPanel Spacing="3">
                                <TextBlock Text="Privacy &amp; Support" Style="{StaticResource KroiraSectionTitleStyle}" />
                                <TextBlock Text="Release support, privacy, and contact details."
                                           Style="{StaticResource KroiraBodyStyle}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource KroiraBorderBrush}" Opacity="0.45" />

                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Privacy policy" Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock Text="{x:Bind ViewModel.PrivacyPolicyDisplayText, Mode=OneWay}"
                                               Style="{StaticResource KroiraBodyStyle}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <HyperlinkButton Grid.Column="1"
                                                 Content="Open"
                                                 Command="{x:Bind ViewModel.OpenPrivacyPolicyCommand}"
                                                 IsEnabled="{x:Bind ViewModel.CanOpenPrivacyPolicy, Mode=OneWay}"
                                                 Foreground="{StaticResource KroiraAccentBrush}"
                                                 Padding="0"
                                                 VerticalAlignment="Center" />
                            </Grid>

                            <TextBlock Text="{x:Bind ViewModel.PrivacySummaryText, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       TextWrapping="Wrap" />

                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Support page" Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock Text="{x:Bind ViewModel.SupportPageDisplayText, Mode=OneWay}"
                                               Style="{StaticResource KroiraBodyStyle}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <HyperlinkButton Grid.Column="1"
                                                 Content="Open"
                                                 Command="{x:Bind ViewModel.OpenSupportCommand}"
                                                 IsEnabled="{x:Bind ViewModel.CanOpenSupportPage, Mode=OneWay}"
                                                 Foreground="{StaticResource KroiraAccentBrush}"
                                                 Padding="0"
                                                 VerticalAlignment="Center" />
                            </Grid>

                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Support email" Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock Text="{x:Bind ViewModel.SupportEmailText, Mode=OneWay}"
                                               Style="{StaticResource KroiraBodyStyle}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <HyperlinkButton Grid.Column="1"
                                                 Content="Email"
                                                 Command="{x:Bind ViewModel.OpenSupportEmailCommand}"
                                                 IsEnabled="{x:Bind ViewModel.CanEmailSupport, Mode=OneWay}"
                                                 Foreground="{StaticResource KroiraAccentBrush}"
                                                 Padding="0"
                                                 VerticalAlignment="Center" />
                            </Grid>

                            <TextBlock Text="{x:Bind ViewModel.SupportSummaryText, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       TextWrapping="Wrap" />

                            <TextBlock Text="{x:Bind ViewModel.ResourceStatusText, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KroiraSettingsGroupStyle}">
                        <StackPanel Spacing="12">
                            <StackPanel Spacing="3">
                                <TextBlock Text="Disclaimer" Style="{StaticResource KroiraSectionTitleStyle}" />
                                <TextBlock Text="Content and source responsibility."
                                           Style="{StaticResource KroiraBodyStyle}" />
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource KroiraBorderBrush}" Opacity="0.45" />

                            <TextBlock Text="{x:Bind ViewModel.LegalDisclaimerText, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Copyright 2026 KROIRA."
                               Foreground="{StaticResource KroiraTextTertiaryBrush}"
                               FontSize="12"
                               Margin="2,0,0,0" />
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
    </Grid>
</Page>
