<Page
    x:Class="Kroira.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <StackPanel Padding="30" Spacing="20">
        <TextBlock Text="Settings" Style="{ThemeResource TitleTextBlockStyle}" />
        <TextBlock Text="Licensing Details" Style="{ThemeResource SubtitleTextBlockStyle}" />
        
        <Border Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}" Padding="20" CornerRadius="8" HorizontalAlignment="Left">
            <StackPanel Spacing="10">
                <TextBlock Text="Current Tier:" FontWeight="SemiBold" />
                
                <Grid>
                    <TextBlock Text="KROIRA PRO" Foreground="LimeGreen" FontWeight="Bold" FontSize="20" Visibility="{x:Bind ViewModel.ProTierVisibility, Mode=OneWay}" />
                    <TextBlock Text="KROIRA FREE" Foreground="LightSkyBlue" FontWeight="Bold" FontSize="20" Visibility="{x:Bind ViewModel.FreeTierVisibility, Mode=OneWay}" />
                </Grid>
                
                <TextBlock Text="{x:Bind ViewModel.LicenseStatusDescription, Mode=OneWay}" TextWrapping="Wrap" MaxWidth="600" Margin="0,10,0,20" />

                <Button Content="Upgrade to Pro" 
                        Command="{x:Bind ViewModel.UpgradeCommand}" 
                        Visibility="{x:Bind ViewModel.FreeTierVisibility, Mode=OneWay}"
                        Style="{ThemeResource AccentButtonStyle}"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Page>
