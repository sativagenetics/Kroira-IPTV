<Page
    x:Class="Kroira.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Kroira.App.Controls"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Grid>
        <controls:AmbientPageBackground />

    <ScrollViewer x:Name="PageScrollViewer">
        <Grid Padding="34,28,34,34"
              RowSpacing="22"
              XYFocusKeyboardNavigation="Enabled"
              MaxWidth="980"
              HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    BorderBrush="{StaticResource KroiraGhostBorderBrush}"
                    BorderThickness="0"
                    CornerRadius="{StaticResource KroiraRadiusSheet}"
                    Padding="24">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1B1130" Offset="0" />
                        <GradientStop Color="#10141A" Offset="0.58" />
                        <GradientStop Color="#090A0D" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="8">
                        <TextBlock x:Uid="SettingsPageTitle" Text="Settings" Style="{StaticResource KroiraPageTitleStyle}" />
                        <TextBlock x:Uid="SettingsPageSubtitle" Text="Playback, library, appearance, and support settings."
                                   Style="{StaticResource KroiraPageSubtitleStyle}"
                                   MaxWidth="680" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Width="70"
                            Height="70"
                            CornerRadius="16"
                            Background="#8010141A"
                            BorderBrush="{StaticResource KroiraChromeLineBrush}"
                            BorderThickness="1"
                            VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE713;"
                                  FontSize="28"
                                  Foreground="{StaticResource KroiraAccentBrush}" />
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnSpacing="22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.35*" />
                    <ColumnDefinition Width="0.9*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="18">
                    <Border Style="{StaticResource KroiraSettingsGroupStyle}">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="3">
                                <TextBlock x:Uid="SettingsApplicationTitle" Text="Application" Style="{StaticResource KroiraSectionTitleStyle}" />
                                <TextBlock x:Uid="SettingsApplicationSubtitle" Text="Preferences that shape your local library experience."
                                           Style="{StaticResource KroiraBodyStyle}" />
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource KroiraBorderBrush}" Opacity="0.45" />

                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="220" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="5">
                                    <TextBlock x:Uid="SettingsRemoteModeTitle" Text="Remote-friendly mode" Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock Text="{x:Bind ViewModel.RemoteModeStatusText, Mode=OneWay}"
                                               Style="{StaticResource KroiraBodyStyle}"
                                               MaxWidth="520"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                 <ToggleSwitch x:Name="RemoteModeToggle"
                                               x:Uid="SettingsRemoteModeToggle"
                                               Grid.Column="1"
                                               IsOn="{x:Bind ViewModel.RemoteModeEnabled, Mode=TwoWay}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               AutomationProperties.Name="Remote-friendly mode" />
                            </Grid>

                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="220" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="5">
                                    <TextBlock x:Uid="SettingsLanguageTitle" Text="App language" Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock Text="{x:Bind ViewModel.LanguageStatusText, Mode=OneWay}"
                                               Style="{StaticResource KroiraBodyStyle}"
                                               MaxWidth="520" />
                                </StackPanel>

                                 <ComboBox x:Name="LanguageComboBox"
                                           x:Uid="SettingsLanguageComboBox"
                                           Grid.Column="1"
                                           Style="{StaticResource KroiraComboBoxStyle}"
                                           ItemsSource="{x:Bind ViewModel.Languages, Mode=OneWay}"
                                           SelectedItem="{x:Bind ViewModel.SelectedLanguage, Mode=TwoWay}"
                                           DisplayMemberPath="DisplayName"
                                           MinWidth="180"
                                           MaxWidth="220"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Center"
                                           AutomationProperties.Name="App language" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KroiraSettingsGroupStyle}">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="3">
                                <TextBlock x:Uid="SettingsAppearanceTitle" Text="Appearance" Style="{StaticResource KroiraSectionTitleStyle}" />
                                <TextBlock x:Uid="SettingsAppearanceSubtitle" Text="Choose the visual preset and accent combination that fits your setup."
                                           Style="{StaticResource KroiraBodyStyle}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource KroiraBorderBrush}" Opacity="0.45" />

                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="220" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="4">
                                    <TextBlock x:Uid="SettingsThemePresetTitle" Text="Theme preset" Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock x:Uid="SettingsThemePresetSubtitle" Text="Adjust the page atmosphere and surface gradient family."
                                               Style="{StaticResource KroiraBodyStyle}" />
                                </StackPanel>

                                 <ComboBox x:Uid="SettingsThemePresetComboBox"
                                           Grid.Column="1"
                                           Style="{StaticResource KroiraComboBoxStyle}"
                                           ItemsSource="{x:Bind ViewModel.ThemeOptions, Mode=OneWay}"
                                           SelectedItem="{x:Bind ViewModel.SelectedThemeOption, Mode=TwoWay}"
                                           DisplayMemberPath="DisplayName"
                                           IsEnabled="{x:Bind ViewModel.CanUseThemePresets, Mode=OneWay}"
                                           MinWidth="180"
                                           MaxWidth="220"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Center"
                                           AutomationProperties.Name="Theme preset" />
                            </Grid>

                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="220" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="4">
                                    <TextBlock x:Uid="SettingsAccentPackTitle" Text="Accent pack" Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock x:Uid="SettingsAccentPackSubtitle" Text="Retune action chrome, focus color, and highlight accents across the app."
                                               Style="{StaticResource KroiraBodyStyle}" />
                                </StackPanel>

                                 <ComboBox x:Uid="SettingsAccentPackComboBox"
                                           Grid.Column="1"
                                           Style="{StaticResource KroiraComboBoxStyle}"
                                           ItemsSource="{x:Bind ViewModel.AccentOptions, Mode=OneWay}"
                                           SelectedItem="{x:Bind ViewModel.SelectedAccentOption, Mode=TwoWay}"
                                           DisplayMemberPath="DisplayName"
                                           IsEnabled="{x:Bind ViewModel.CanUseAccentPacks, Mode=OneWay}"
                                           MinWidth="180"
                                           MaxWidth="220"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Center"
                                           AutomationProperties.Name="Accent pack" />
                            </Grid>

                            <TextBlock Text="{x:Bind ViewModel.AppearanceStatusText, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Grid ColumnSpacing="18"
                          RowSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource KroiraSettingsGroupStyle}">
                            <StackPanel Spacing="10">
                                <TextBlock x:Uid="SettingsPlaybackPreferencesTitle" Text="Playback preferences" Style="{StaticResource KroiraSectionTitleStyle}" />
                                <TextBlock x:Uid="SettingsPlaybackPreferencesSubtitle" Text="Resume state, favorites, and playback routing stay local and are applied without blocking app launch."
                                            Style="{StaticResource KroiraBodyStyle}"
                                            TextWrapping="Wrap" />
                                <Border Height="1" Background="{StaticResource KroiraBorderBrush}" Opacity="0.45" />
                                <TextBlock x:Uid="SettingsLocalResumeRouting" Text="Local resume and routing"
                                           Foreground="{StaticResource KroiraAccentBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource KroiraSettingsGroupStyle}">
                            <StackPanel Spacing="10">
                                <TextBlock x:Uid="SettingsEpgPreferencesTitle" Text="EPG preferences" Style="{StaticResource KroiraSectionTitleStyle}" />
                                <TextBlock x:Uid="SettingsEpgPreferencesSubtitle" Text="Guide sources, stale guide warnings, and manual channel matching are managed from the guide and source diagnostics surfaces."
                                            Style="{StaticResource KroiraBodyStyle}"
                                            TextWrapping="Wrap" />
                                <Border Height="1" Background="{StaticResource KroiraBorderBrush}" Opacity="0.45" />
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button x:Uid="SettingsOpenGuideButton" Content="Open Guide"
                                            Click="OpenGuideFromSettings_Click"
                                            Style="{StaticResource KroiraGhostButtonStyle}"
                                            AutomationProperties.Name="Open guide settings" />
                                    <Button x:Uid="SettingsSourcesButton" Content="Sources"
                                            Click="OpenSourcesFromSettings_Click"
                                            Style="{StaticResource KroiraGhostButtonStyle}"
                                            AutomationProperties.Name="Open source diagnostics" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource KroiraSettingsGroupStyle}">
                            <StackPanel Spacing="10">
                                <TextBlock x:Uid="SettingsMetadataPreferencesTitle" Text="Metadata preferences" Style="{StaticResource KroiraSectionTitleStyle}" />
                                <TextBlock x:Uid="SettingsMetadataPreferencesSubtitle" Text="TMDb enrichment is a background fallback when local provider artwork or titles are incomplete."
                                           Style="{StaticResource KroiraBodyStyle}"
                                           TextWrapping="Wrap" />
                                <Border Height="1" Background="{StaticResource KroiraBorderBrush}" Opacity="0.45" />
                                <TextBlock x:Uid="SettingsProviderMetadataFirst" Text="Provider metadata first"
                                           Foreground="{StaticResource KroiraAccentBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource KroiraSettingsGroupStyle}">
                            <StackPanel Spacing="10">
                                <TextBlock x:Uid="SettingsDiagnosticsExportTitle" Text="Diagnostics export" Style="{StaticResource KroiraSectionTitleStyle}" />
                                <TextBlock x:Uid="SettingsDiagnosticsExportSubtitle" Text="Sanitized source reports are available per source and do not include credentials or provider tokens."
                                           Style="{StaticResource KroiraBodyStyle}"
                                           TextWrapping="Wrap" />
                                <Border Height="1" Background="{StaticResource KroiraBorderBrush}" Opacity="0.45" />
                                <Button x:Uid="SettingsOpenSourcesButton" Content="Open Sources"
                                        Click="OpenSourcesFromSettings_Click"
                                        Style="{StaticResource KroiraGhostButtonStyle}"
                                        HorizontalAlignment="Left"
                                        AutomationProperties.Name="Open diagnostics export" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Style="{StaticResource KroiraSettingsGroupStyle}">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="3">
                                <TextBlock x:Uid="SettingsAutoRefreshTitle" Text="Automatic refresh" Style="{StaticResource KroiraSectionTitleStyle}" />
                                <TextBlock x:Uid="SettingsAutoRefreshSubtitle" Text="Keep sources current on a bounded cadence while the app is open. Refreshes update guide data, artwork, and library availability."
                                           Style="{StaticResource KroiraBodyStyle}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource KroiraBorderBrush}" Opacity="0.45" />

                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="220" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="4">
                                    <TextBlock x:Uid="SettingsEnableAutoRefreshTitle" Text="Enable automatic refresh" Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock Text="{x:Bind ViewModel.AutoRefreshStatusText, Mode=OneWay}"
                                               Style="{StaticResource KroiraBodyStyle}"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                 <ToggleSwitch x:Uid="SettingsEnableAutoRefreshToggle"
                                               Grid.Column="1"
                                               IsOn="{x:Bind ViewModel.AutoRefreshEnabled, Mode=TwoWay}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               AutomationProperties.Name="Enable automatic refresh" />
                            </Grid>

                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="220" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="4">
                                    <TextBlock x:Uid="SettingsRefreshCadenceTitle" Text="Refresh cadence" Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock x:Uid="SettingsRefreshCadenceSubtitle" Text="Choose how often sources become due while the app stays open."
                                               Style="{StaticResource KroiraBodyStyle}" />
                                </StackPanel>

                                 <ComboBox x:Uid="SettingsRefreshCadenceComboBox"
                                           Grid.Column="1"
                                           Style="{StaticResource KroiraComboBoxStyle}"
                                           ItemsSource="{x:Bind ViewModel.AutoRefreshIntervalOptions, Mode=OneWay}"
                                           SelectedItem="{x:Bind ViewModel.SelectedAutoRefreshInterval, Mode=TwoWay}"
                                           DisplayMemberPath="DisplayName"
                                           IsEnabled="{x:Bind ViewModel.AutoRefreshEnabled, Mode=OneWay}"
                                           MinWidth="180"
                                           MaxWidth="220"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Center"
                                           AutomationProperties.Name="Refresh cadence" />
                            </Grid>

                             <ToggleSwitch x:Uid="SettingsRunRefreshAfterLaunchSwitch" Header="Run shortly after launch"
                                           IsOn="{x:Bind ViewModel.RunAutoRefreshAfterLaunch, Mode=TwoWay}"
                                           IsEnabled="{x:Bind ViewModel.AutoRefreshEnabled, Mode=OneWay}"
                                           AutomationProperties.Name="Run refresh shortly after launch" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="18">
                    <Border Style="{StaticResource KroiraSettingsGroupStyle}">
                        <StackPanel Spacing="14">
                            <StackPanel Spacing="3">
                                <TextBlock x:Uid="SettingsAppInformationTitle" Text="App information" Style="{StaticResource KroiraSectionTitleStyle}" />
                                <TextBlock x:Uid="SettingsAppInformationSubtitle" Text="About, help, privacy, support, version, and legal information live on a separate information page."
                                           Style="{StaticResource KroiraBodyStyle}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource KroiraBorderBrush}" Opacity="0.45" />

                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Bind ViewModel.AppName, Mode=OneWay}" Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock Text="{x:Bind ViewModel.ReleaseVersionText, Mode=OneWay}"
                                               Style="{StaticResource KroiraBodyStyle}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <Button x:Uid="SettingsAppInformationOpenButton"
                                        Grid.Column="1"
                                        Content="Open"
                                        Click="OpenAboutFromSettings_Click"
                                        Style="{StaticResource KroiraGhostButtonStyle}"
                                        VerticalAlignment="Center"
                                        AutomationProperties.Name="Open app information" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KroiraSettingsGroupStyle}" Visibility="Collapsed">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="3">
                                <TextBlock x:Uid="SettingsAboutTitle" Text="About" Style="{StaticResource KroiraSectionTitleStyle}" />
                                <TextBlock x:Uid="SettingsAboutSubtitle" Text="Installed build and release information."
                                           Style="{StaticResource KroiraBodyStyle}" />
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource KroiraBorderBrush}" Opacity="0.45" />

                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock x:Uid="SettingsAppLabel" Text="App" Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock x:Uid="SettingsNameLabel" Text="Name" Style="{StaticResource KroiraBodyStyle}" />
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind ViewModel.AppName, Mode=OneWay}"
                                           Foreground="{StaticResource KroiraTextPrimaryBrush}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock x:Uid="SettingsReleaseLabel" Text="Release" Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock x:Uid="SettingsStoreSubmissionVersionLabel" Text="Store submission version" Style="{StaticResource KroiraBodyStyle}" />
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind ViewModel.ReleaseVersionText, Mode=OneWay}"
                                           Foreground="{StaticResource KroiraTextPrimaryBrush}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock x:Uid="SettingsVersionBuildLabel" Text="Version / build" Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock x:Uid="SettingsInstalledPackageLabel" Text="Installed package" Style="{StaticResource KroiraBodyStyle}" />
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind ViewModel.AppVersionBuildText, Mode=OneTime}"
                                           Foreground="{StaticResource KroiraTextPrimaryBrush}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <TextBlock Text="{x:Bind ViewModel.ShortDescription, Mode=OneWay}"
                                       Foreground="{StaticResource KroiraAccentBrush}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />

                            <TextBlock Text="{x:Bind ViewModel.ProductDescription, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KroiraSettingsGroupStyle}">
                        <StackPanel Spacing="14">
                            <StackPanel Spacing="3">
                                <TextBlock Text="{x:Bind BackupSectionTitle, Mode=OneWay}" Style="{StaticResource KroiraSectionTitleStyle}" />
                                <TextBlock Text="{x:Bind BackupSectionDescription, Mode=OneWay}"
                                           Style="{StaticResource KroiraBodyStyle}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource KroiraBorderBrush}" Opacity="0.45" />

                            <TextBlock x:Uid="SettingsRestoreWarning" Text="Restore replaces the current local setup, then rebuilds the library from the restored sources on this device."
                                       Visibility="{x:Bind RestoreBackupVisibility, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       TextWrapping="Wrap" />

                            <StackPanel Orientation="Horizontal" Spacing="12">
                                 <Button x:Uid="SettingsExportButton" Content="Export"
                                         Click="OnExportBackupClick"
                                         IsEnabled="{x:Bind ViewModel.CanStartBackupAction, Mode=OneWay}"
                                         AutomationProperties.Name="Export backup" />

                                 <Button x:Uid="SettingsRestoreButton" Content="Restore"
                                         Click="OnRestoreBackupClick"
                                         Visibility="{x:Bind RestoreBackupVisibility, Mode=OneWay}"
                                         IsEnabled="{x:Bind ViewModel.CanStartBackupAction, Mode=OneWay}"
                                         AutomationProperties.Name="Restore backup" />

                                <ProgressRing Width="18"
                                              Height="18"
                                              Margin="8,0,0,0"
                                              IsActive="{x:Bind ViewModel.IsBackupBusy, Mode=OneWay}"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center" />
                            </StackPanel>

                            <TextBlock Text="{x:Bind ViewModel.BackupStatusText, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KroiraSettingsGroupStyle}" Visibility="Collapsed">
                        <StackPanel Spacing="14">
                            <StackPanel Spacing="3">
                                <TextBlock x:Uid="SettingsHelpTitle" Text="Help" Style="{StaticResource KroiraSectionTitleStyle}" />
                                <TextBlock x:Uid="SettingsHelpSubtitle" Text="Quick start for bringing your own sources."
                                           Style="{StaticResource KroiraBodyStyle}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource KroiraBorderBrush}" Opacity="0.45" />

                            <StackPanel Spacing="8">
                                <TextBlock Text="{x:Bind ViewModel.HelpStepOne, Mode=OneWay}"
                                           Style="{StaticResource KroiraBodyStyle}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{x:Bind ViewModel.HelpStepTwo, Mode=OneWay}"
                                           Style="{StaticResource KroiraBodyStyle}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{x:Bind ViewModel.HelpStepThree, Mode=OneWay}"
                                           Style="{StaticResource KroiraBodyStyle}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{x:Bind ViewModel.HelpStepFour, Mode=OneWay}"
                                           Style="{StaticResource KroiraBodyStyle}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KroiraSettingsGroupStyle}" Visibility="Collapsed">
                        <StackPanel Spacing="14">
                            <StackPanel Spacing="3">
                                <TextBlock x:Uid="SettingsPrivacySupportTitle" Text="Privacy &amp; Support" Style="{StaticResource KroiraSectionTitleStyle}" />
                                <TextBlock x:Uid="SettingsPrivacySupportSubtitle" Text="Release support, privacy, and contact details."
                                           Style="{StaticResource KroiraBodyStyle}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource KroiraBorderBrush}" Opacity="0.45" />

                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock x:Uid="SettingsPrivacyPolicyTitle" Text="Privacy policy" Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock Text="{x:Bind ViewModel.PrivacyPolicyDisplayText, Mode=OneWay}"
                                               Style="{StaticResource KroiraBodyStyle}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                 <HyperlinkButton x:Uid="SettingsPrivacyPolicyOpenButton"
                                                  Grid.Column="1"
                                                  Content="Open"
                                                  Command="{x:Bind ViewModel.OpenPrivacyPolicyCommand}"
                                                  IsEnabled="{x:Bind ViewModel.CanOpenPrivacyPolicy, Mode=OneWay}"
                                                  Foreground="{StaticResource KroiraAccentBrush}"
                                                  Padding="0"
                                                  VerticalAlignment="Center"
                                                  AutomationProperties.Name="Open privacy policy" />
                            </Grid>

                            <TextBlock Text="{x:Bind ViewModel.PrivacySummaryText, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       TextWrapping="Wrap" />

                            <TextBlock Text="{x:Bind ViewModel.CredentialHandlingText, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       TextWrapping="Wrap" />

                            <TextBlock Text="{x:Bind ViewModel.SanitizedLogsText, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       TextWrapping="Wrap" />

                            <TextBlock Text="{x:Bind ViewModel.TelemetryText, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       TextWrapping="Wrap" />

                            <TextBlock Text="{x:Bind ViewModel.MetadataProviderText, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       TextWrapping="Wrap" />

                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock x:Uid="SettingsSupportPageTitle" Text="Support page" Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock Text="{x:Bind ViewModel.SupportPageDisplayText, Mode=OneWay}"
                                               Style="{StaticResource KroiraBodyStyle}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                 <HyperlinkButton x:Uid="SettingsSupportOpenButton"
                                                  Grid.Column="1"
                                                  Content="Open"
                                                  Command="{x:Bind ViewModel.OpenSupportCommand}"
                                                  IsEnabled="{x:Bind ViewModel.CanOpenSupportPage, Mode=OneWay}"
                                                  Foreground="{StaticResource KroiraAccentBrush}"
                                                  Padding="0"
                                                  VerticalAlignment="Center"
                                                  AutomationProperties.Name="Open support page" />
                            </Grid>

                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock x:Uid="SettingsSupportEmailTitle" Text="Support email" Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock Text="{x:Bind ViewModel.SupportEmailText, Mode=OneWay}"
                                               Style="{StaticResource KroiraBodyStyle}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                 <HyperlinkButton x:Uid="SettingsSupportEmailButton"
                                                  Grid.Column="1"
                                                  Content="Email"
                                                  Command="{x:Bind ViewModel.OpenSupportEmailCommand}"
                                                  IsEnabled="{x:Bind ViewModel.CanEmailSupport, Mode=OneWay}"
                                                  Foreground="{StaticResource KroiraAccentBrush}"
                                                  Padding="0"
                                                  VerticalAlignment="Center"
                                                  AutomationProperties.Name="Email support" />
                            </Grid>

                            <TextBlock Text="{x:Bind ViewModel.SupportSummaryText, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       TextWrapping="Wrap" />

