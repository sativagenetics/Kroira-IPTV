<Page
    x:Class="Kroira.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <ScrollViewer>
        <Grid Padding="34,28,34,34"
              RowSpacing="22"
              MaxWidth="1040"
              HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="6">
                <TextBlock Text="Settings" Style="{StaticResource KroiraPageTitleStyle}" />
                <TextBlock Text="Application preferences and local behavior."
                           Style="{StaticResource KroiraPageSubtitleStyle}"
                           MaxWidth="680" />
            </StackPanel>

            <Grid Grid.Row="1" ColumnSpacing="22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.35*" />
                    <ColumnDefinition Width="0.9*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="18">
                    <Border Style="{StaticResource KroiraSettingsGroupStyle}">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="3">
                                <TextBlock Text="Application" Style="{StaticResource KroiraSectionTitleStyle}" />
                                <TextBlock Text="Preferences that affect local catalog presentation."
                                           Style="{StaticResource KroiraBodyStyle}" />
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource KroiraBorderBrush}" Opacity="0.45" />

                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="260" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="5">
                                    <TextBlock Text="App language" Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock Text="{x:Bind ViewModel.LanguageStatusText, Mode=OneWay}"
                                               Style="{StaticResource KroiraBodyStyle}"
                                               MaxWidth="520" />
                                </StackPanel>

                                <ComboBox Grid.Column="1"
                                          Style="{StaticResource KroiraComboBoxStyle}"
                                          ItemsSource="{x:Bind ViewModel.Languages, Mode=OneWay}"
                                          SelectedItem="{x:Bind ViewModel.SelectedLanguage, Mode=TwoWay}"
                                          DisplayMemberPath="DisplayName"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Center" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="18">
                    <Border Style="{StaticResource KroiraSettingsGroupStyle}">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="3">
                                <TextBlock Text="Product" Style="{StaticResource KroiraSectionTitleStyle}" />
                                <TextBlock Text="Installed build and official resources."
                                           Style="{StaticResource KroiraBodyStyle}" />
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource KroiraBorderBrush}" Opacity="0.45" />

                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Version" Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock Text="Installed package" Style="{StaticResource KroiraBodyStyle}" />
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind ViewModel.AppVersion, Mode=OneTime}"
                                           Foreground="{StaticResource KroiraTextPrimaryBrush}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KroiraSettingsGroupStyle}">
                        <StackPanel Spacing="14">
                            <StackPanel Spacing="3">
                                <TextBlock Text="Links" Style="{StaticResource KroiraSectionTitleStyle}" />
                                <TextBlock Text="Open policy and support resources." Style="{StaticResource KroiraBodyStyle}" />
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource KroiraBorderBrush}" Opacity="0.45" />

                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Privacy policy" Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock Text="View data and privacy information." Style="{StaticResource KroiraBodyStyle}" />
                                </StackPanel>
                                <HyperlinkButton Grid.Column="1"
                                                 Content="Open"
                                                 Command="{x:Bind ViewModel.OpenPrivacyPolicyCommand}"
                                                 Foreground="{StaticResource KroiraAccentBrush}"
                                                 Padding="0"
                                                 VerticalAlignment="Center" />
                            </Grid>

                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Support" Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock Text="Open help and feedback resources." Style="{StaticResource KroiraBodyStyle}" />
                                </StackPanel>
                                <HyperlinkButton Grid.Column="1"
                                                 Content="Open"
                                                 Command="{x:Bind ViewModel.OpenSupportCommand}"
                                                 Foreground="{StaticResource KroiraAccentBrush}"
                                                 Padding="0"
                                                 VerticalAlignment="Center" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="2026 KROIRA. All rights reserved."
                               Foreground="{StaticResource KroiraTextTertiaryBrush}"
                               FontSize="12"
                               Margin="2,0,0,0" />
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
