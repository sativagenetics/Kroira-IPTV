<Page
    x:Class="Kroira.App.Views.FavoritesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Grid Padding="28" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource KroiraPanelStyle}">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Favorites" Style="{StaticResource KroiraPageTitleStyle}" />
                    <TextBlock Text="Your saved live channels and quick-return picks." Style="{StaticResource KroiraPageSubtitleStyle}" Margin="0,4,0,0" />
                </StackPanel>
                <Border HorizontalAlignment="Right" VerticalAlignment="Center" Background="#221F42" BorderBrush="{StaticResource KroiraBorderStrongBrush}" BorderThickness="1" CornerRadius="999" Padding="12,5">
                    <TextBlock Text="Pinned" Foreground="{StaticResource KroiraGoldBrush}" FontSize="12" FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}" Style="{StaticResource KroiraPanelStyle}" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="440">
            <StackPanel Spacing="10">
                <FontIcon Glyph="&#xE734;" Foreground="{StaticResource KroiraGoldBrush}" FontSize="30" HorizontalAlignment="Left" />
                <TextBlock Text="No favorites yet" Style="{StaticResource KroiraSectionTitleStyle}" />
                <TextBlock Text="Mark channels as favorites to keep your everyday lineup close." Style="{StaticResource KroiraPageSubtitleStyle}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" ColumnSpacing="16" MaxWidth="960" HorizontalAlignment="Left" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource KroiraPanelStyle}" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Saved lineup" Style="{StaticResource KroiraSectionTitleStyle}" />
                    <GridView ItemsSource="{x:Bind ViewModel.FavoriteChannels, Mode=OneWay}" SelectionMode="Single" SelectionChanged="ChannelList_SelectionChanged">
                        <GridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="2" />
                            </ItemsPanelTemplate>
                        </GridView.ItemsPanel>
                        <GridView.ItemContainerStyle>
                            <Style TargetType="GridViewItem">
                                <Setter Property="Margin" Value="0,0,12,12" />
                            </Style>
                        </GridView.ItemContainerStyle>
                        <GridView.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="292" Height="96" Padding="12" BorderBrush="{StaticResource KroiraBorderBrush}" BorderThickness="1" CornerRadius="18" ColumnSpacing="12">
                                    <Grid.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#1B2134" Offset="0" />
                                            <GradientStop Color="#101722" Offset="1" />
                                        </LinearGradientBrush>
                                    </Grid.Background>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="62" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="52" Height="52" CornerRadius="16" Background="{StaticResource KroiraMediaGradientBrush}">
                                        <Image Source="{Binding LogoUrl}" Stretch="Uniform" Margin="6" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                        <TextBlock Text="{Binding Name}" TextWrapping="Wrap" MaxLines="2" FontWeight="SemiBold" FontSize="15" Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                                        <TextBlock Text="Favorite channel" Foreground="{StaticResource KroiraGoldBrush}" FontSize="11" />
                                    </StackPanel>
                                    <Button Grid.Column="2" Content="Remove" Tag="{Binding Id}" Click="RemoveFavorite_Click" Style="{StaticResource KroiraDangerButtonStyle}" FontSize="11" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource KroiraPanelStyle}" Padding="16">
                <StackPanel Spacing="10">
                    <Border Height="72" CornerRadius="18" Background="{StaticResource KroiraMediaGradientBrush}">
                        <Grid>
                            <FontIcon Glyph="&#xE734;" Foreground="{StaticResource KroiraGoldBrush}" FontSize="26" />
                            <Border Width="92" Height="4" Background="{StaticResource KroiraGoldBrush}" CornerRadius="2" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="16,0,0,14" />
                            <Border Width="170" Height="4" Background="#35FFFFFF" CornerRadius="2" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="16,0,0,14" Opacity="0.2" />
                        </Grid>
                    </Border>
                    <TextBlock Text="Your fastest route back" Style="{StaticResource KroiraSectionTitleStyle}" />
                    <TextBlock Text="Favorites stay focused on live channels you actually use, so a short list still feels intentional." Style="{StaticResource KroiraPageSubtitleStyle}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
