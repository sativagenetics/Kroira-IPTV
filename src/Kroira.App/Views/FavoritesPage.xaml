<Page
    x:Class="Kroira.App.Views.FavoritesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Kroira.App.Controls"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Page.Resources>
        <Style x:Key="HubColumnStyle" TargetType="Border" BasedOn="{StaticResource KroiraLaneColumnStyle}" />

        <Style x:Key="HubItemContainerStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="QuietManagementButtonStyle" TargetType="Button" BasedOn="{StaticResource KroiraGhostButtonStyle}">
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource KroiraTextTertiaryBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Background" Value="#08000000" />
            <Setter Property="Opacity" Value="0.62" />
        </Style>

        <Style x:Key="QuietIconButtonStyle" TargetType="Button" BasedOn="{StaticResource KroiraGhostButtonStyle}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource KroiraTextTertiaryBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Background" Value="#08000000" />
            <Setter Property="Opacity" Value="0.58" />
        </Style>
    </Page.Resources>

    <Grid XYFocusKeyboardNavigation="Enabled">
        <controls:AmbientPageBackground />

        <Grid Padding="34,28,36,34"
              RowSpacing="18"
              MaxWidth="1180"
              HorizontalAlignment="Center"
              Visibility="{x:Bind ViewModel.SurfaceState.ContentVisibility, Mode=OneWay}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="8">
                <Border Width="54"
                        Height="5"
                        Background="{StaticResource KroiraAccentGradientBrush}"
                        CornerRadius="3"
                        HorizontalAlignment="Left" />
                <TextBlock Text="Favorites" Style="{StaticResource KroiraPageTitleStyle}" />
                <TextBlock Text="Your saved Live TV, Movies, and Series in dedicated media lanes."
                           Style="{StaticResource KroiraPageSubtitleStyle}"
                           MaxWidth="720" />
            </StackPanel>
            <Border Grid.Column="1"
                    Background="#42111827"
                    BorderBrush="{StaticResource KroiraGhostBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14,10"
                    VerticalAlignment="Bottom">
                <TextBlock Text="{x:Bind ViewModel.FavoriteCountText, Mode=OneWay}"
                           Foreground="{StaticResource KroiraAccentBrush}"
                           FontSize="12"
                           FontWeight="SemiBold" />
            </Border>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource HubColumnStyle}">
                <Grid RowSpacing="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Style="{StaticResource KroiraLaneHeaderStyle}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="3">
                            <TextBlock Text="Live TV" Style="{StaticResource KroiraSectionTitleStyle}" />
                            <TextBlock Text="Saved channels" Style="{StaticResource KroiraBodyStyle}" />
                        </StackPanel>
                        <Border Grid.Column="1"
                                Style="{StaticResource KroiraLaneCountBadgeStyle}"
                                VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind ViewModel.ChannelCountText, Mode=OneWay}"
                                       Foreground="{StaticResource KroiraLiveDotBrush}"
                                       FontSize="10"
                                       FontWeight="SemiBold" />
                        </Border>
                        <Button Grid.Column="2"
                                Content="Clear all"
                                Click="ClearChannelFavorites_Click"
                                Style="{StaticResource KroiraLaneClearButtonStyle}"
                                Visibility="{x:Bind ViewModel.ClearChannelsVisibility, Mode=OneWay}"
                                VerticalAlignment="Center"
                                AutomationProperties.Name="Clear all favorite live channels" />
                    </Grid>
                    </Border>

                    <Grid Grid.Row="1" Padding="10,0,10,12">
                        <controls:EmptyStateView IconGlyph="&#xE714;"
                                                 Title="No saved channels"
                                                 Message="Star channels from Live TV to build a quick launch lane."
                                                 Visibility="{x:Bind ViewModel.ChannelsEmptyVisibility, Mode=OneWay}"
                                                 VerticalAlignment="Top" />

                        <ListView x:Name="ChannelList"
                                  ItemsSource="{x:Bind ViewModel.FavoriteChannels, Mode=OneWay}"
                                  SelectionMode="None"
                                  IsItemClickEnabled="True"
                                  ItemClick="ChannelList_ItemClick"
                                  KeyDown="ChannelList_KeyDown"
                                  ItemContainerStyle="{StaticResource HubItemContainerStyle}"
                                  ScrollViewer.VerticalScrollMode="Enabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  Padding="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#40111827"
                                            BorderBrush="Transparent"
                                            BorderThickness="0"
                                            CornerRadius="12"
                                            Padding="12">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="46" Height="46" CornerRadius="10" Background="{StaticResource KroiraMediaGradientBrush}">
                                                <Grid>
                                                    <FontIcon Glyph="&#xE714;" Foreground="{StaticResource KroiraAccentBrush}" FontSize="16" Opacity="0.55" />
                                                    <Image Source="{Binding LogoUrl, Converter={StaticResource UrlToImageSourceConverter}}" Stretch="Uniform" Margin="6" />
                                                </Grid>
                                            </Border>
                                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" Style="{StaticResource KroiraTitleStyle}" MaxLines="1" TextTrimming="CharacterEllipsis" />
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Ellipse Width="6" Height="6" Fill="{StaticResource KroiraLiveDotBrush}" VerticalAlignment="Center" />
                                                    <TextBlock Text="Live favorite" Style="{StaticResource KroiraMetaStyle}" />
                                                </StackPanel>
                                            </StackPanel>
                                            <Button Grid.Column="2"
                                                    Tag="{Binding Id}"
                                                    Click="RemoveChannelFavorite_Click"
                                                    Style="{StaticResource QuietIconButtonStyle}"
                                                    VerticalAlignment="Center"
                                                    AutomationProperties.Name="Remove favorite"
                                                    ToolTipService.ToolTip="Remove">
                                                <FontIcon Glyph="&#xE74D;" FontSize="11" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource HubColumnStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Style="{StaticResource KroiraLaneHeaderStyle}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="3">
                            <TextBlock Text="Movies" Style="{StaticResource KroiraSectionTitleStyle}" />
                            <TextBlock Text="Saved films" Style="{StaticResource KroiraBodyStyle}" />
                        </StackPanel>
                        <Border Grid.Column="1" Style="{StaticResource KroiraLaneCountBadgeStyle}">
                            <TextBlock Text="{x:Bind ViewModel.MovieCountText, Mode=OneWay}" Foreground="{StaticResource KroiraAccentBrush}" FontSize="10" FontWeight="SemiBold" />
                        </Border>
                        <Button Grid.Column="2"
                                Content="Clear all"
                                Click="ClearMovieFavorites_Click"
                                Style="{StaticResource KroiraLaneClearButtonStyle}"
                                Visibility="{x:Bind ViewModel.ClearMoviesVisibility, Mode=OneWay}"
                                VerticalAlignment="Center"
                                AutomationProperties.Name="Clear all favorite movies" />
                    </Grid>
                    </Border>

                    <Grid Grid.Row="1" Padding="10,0,10,12">
                        <controls:EmptyStateView IconGlyph="&#xE8B2;"
                                                 Title="No saved movies"
                                                 Message="Save movie cards to keep a focused watchlist here."
                                                 Visibility="{x:Bind ViewModel.MoviesEmptyVisibility, Mode=OneWay}"
                                                 VerticalAlignment="Top" />

                        <ListView x:Name="MovieList"
                                  ItemsSource="{x:Bind ViewModel.FavoriteMovies, Mode=OneWay}"
                                  SelectionMode="None"
                                  IsItemClickEnabled="True"
                                  ItemClick="MovieList_ItemClick"
                                  KeyDown="MovieList_KeyDown"
                                  ItemContainerStyle="{StaticResource HubItemContainerStyle}"
                                  ScrollViewer.VerticalScrollMode="Enabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  Padding="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#40111827" BorderBrush="Transparent" BorderThickness="0" CornerRadius="12" Padding="10">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="54" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="48" Height="68" CornerRadius="8" Background="{StaticResource KroiraPosterPlaceholderBrush}">
                                                <Image Source="{Binding PosterUrl, Converter={StaticResource UrlToImageSourceConverter}}" Stretch="UniformToFill" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" Style="{StaticResource KroiraTitleStyle}" MaxLines="2" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding MetadataLine}" Style="{StaticResource KroiraMetaStyle}" MaxLines="1" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="Movie" Style="{StaticResource KroiraMetaStyle}" />
                                            </StackPanel>
                                            <Button Grid.Column="2"
                                                    Tag="{Binding Id}"
                                                    Click="RemoveMovieFavorite_Click"
                                                    Style="{StaticResource QuietIconButtonStyle}"
                                                    VerticalAlignment="Center"
                                                    AutomationProperties.Name="Remove favorite"
                                                    ToolTipService.ToolTip="Remove">
                                                <FontIcon Glyph="&#xE74D;" FontSize="11" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource HubColumnStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Style="{StaticResource KroiraLaneHeaderStyle}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="3">
                            <TextBlock Text="Series" Style="{StaticResource KroiraSectionTitleStyle}" />
                            <TextBlock Text="Saved shows" Style="{StaticResource KroiraBodyStyle}" />
                        </StackPanel>
                        <Border Grid.Column="1" Style="{StaticResource KroiraLaneCountBadgeStyle}">
                            <TextBlock Text="{x:Bind ViewModel.SeriesCountText, Mode=OneWay}" Foreground="{StaticResource KroiraAccentBrush}" FontSize="10" FontWeight="SemiBold" />
                        </Border>
                        <Button Grid.Column="2"
                                Content="Clear all"
                                Click="ClearSeriesFavorites_Click"
                                Style="{StaticResource KroiraLaneClearButtonStyle}"
                                Visibility="{x:Bind ViewModel.ClearSeriesVisibility, Mode=OneWay}"
                                VerticalAlignment="Center"
                                AutomationProperties.Name="Clear all favorite series" />
                    </Grid>
                    </Border>

                    <Grid Grid.Row="1" Padding="10,0,10,12">
                        <controls:EmptyStateView IconGlyph="&#xE8A9;"
                                                 Title="No saved series"
                                                 Message="Saved series appear here as a dedicated show lane."
                                                 Visibility="{x:Bind ViewModel.SeriesEmptyVisibility, Mode=OneWay}"
                                                 VerticalAlignment="Top" />

                        <ListView x:Name="SeriesList"
                                  ItemsSource="{x:Bind ViewModel.FavoriteSeries, Mode=OneWay}"
                                  SelectionMode="Single"
                                  SelectionChanged="SeriesList_SelectionChanged"
                                  KeyDown="SeriesList_KeyDown"
                                  ItemContainerStyle="{StaticResource HubItemContainerStyle}"
                                  ScrollViewer.VerticalScrollMode="Enabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  Padding="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#40111827" BorderBrush="Transparent" BorderThickness="0" CornerRadius="12" Padding="10">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="54" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="48" Height="68" CornerRadius="8" Background="{StaticResource KroiraPosterPlaceholderBrush}">
                                                <Image Source="{Binding PosterUrl, Converter={StaticResource UrlToImageSourceConverter}}" Stretch="UniformToFill" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" Style="{StaticResource KroiraTitleStyle}" MaxLines="2" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding MetadataLine}" Style="{StaticResource KroiraMetaStyle}" MaxLines="1" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="Series" Style="{StaticResource KroiraMetaStyle}" />
                                            </StackPanel>
                                            <Button Grid.Column="2"
                                                    Tag="{Binding Id}"
                                                    Click="RemoveSeriesFavorite_Click"
                                                    Style="{StaticResource QuietIconButtonStyle}"
                                                    VerticalAlignment="Center"
                                                    AutomationProperties.Name="Remove favorite"
                                                    ToolTipService.ToolTip="Remove">
                                                <FontIcon Glyph="&#xE74D;" FontSize="11" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Width="540"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Visibility="{x:Bind ViewModel.SeriesDetailVisibility, Mode=OneWay}"
                Background="#D0080A0D"
                BorderBrush="Transparent"
                BorderThickness="0"
                CornerRadius="18"
                Padding="0"
                Margin="0,0,0,0">
            <Grid>
                <Border Width="5"
                        HorizontalAlignment="Left"
                        Background="{StaticResource KroiraAccentGradientBrush}"
                        CornerRadius="18,0,0,18" />
                <ScrollViewer VerticalScrollMode="Auto"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollMode="Disabled"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Padding="18,18,18,20" Spacing="14">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="3">
                                <TextBlock Text="SAVED SERIES"
                                           Style="{StaticResource KroiraLabelStyle}"
                                           Foreground="{StaticResource KroiraAccentBrush}" />
                                <TextBlock Text="Series details"
                                           Style="{StaticResource KroiraSectionTitleStyle}" />
                            </StackPanel>
                            <Button x:Name="CloseSeriesDetailButton"
                                    Grid.Column="1"
                                    Content="Close"
                                    Click="CloseSeriesDetail_Click"
                                    Style="{StaticResource KroiraGhostButtonStyle}"
                                    Padding="12,8"
                                    VerticalAlignment="Top" />
                        </Grid>

                        <Border MinHeight="232"
                                CornerRadius="14"
                                Background="{StaticResource KroiraMediaGradientBrush}"
                                BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Image Source="{x:Bind ViewModel.SelectedSeries.HeroArtworkUrl, Mode=OneWay, Converter={StaticResource UrlToImageSourceConverter}}"
                                       Stretch="UniformToFill"
                                       Opacity="0.72" />
                                <Border>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#44000000" Offset="0" />
                                            <GradientStop Color="#B0090B0F" Offset="0.52" />
                                            <GradientStop Color="#F0080A0D" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Grid Padding="16" ColumnSpacing="14" VerticalAlignment="Bottom">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="104" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="104"
                                            Height="154"
                                            CornerRadius="10"
                                            Background="{StaticResource KroiraPosterPlaceholderBrush}"
                                            BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                            BorderThickness="1">
                                        <Image Source="{x:Bind ViewModel.SelectedSeries.PosterUrl, Mode=OneWay, Converter={StaticResource UrlToImageSourceConverter}}"
                                               Stretch="UniformToFill" />
                                    </Border>
                                    <StackPanel Grid.Column="1"
                                                Spacing="6"
                                                VerticalAlignment="Bottom">
                                        <TextBlock Text="{x:Bind ViewModel.SelectedSeries.Title, Mode=OneWay}"
                                                   Style="{StaticResource KroiraSectionTitleStyle}"
                                                   FontSize="22"
                                                   MaxLines="2"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{x:Bind ViewModel.SelectedSeries.MetadataLine, Mode=OneWay}"
                                                   Style="{StaticResource KroiraBodyStyle}"
                                                   Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                                   MaxLines="1"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{x:Bind ViewModel.SelectedSeries.Overview, Mode=OneWay}"
                                                   Style="{StaticResource KroiraBodyStyle}"
                                                   FontSize="12"
                                                   LineHeight="17"
                                                   MaxLines="4"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Background="#3E111827"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                CornerRadius="12"
                                Padding="13">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="7">
                                    <TextBlock Text="SEASON"
                                               Style="{StaticResource KroiraLabelStyle}"
                                               Foreground="{StaticResource KroiraAccentBrush}" />
                                    <ComboBox x:Name="SeasonComboBox"
                                              Style="{StaticResource KroiraFilterComboBoxStyle}"
                                              ItemsSource="{x:Bind ViewModel.SelectedSeries.Seasons, Mode=OneWay}"
                                              SelectedItem="{x:Bind ViewModel.SelectedSeason, Mode=TwoWay}"
                                              HorizontalAlignment="Stretch">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding SeasonNumber}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                                <Button x:Name="PlaySelectedEpisodeButton"
                                        Grid.Column="1"
                                        Content="Play"
                                        Click="PlaySelectedEpisode_Click"
                                        Visibility="{x:Bind ViewModel.SelectedEpisodePlayVisibility, Mode=OneWay}"
                                        Style="{StaticResource KroiraPrimaryButtonStyle}"
                                        Padding="16,11"
                                        VerticalAlignment="Bottom" />
                                <Button Grid.Column="2"
                                        Content="Open Series page"
                                        Click="OpenSeriesPage_Click"
                                        Style="{StaticResource KroiraGhostButtonStyle}"
                                        Padding="14,11"
                                        VerticalAlignment="Bottom" />
                            </Grid>
                        </Border>

                        <controls:EmptyStateView IconGlyph="&#xE8A9;"
                                                 Title="No playable episodes"
                                                 Message="This saved series does not currently have playable episode data in the local library."
                                                 Visibility="{x:Bind ViewModel.SelectedSeriesEpisodesEmptyVisibility, Mode=OneWay}" />

                        <ListView x:Name="EpisodeList"
                                  Visibility="{x:Bind ViewModel.SelectedSeriesEpisodesVisibility, Mode=OneWay}"
                                  ItemsSource="{x:Bind ViewModel.SelectedSeason.Episodes, Mode=OneWay}"
                                  SelectionMode="Single"
                                  SelectionChanged="EpisodeList_SelectionChanged"
                                  KeyDown="EpisodeList_KeyDown"
                                  ItemContainerStyle="{StaticResource HubItemContainerStyle}"
                                  MaxHeight="330"
                                  Padding="0"
                                  ScrollViewer.VerticalScrollMode="Enabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#3E111827"
                                            BorderBrush="Transparent"
                                            BorderThickness="0"
                                            CornerRadius="10"
                                            Padding="12,10">
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Background="#24FFFFFF"
                                                    CornerRadius="6"
                                                    Padding="6,2"
                                                    MinWidth="28"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding EpisodeNumber}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                           HorizontalAlignment="Center" />
                                            </Border>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Title}"
                                                       Style="{StaticResource KroiraTitleStyle}"
                                                       FontSize="13"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />
                                            <FontIcon Grid.Column="2"
                                                      Glyph="&#xE102;"
                                                      FontSize="11"
                                                      Foreground="{StaticResource KroiraAccentBrush}"
                                                      VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
        </Grid>

        <Grid Visibility="{x:Bind ViewModel.SurfaceState.StateVisibility, Mode=OneWay}"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Margin="32">
            <controls:LoadingStateView Title="{x:Bind ViewModel.SurfaceState.Title, Mode=OneWay}"
                                       Message="{x:Bind ViewModel.SurfaceState.Message, Mode=OneWay}"
                                       Visibility="{x:Bind ViewModel.SurfaceState.LoadingStateVisibility, Mode=OneWay}" />
            <controls:EmptyStateView IconGlyph="{x:Bind ViewModel.SurfaceState.Glyph, Mode=OneWay}"
                                     Title="{x:Bind ViewModel.SurfaceState.Title, Mode=OneWay}"
                                     Message="{x:Bind ViewModel.SurfaceState.Message, Mode=OneWay}"
                                     PrimaryActionLabel="{x:Bind ViewModel.SurfaceState.ActionLabel, Mode=OneWay}"
                                     PrimaryActionVisibility="{x:Bind ViewModel.SurfaceState.ActionVisibility, Mode=OneWay}"
                                     Visibility="{x:Bind ViewModel.SurfaceState.EmptyStateVisibility, Mode=OneWay}"
                                     PrimaryActionClick="OpenSources_Click" />
            <controls:ErrorStateView IconGlyph="{x:Bind ViewModel.SurfaceState.Glyph, Mode=OneWay}"
                                     Title="{x:Bind ViewModel.SurfaceState.Title, Mode=OneWay}"
                                     Message="{x:Bind ViewModel.SurfaceState.Message, Mode=OneWay}"
                                     RetryActionLabel="Retry"
                                     DiagnosticsActionLabel="{x:Bind ViewModel.SurfaceState.ActionLabel, Mode=OneWay}"
                                     DiagnosticsActionVisibility="{x:Bind ViewModel.SurfaceState.DiagnosticsActionVisibility, Mode=OneWay}"
                                     Visibility="{x:Bind ViewModel.SurfaceState.ErrorStateVisibility, Mode=OneWay}"
                                     RetryClick="RetrySurface_Click"
                                     DiagnosticsClick="OpenSources_Click" />
        </Grid>
    </Grid>
</Page>
