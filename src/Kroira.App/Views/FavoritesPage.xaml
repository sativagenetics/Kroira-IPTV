<Page
    x:Class="Kroira.App.Views.FavoritesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  VerticalScrollMode="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  HorizontalScrollMode="Disabled">
        <Grid Padding="34,30,36,40" RowSpacing="24" MaxWidth="1220" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Page header -->
            <Grid Grid.Row="0" ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="10">
                    <Border Width="54"
                            Height="5"
                            Background="{StaticResource KroiraAccentGradientBrush}"
                            CornerRadius="3"
                            HorizontalAlignment="Left" />
                    <TextBlock Text="Favorites" Style="{StaticResource KroiraPageTitleStyle}" />
                    <TextBlock Text="Saved live channels for fast playback access."
                               Style="{StaticResource KroiraPageSubtitleStyle}"
                               MaxWidth="680" />
                </StackPanel>

                <Border Grid.Column="1"
                        Background="{StaticResource KroiraSurfaceSoftBrush}"
                        CornerRadius="8"
                        Padding="12,7"
                        VerticalAlignment="Center"
                        Visibility="{x:Bind ViewModel.ContentVisibility, Mode=OneWay}">
                    <TextBlock Text="{x:Bind ViewModel.FavoriteCountText, Mode=OneWay}"
                               Foreground="{StaticResource KroiraAccentBrush}"
                               FontSize="12"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>

            <!-- ══════ EMPTY STATE ══════ -->
            <Grid Grid.Row="1"
                  Visibility="{x:Bind ViewModel.EmptyVisibility, Mode=OneWay}"
                  ColumnSpacing="22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.35*" />
                    <ColumnDefinition Width="0.9*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource KroiraPanelStyle}" Padding="30">
                    <Grid RowSpacing="22">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Spacing="16">
                            <Border Width="58"
                                    Height="58"
                                    CornerRadius="14"
                                    Background="{StaticResource KroiraSurfaceElevatedBrush}"
                                    HorizontalAlignment="Left">
                                <FontIcon Glyph="&#xE734;" Foreground="{StaticResource KroiraGoldBrush}" FontSize="24" />
                            </Border>
                            <TextBlock Text="No saved channels yet" Style="{StaticResource KroiraSectionTitleStyle}" FontSize="26" />
                            <TextBlock Text="Mark channels as favorites from the Live TV browser and they will appear here as a focused lineup with quick playback access."
                                       Style="{StaticResource KroiraPageSubtitleStyle}"
                                       MaxWidth="560" />
                        </StackPanel>

                        <Grid Grid.Row="1" ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Background="{StaticResource KroiraSurfaceSoftBrush}"
                                    BorderBrush="{StaticResource KroiraGhostBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource KroiraRadiusCard}"
                                    Padding="16">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="How to save" Style="{StaticResource KroiraLabelStyle}" />
                                    <TextBlock Text="Open Live TV" Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock Text="Use the star on any channel tile to add it here." Style="{StaticResource KroiraBodyStyle}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Background="{StaticResource KroiraSurfaceSoftBrush}"
                                    BorderBrush="{StaticResource KroiraGhostBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource KroiraRadiusCard}"
                                    Padding="16">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Saved scope" Style="{StaticResource KroiraLabelStyle}" />
                                    <TextBlock Text="Live channels" Style="{StaticResource KroiraTitleStyle}" />
                                    <TextBlock Text="Favorites are kept as a clean launch surface for channel playback." Style="{StaticResource KroiraBodyStyle}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" Spacing="14">
                    <Border Style="{StaticResource KroiraPanelStyle}" Padding="22">
                        <StackPanel Spacing="10">
                            <Border Width="44" Height="44" CornerRadius="12"
                                    Background="{StaticResource KroiraSurfaceElevatedBrush}">
                                <FontIcon Glyph="&#xE102;" FontSize="18" Foreground="{StaticResource KroiraAccentBrush}" />
                            </Border>
                            <TextBlock Text="Fast access" Style="{StaticResource KroiraSectionTitleStyle}" />
                            <TextBlock Text="Saved channels appear with logos, live status, and a one-click remove action." Style="{StaticResource KroiraBodyStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KroiraPanelStyle}" Padding="22">
                        <StackPanel Spacing="10">
                            <Border Width="44" Height="44" CornerRadius="12"
                                    Background="{StaticResource KroiraSurfaceElevatedBrush}">
                                <FontIcon Glyph="&#xE714;" FontSize="18" Foreground="{StaticResource KroiraLiveDotBrush}" />
                            </Border>
                            <TextBlock Text="Live playback" Style="{StaticResource KroiraSectionTitleStyle}" />
                            <TextBlock Text="Selecting a favorite uses the same launch path as the Live TV browser." Style="{StaticResource KroiraBodyStyle}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ══════ CONTENT STATE ══════ -->
            <StackPanel Grid.Row="1"
                        Visibility="{x:Bind ViewModel.ContentVisibility, Mode=OneWay}"
                        Spacing="22">

                <!-- Featured channel hero -->
                <Border MinHeight="128"
                        CornerRadius="16"
                        BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                        BorderThickness="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1E2C38" Offset="0" />
                            <GradientStop Color="#0E1219" Offset="0.56" />
                            <GradientStop Color="#090B0F" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Border Width="5"
                                HorizontalAlignment="Left"
                                Background="{StaticResource KroiraAccentGradientBrush}"
                                CornerRadius="16,0,0,16" />
                        <Grid Padding="24,20" ColumnSpacing="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Channel logo -->
                            <Border Width="74"
                                    Height="74"
                                    CornerRadius="12"
                                    BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                    BorderThickness="1"
                                    VerticalAlignment="Center">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#1A2330" Offset="0" />
                                        <GradientStop Color="#0A0D12" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid>
                                    <FontIcon Glyph="&#xE714;"
                                              FontSize="24"
                                              Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                              Opacity="0.45" />
                                    <Image Source="{x:Bind ViewModel.FeaturedChannel.LogoUrl, Mode=OneWay, Converter={StaticResource UrlToImageSourceConverter}}"
                                           Stretch="Uniform"
                                           Margin="10" />
                                </Grid>
                            </Border>

                            <!-- Name + badge -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                                <TextBlock Text="QUICK PLAY"
                                           Style="{StaticResource KroiraLabelStyle}"
                                           Foreground="{StaticResource KroiraAccentBrush}" />
                                <TextBlock Text="{x:Bind ViewModel.FeaturedChannel.Name, Mode=OneWay}"
                                           Style="{StaticResource KroiraSectionTitleStyle}"
                                           FontSize="22"
                                           MaxLines="1"
                                           TextTrimming="CharacterEllipsis" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Background="{StaticResource KroiraStateDangerSoftBrush}"
                                            BorderBrush="#33FF5A5F"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="7,3">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <Ellipse Width="6" Height="6" Fill="{StaticResource KroiraLiveDotBrush}" />
                                            <TextBlock Text="LIVE"
                                                       Foreground="{StaticResource KroiraLiveDotBrush}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Text="Favorite channel"
                                               Style="{StaticResource KroiraMetaStyle}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Play button -->
                            <Button Grid.Column="2"
                                    x:Name="FeaturedPlayButton"
                                    Click="FeaturedChannel_Click"
                                    Style="{StaticResource KroiraPrimaryButtonStyle}"
                                    Padding="22,13"
                                    VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE102;" FontSize="13" />
                                    <TextBlock Text="Play" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Channels list + side panel -->
                <Grid ColumnSpacing="22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="268" />
                    </Grid.ColumnDefinitions>

                    <!-- Saved channels list -->
                    <Border Grid.Column="0" Style="{StaticResource KroiraPanelStyle}" Padding="0">
                        <Grid RowSpacing="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Padding="18,16,18,12" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="3">
                                    <TextBlock Text="Saved channels"
                                               Style="{StaticResource KroiraSectionTitleStyle}" />
                                    <TextBlock Text="Select a row to start playback. Remove only clears it from this saved list."
                                               Style="{StaticResource KroiraBodyStyle}" />
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Background="{StaticResource KroiraStateDangerSoftBrush}"
                                        BorderBrush="#33FF5A5F"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="8,4"
                                        VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <Ellipse Width="6" Height="6" Fill="{StaticResource KroiraLiveDotBrush}" VerticalAlignment="Center" />
                                        <TextBlock Text="LIVE"
                                                   Foreground="{StaticResource KroiraLiveDotBrush}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <ListView Grid.Row="1"
                                      ItemsSource="{x:Bind ViewModel.FavoriteChannels, Mode=OneWay}"
                                      SelectionMode="Single"
                                      SelectionChanged="ChannelList_SelectionChanged"
                                      ItemContainerStyle="{StaticResource KroiraMediaRowContainerStyle}"
                                      Padding="10,0,10,12">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource KroiraSurfaceSoftBrush}"
                                                CornerRadius="8"
                                                Padding="12,11">
                                            <Grid ColumnSpacing="14">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="56" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border Width="48"
                                                        Height="48"
                                                        CornerRadius="8"
                                                        Background="{StaticResource KroiraMediaGradientBrush}"
                                                        VerticalAlignment="Center">
                                                    <Grid>
                                                        <FontIcon Glyph="&#xE714;"
                                                                  Foreground="{StaticResource KroiraAccentBrush}"
                                                                  FontSize="16"
                                                                  Opacity="0.5" />
                                                        <Image Source="{Binding LogoUrl, Converter={StaticResource UrlToImageSourceConverter}}"
                                                               Stretch="Uniform"
                                                               Margin="6" />
                                                    </Grid>
                                                </Border>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                                    <TextBlock Text="{Binding Name}"
                                                               Style="{StaticResource KroiraTitleStyle}"
                                                               MaxLines="1"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <Ellipse Width="6" Height="6"
                                                                 Fill="{StaticResource KroiraLiveDotBrush}"
                                                                 VerticalAlignment="Center" />
                                                        <TextBlock Text="Favorite channel"
                                                                   Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                                                   FontSize="12" />
                                                    </StackPanel>
                                                </StackPanel>

                                                <Button Grid.Column="2"
                                                        Content="Remove"
                                                        Tag="{Binding Id}"
                                                        Click="RemoveFavorite_Click"
                                                        Style="{StaticResource KroiraDangerButtonStyle}"
                                                        FontSize="12"
                                                        VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <!-- Side info panels -->
                    <StackPanel Grid.Column="1" Spacing="14">

                        <!-- Count card -->
                        <Border Background="{StaticResource KroiraSurfaceElevatedBrush}"
                                BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="18,16">
                            <StackPanel Spacing="4">
                                <Border Height="4"
                                        Width="44"
                                        Background="{StaticResource KroiraGoldBrush}"
                                        CornerRadius="2"
                                        HorizontalAlignment="Left" />
                                <TextBlock Text="{x:Bind ViewModel.FavoriteCountText, Mode=OneWay}"
                                           Style="{StaticResource KroiraSectionTitleStyle}"
                                           FontSize="20"
                                           Margin="0,6,0,0" />
                                <TextBlock Text="in your saved lineup"
                                           Style="{StaticResource KroiraBodyStyle}" />
                            </StackPanel>
                        </Border>

                        <!-- Quick return description -->
                        <Border Style="{StaticResource KroiraPanelStyle}" Padding="18">
                            <StackPanel Spacing="10">
                                <Border Width="40" Height="40" CornerRadius="10"
                                        Background="{StaticResource KroiraSurfaceElevatedBrush}"
                                        HorizontalAlignment="Left">
                                    <FontIcon Glyph="&#xE734;" FontSize="17" Foreground="{StaticResource KroiraGoldBrush}" />
                                </Border>
                                <TextBlock Text="Built for quick return"
                                           Style="{StaticResource KroiraSectionTitleStyle}" />
                                <TextBlock Text="This lineup stays focused on live channels so the page behaves like a reliable fast-dial surface."
                                           Style="{StaticResource KroiraBodyStyle}" />
                            </StackPanel>
                        </Border>

                        <!-- Saved type -->
                        <Border Background="{StaticResource KroiraSurfaceSoftBrush}"
                                CornerRadius="10"
                                Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Saved type" Style="{StaticResource KroiraLabelStyle}" />
                                <TextBlock Text="Channels" Style="{StaticResource KroiraTitleStyle}" />
                                <TextBlock Text="Movie and series favorites can be added once the data path supports them safely."
                                           Style="{StaticResource KroiraBodyStyle}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>

        </Grid>
    </ScrollViewer>
</Page>
