<Page
    x:Class="Kroira.App.Views.ChannelBrowserPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Grid Padding="28" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource KroiraPanelStyle}">
        <StackPanel Spacing="16">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="Back" Click="Back_Click" Style="{StaticResource KroiraButtonStyle}" />
                <StackPanel>
                    <TextBlock Text="Browser" Style="{StaticResource KroiraPageTitleStyle}" />
                    <TextBlock Text="Source-level channel browser with guide-aware context." Style="{StaticResource KroiraPageSubtitleStyle}" />
                </StackPanel>
            </StackPanel>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Column="0" Style="{StaticResource KroiraComboBoxStyle}" ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}" DisplayMemberPath="Name" HorizontalAlignment="Stretch" />
                <TextBox Grid.Column="1" Style="{StaticResource KroiraTextBoxStyle}" PlaceholderText="Search channels..." Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
        </StackPanel>
        </Border>

        <GridView Grid.Row="1" ItemsSource="{x:Bind ViewModel.DisplayedChannels, Mode=OneWay}" SelectionMode="Single" SelectionChanged="ChannelList_SelectionChanged">
            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="Margin" Value="0,0,10,10" />
                </Style>
            </GridView.ItemContainerStyle>
            <GridView.ItemTemplate>
                <DataTemplate>
                    <Grid Width="332" Height="148" Padding="12" BorderBrush="{StaticResource KroiraBorderBrush}" BorderThickness="1" CornerRadius="16" ColumnSpacing="12">
                        <Grid.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#171E2E" Offset="0" />
                                <GradientStop Color="#101722" Offset="1" />
                            </LinearGradientBrush>
                        </Grid.Background>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="62" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="56" Height="56" CornerRadius="16" Background="{StaticResource KroiraMediaGradientBrush}" BorderBrush="#32B7B2FF" BorderThickness="1" VerticalAlignment="Top">
                            <Grid>
                                <FontIcon Glyph="&#xE714;" Foreground="{StaticResource KroiraAccentBrush}" FontSize="22" Opacity="0.54" />
                                <Image Source="{Binding LogoUrl, Converter={StaticResource UrlToImageSourceConverter}}" Stretch="Uniform" Margin="6" />
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Top" Spacing="5">
                            <TextBlock Text="{Binding Name}" TextWrapping="Wrap" MaxLines="1" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                            <TextBlock Text="{Binding CurrentProgramTitle}" Foreground="{StaticResource KroiraTextSecondaryBrush}" FontSize="12" MaxLines="1" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding GuideMetaText}" Visibility="{Binding GuideMetaVisibility}" Foreground="{StaticResource KroiraTextTertiaryBrush}" FontSize="11" MaxLines="2" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding CurrentProgramSubtitle}" Visibility="{Binding SubtitleVisibility}" Foreground="{StaticResource KroiraTextTertiaryBrush}" FontSize="11" MaxLines="1" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding CurrentProgramDescription}" Visibility="{Binding DescriptionVisibility}" Foreground="{StaticResource KroiraTextTertiaryBrush}" FontSize="11" MaxLines="1" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding CatchupBadgeText}" Visibility="{Binding CatchupVisibility}" Foreground="{StaticResource KroiraAccentBrush}" FontSize="11" FontWeight="SemiBold" MaxLines="1" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding CatchupStatusText}" Visibility="{Binding CatchupStatusVisibility}" Foreground="{StaticResource KroiraTextTertiaryBrush}" FontSize="11" MaxLines="2" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" />
                            <Grid Visibility="{Binding EpgVisibility}" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding CurrentProgramTimeText}" Foreground="{StaticResource KroiraGoldBrush}" FontSize="11" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="{Binding LiveProgressText}" Foreground="{StaticResource KroiraTextTertiaryBrush}" FontSize="11" />
                            </Grid>
                            <ProgressBar Value="{Binding LiveProgressValue}" Maximum="100" Visibility="{Binding EpgVisibility}" Height="4" Foreground="{StaticResource KroiraGoldBrush}" Background="#30364B" />
                            <Grid Visibility="{Binding NextProgramVisibility}" ColumnSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding NextProgramTitle}" Foreground="{StaticResource KroiraTextTertiaryBrush}" FontSize="11" MaxLines="1" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1" Text="{Binding NextProgramTimeText}" Foreground="{StaticResource KroiraTextTertiaryBrush}" FontSize="11" />
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="8" VerticalAlignment="Top">
                            <Button Content="Inspect"
                                    Click="InspectChannel_Click"
                                    Background="#141A29"
                                    Foreground="{StaticResource KroiraTextPrimaryBrush}"
                                    BorderBrush="{StaticResource KroiraBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    FontSize="11"
                                    Padding="8,4" />
                            <Button Content="{Binding FavoriteIcon}"
                                    Tag="{Binding Id}"
                                    Click="FavoriteToggle_Click"
                                    Background="#141A29"
                                    Foreground="{StaticResource KroiraGoldBrush}"
                                    BorderBrush="{StaticResource KroiraBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    FontSize="17"
                                    Padding="5,1"
                                    VerticalAlignment="Top" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Page>
