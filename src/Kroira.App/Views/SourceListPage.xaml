<Page
    x:Class="Kroira.App.Views.SourceListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <RelativePanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Saved Sources" Style="{ThemeResource TitleTextBlockStyle}" RelativePanel.AlignLeftWithPanel="True" RelativePanel.AlignVerticalCenterWithPanel="True"/>
            <StackPanel Orientation="Horizontal" Spacing="8" RelativePanel.AlignRightWithPanel="True" RelativePanel.AlignVerticalCenterWithPanel="True">
                <Button Content="Refresh" Command="{x:Bind ViewModel.LoadSourcesCommand}" />
                <Button Content="Add New Source" Click="AddNewSource_Click" Style="{ThemeResource AccentButtonStyle}" />
            </StackPanel>
        </RelativePanel>

        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Sources, Mode=OneWay}" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="12" Background="#11FFFFFF" CornerRadius="4" Margin="0,0,0,8" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="16" />
                            <TextBlock Text="{Binding Type}" Foreground="Gray" FontSize="12" />
                            <TextBlock Text="{Binding Status}" Foreground="LimeGreen" FontSize="12" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button Content="Browse" Tag="{Binding Id}" Click="BrowseSource_Click" Visibility="{Binding BrowseVisibility}" />
                            <Button Content="Import / Parse" Tag="{Binding Id}" Click="ParseSource_Click" Visibility="{Binding ParseVisibility}" />
                            <Button Content="Sync EPG" Tag="{Binding Id}" Click="SyncEpgSource_Click" Visibility="{Binding SyncEpgVisibility}" />
                            <Button Content="Sync Xtream Live" Tag="{Binding Id}" Click="SyncXtreamSource_Click" Visibility="{Binding SyncXtreamVisibility}" />
                            <Button Content="Sync Xtream VOD" Tag="{Binding Id}" Click="SyncXtreamVodSource_Click" Visibility="{Binding SyncXtreamVisibility}" />
                            <Button Content="Delete" Tag="{Binding Id}" Click="DeleteSource_Click" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Margin" Value="0,0,0,4" />
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>
    </Grid>
</Page>
