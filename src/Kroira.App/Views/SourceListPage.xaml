<Page
    x:Class="Kroira.App.Views.SourceListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Kroira.App.Controls"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Page.Resources>
        <Style x:Key="SourceConsoleCardStyle" TargetType="Border" BasedOn="{StaticResource KroiraCardStyle}">
            <Setter Property="Background" Value="#DC11141A" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="SourceShellCardStyle" TargetType="Border" BasedOn="{StaticResource KroiraRowStyle}">
            <Setter Property="Background" Value="#DC12161D" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="SourceSearchBoxStyle" TargetType="TextBox" BasedOn="{StaticResource KroiraTextBoxStyle}">
            <Setter Property="MinWidth" Value="280" />
            <Setter Property="Padding" Value="42,10,14,10" />
        </Style>

        <Style x:Key="SourceMetricLabelStyle" TargetType="TextBlock">
            <Setter Property="Style" Value="{StaticResource KroiraLabelStyle}" />
            <Setter Property="Opacity" Value="0.78" />
        </Style>

        <Style x:Key="SourceMetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="27" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
        </Style>

        <Style x:Key="SourceMiniLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource KroiraTextTertiaryBrush}" />
            <Setter Property="CharacterSpacing" Value="70" />
        </Style>

        <Style x:Key="SourceMiniValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
        </Style>

        <Style x:Key="SourceActivityHeaderStyle" TargetType="TextBlock">
            <Setter Property="Style" Value="{StaticResource KroiraLabelStyle}" />
            <Setter Property="Opacity" Value="0.72" />
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
        <Grid Padding="28" RowSpacing="18" Background="{StaticResource KroiraPageAtmosphereBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="380" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Text="Sources Management"
                    Style="{StaticResource KroiraLabelStyle}"
                    VerticalAlignment="Center" />

                <Grid Grid.Column="1" VerticalAlignment="Center">
                    <TextBox
                        Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Search provider or XMLTV URL..."
                        Style="{StaticResource SourceSearchBoxStyle}" />
                    <FontIcon
                        Glyph="&#xE721;"
                        Foreground="{StaticResource KroiraTextTertiaryBrush}"
                        Margin="14,0,0,0"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left" />
                </Grid>
            </Grid>

            <Grid Grid.Row="1" ColumnSpacing="28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="8">
                    <TextBlock
                        Text="SYSTEM REPOSITORY"
                        Style="{StaticResource KroiraLabelStyle}" />
                    <TextBlock
                        Text="Library Sources"
                        Style="{StaticResource KroiraPageTitleStyle}" />
                    <TextBlock
                        Text="Manage content delivery endpoints, live sync health, guide integrity, and provider diagnostics without changing existing source behavior."
                        Style="{StaticResource KroiraPageSubtitleStyle}"
                        MaxWidth="760" />
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="10"
                    VerticalAlignment="Center">
                    <Button
                        Content="Refresh"
                        Command="{x:Bind ViewModel.LoadSourcesCommand}"
                        Style="{StaticResource KroiraGhostButtonStyle}" />
                    <Button
                        Content="+ Add Source"
                        Click="AddNewSource_Click"
                        Style="{StaticResource KroiraPrimaryButtonStyle}" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2" ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource SourceConsoleCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="ACTIVE SOURCES" Style="{StaticResource SourceMetricLabelStyle}" />
                        <TextBlock Text="{x:Bind ViewModel.SourceCount, Mode=OneWay, Converter={StaticResource NumberFormatConverter}}" Style="{StaticResource SourceMetricValueStyle}" />
                        <TextBlock Style="{StaticResource KroiraBodyStyle}">
                            <Run Text="{x:Bind ViewModel.M3uSourceCount, Mode=OneWay, Converter={StaticResource NumberFormatConverter}}" />
                            <Run Text=" M3U / " />
                            <Run Text="{x:Bind ViewModel.XtreamSourceCount, Mode=OneWay, Converter={StaticResource NumberFormatConverter}}" />
                            <Run Text=" Xtream" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource SourceConsoleCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="HEALTH STATUS" Style="{StaticResource SourceMetricLabelStyle}" />
                        <controls:StatusPill Label="{x:Bind ViewModel.HealthStatusHeadline, Mode=OneWay}" Kind="{x:Bind ViewModel.HealthStatusKind, Mode=OneWay}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.HealthStatusCaption, Mode=OneWay}"
                            Style="{StaticResource KroiraBodyStyle}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource SourceConsoleCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="TOTAL ASSETS" Style="{StaticResource SourceMetricLabelStyle}" />
                        <TextBlock Text="{x:Bind ViewModel.TotalAssetCount, Mode=OneWay, Converter={StaticResource NumberFormatConverter}}" Style="{StaticResource SourceMetricValueStyle}" />
                        <TextBlock
                            Text="Indexed across live, movies, and series"
                            Style="{StaticResource KroiraBodyStyle}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource SourceConsoleCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="GUIDE COVERAGE" Style="{StaticResource SourceMetricLabelStyle}" />
                        <TextBlock Text="{x:Bind ViewModel.GuideCoverageHeadline, Mode=OneWay}" Style="{StaticResource SourceMetricValueStyle}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.GuideCoverageCaption, Mode=OneWay}"
                            Style="{StaticResource KroiraBodyStyle}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="3" RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    Text="Managed Sources"
                    Style="{StaticResource KroiraSectionTitleStyle}" />

                <ItemsControl
                    Grid.Row="1"
                    ItemsSource="{x:Bind ViewModel.Sources, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource SourceShellCardStyle}" Margin="0,0,0,14">
                                <Grid ColumnSpacing="18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="260" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="220" />
                                    </Grid.ColumnDefinitions>

                                    <Border
                                        Background="#7A151B22"
                                        BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="16">
                                        <StackPanel Spacing="14">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="46" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Border
                                                    Width="46"
                                                    Height="46"
                                                    CornerRadius="10"
                                                    Background="{StaticResource KroiraSurfaceHighBrush}">
                                                    <TextBlock
                                                        Text="{Binding Type}"
                                                        FontSize="11"
                                                        FontWeight="SemiBold"
                                                        Foreground="{StaticResource KroiraAccentBrush}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center" />
                                                </Border>

                                                <StackPanel Grid.Column="1" Spacing="3">
                                                    <TextBlock
                                                        Text="{Binding Name}"
                                                        Style="{StaticResource KroiraTitleStyle}"
                                                        FontSize="17"
                                                        TextTrimming="CharacterEllipsis" />
                                                    <TextBlock
                                                        Text="{Binding SourceKindText}"
                                                        Style="{StaticResource KroiraLabelStyle}" />
                                                </StackPanel>
                                            </Grid>

                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <controls:StatusPill Label="{Binding HealthBadgeText}" Kind="{Binding HealthPillKind}" />
                                                <controls:StatusPill Label="{Binding GuideBadgeText}" Kind="{Binding GuidePillKind}" />
                                            </StackPanel>

                                            <TextBlock
                                                Text="{Binding SourcePanelSummaryText}"
                                                Style="{StaticResource KroiraBodyStyle}"
                                                MaxLines="3"
                                                TextWrapping="WrapWholeWords"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Grid.Column="1" Spacing="16" VerticalAlignment="Center">
                                        <Grid ColumnSpacing="18">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Spacing="4">
                                                <TextBlock Text="LIVE CHANNELS" Style="{StaticResource SourceMiniLabelStyle}" />
                                                <TextBlock Text="{Binding ChannelCount, Converter={StaticResource NumberFormatConverter}}" Style="{StaticResource SourceMiniValueStyle}" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Spacing="4">
                                                <TextBlock Text="VOD / SERIES" Style="{StaticResource SourceMiniLabelStyle}" />
                                                <TextBlock Style="{StaticResource SourceMiniValueStyle}">
                                                    <Run Text="{Binding MovieCount, Converter={StaticResource NumberFormatConverter}}" />
                                                    <Run Text=" / " />
                                                    <Run Text="{Binding SeriesCount, Converter={StaticResource NumberFormatConverter}}" />
                                                </TextBlock>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" Spacing="4">
                                                <TextBlock Text="LAST SYNC" Style="{StaticResource SourceMiniLabelStyle}" />
                                                <TextBlock Text="{Binding LastSyncText}" Style="{StaticResource SourceMiniValueStyle}" />
                                                <TextBlock Text="{Binding LastSuccessfulSyncText}" Style="{StaticResource KroiraBodyStyle}" MaxLines="2" TextWrapping="WrapWholeWords" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="3" Spacing="4">
                                                <TextBlock Text="CONNECTION" Style="{StaticResource SourceMiniLabelStyle}" />
                                                <controls:StatusPill Label="{Binding ConnectionLabelText}" Kind="{Binding GuidePillKind}" />
                                            </StackPanel>
                                        </Grid>

                                        <Grid ColumnSpacing="18">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Spacing="5">
                                                <TextBlock Text="{Binding Status}" Style="{StaticResource KroiraBodyStyle}" MaxLines="2" TextWrapping="WrapWholeWords" />
                                                <TextBlock Text="{Binding ImportResultText}" Style="{StaticResource KroiraBodyStyle}" MaxLines="1" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding EpgCoverageText}" Style="{StaticResource KroiraBodyStyle}" MaxLines="1" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Visibility="{Binding ParseWarningsVisibility}" Text="{Binding ParseWarningsText}" Foreground="{StaticResource KroiraGoldBrush}" FontSize="11" MaxLines="2" TextWrapping="WrapWholeWords" />
                                                <TextBlock Visibility="{Binding NetworkFailureVisibility}" Text="{Binding NetworkFailureText}" Foreground="{StaticResource KroiraLiveDotBrush}" FontSize="11" MaxLines="2" TextWrapping="WrapWholeWords" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Spacing="5">
                                                <TextBlock Text="{Binding GuideStatusText}" Style="{StaticResource KroiraBodyStyle}" MaxLines="1" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding GuideModeText}" Style="{StaticResource KroiraBodyStyle}" MaxLines="1" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Visibility="{Binding GuideUrlVisibility}" Text="{Binding GuideUrlText}" Style="{StaticResource KroiraBodyStyle}" MaxLines="2" TextWrapping="WrapWholeWords" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Visibility="{Binding GuideMatchVisibility}" Text="{Binding GuideMatchText}" Style="{StaticResource KroiraBodyStyle}" MaxLines="2" TextWrapping="WrapWholeWords" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Visibility="{Binding GuideStatusSummaryVisibility}" Text="{Binding GuideStatusSummaryText}" Style="{StaticResource KroiraBodyStyle}" MaxLines="2" TextWrapping="WrapWholeWords" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Spacing="10" VerticalAlignment="Center">
                                        <Button
                                            Content="{Binding PrimarySyncText}"
                                            Tag="{Binding Id}"
                                            Click="SyncSource_Click"
                                            Visibility="{Binding PrimarySyncVisibility}"
                                            Style="{StaticResource KroiraPrimaryButtonStyle}" />
                                        <Button
                                            Content="Guide Sync"
                                            Tag="{Binding Id}"
                                            Click="SyncEpgSource_Click"
                                            Visibility="{Binding SyncEpgVisibility}"
                                            IsEnabled="{Binding IsEpgSyncEnabled}"
                                            Style="{StaticResource KroiraGhostButtonStyle}" />
                                        <Button
                                            Content="Browse"
                                            Tag="{Binding Id}"
                                            Click="BrowseSource_Click"
                                            Visibility="{Binding BrowseVisibility}"
                                            Style="{StaticResource KroiraButtonStyle}" />
                                        <Button
                                            Content="Guide"
                                            Tag="{Binding Id}"
                                            Click="EditGuideSettings_Click"
                                            Visibility="{Binding SyncEpgVisibility}"
                                            Style="{StaticResource KroiraButtonStyle}" />
                                        <Button
                                            Content="VOD Only"
                                            Tag="{Binding Id}"
                                            Click="SyncXtreamVodSource_Click"
                                            Visibility="{Binding XtreamVodOnlyVisibility}"
                                            Style="{StaticResource KroiraButtonStyle}" />
                                        <Button
                                            Content="Delete"
                                            Tag="{Binding Id}"
                                            Click="DeleteSource_Click"
                                            Style="{StaticResource KroiraDangerButtonStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border
                    Grid.Row="2"
                    Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
                    Style="{StaticResource SourceConsoleCardStyle}"
                    MaxWidth="620"
                    HorizontalAlignment="Center">
                    <StackPanel Spacing="12">
                        <FontIcon
                            Glyph="&#xE8F1;"
                            Foreground="{StaticResource KroiraAccentBrush}"
                            FontSize="28"
                            HorizontalAlignment="Left" />
                        <TextBlock
                            Text="{x:Bind ViewModel.EmptyStateTitle, Mode=OneWay}"
                            Style="{StaticResource KroiraSectionTitleStyle}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.EmptyStateMessage, Mode=OneWay}"
                            Style="{StaticResource KroiraBodyStyle}"
                            TextWrapping="WrapWholeWords" />
                        <Button
                            Content="Add Source"
                            Click="AddNewSource_Click"
                            Style="{StaticResource KroiraPrimaryButtonStyle}"
                            HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="4" Style="{StaticResource SourceConsoleCardStyle}">
                <StackPanel Spacing="18">
                    <TextBlock
                        Text="Recent Sync Activity"
                        Style="{StaticResource KroiraSectionTitleStyle}" />

                    <Grid ColumnSpacing="16" Padding="4,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="190" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Timestamp" Style="{StaticResource SourceActivityHeaderStyle}" />
                        <TextBlock Grid.Column="1" Text="Source Name" Style="{StaticResource SourceActivityHeaderStyle}" />
                        <TextBlock Grid.Column="2" Text="Action" Style="{StaticResource SourceActivityHeaderStyle}" />
                        <TextBlock Grid.Column="3" Text="Status" Style="{StaticResource SourceActivityHeaderStyle}" />
                        <TextBlock Grid.Column="4" Text="Payload" Style="{StaticResource SourceActivityHeaderStyle}" />
                    </Grid>

                    <ItemsControl ItemsSource="{x:Bind ViewModel.RecentActivities, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Background="#8C11141A"
                                    BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="12,10"
                                    Margin="0,0,0,10">
                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="170" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="190" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding TimestampText}" Style="{StaticResource KroiraBodyStyle}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SourceName}" Style="{StaticResource KroiraBodyStyle}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2" Text="{Binding ActionText}" Style="{StaticResource KroiraBodyStyle}" TextTrimming="CharacterEllipsis" />
                                        <controls:StatusPill Grid.Column="3" Label="{Binding StatusText}" Kind="{Binding StatusKind}" />
                                        <TextBlock Grid.Column="4" Text="{Binding PayloadText}" Style="{StaticResource KroiraBodyStyle}" TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
