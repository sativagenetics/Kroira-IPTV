<Page
    x:Class="Kroira.App.Views.SourceListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Kroira.App.Controls"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Page.Resources>
        <Style x:Key="SourceDashboardCardStyle" TargetType="Border" BasedOn="{StaticResource KroiraCardStyle}">
            <Setter Property="Background" Value="#D911151B" />
            <Setter Property="BorderBrush" Value="{StaticResource KroiraGlassBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <Style x:Key="SourceSummaryCardStyle" TargetType="Border" BasedOn="{StaticResource SourceDashboardCardStyle}">
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="SourceShellCardStyle" TargetType="Border" BasedOn="{StaticResource SourceDashboardCardStyle}">
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="SourceSearchBoxStyle" TargetType="TextBox" BasedOn="{StaticResource KroiraTextBoxStyle}">
            <Setter Property="MinWidth" Value="320" />
            <Setter Property="Padding" Value="42,11,14,11" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>

        <Style x:Key="SourceActionSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource KroiraGhostButtonStyle}">
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>

        <Style x:Key="SourceActionQuietButtonStyle" TargetType="Button" BasedOn="{StaticResource KroiraButtonStyle}">
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>

        <Style x:Key="SourceMetricLabelStyle" TargetType="TextBlock">
            <Setter Property="Style" Value="{StaticResource KroiraLabelStyle}" />
            <Setter Property="Opacity" Value="0.74" />
        </Style>

        <Style x:Key="SourceMetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="30" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
        </Style>

        <Style x:Key="SourceMiniLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource KroiraTextTertiaryBrush}" />
            <Setter Property="CharacterSpacing" Value="65" />
        </Style>

        <Style x:Key="SourceMiniValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
        </Style>

        <Style x:Key="SourceMetricChipStyle" TargetType="Border">
            <Setter Property="Background" Value="#8611161E" />
            <Setter Property="BorderBrush" Value="{StaticResource KroiraChromeLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14,12" />
        </Style>

        <Style x:Key="SourceDetailPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="#8C10141B" />
            <Setter Property="BorderBrush" Value="{StaticResource KroiraChromeLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14,12" />
        </Style>

        <Style x:Key="SourceActivityCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#9611161E" />
            <Setter Property="BorderBrush" Value="{StaticResource KroiraGlassBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14,12" />
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
        <Grid Background="{StaticResource KroiraPageAtmosphereBrush}">
            <Grid MaxWidth="1480"
                  HorizontalAlignment="Center"
                  Padding="32,28,32,36"
                  RowSpacing="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="8">
                        <TextBlock Text="CONTENT DELIVERY"
                                   Style="{StaticResource KroiraLabelStyle}"
                                   Foreground="{StaticResource KroiraAccentBrush}" />
                        <TextBlock Text="Sources"
                                   Style="{StaticResource KroiraPageTitleStyle}" />
                        <TextBlock Text="Monitor source health, guide coverage, and recent sync activity."
                                   Style="{StaticResource KroiraPageSubtitleStyle}"
                                   MaxWidth="760" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Spacing="12"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Right">
                        <Grid>
                            <TextBox Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="Search sources, guide mode, or health"
                                     Style="{StaticResource SourceSearchBoxStyle}" />
                            <FontIcon Glyph="&#xE721;"
                                      Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                      Margin="14,0,0,0"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Left" />
                        </Grid>

                        <StackPanel Orientation="Horizontal"
                                    Spacing="10"
                                    HorizontalAlignment="Right">
                            <Button Command="{x:Bind ViewModel.LoadSourcesCommand}"
                                    Style="{StaticResource SourceActionSecondaryButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE72C;" FontSize="12" />
                                    <TextBlock Text="Refresh" />
                                </StackPanel>
                            </Button>
                            <Button Click="AddNewSource_Click"
                                    Style="{StaticResource KroiraPrimaryButtonStyle}"
                                    Padding="18,10">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE710;" FontSize="12" />
                                    <TextBlock Text="Add Source" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource SourceSummaryCardStyle}">
                        <Grid RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="ACTIVE SOURCES" Style="{StaticResource SourceMetricLabelStyle}" />
                            <FontIcon Grid.Column="1" Glyph="&#xE8FD;" Foreground="{StaticResource KroiraAccentBrush}" FontSize="15" />
                            <TextBlock Grid.Row="1"
                                       Text="{x:Bind ViewModel.SourceCount, Mode=OneWay, Converter={StaticResource NumberFormatConverter}}"
                                       Style="{StaticResource SourceMetricValueStyle}" />
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                                <controls:StatusPill Label="{x:Bind ViewModel.M3uSourceCountLabel, Mode=OneWay}" Kind="Neutral" />
                                <controls:StatusPill Label="{x:Bind ViewModel.XtreamSourceCountLabel, Mode=OneWay}" Kind="Neutral" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource SourceSummaryCardStyle}">
                        <Grid RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="SYSTEM HEALTH" Style="{StaticResource SourceMetricLabelStyle}" />
                            <FontIcon Grid.Column="1" Glyph="&#xE73E;" Foreground="{StaticResource KroiraAccentBrush}" FontSize="15" />
                            <controls:StatusPill Grid.Row="1"
                                                 Label="{x:Bind ViewModel.HealthStatusHeadline, Mode=OneWay}"
                                                 Kind="{x:Bind ViewModel.HealthStatusKind, Mode=OneWay}" />
                            <TextBlock Grid.Row="2"
                                       Text="{x:Bind ViewModel.HealthStatusCaption, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       TextWrapping="WrapWholeWords" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource SourceSummaryCardStyle}">
                        <Grid RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="CATALOG INDEX" Style="{StaticResource SourceMetricLabelStyle}" />
                            <FontIcon Grid.Column="1" Glyph="&#xE8D2;" Foreground="{StaticResource KroiraAccentBrush}" FontSize="15" />
                            <TextBlock Grid.Row="1"
                                       Text="{x:Bind ViewModel.TotalAssetCount, Mode=OneWay, Converter={StaticResource NumberFormatConverter}}"
                                       Style="{StaticResource SourceMetricValueStyle}" />
                            <TextBlock Grid.Row="2" Style="{StaticResource KroiraBodyStyle}">
                                <Run Text="{x:Bind ViewModel.TotalLiveChannelCount, Mode=OneWay, Converter={StaticResource NumberFormatConverter}}" />
                                <Run Text=" live / " />
                                <Run Text="{x:Bind ViewModel.TotalLibraryAssetCount, Mode=OneWay, Converter={StaticResource NumberFormatConverter}}" />
                                <Run Text=" library" />
                            </TextBlock>
                        </Grid>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource SourceSummaryCardStyle}">
                        <Grid RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="GUIDE COVERAGE" Style="{StaticResource SourceMetricLabelStyle}" />
                            <FontIcon Grid.Column="1" Glyph="&#xE787;" Foreground="{StaticResource KroiraAccentBrush}" FontSize="15" />
                            <TextBlock Grid.Row="1"
                                       Text="{x:Bind ViewModel.GuideCoverageHeadline, Mode=OneWay}"
                                       Style="{StaticResource SourceMetricValueStyle}" />
                            <ProgressBar Grid.Row="2"
                                         Value="{x:Bind ViewModel.GuideCoveragePercent, Mode=OneWay}"
                                         Maximum="100"
                                         Height="6"
                                         Foreground="{StaticResource KroiraAccentBrush}"
                                         Background="#18FFFFFF" />
                            <TextBlock Grid.Row="3"
                                       Text="{x:Bind ViewModel.GuideCoverageCaption, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       TextWrapping="WrapWholeWords" />
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="2" ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock Text="MANAGED SOURCES"
                                   Style="{StaticResource KroiraLabelStyle}"
                                   Foreground="{StaticResource KroiraAccentBrush}" />
                        <TextBlock Text="Source Overview"
                                   Style="{StaticResource KroiraSectionTitleStyle}" />
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Text="{x:Bind ViewModel.ConfiguredSourceCountText, Mode=OneWay}"
                               Style="{StaticResource KroiraBodyStyle}"
                               VerticalAlignment="Center" />
                </Grid>

                <Grid Grid.Row="3" RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ItemsControl ItemsSource="{x:Bind ViewModel.Sources, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource SourceShellCardStyle}" Margin="0,0,0,14">
                                <Grid RowSpacing="16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid ColumnSpacing="18">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Grid ColumnSpacing="14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="54" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Width="54"
                                                    Height="54"
                                                    CornerRadius="14"
                                                    Background="#8C151B22"
                                                    BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <FontIcon Glyph="&#xE774;"
                                                              FontSize="16"
                                                              Foreground="{StaticResource KroiraAccentBrush}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding Type}"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Margin="0,0,0,7"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Bottom"
                                                               Foreground="{StaticResource KroiraTextTertiaryBrush}" />
                                                </Grid>
                                            </Border>

                                            <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <TextBlock Text="{Binding Name}"
                                                               Style="{StaticResource KroiraTitleStyle}"
                                                               FontSize="18"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <controls:StatusPill Label="{Binding HealthBadgeText}" Kind="{Binding HealthPillKind}" />
                                                    <controls:StatusPill Label="{Binding GuideBadgeText}" Kind="{Binding GuidePillKind}" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding SourceKindText}"
                                                           Style="{StaticResource KroiraLabelStyle}" />
                                                <TextBlock Text="{Binding OperationalSummaryText}"
                                                           Style="{StaticResource KroiraBodyStyle}"
                                                           MaxLines="2"
                                                           TextWrapping="WrapWholeWords"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>

                                        <StackPanel Grid.Column="1"
                                                    Spacing="8"
                                                    VerticalAlignment="Top">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="8"
                                                        HorizontalAlignment="Right">
                                                <Button Tag="{Binding Id}"
                                                        Click="SyncSource_Click"
                                                        Visibility="{Binding PrimarySyncVisibility}"
                                                        Style="{StaticResource KroiraPrimaryButtonStyle}"
                                                        Padding="18,10">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon Glyph="&#xE895;" FontSize="12" />
                                                        <TextBlock Text="{Binding PrimarySyncText}" />
                                                    </StackPanel>
                                                </Button>

                                                <Button Tag="{Binding Id}"
                                                        Click="BrowseSource_Click"
                                                        Visibility="{Binding BrowseVisibility}"
                                                        Style="{StaticResource SourceActionSecondaryButtonStyle}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon Glyph="&#xE8B6;" FontSize="12" />
                                                        <TextBlock Text="Browse" />
                                                    </StackPanel>
                                                </Button>

                                                <Button Tag="{Binding Id}"
                                                        Click="EditGuideSettings_Click"
                                                        Visibility="{Binding SyncEpgVisibility}"
                                                        Style="{StaticResource SourceActionQuietButtonStyle}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon Glyph="&#xE787;" FontSize="12" />
                                                        <TextBlock Text="Guide" />
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>

                                            <Button HorizontalAlignment="Right"
                                                    Style="{StaticResource SourceActionQuietButtonStyle}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <FontIcon Glyph="&#xE712;" FontSize="12" />
                                                    <TextBlock Text="More" />
                                                </StackPanel>
                                                <Button.Flyout>
                                                    <MenuFlyout>
                                                        <MenuFlyoutItem Text="Guide Sync"
                                                                        Tag="{Binding Id}"
                                                                        Click="SyncEpgSource_Click"
                                                                        Visibility="{Binding SyncEpgVisibility}"
                                                                        IsEnabled="{Binding IsEpgSyncEnabled}">
                                                            <MenuFlyoutItem.Icon>
                                                                <FontIcon Glyph="&#xE787;" />
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                        <MenuFlyoutItem Text="VOD Only"
                                                                        Tag="{Binding Id}"
                                                                        Click="SyncXtreamVodSource_Click"
                                                                        Visibility="{Binding XtreamVodOnlyVisibility}">
                                                            <MenuFlyoutItem.Icon>
                                                                <FontIcon Glyph="&#xE7C3;" />
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                        <MenuFlyoutSeparator />
                                                        <MenuFlyoutItem Text="Delete Source"
                                                                        Tag="{Binding Id}"
                                                                        Click="DeleteSource_Click">
                                                            <MenuFlyoutItem.Icon>
                                                                <FontIcon Glyph="&#xE74D;" />
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                    </MenuFlyout>
                                                </Button.Flyout>
                                            </Button>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="1" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="1.3*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Style="{StaticResource SourceMetricChipStyle}">
                                            <StackPanel Spacing="5">
                                                <TextBlock Text="LIVE CHANNELS" Style="{StaticResource SourceMiniLabelStyle}" />
                                                <TextBlock Text="{Binding ChannelCount, Converter={StaticResource NumberFormatConverter}}" Style="{StaticResource SourceMiniValueStyle}" />
                                                <TextBlock Text="{Binding ConnectionLabelText}" Style="{StaticResource KroiraBodyStyle}" MaxLines="1" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="1" Style="{StaticResource SourceMetricChipStyle}">
                                            <StackPanel Spacing="5">
                                                <TextBlock Text="CATALOG" Style="{StaticResource SourceMiniLabelStyle}" />
                                                <TextBlock Text="{Binding CatalogAssetCount, Converter={StaticResource NumberFormatConverter}}" Style="{StaticResource SourceMiniValueStyle}" />
                                                <TextBlock Style="{StaticResource KroiraBodyStyle}">
                                                    <Run Text="{Binding MovieCount, Converter={StaticResource NumberFormatConverter}}" />
                                                    <Run Text=" movies / " />
                                                    <Run Text="{Binding SeriesCount, Converter={StaticResource NumberFormatConverter}}" />
                                                    <Run Text=" series" />
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2" Style="{StaticResource SourceMetricChipStyle}">
                                            <StackPanel Spacing="5">
                                                <TextBlock Text="LAST SUCCESS" Style="{StaticResource SourceMiniLabelStyle}" />
                                                <TextBlock Text="{Binding LastSyncText}" Style="{StaticResource SourceMiniValueStyle}" />
                                                <TextBlock Style="{StaticResource KroiraBodyStyle}" MaxLines="1" TextTrimming="CharacterEllipsis">
                                                    <Run Text="Last attempt " />
                                                    <Run Text="{Binding LastAttemptText}" />
                                                </TextBlock>
                                                <TextBlock Text="{Binding LastSuccessfulSyncText}" Style="{StaticResource KroiraBodyStyle}" MaxLines="2" TextTrimming="CharacterEllipsis" TextWrapping="WrapWholeWords" />
                                                <TextBlock Text="{Binding AutoRefreshSummaryText}"
                                                           Visibility="{Binding AutoRefreshSummaryVisibility}"
                                                           Style="{StaticResource KroiraBodyStyle}"
                                                           Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                                           MaxLines="2"
                                                           TextWrapping="WrapWholeWords"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="3" Style="{StaticResource SourceMetricChipStyle}">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="GUIDE MAPPING" Style="{StaticResource SourceMiniLabelStyle}" />
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding GuideCoverageRatioText}" Style="{StaticResource SourceMiniValueStyle}" />
                                                    <controls:StatusPill Label="{Binding GuideBadgeText}" Kind="{Binding GuidePillKind}" />
                                                </StackPanel>
                                                <ProgressBar Value="{Binding GuideCoveragePercent}"
                                                             Maximum="100"
                                                             Height="6"
                                                             Foreground="{StaticResource KroiraAccentBrush}"
                                                             Background="#18FFFFFF"
                                                             Visibility="{Binding GuideCoverageVisibility}" />
                                                <TextBlock Text="{Binding GuideCoverageSecondaryText}" Style="{StaticResource KroiraBodyStyle}" MaxLines="1" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Grid Grid.Row="2" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.2*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Style="{StaticResource SourceDetailPanelStyle}">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="HEALTH SUMMARY" Style="{StaticResource SourceMiniLabelStyle}" />
                                                <TextBlock Text="{Binding Status}" Style="{StaticResource KroiraBodyStyle}" MaxLines="3" TextWrapping="WrapWholeWords" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding ValidationResultText}" Visibility="{Binding ValidationVisibility}" Style="{StaticResource KroiraBodyStyle}" MaxLines="3" TextWrapping="WrapWholeWords" TextTrimming="CharacterEllipsis" />
                                                <ItemsControl ItemsSource="{Binding HealthComponents}" Visibility="{Binding HealthComponentsVisibility}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="3" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <controls:StatusPill Label="{Binding PillLabel}" Kind="{Binding PillKind}" Margin="0,0,8,8" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <TextBlock Text="{Binding ValidationScoreText}" Style="{StaticResource KroiraBodyStyle}" Foreground="{StaticResource KroiraTextSecondaryBrush}" MaxLines="1" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding OperationalStatusText}"
                                                           Visibility="{Binding OperationalStatusVisibility}"
                                                           Style="{StaticResource KroiraBodyStyle}"
                                                           Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                                           MaxLines="2"
                                                           TextWrapping="WrapWholeWords"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="1" Style="{StaticResource SourceDetailPanelStyle}">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="GUIDE SNAPSHOT" Style="{StaticResource SourceMiniLabelStyle}" />
                                                <TextBlock Text="{Binding GuideStatusText}" Style="{StaticResource KroiraBodyStyle}" FontWeight="SemiBold" MaxLines="1" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding EpgCoverageText}" Style="{StaticResource KroiraBodyStyle}" MaxLines="2" TextWrapping="WrapWholeWords" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding ProxyStatusText}"
                                                           Visibility="{Binding ProxyStatusVisibility}"
                                                           Style="{StaticResource KroiraBodyStyle}"
                                                           Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                                           MaxLines="2"
                                                           TextWrapping="WrapWholeWords"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Expander Grid.Row="3" Header="Health and guide details">
                                        <Grid Margin="0,12,0,0" ColumnSpacing="16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Spacing="7">
                                                <TextBlock Text="Sync and validation" Style="{StaticResource SourceMiniLabelStyle}" />
                                                <TextBlock Text="{Binding ImportResultText}" Style="{StaticResource KroiraBodyStyle}" MaxLines="2" TextWrapping="WrapWholeWords" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding ValidationResultText}" Visibility="{Binding ValidationVisibility}" Style="{StaticResource KroiraBodyStyle}" MaxLines="3" TextWrapping="WrapWholeWords" TextTrimming="CharacterEllipsis" />
                                                <ItemsControl ItemsSource="{Binding HealthComponents}" Visibility="{Binding HealthComponentsVisibility}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Spacing="4">
                                                                <controls:StatusPill Label="{Binding PillLabel}" Kind="{Binding PillKind}" />
                                                                <TextBlock Text="{Binding Summary}" Style="{StaticResource KroiraBodyStyle}" MaxLines="2" TextWrapping="WrapWholeWords" TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <TextBlock Style="{StaticResource KroiraBodyStyle}">
                                                    <Run Text="Last attempt " />
                                                    <Run Text="{Binding LastAttemptText}" />
                                                </TextBlock>
                                                <TextBlock Text="{Binding LastSuccessfulSyncText}" Style="{StaticResource KroiraBodyStyle}" MaxLines="2" TextWrapping="WrapWholeWords" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding ParseWarningsText}" Visibility="{Binding ParseWarningsVisibility}" Foreground="{StaticResource KroiraGoldBrush}" FontSize="11" MaxLines="2" TextWrapping="WrapWholeWords" />
                                                <TextBlock Text="{Binding NetworkFailureText}" Visibility="{Binding NetworkFailureVisibility}" Foreground="{StaticResource KroiraLiveDotBrush}" FontSize="11" MaxLines="2" TextWrapping="WrapWholeWords" />
                                                <ItemsControl ItemsSource="{Binding HealthIssues}" Visibility="{Binding HealthIssuesVisibility}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Spacing="4">
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <controls:StatusPill Label="{Binding Title}" Kind="{Binding SeverityKind}" />
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding Message}" Style="{StaticResource KroiraBodyStyle}" MaxLines="2" TextWrapping="WrapWholeWords" TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Spacing="7">
                                                <TextBlock Text="Guide diagnostics" Style="{StaticResource SourceMiniLabelStyle}" />
                                                <TextBlock Text="{Binding GuideModeText}" Style="{StaticResource KroiraBodyStyle}" MaxLines="1" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding GuideStatusSummaryText}" Visibility="{Binding GuideStatusSummaryVisibility}" Style="{StaticResource KroiraBodyStyle}" MaxLines="2" TextWrapping="WrapWholeWords" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding GuideUrlText}" Visibility="{Binding GuideUrlVisibility}" Style="{StaticResource KroiraBodyStyle}" MaxLines="2" TextWrapping="WrapWholeWords" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding GuideMatchText}" Visibility="{Binding GuideMatchVisibility}" Style="{StaticResource KroiraBodyStyle}" MaxLines="2" TextWrapping="WrapWholeWords" TextTrimming="CharacterEllipsis" />
                                                <Border Height="1" Background="{StaticResource KroiraBorderBrush}" Opacity="0.3" Margin="0,4,0,4" />
                                                <TextBlock Text="Acquisition profile"
                                                           Visibility="{Binding AcquisitionProfileVisibility}"
                                                           Style="{StaticResource SourceMiniLabelStyle}" />
                                                <TextBlock Text="{Binding AcquisitionProfileText}"
                                                           Visibility="{Binding AcquisitionProfileVisibility}"
                                                           Style="{StaticResource KroiraBodyStyle}"
                                                           MaxLines="2"
                                                           TextWrapping="WrapWholeWords"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding AcquisitionRuleSummaryText}"
                                                           Visibility="{Binding AcquisitionRuleSummaryVisibility}"
                                                           Style="{StaticResource KroiraBodyStyle}"
                                                           MaxLines="3"
                                                           TextWrapping="WrapWholeWords"
                                                           TextTrimming="CharacterEllipsis" />
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="8"
                                                            Visibility="{Binding AcquisitionProfileVisibility}">
                                                    <controls:StatusPill Label="{Binding AcquisitionRunStatusText}"
                                                                         Kind="{Binding AcquisitionRunPillKind}" />
                                                    <TextBlock Text="{Binding AcquisitionLastRunText}"
                                                               Style="{StaticResource KroiraBodyStyle}"
                                                               Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding AcquisitionRunSummaryText}"
                                                           Visibility="{Binding AcquisitionRunSummaryVisibility}"
                                                           Style="{StaticResource KroiraBodyStyle}"
                                                           MaxLines="2"
                                                           TextWrapping="WrapWholeWords"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding AcquisitionRunMessageText}"
                                                           Visibility="{Binding AcquisitionRunMessageVisibility}"
                                                           Style="{StaticResource KroiraBodyStyle}"
                                                           Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                                           MaxLines="2"
                                                           TextWrapping="WrapWholeWords"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding AcquisitionStatsText}"
                                                           Visibility="{Binding AcquisitionStatsVisibility}"
                                                           Style="{StaticResource KroiraBodyStyle}"
                                                           Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                                           MaxLines="3"
                                                           TextWrapping="WrapWholeWords"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding AcquisitionRoutingText}"
                                                           Visibility="{Binding AcquisitionRoutingVisibility}"
                                                           Style="{StaticResource KroiraBodyStyle}"
                                                           Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                                           MaxLines="3"
                                                           TextWrapping="WrapWholeWords"
                                                           TextTrimming="CharacterEllipsis" />
                                                <ItemsControl ItemsSource="{Binding AcquisitionEvidence}"
                                                              Visibility="{Binding AcquisitionEvidenceVisibility}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Spacing="4">
                                                                <controls:StatusPill Label="{Binding PillLabel}" Kind="{Binding PillKind}" />
                                                                <TextBlock Text="{Binding Label}"
                                                                           Style="{StaticResource KroiraBodyStyle}"
                                                                           FontWeight="SemiBold"
                                                                           MaxLines="1"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Text="{Binding Detail}"
                                                                           Style="{StaticResource KroiraBodyStyle}"
                                                                           Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                                                           MaxLines="3"
                                                                           TextWrapping="WrapWholeWords"
                                                                           TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <Border Height="1" Background="{StaticResource KroiraBorderBrush}" Opacity="0.3" Margin="0,4,0,4" />
                                                <TextBlock Text="Automatic refresh" Style="{StaticResource SourceMiniLabelStyle}" />
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <controls:StatusPill Label="{Binding AutoRefreshStatusText}" Kind="Neutral" />
                                                    <TextBlock Text="{Binding NextAutoRefreshText}"
                                                               Style="{StaticResource KroiraBodyStyle}"
                                                               Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding AutoRefreshSummaryText}"
                                                           Visibility="{Binding AutoRefreshSummaryVisibility}"
                                                           Style="{StaticResource KroiraBodyStyle}"
                                                           MaxLines="2"
                                                           TextWrapping="WrapWholeWords"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding LastAutoRefreshText}"
                                                           Style="{StaticResource KroiraBodyStyle}"
                                                           Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                                           MaxLines="1"
                                                           TextTrimming="CharacterEllipsis" />
                                                <Border Height="1" Background="{StaticResource KroiraBorderBrush}" Opacity="0.3" Margin="0,4,0,4" />
                                                <TextBlock Text="Operational routing" Style="{StaticResource SourceMiniLabelStyle}" />
                                                <TextBlock Text="{Binding OperationalStatusText}"
                                                           Visibility="{Binding OperationalStatusVisibility}"
                                                           Style="{StaticResource KroiraBodyStyle}"
                                                           MaxLines="2"
                                                           TextWrapping="WrapWholeWords"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding ProxyStatusText}"
                                                           Visibility="{Binding ProxyStatusVisibility}"
                                                           Style="{StaticResource KroiraBodyStyle}"
                                                           Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                                           MaxLines="2"
                                                           TextWrapping="WrapWholeWords"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                    </Expander>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border
                    Grid.Row="1"
                    Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
                    Style="{StaticResource SourceDashboardCardStyle}"
                    MaxWidth="620"
                    HorizontalAlignment="Center">
                    <StackPanel Spacing="12">
                        <FontIcon
                            Glyph="&#xE8F1;"
                            Foreground="{StaticResource KroiraAccentBrush}"
                            FontSize="28"
                            HorizontalAlignment="Left" />
                        <TextBlock
                            Text="{x:Bind ViewModel.EmptyStateTitle, Mode=OneWay}"
                            Style="{StaticResource KroiraSectionTitleStyle}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.EmptyStateMessage, Mode=OneWay}"
                            Style="{StaticResource KroiraBodyStyle}"
                            TextWrapping="WrapWholeWords" />
                        <Button
                            Content="Add Source"
                            Click="AddNewSource_Click"
                            Style="{StaticResource KroiraPrimaryButtonStyle}"
                            HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="4" Style="{StaticResource SourceDashboardCardStyle}">
                <StackPanel Spacing="18">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="4">
                            <TextBlock Text="RECENT ACTIVITY"
                                       Style="{StaticResource KroiraLabelStyle}"
                                       Foreground="{StaticResource KroiraAccentBrush}" />
                            <TextBlock Text="Recent Sync Activity"
                                       Style="{StaticResource KroiraSectionTitleStyle}" />
                            <TextBlock Text="Latest source imports, guide updates, and recovery activity."
                                       Style="{StaticResource KroiraBodyStyle}" />
                        </StackPanel>

                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind ViewModel.RecentActivityCountText, Mode=OneWay}"
                                   Style="{StaticResource KroiraBodyStyle}"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <ItemsControl ItemsSource="{x:Bind ViewModel.RecentActivities, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource SourceActivityCardStyle}">
                                    <Grid ColumnSpacing="14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border Background="{StaticResource KroiraAccentBrush}"
                                                CornerRadius="999"
                                                Opacity="0.7" />

                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock Text="{Binding SourceName}"
                                                       Style="{StaticResource KroiraTitleStyle}"
                                                       FontSize="16"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding ActionText}"
                                                       Style="{StaticResource KroiraBodyStyle}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding PayloadText}"
                                                       Style="{StaticResource KroiraBodyStyle}"
                                                       Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                                       MaxLines="2"
                                                       TextWrapping="WrapWholeWords"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2"
                                                    Spacing="8"
                                                    HorizontalAlignment="Right">
                                            <controls:StatusPill Label="{Binding StatusText}"
                                                                 Kind="{Binding StatusKind}"
                                                                 HorizontalAlignment="Right" />
                                            <TextBlock Text="{Binding TimestampText}"
                                                       Style="{StaticResource KroiraBodyStyle}"
                                                       Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                                       HorizontalAlignment="Right" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
        </Grid>
    </ScrollViewer>
</Page>
