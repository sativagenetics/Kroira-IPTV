<Page
    x:Class="Kroira.App.Views.SourceListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Grid Padding="28" RowSpacing="18" Background="{StaticResource KroiraPageAtmosphereBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="4">
                <TextBlock Text="Sources" Style="{StaticResource KroiraPageTitleStyle}" />
                <TextBlock
                    Text="Operational management for M3U and Xtream providers, imports, EPG sync, and library health."
                    Style="{StaticResource KroiraPageSubtitleStyle}"
                    MaxWidth="720" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Content="Refresh" Command="{x:Bind ViewModel.LoadSourcesCommand}" Style="{StaticResource KroiraGhostButtonStyle}" />
                <Button Content="Add Source" Click="AddNewSource_Click" Style="{StaticResource KroiraPrimaryButtonStyle}" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Background="{StaticResource KroiraSurfaceSoftBrush}" CornerRadius="8" Padding="16,12">
            <Grid ColumnSpacing="28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="2">
                    <TextBlock Text="SOURCES" Style="{StaticResource KroiraLabelStyle}" />
                    <TextBlock
                        Text="{x:Bind ViewModel.SourceCount, Mode=OneWay, Converter={StaticResource NumberFormatConverter}}"
                        FontSize="24"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock Text="M3U" Style="{StaticResource KroiraLabelStyle}" />
                    <TextBlock
                        Text="{x:Bind ViewModel.M3uSourceCount, Mode=OneWay, Converter={StaticResource NumberFormatConverter}}"
                        FontSize="24"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Spacing="2">
                    <TextBlock Text="XTREAM" Style="{StaticResource KroiraLabelStyle}" />
                    <TextBlock
                        Text="{x:Bind ViewModel.XtreamSourceCount, Mode=OneWay, Converter={StaticResource NumberFormatConverter}}"
                        FontSize="24"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="3" Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="SOURCE HEALTH" Style="{StaticResource KroiraLabelStyle}" />
                    <TextBlock
                        Text="Status is tracked per provider from the last import or sync attempt."
                        Style="{StaticResource KroiraBodyStyle}"
                        MaxLines="1"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Padding="14,0" ColumnSpacing="16" Opacity="0.82">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="74" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="430" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="TYPE" Style="{StaticResource KroiraLabelStyle}" />
                    <TextBlock Grid.Column="1" Text="PROVIDER" Style="{StaticResource KroiraLabelStyle}" />
                    <TextBlock Grid.Column="2" Text="CONTENT / SYNC" Style="{StaticResource KroiraLabelStyle}" />
                    <TextBlock Grid.Column="3" Text="ACTIONS" Style="{StaticResource KroiraLabelStyle}" HorizontalAlignment="Right" />
                </Grid>

                <ListView
                    Grid.Row="1"
                    ItemsSource="{x:Bind ViewModel.Sources, Mode=OneWay}"
                    SelectionMode="None"
                    ItemContainerStyle="{StaticResource KroiraMediaRowContainerStyle}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource KroiraRowStyle}" MinHeight="104">
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="74" />
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="300" />
                                        <ColumnDefinition Width="430" />
                                    </Grid.ColumnDefinitions>

                                    <Border
                                        Width="58"
                                        Height="44"
                                        CornerRadius="8"
                                        Background="{StaticResource KroiraSurfaceHighBrush}"
                                        VerticalAlignment="Center">
                                        <TextBlock
                                            Text="{Binding Type}"
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource KroiraAccentBrush}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center" />
                                    </Border>

                                    <StackPanel Grid.Column="1" Spacing="7" VerticalAlignment="Center">
                                        <TextBlock
                                            Text="{Binding Name}"
                                            Style="{StaticResource KroiraTitleStyle}"
                                            FontSize="16"
                                            TextTrimming="CharacterEllipsis" />

                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Grid Width="8" Height="8" VerticalAlignment="Center">
                                                <Ellipse Fill="{StaticResource KroiraAccentBrush}" Visibility="{Binding HealthyVisibility}" />
                                                <Ellipse Fill="{StaticResource KroiraGoldBrush}" Visibility="{Binding IdleVisibility}" />
                                                <Ellipse Fill="{StaticResource KroiraLiveDotBrush}" Visibility="{Binding AttentionVisibility}" />
                                                <Ellipse Fill="{StaticResource KroiraAccentStrongBrush}" Visibility="{Binding WorkingVisibility}" />
                                            </Grid>
                                            <TextBlock
                                                Text="{Binding HealthLabel}"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                                            <TextBlock
                                                Text="{Binding Status}"
                                                Style="{StaticResource KroiraBodyStyle}"
                                                MaxLines="1"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </StackPanel>

                                    <Grid Grid.Column="2" ColumnSpacing="12" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="58" />
                                            <ColumnDefinition Width="68" />
                                            <ColumnDefinition Width="68" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Spacing="2">
                                            <TextBlock Text="LIVE" Style="{StaticResource KroiraLabelStyle}" />
                                            <TextBlock
                                                Text="{Binding ChannelCount, Converter={StaticResource NumberFormatConverter}}"
                                                FontSize="15"
                                                FontWeight="SemiBold"
                                                Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="MOVIES" Style="{StaticResource KroiraLabelStyle}" />
                                            <TextBlock
                                                Text="{Binding MovieCount, Converter={StaticResource NumberFormatConverter}}"
                                                FontSize="15"
                                                FontWeight="SemiBold"
                                                Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Spacing="2">
                                            <TextBlock Text="SERIES" Style="{StaticResource KroiraLabelStyle}" />
                                            <TextBlock
                                                Text="{Binding SeriesCount, Converter={StaticResource NumberFormatConverter}}"
                                                FontSize="15"
                                                FontWeight="SemiBold"
                                                Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="3" Spacing="2">
                                            <TextBlock Text="LAST SYNC" Style="{StaticResource KroiraLabelStyle}" />
                                            <TextBlock
                                                Text="{Binding LastSyncText}"
                                                FontSize="13"
                                                Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                                MaxLines="1"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Grid.Column="3"
                                                Orientation="Horizontal"
                                                Spacing="6"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right">
                                        <Button Content="Browse" Tag="{Binding Id}" Click="BrowseSource_Click" Visibility="{Binding BrowseVisibility}" Style="{StaticResource KroiraButtonStyle}" Padding="10,7" />
                                        <Button Content="Import" Tag="{Binding Id}" Click="ParseSource_Click" Visibility="{Binding ParseVisibility}" Style="{StaticResource KroiraButtonStyle}" Padding="10,7" />
                                        <Button Content="EPG" Tag="{Binding Id}" Click="SyncEpgSource_Click" Visibility="{Binding SyncEpgVisibility}" Style="{StaticResource KroiraButtonStyle}" Padding="10,7" />
                                        <Button Content="Live" Tag="{Binding Id}" Click="SyncXtreamSource_Click" Visibility="{Binding SyncXtreamVisibility}" Style="{StaticResource KroiraButtonStyle}" Padding="10,7" />
                                        <Button Content="VOD" Tag="{Binding Id}" Click="SyncXtreamVodSource_Click" Visibility="{Binding SyncXtreamVisibility}" Style="{StaticResource KroiraButtonStyle}" Padding="10,7" />
                                        <Button Content="Delete" Tag="{Binding Id}" Click="DeleteSource_Click" Style="{StaticResource KroiraDangerButtonStyle}" Padding="10,7" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <Border
                Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
                Background="{StaticResource KroiraSurfaceBrush}"
                CornerRadius="10"
                Padding="26"
                MaxWidth="560"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <StackPanel Spacing="12">
                    <FontIcon Glyph="&#xE8F1;" Foreground="{StaticResource KroiraAccentBrush}" FontSize="30" HorizontalAlignment="Left" />
                    <TextBlock Text="No sources configured" Style="{StaticResource KroiraSectionTitleStyle}" />
                    <TextBlock
                        Text="Add an M3U playlist or Xtream provider to populate live channels, VOD, and guide data."
                        Style="{StaticResource KroiraBodyStyle}" />
                    <Button Content="Add Source" Click="AddNewSource_Click" Style="{StaticResource KroiraPrimaryButtonStyle}" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
