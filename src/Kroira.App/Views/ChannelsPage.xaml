<Page
    x:Class="Kroira.App.Views.ChannelsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Grid Padding="28" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource KroiraPanelStyle}">
            <StackPanel Spacing="16">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Channels" Style="{StaticResource KroiraPageTitleStyle}" />
                        <TextBlock Text="Browse live TV with category filters, favorites, and fast playback." Style="{StaticResource KroiraPageSubtitleStyle}" Margin="0,4,0,0" />
                    </StackPanel>
                    <Border HorizontalAlignment="Right" VerticalAlignment="Center" Background="#221F42" BorderBrush="{StaticResource KroiraBorderStrongBrush}" BorderThickness="1" CornerRadius="999" Padding="12,5">
                        <TextBlock Text="Live TV" Foreground="{StaticResource KroiraAccentBrush}" FontSize="12" FontWeight="SemiBold" />
                    </Border>
                </Grid>

                <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250" />
                    <ColumnDefinition Width="*" MaxWidth="400" />
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0" Style="{StaticResource KroiraComboBoxStyle}" ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}" DisplayMemberPath="Name" HorizontalAlignment="Stretch" />
                <TextBox Grid.Column="1" Style="{StaticResource KroiraTextBoxStyle}" Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Search channels..." HorizontalAlignment="Stretch" />
            </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}" Style="{StaticResource KroiraPanelStyle}" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="440">
            <StackPanel Spacing="10">
                <FontIcon Glyph="&#xE714;" Foreground="{StaticResource KroiraAccentBrush}" FontSize="30" HorizontalAlignment="Left" />
                <TextBlock Text="No channels imported yet" Style="{StaticResource KroiraSectionTitleStyle}" />
                <TextBlock Text="Add a source and sync it to start browsing live TV." Style="{StaticResource KroiraPageSubtitleStyle}" />
            </StackPanel>
        </Border>

        <GridView Grid.Row="1" ItemsSource="{x:Bind ViewModel.FilteredChannels, Mode=OneWay}" SelectionMode="Single" SelectionChanged="ChannelList_SelectionChanged">
            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="Margin" Value="0,0,10,10" />
                </Style>
            </GridView.ItemContainerStyle>
            <GridView.ItemTemplate>
                <DataTemplate>
                    <Grid Width="286" Height="88" Padding="12" BorderBrush="{StaticResource KroiraBorderBrush}" BorderThickness="1" CornerRadius="16" ColumnSpacing="12">
                        <Grid.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#171E2E" Offset="0" />
                                <GradientStop Color="#101722" Offset="1" />
                            </LinearGradientBrush>
                        </Grid.Background>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="54" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="14" Background="{StaticResource KroiraMediaGradientBrush}">
                            <Image Source="{Binding LogoUrl}" Stretch="Uniform" Margin="6" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                            <TextBlock Text="{Binding Name}" TextWrapping="Wrap" MaxLines="2" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                            <TextBlock Text="Live channel" Foreground="{StaticResource KroiraTextTertiaryBrush}" FontSize="11" />
                        </StackPanel>
                        <Button Grid.Column="2" Content="{Binding FavoriteIcon}" Tag="{Binding Id}" Click="FavoriteToggle_Click" Background="Transparent" Foreground="{StaticResource KroiraGoldBrush}" BorderThickness="0" FontSize="18" Padding="0" VerticalAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Page>
