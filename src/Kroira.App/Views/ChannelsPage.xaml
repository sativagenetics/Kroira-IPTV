<Page
    x:Class="Kroira.App.Views.ChannelsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16" Spacing="16">
            <TextBlock Text="Channels" Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBox Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Search channels..." MaxWidth="400" HorizontalAlignment="Left" />
        </StackPanel>

        <TextBlock Grid.Row="1" Text="No channels imported yet. Add a source and sync to get started."
                   Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
                   Style="{ThemeResource BodyTextBlockStyle}" Foreground="Gray"
                   HorizontalAlignment="Center" VerticalAlignment="Center" />

        <GridView Grid.Row="1" ItemsSource="{x:Bind ViewModel.FilteredChannels, Mode=OneWay}" SelectionMode="Single" SelectionChanged="ChannelList_SelectionChanged">
            <GridView.ItemTemplate>
                <DataTemplate>
                    <Grid Width="280" Height="80" Padding="12" Background="#11FFFFFF" CornerRadius="4" Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="48" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0" Source="{Binding LogoUrl}" Stretch="Uniform" Margin="0,0,8,0" />
                        <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" TextWrapping="Wrap" MaxLines="2" FontWeight="SemiBold" FontSize="14" />
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Page>
