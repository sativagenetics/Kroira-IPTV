<Page
    x:Class="Kroira.App.Views.ChannelsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="LiveTvPage"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Page.Resources>
        <Style x:Key="ChannelTileContainerStyle" TargetType="GridViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="UseSystemFocusVisuals" Value="True" />
        </Style>

        <Style x:Key="ChannelFavoriteButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource KroiraGoldBrush}" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="MinHeight" Value="30" />
        </Style>
    </Page.Resources>

    <Grid Padding="34,26,34,32"
          MaxWidth="1320"
          HorizontalAlignment="Center"
          RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="6">
                <TextBlock Text="LIVE TV"
                           Style="{StaticResource KroiraLabelStyle}"
                           Foreground="{StaticResource KroiraAccentBrush}" />
                <TextBlock Text="Channels"
                           Style="{StaticResource KroiraPageTitleStyle}" />
                <TextBlock Text="Browse live channels in a compact six-column desktop grid."
                           Style="{StaticResource KroiraPageSubtitleStyle}"
                           MaxWidth="620" />
            </StackPanel>

            <Border Grid.Column="1"
                    Background="#99161B24"
                    BorderBrush="#24FFFFFF"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14,10"
                    VerticalAlignment="Bottom">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Ellipse Width="7" Height="7" Fill="{StaticResource KroiraLiveDotBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.FilteredChannels.Count, Mode=OneWay, Converter={StaticResource NumberFormatConverter}}"
                               Style="{StaticResource KroiraTitleStyle}"
                               FontSize="13" />
                    <TextBlock Text="available" Style="{StaticResource KroiraMetaStyle}" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MaxWidth="520" />
                <ColumnDefinition Width="220" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="SearchBox"
                     Grid.Column="0"
                     Style="{StaticResource KroiraFilterTextBoxStyle}"
                     Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="Search channels"
                     AutomationProperties.Name="Search channels"
                     TabIndex="0"
                     KeyDown="SearchBox_KeyDown" />

            <ComboBox x:Name="CategoryComboBox"
                      Grid.Column="1"
                      Style="{StaticResource KroiraFilterComboBoxStyle}"
                      ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                      DisplayMemberPath="Name"
                      AutomationProperties.Name="Channel category"
                      TabIndex="1" />
        </Grid>

        <Grid Grid.Row="2">
            <StackPanel Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="10"
                        MaxWidth="460">
                <FontIcon Glyph="&#xE714;"
                          Foreground="{StaticResource KroiraTextTertiaryBrush}"
                          FontSize="28"
                          HorizontalAlignment="Center" />
                <TextBlock Text="No channels to show"
                           Style="{StaticResource KroiraSectionTitleStyle}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Sync an Xtream live source, or clear your search and category filters."
                           Style="{StaticResource KroiraBodyStyle}"
                           TextAlignment="Center" />
            </StackPanel>

            <GridView x:Name="ChannelList"
                      ItemsSource="{x:Bind ViewModel.FilteredChannels, Mode=OneWay}"
                      SelectionMode="None"
                      IsItemClickEnabled="True"
                      ItemClick="ChannelList_ItemClick"
                      ItemContainerStyle="{StaticResource ChannelTileContainerStyle}"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      Padding="0,2,0,22"
                      AutomationProperties.Name="Live channels"
                      TabIndex="2"
                      KeyDown="ChannelList_KeyDown">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"
                                       MaximumRowsOrColumns="6" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border Width="198"
                                Height="154"
                                Background="#99161B24"
                                BorderBrush="#24FFFFFF"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="13">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Border Width="48"
                                            Height="48"
                                            CornerRadius="10"
                                            Background="{StaticResource KroiraSurfaceHighBrush}"
                                            HorizontalAlignment="Left">
                                        <Grid>
                                            <FontIcon Glyph="&#xE714;"
                                                      Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                      FontSize="18"
                                                      Opacity="0.55" />
                                            <Image Source="{Binding LogoUrl, Converter={StaticResource UrlToImageSourceConverter}}"
                                                   Stretch="Uniform"
                                                   Margin="6" />
                                        </Grid>
                                    </Border>
                                    <Button HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Content="{Binding FavoriteIcon}"
                                            Tag="{Binding Id}"
                                            Click="FavoriteToggle_Click"
                                            Style="{StaticResource ChannelFavoriteButtonStyle}"
                                            AutomationProperties.Name="Toggle favorite"
                                            ToolTipService.ToolTip="Toggle favorite" />
                                </Grid>

                                <StackPanel Grid.Row="1" Spacing="4" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               Style="{StaticResource KroiraTitleStyle}"
                                               MaxLines="2"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding CurrentProgramTitle}"
                                               Style="{StaticResource KroiraMetaStyle}"
                                               MaxLines="1"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding EpgVisibility}" />
                                </StackPanel>

                                <Grid Grid.Row="2" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Background="{StaticResource KroiraStateDangerSoftBrush}"
                                            BorderBrush="#33FF5A5F"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="8,3">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <Ellipse Width="6" Height="6" Fill="{StaticResource KroiraLiveDotBrush}" />
                                            <TextBlock Text="LIVE"
                                                       Foreground="{StaticResource KroiraLiveDotBrush}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Border>
                                    <ProgressBar Grid.Column="1"
                                                 Value="{Binding LiveProgressValue}"
                                                 Maximum="100"
                                                 Height="3"
                                                 Foreground="{StaticResource KroiraAccentBrush}"
                                                 Background="{StaticResource KroiraBorderBrush}"
                                                 Visibility="{Binding EpgVisibility}"
                                                 VerticalAlignment="Center" />
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </Grid>
    </Grid>
</Page>
