<Page
    x:Class="Kroira.App.Views.ChannelsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Grid Padding="40,24,40,32" MaxWidth="1360" HorizontalAlignment="Stretch" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 1 · Editorial page header -->
        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock Text="LIVE TV" Style="{StaticResource KroiraLabelStyle}" Foreground="{StaticResource KroiraAccentBrush}" />
            <TextBlock Text="Channels" Style="{StaticResource KroiraPageTitleStyle}" />
        </StackPanel>

        <!-- 2 · Flat filter bar -->
        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MaxWidth="460" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Style="{StaticResource KroiraFilterTextBoxStyle}"
                     Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="Search channels"
                     HorizontalAlignment="Stretch" />

            <ComboBox Grid.Column="1"
                      Style="{StaticResource KroiraFilterComboBoxStyle}"
                      ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                      DisplayMemberPath="Name"
                      MinWidth="220" />
        </Grid>

        <!-- 3 · Result count -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="5" Margin="2,0,0,0">
            <TextBlock Text="{x:Bind ViewModel.FilteredChannels.Count, Mode=OneWay, Converter={StaticResource NumberFormatConverter}}" Style="{StaticResource KroiraResultCountStyle}" />
            <TextBlock Text="channels" Style="{StaticResource KroiraResultCountStyle}" />
        </StackPanel>

        <!-- 4a · Empty state -->
        <StackPanel Grid.Row="3"
                    Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="10"
                    MaxWidth="460">
            <FontIcon Glyph="&#xE714;" Foreground="{StaticResource KroiraTextTertiaryBrush}" FontSize="28" HorizontalAlignment="Center" />
            <TextBlock Text="No channels to show"
                       Style="{StaticResource KroiraSectionTitleStyle}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Sync an Xtream live source, or clear your search and category filters."
                       Style="{StaticResource KroiraBodyStyle}"
                       TextAlignment="Center"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <!-- 4b · Dense channel row list -->
        <ListView Grid.Row="3"
                  ItemsSource="{x:Bind ViewModel.FilteredChannels, Mode=OneWay}"
                  SelectionMode="Single"
                  SelectionChanged="ChannelList_SelectionChanged"
                  ItemContainerStyle="{StaticResource KroiraMediaRowContainerStyle}"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  Padding="0,4,0,24">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource KroiraRowStyle}"
                            MinHeight="68">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <!-- Logo -->
                                <ColumnDefinition Width="Auto" />
                                <!-- Name + now/next -->
                                <ColumnDefinition Width="*" />
                                <!-- Progress + time -->
                                <ColumnDefinition Width="Auto" />
                                <!-- LIVE dot -->
                                <ColumnDefinition Width="Auto" />
                                <!-- Favorite -->
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                        <!-- Logo -->
                        <Grid Grid.Column="0"
                              Width="44" Height="44"
                              VerticalAlignment="Center">
                            <Border CornerRadius="8"
                                    Background="{StaticResource KroiraPosterPlaceholderBrush}">
                                <FontIcon Glyph="&#xE714;"
                                          Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                          FontSize="16" />
                            </Border>
                            <Border CornerRadius="8">
                                <Image Source="{Binding LogoUrl, Converter={StaticResource UrlToImageSourceConverter}}"
                                       Stretch="Uniform"
                                       Margin="6" />
                            </Border>
                        </Grid>

                        <!-- Name + now/next -->
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Spacing="2">
                            <TextBlock Text="{Binding Name}"
                                       Style="{StaticResource KroiraTitleStyle}"
                                       FontSize="14"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis" />
                            <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{Binding EpgVisibility}">
                                <TextBlock Text="{Binding CurrentProgramTitle}"
                                           Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                           FontSize="12"
                                           MaxLines="1"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="6"
                                        Visibility="{Binding NextProgramVisibility}">
                                <TextBlock Text="Next"
                                           Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                           FontSize="11"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding NextProgramTitle}"
                                           Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                           FontSize="11"
                                           MaxLines="1"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding NextProgramTimeText}"
                                           Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                           FontSize="11" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Progress + current time window -->
                        <StackPanel Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Spacing="5"
                                    Width="160"
                                    Visibility="{Binding EpgVisibility}">
                            <TextBlock Text="{Binding CurrentProgramTimeText}"
                                       Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                       FontSize="11"
                                       HorizontalAlignment="Right" />
                            <ProgressBar Value="{Binding LiveProgressValue}"
                                         Maximum="100"
                                         Height="2"
                                         Foreground="{StaticResource KroiraAccentBrush}"
                                         Background="#22252C" />
                        </StackPanel>

                        <!-- LIVE dot -->
                        <StackPanel Grid.Column="3"
                                    Orientation="Horizontal"
                                    Spacing="6"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding EpgVisibility}">
                            <Ellipse Width="7" Height="7" Fill="{StaticResource KroiraLiveDotBrush}" />
                            <TextBlock Text="LIVE"
                                       Foreground="{StaticResource KroiraLiveDotBrush}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       CharacterSpacing="80" />
                        </StackPanel>

                        <!-- Favorite -->
                        <Button Grid.Column="4"
                                Content="{Binding FavoriteIcon}"
                                Tag="{Binding Id}"
                                Click="FavoriteToggle_Click"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Foreground="{StaticResource KroiraGoldBrush}"
                                FontSize="16"
                                Padding="8,4"
                                VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
