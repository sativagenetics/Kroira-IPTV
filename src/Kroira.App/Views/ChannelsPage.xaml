<Page
    x:Class="Kroira.App.Views.ChannelsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="LiveTvPage"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Page.Resources>
        <Style x:Key="ChannelTileContainerStyle" TargetType="GridViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,12,18" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="UseSystemFocusVisuals" Value="True" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="ChannelFavoriteButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource KroiraGoldBrush}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="28" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>

        <Style x:Key="ChannelInputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#E80A0D11" />
            <Setter Property="BorderBrush" Value="{StaticResource KroiraGlassBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
            <Setter Property="PlaceholderForeground" Value="{StaticResource KroiraTextTertiaryBrush}" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="ChannelComboStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#E80A0D11" />
            <Setter Property="BorderBrush" Value="{StaticResource KroiraGlassBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="LiveQuickAccessButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#CC11161D" />
            <Setter Property="BorderBrush" Value="{StaticResource KroiraGlassBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="MinWidth" Value="180" />
        </Style>
    </Page.Resources>

    <Grid Padding="42,36,42,40"
          MaxWidth="1440"
          HorizontalAlignment="Center"
          RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                MinHeight="156"
                BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="26,24">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#172B2F" Offset="0" />
                    <GradientStop Color="#151B22" Offset="0.48" />
                    <GradientStop Color="#080A0E" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid ColumnSpacing="28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="BROADCAST"
                               Style="{StaticResource KroiraLabelStyle}"
                               Foreground="{StaticResource KroiraAccentBrush}" />
                    <TextBlock Text="Live TV"
                               Style="{StaticResource KroiraDisplayLgStyle}"
                               FontSize="42"
                               LineHeight="48" />
                    <TextBlock Text="Fast channel scanning with program progress, favorite access, and tuned category control."
                               Style="{StaticResource KroiraPageSubtitleStyle}"
                               MaxWidth="640" />
                </StackPanel>

                <Border Grid.Column="1"
                        Style="{StaticResource KroiraCountBadgeStyle}"
                        VerticalAlignment="Bottom"
                        MinWidth="148">
                    <StackPanel Spacing="2">
                        <TextBlock Text="{x:Bind ViewModel.FilteredChannels.Count, Mode=OneWay, Converter={StaticResource NumberFormatConverter}}"
                                   Foreground="{StaticResource KroiraTextPrimaryBrush}"
                                   FontSize="24"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="CHANNELS"
                                   Style="{StaticResource KroiraLabelStyle}"
                                   FontSize="10" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource KroiraFilterStripStyle}">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MaxWidth="560" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <TextBox x:Name="SearchBox"
                                 Style="{StaticResource ChannelInputStyle}"
                                 Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Search channels"
                                 AutomationProperties.Name="Search channels"
                                 TabIndex="0"
                                 KeyDown="SearchBox_KeyDown" />
                        <FontIcon Glyph="&#xE721;"
                                  FontSize="14"
                                  Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                  HorizontalAlignment="Right"
                                  Margin="0,0,16,0"
                                  VerticalAlignment="Center" />
                    </Grid>

                    <ComboBox x:Name="CategoryComboBox"
                              Grid.Column="1"
                              Style="{StaticResource ChannelComboStyle}"
                              ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName"
                              AutomationProperties.Name="Channel category"
                              TabIndex="1" />

                    <ComboBox Grid.Column="2"
                              Style="{StaticResource ChannelComboStyle}"
                              ItemsSource="{x:Bind ViewModel.SourceOptions, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedSourceOption, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName"
                              AutomationProperties.Name="Channel provider" />

                    <ComboBox Grid.Column="3"
                              Style="{StaticResource ChannelComboStyle}"
                              ItemsSource="{x:Bind ViewModel.SortOptions, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedSortOption, Mode=TwoWay}"
                              DisplayMemberPath="Label"
                              AutomationProperties.Name="Channel sort" />

                    <StackPanel Grid.Column="4"
                                Orientation="Horizontal"
                                Spacing="10"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <CheckBox Content="Favorites"
                                  IsChecked="{x:Bind ViewModel.FavoritesOnly, Mode=TwoWay}" />
                        <CheckBox Content="Guide matched"
                                  IsChecked="{x:Bind ViewModel.GuideMatchedOnly, Mode=TwoWay}" />
                        <Border Width="7"
                                Height="7"
                                CornerRadius="4"
                                Background="{StaticResource KroiraStateInfoBrush}" />
                        <TextBlock Text="LIVE GRID"
                                   Style="{StaticResource KroiraLabelStyle}" />
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="1"
                            Spacing="8"
                            Visibility="{x:Bind ViewModel.QuickAccessVisibility, Mode=OneWay}">
                    <TextBlock Text="Recent &amp; last tuned"
                               Style="{StaticResource KroiraLabelStyle}"
                               Foreground="{StaticResource KroiraAccentBrush}" />
                    <ScrollViewer HorizontalScrollMode="Enabled"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollMode="Disabled"
                                  VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{x:Bind ViewModel.RecentChannels, Mode=OneWay}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="10" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Click="RecentChannelButton_Click"
                                            Style="{StaticResource LiveQuickAccessButtonStyle}">
                                        <StackPanel Spacing="4">
                                            <Border Background="#2CE7C46E"
                                                    CornerRadius="999"
                                                    Padding="7,2"
                                                    HorizontalAlignment="Left"
                                                    Visibility="{Binding QuickAccessBadgeVisibility}">
                                                <TextBlock Text="{Binding QuickAccessBadgeText}"
                                                           Style="{StaticResource KroiraLabelStyle}"
                                                           FontSize="9"
                                                           Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                                            </Border>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{StaticResource KroiraTextPrimaryBrush}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       MaxLines="1"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding CurrentProgramTitle}"
                                                       Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                                       FontSize="11"
                                                       MaxLines="1"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding GuideMetaText}"
                                                       Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                       FontSize="11"
                                                       MaxLines="1"
                                                       TextTrimming="CharacterEllipsis"
                                                       Visibility="{Binding GuideMetaVisibility}" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>

                <Expander Grid.Row="2"
                          Header="Advanced browse controls"
                          IsExpanded="{x:Bind ViewModel.HasAdvancedFilters, Mode=OneWay}">
                    <Grid Margin="0,12,0,0" ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="1.2*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="10">
                            <TextBlock Text="Visible providers"
                                       Style="{StaticResource KroiraLabelStyle}"
                                       Foreground="{StaticResource KroiraAccentBrush}" />
                            <ItemsControl ItemsSource="{x:Bind ViewModel.SourceVisibilityOptions, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsVisible, Mode=TwoWay}" Margin="0,2,0,2">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" />
                                                <TextBlock Text="{Binding Detail}"
                                                           Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                           FontSize="11" />
                                            </StackPanel>
                                        </CheckBox>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="10">
                            <TextBlock Text="Category alias / hide"
                                       Style="{StaticResource KroiraLabelStyle}"
                                       Foreground="{StaticResource KroiraAccentBrush}" />
                            <ComboBox Style="{StaticResource ChannelComboStyle}"
                                      ItemsSource="{x:Bind ViewModel.ManageCategoryOptions, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedManageCategory, Mode=TwoWay}"
                                      DisplayMemberPath="DisplayName" />
                            <TextBox Style="{StaticResource ChannelInputStyle}"
                                     IsEnabled="{x:Bind ViewModel.HasManageCategorySelection, Mode=OneWay}"
                                     Text="{x:Bind ViewModel.ManageCategoryAliasDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="Rename selected category for browsing" />
                            <ToggleSwitch Header="Hide selected category"
                                          IsEnabled="{x:Bind ViewModel.HasManageCategorySelection, Mode=OneWay}"
                                          IsOn="{x:Bind ViewModel.IsManageCategoryHidden, Mode=TwoWay}" />
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button Content="Save category rule"
                                        Command="{x:Bind ViewModel.SaveCategoryPreferenceCommand}"
                                        IsEnabled="{x:Bind ViewModel.HasManageCategorySelection, Mode=OneWay}" />
                                <Button Content="Clear rule"
                                        Command="{x:Bind ViewModel.ClearCategoryPreferenceCommand}"
                                        IsEnabled="{x:Bind ViewModel.HasManageCategorySelection, Mode=OneWay}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Expander>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <StackPanel Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="10"
                        MaxWidth="460">
                <FontIcon Glyph="&#xE714;"
                          Foreground="{StaticResource KroiraTextTertiaryBrush}"
                          FontSize="28"
                          HorizontalAlignment="Center" />
                <TextBlock Text="No channels to show"
                           Foreground="{StaticResource KroiraTextPrimaryBrush}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Sync an Xtream live source, or clear your search and category filters."
                           Foreground="{StaticResource KroiraTextSecondaryBrush}"
                           FontSize="13"
                           TextWrapping="Wrap"
                           TextAlignment="Center" />
            </StackPanel>

            <GridView x:Name="ChannelList"
                      ItemsSource="{x:Bind ViewModel.FilteredChannels, Mode=OneWay}"
                      SelectionMode="None"
                      IsItemClickEnabled="True"
                      ItemClick="ChannelList_ItemClick"
                      ItemContainerStyle="{StaticResource ChannelTileContainerStyle}"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      Padding="0,0,0,28"
                      AutomationProperties.Name="Live channels"
                      TabIndex="2"
                      KeyDown="ChannelList_KeyDown">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"
                                       ItemWidth="176"
                                       ItemHeight="216"
                                       MaximumRowsOrColumns="6" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="168" Height="198">
                            <ToolTipService.ToolTip>
                                <ToolTip Placement="Mouse">
                                            <Border Background="{StaticResource KroiraSurfaceElevatedBrush}"
                                                    BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                                    BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12,9"
                                            MaxWidth="260">
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="{Binding CurrentProgramTitle}"
                                                       Foreground="{StaticResource KroiraTextPrimaryBrush}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       MaxLines="1"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding CurrentProgramTimeText}"
                                                       Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                                       FontSize="12"
                                                       MaxLines="1"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>
                                </ToolTip>
                            </ToolTipService.ToolTip>

                            <Border CornerRadius="10"
                                    BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                    BorderThickness="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#1D252C" Offset="0" />
                                        <GradientStop Color="#11161D" Offset="0.56" />
                                        <GradientStop Color="#090B0F" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid Padding="13,14,13,12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border Grid.RowSpan="5"
                                            Background="#26E7C46E"
                                            BorderBrush="{StaticResource KroiraAccentBrush}"
                                            BorderThickness="1"
                                            CornerRadius="999"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Padding="7,2"
                                            Visibility="{Binding LastTunedVisibility}">
                                        <TextBlock Text="LAST"
                                                   Style="{StaticResource KroiraLabelStyle}"
                                                   FontSize="9"
                                                   Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                                    </Border>

                                    <Grid Grid.Row="0">
                                        <Border Width="112"
                                                Height="70"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Background="#5810141A"
                                                BorderBrush="#18FFFFFF"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                            <Grid>
                                                <FontIcon Glyph="&#xE714;"
                                                          Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                          FontSize="30"
                                                          Opacity="0.45" />
                                                <Image Source="{Binding LogoUrl, Converter={StaticResource UrlToImageSourceConverter}}"
                                                       Stretch="Uniform" />
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <TextBlock Grid.Row="1"
                                               Text="{Binding Name}"
                                               Foreground="{StaticResource KroiraTextPrimaryBrush}"
                                               FontSize="13"
                                               FontWeight="Normal"
                                               MaxLines="1"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,26,4" />

                                    <TextBlock Grid.Row="2"
                                               Text="{Binding CurrentProgramTitle}"
                                               Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                               FontSize="11"
                                               MaxLines="1"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,0,3" />

                                    <StackPanel Grid.Row="3"
                                                Spacing="2">
                                        <TextBlock Text="{Binding GuideMetaText}"
                                                   Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                                   FontSize="10"
                                                   MaxLines="1"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="{Binding GuideMetaVisibility}" />
                                        <TextBlock Text="{Binding NextProgramCompactText}"
                                                   Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                   FontSize="10"
                                                   MaxLines="1"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="{Binding NextProgramVisibility}" />
                                    </StackPanel>

                                    <Grid Grid.Row="4" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <ProgressBar Grid.Column="0"
                                                     Value="{Binding LiveProgressValue}"
                                                     Maximum="100"
                                                     Height="2"
                                                     Foreground="{StaticResource KroiraAccentBrush}"
                                                     Background="{StaticResource KroiraBorderBrush}"
                                                     VerticalAlignment="Center"
                                                     Visibility="{Binding EpgVisibility}" />

                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    Spacing="6">
                                            <Button Content="●"
                                                    Click="RecordChannel_Click"
                                                    Style="{StaticResource ChannelFavoriteButtonStyle}"
                                                    Foreground="#FF7B6A"
                                                    AutomationProperties.Name="Schedule recording"
                                                    ToolTipService.ToolTip="Schedule recording" />
                                            <Button Content="{Binding FavoriteIcon}"
                                                    Tag="{Binding Id}"
                                                    Click="FavoriteToggle_Click"
                                                    Style="{StaticResource ChannelFavoriteButtonStyle}"
                                                    AutomationProperties.Name="Toggle favorite"
                                                    ToolTipService.ToolTip="Toggle favorite" />
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </Grid>
    </Grid>
</Page>
