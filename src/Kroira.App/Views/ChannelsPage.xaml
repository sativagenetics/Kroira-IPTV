<Page
    x:Class="Kroira.App.Views.ChannelsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="LiveTvPage"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Page.Resources>
        <Style x:Key="ChannelTileContainerStyle" TargetType="GridViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,12,18" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="UseSystemFocusVisuals" Value="True" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="ChannelFavoriteButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource KroiraGoldBrush}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="28" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>

        <Style x:Key="ChannelInputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#E80A0D11" />
            <Setter Property="BorderBrush" Value="{StaticResource KroiraGlassBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
            <Setter Property="PlaceholderForeground" Value="{StaticResource KroiraTextTertiaryBrush}" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="ChannelComboStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#E80A0D11" />
            <Setter Property="BorderBrush" Value="{StaticResource KroiraGlassBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="FontSize" Value="13" />
        </Style>
    </Page.Resources>

    <Grid Padding="42,36,42,40"
          MaxWidth="1440"
          HorizontalAlignment="Center"
          RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                MinHeight="156"
                BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="26,24">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#172B2F" Offset="0" />
                    <GradientStop Color="#151B22" Offset="0.48" />
                    <GradientStop Color="#080A0E" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid ColumnSpacing="28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="BROADCAST"
                               Style="{StaticResource KroiraLabelStyle}"
                               Foreground="{StaticResource KroiraAccentBrush}" />
                    <TextBlock Text="Live TV"
                               Style="{StaticResource KroiraDisplayLgStyle}"
                               FontSize="42"
                               LineHeight="48" />
                    <TextBlock Text="Fast channel scanning with program progress, favorite access, and tuned category control."
                               Style="{StaticResource KroiraPageSubtitleStyle}"
                               MaxWidth="640" />
                </StackPanel>

                <Border Grid.Column="1"
                        Style="{StaticResource KroiraCountBadgeStyle}"
                        VerticalAlignment="Bottom"
                        MinWidth="148">
                    <StackPanel Spacing="2">
                        <TextBlock Text="{x:Bind ViewModel.FilteredChannels.Count, Mode=OneWay, Converter={StaticResource NumberFormatConverter}}"
                                   Foreground="{StaticResource KroiraTextPrimaryBrush}"
                                   FontSize="24"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="CHANNELS"
                                   Style="{StaticResource KroiraLabelStyle}"
                                   FontSize="10" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource KroiraFilterStripStyle}">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MaxWidth="620" />
                    <ColumnDefinition Width="244" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <TextBox x:Name="SearchBox"
                             Style="{StaticResource ChannelInputStyle}"
                             Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="Search channels"
                             AutomationProperties.Name="Search channels"
                             TabIndex="0"
                             KeyDown="SearchBox_KeyDown" />
                    <FontIcon Glyph="&#xE721;"
                              FontSize="14"
                              Foreground="{StaticResource KroiraTextTertiaryBrush}"
                              HorizontalAlignment="Right"
                              Margin="0,0,16,0"
                              VerticalAlignment="Center" />
                </Grid>

                <ComboBox x:Name="CategoryComboBox"
                          Grid.Column="1"
                          Style="{StaticResource ChannelComboStyle}"
                          ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                          DisplayMemberPath="Name"
                          AutomationProperties.Name="Channel category"
                          TabIndex="1" />

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="8"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Border Width="7"
                            Height="7"
                            CornerRadius="4"
                            Background="{StaticResource KroiraStateInfoBrush}" />
                    <TextBlock Text="LIVE GRID"
                               Style="{StaticResource KroiraLabelStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <StackPanel Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="10"
                        MaxWidth="460">
                <FontIcon Glyph="&#xE714;"
                          Foreground="{StaticResource KroiraTextTertiaryBrush}"
                          FontSize="28"
                          HorizontalAlignment="Center" />
                <TextBlock Text="No channels to show"
                           Foreground="{StaticResource KroiraTextPrimaryBrush}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Sync an Xtream live source, or clear your search and category filters."
                           Foreground="{StaticResource KroiraTextSecondaryBrush}"
                           FontSize="13"
                           TextWrapping="Wrap"
                           TextAlignment="Center" />
            </StackPanel>

            <GridView x:Name="ChannelList"
                      ItemsSource="{x:Bind ViewModel.FilteredChannels, Mode=OneWay}"
                      SelectionMode="None"
                      IsItemClickEnabled="True"
                      ItemClick="ChannelList_ItemClick"
                      ItemContainerStyle="{StaticResource ChannelTileContainerStyle}"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      Padding="0,0,0,28"
                      AutomationProperties.Name="Live channels"
                      TabIndex="2"
                      KeyDown="ChannelList_KeyDown">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"
                                       ItemWidth="176"
                                       ItemHeight="202"
                                       MaximumRowsOrColumns="6" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="168" Height="184">
                            <ToolTipService.ToolTip>
                                <ToolTip Placement="Mouse">
                                            <Border Background="{StaticResource KroiraSurfaceElevatedBrush}"
                                                    BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                                    BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12,9"
                                            MaxWidth="260">
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="{Binding CurrentProgramTitle}"
                                                       Foreground="{StaticResource KroiraTextPrimaryBrush}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       MaxLines="1"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding CurrentProgramTimeText}"
                                                       Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                                       FontSize="12"
                                                       MaxLines="1"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>
                                </ToolTip>
                            </ToolTipService.ToolTip>

                            <Border CornerRadius="10"
                                    BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                    BorderThickness="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#1D252C" Offset="0" />
                                        <GradientStop Color="#11161D" Offset="0.56" />
                                        <GradientStop Color="#090B0F" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid Padding="13,14,13,12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Border Width="112"
                                                Height="70"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Background="#5810141A"
                                                BorderBrush="#18FFFFFF"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                            <Grid>
                                                <FontIcon Glyph="&#xE714;"
                                                          Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                          FontSize="30"
                                                          Opacity="0.45" />
                                                <Image Source="{Binding LogoUrl, Converter={StaticResource UrlToImageSourceConverter}}"
                                                       Stretch="Uniform" />
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <TextBlock Grid.Row="1"
                                               Text="{Binding Name}"
                                               Foreground="{StaticResource KroiraTextPrimaryBrush}"
                                               FontSize="13"
                                               FontWeight="Normal"
                                               MaxLines="1"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,26,8" />

                                    <Grid Grid.Row="2" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <ProgressBar Grid.Column="0"
                                                     Value="{Binding LiveProgressValue}"
                                                     Maximum="100"
                                                     Height="2"
                                                     Foreground="{StaticResource KroiraAccentBrush}"
                                                     Background="{StaticResource KroiraBorderBrush}"
                                                     VerticalAlignment="Center"
                                                     Visibility="{Binding EpgVisibility}" />

                                        <Button Grid.Column="1"
                                                Content="{Binding FavoriteIcon}"
                                                Tag="{Binding Id}"
                                                Click="FavoriteToggle_Click"
                                                Style="{StaticResource ChannelFavoriteButtonStyle}"
                                                AutomationProperties.Name="Toggle favorite"
                                                ToolTipService.ToolTip="Toggle favorite" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </Grid>
    </Grid>
</Page>
