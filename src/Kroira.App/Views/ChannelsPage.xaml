<Page
    x:Class="Kroira.App.Views.ChannelsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:runtime="using:Kroira.App.Services"
    xmlns:controls="using:Kroira.App.Controls"
    x:Name="LiveTvPage"
    NavigationCacheMode="Required"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Page.Resources>
        <Style x:Key="ChannelTileContainerStyle" TargetType="GridViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,10,14" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="UseSystemFocusVisuals" Value="True" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="ChannelFavoriteButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource KroiraGoldBrush}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="28" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>

        <Style x:Key="CategoryRailItemContainerStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="ChannelInputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#95070B12" />
            <Setter Property="BorderBrush" Value="{StaticResource KroiraControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
            <Setter Property="PlaceholderForeground" Value="{StaticResource KroiraTextTertiaryBrush}" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="ChannelComboStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#95070B12" />
            <Setter Property="BorderBrush" Value="{StaticResource KroiraControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="LiveQuickAccessButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#5F111827" />
            <Setter Property="BorderBrush" Value="{StaticResource KroiraGlassBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="MinWidth" Value="196" />
        </Style>

        <Style x:Key="LiveQuickOverlayButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#70111827" />
            <Setter Property="BorderBrush" Value="{StaticResource KroiraGlassBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="MinWidth" Value="28" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource KroiraTextPrimaryBrush}" />
        </Style>

    </Page.Resources>

    <Grid XYFocusKeyboardNavigation="Enabled">
        <controls:AmbientPageBackground />

        <Grid Padding="30,24,30,34"
              MaxWidth="1660"
              HorizontalAlignment="Center"
              RowSpacing="14"
              Visibility="{x:Bind ViewModel.SurfaceState.ContentVisibility, Mode=OneWay}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                MinHeight="76"
                BorderBrush="{StaticResource KroiraGhostBorderBrush}"
                BorderThickness="0"
                CornerRadius="{StaticResource KroiraRadiusHero}"
                Padding="0,0,0,2">
            <Border.Background>
                <SolidColorBrush Color="#00000000" />
            </Border.Background>

            <Grid>
                <StackPanel Spacing="3" VerticalAlignment="Center">
                    <TextBlock x:Uid="ChannelsBroadcastLabel" runtime:RuntimeLocalizer.Uid="ChannelsBroadcastLabel" Text="BROADCAST"
                               Style="{StaticResource KroiraLabelStyle}"
                               Foreground="{StaticResource KroiraAccentBrush}"
                               Visibility="Collapsed" />
                    <TextBlock x:Uid="ChannelsPageTitle" runtime:RuntimeLocalizer.Uid="ChannelsPageTitle" Text="Live TV"
                               Style="{StaticResource KroiraDisplayLgStyle}"
                               FontSize="30"
                               LineHeight="34" />
                    <TextBlock x:Uid="ChannelsPageSubtitle" runtime:RuntimeLocalizer.Uid="ChannelsPageSubtitle" Text="Browse live channels, guide times, favorites, and catch-up."
                                Style="{StaticResource KroiraPageSubtitleStyle}"
                               FontSize="12"
                                MaxLines="1"
                                TextTrimming="CharacterEllipsis"
                                MaxWidth="520" />
                </StackPanel>

            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource KroiraLibraryToolbarStyle}">
            <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.2*" MaxWidth="520" />
                        <ColumnDefinition Width="190" />
                        <ColumnDefinition Width="190" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <TextBox x:Name="SearchBox"
                                 x:Uid="ChannelsSearchBox" runtime:RuntimeLocalizer.Uid="ChannelsSearchBox"
                                 Style="{StaticResource KroiraFilterTextBoxStyle}"
                                 Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Search channels"
                                 AutomationProperties.Name="Search channels"
                                 TabIndex="0"
                                 KeyDown="SearchBox_KeyDown" />
                        <FontIcon Glyph="&#xE721;"
                                   FontSize="14"
                                   Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                   HorizontalAlignment="Right"
                                   Margin="0,0,14,0"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <ComboBox x:Uid="ChannelsProviderComboBox" runtime:RuntimeLocalizer.Uid="ChannelsProviderComboBox"
                              Grid.Column="1"
                              Style="{StaticResource KroiraFilterComboBoxStyle}"
                              ItemsSource="{x:Bind ViewModel.SourceOptions, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedSourceOption, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName"
                              AutomationProperties.Name="Channel provider" />

                    <ComboBox x:Uid="ChannelsSortComboBox" runtime:RuntimeLocalizer.Uid="ChannelsSortComboBox"
                              Grid.Column="2"
                              Style="{StaticResource KroiraFilterComboBoxStyle}"
                              ItemsSource="{x:Bind ViewModel.SortOptions, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedSortOption, Mode=TwoWay}"
                              DisplayMemberPath="Label"
                              AutomationProperties.Name="Channel sort" />

                    <StackPanel Grid.Column="3"
                                Orientation="Horizontal"
                                Spacing="6"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <CheckBox x:Uid="ChannelsFavoritesFilter" runtime:RuntimeLocalizer.Uid="ChannelsFavoritesFilter" Content="Favorites"
                                  IsChecked="{x:Bind ViewModel.FavoritesOnly, Mode=TwoWay}"
                                  AutomationProperties.Name="Show favorite channels only" />
                        <CheckBox x:Uid="ChannelsGuideMatchedFilter" runtime:RuntimeLocalizer.Uid="ChannelsGuideMatchedFilter" Content="Guide matched"
                                  IsChecked="{x:Bind ViewModel.GuideMatchedOnly, Mode=TwoWay}"
                                  AutomationProperties.Name="Show guide matched channels only" />
                        <Button x:Uid="GeneralGuideButton" runtime:RuntimeLocalizer.Uid="GeneralGuideButton" Content="Guide"
                                Click="OpenGuide_Click"
                                Style="{StaticResource LiveQuickOverlayButtonStyle}"
                                AutomationProperties.Name="Open guide" />
                        <Button x:Uid="GeneralClearRecentButton" runtime:RuntimeLocalizer.Uid="GeneralClearRecentButton" Content="Clear recent"
                                Click="ClearRecentHistory_Click"
                                Style="{StaticResource LiveQuickOverlayButtonStyle}"
                                Visibility="{x:Bind ViewModel.ClearRecentHistoryVisibility, Mode=OneWay}"
                                AutomationProperties.Name="Clear recently watched channels" />
                    </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="208" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource KroiraCategoryRailPanelStyle}">
                <ListView x:Uid="ChannelsCategoryList" runtime:RuntimeLocalizer.Uid="ChannelsCategoryList"
                          ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                          SelectionMode="Single"
                          ItemContainerStyle="{StaticResource KroiraCategoryRailItemContainerStyle}"
                          ItemTemplate="{StaticResource KroiraCategoryRailItemTemplate}"
                          Background="Transparent"
                          BorderThickness="0"
                          Padding="0"
                          AutomationProperties.Name="Live channel categories"
                          ScrollViewer.VerticalScrollMode="Enabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollMode="Disabled"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
            </Border>

            <Grid Grid.Column="1" RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="2">
                        <TextBlock x:Uid="ChannelsBrowserLabel" runtime:RuntimeLocalizer.Uid="ChannelsBrowserLabel" Text="CHANNEL BROWSER"
                                   Style="{StaticResource KroiraLabelStyle}"
                                   Foreground="{StaticResource KroiraAccentBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.BrowseResultTitle, Mode=OneWay}"
                                   Style="{StaticResource KroiraTitleStyle}"
                                   FontSize="18" />
                        <TextBlock Text="{x:Bind ViewModel.BrowseResultSubtitle, Mode=OneWay}"
                                   Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                   FontSize="12"
                                   MaxWidth="760"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Spacing="8"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.BrowseResultCountText, Mode=OneWay}"
                                   Style="{StaticResource KroiraLabelStyle}"
                                   Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                   HorizontalAlignment="Right" />
                        <Button x:Uid="GeneralClearRecentButton2" runtime:RuntimeLocalizer.Uid="GeneralClearRecentButton2" Content="Clear recent"
                                Click="ClearRecentHistory_Click"
                                Style="{StaticResource LiveQuickOverlayButtonStyle}"
                                HorizontalAlignment="Right"
                                Visibility="{x:Bind ViewModel.BrowseClearRecentVisibility, Mode=OneWay}" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <controls:EmptyStateView IconGlyph="&#xE714;"
                                             Title="{x:Bind ViewModel.EmptyStateTitle, Mode=OneWay}"
                                             Message="{x:Bind ViewModel.EmptyStateMessage, Mode=OneWay}"
                                             Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center" />

                    <GridView x:Name="ChannelList"
                              x:Uid="ChannelsChannelList" runtime:RuntimeLocalizer.Uid="ChannelsChannelList"
                              ItemsSource="{x:Bind ViewModel.FilteredChannels, Mode=OneWay}"
                              SelectionMode="None"
                              IsItemClickEnabled="True"
                              ItemClick="ChannelList_ItemClick"
                              Loaded="ChannelList_Loaded"
                              ItemContainerStyle="{StaticResource ChannelTileContainerStyle}"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              Padding="0,0,0,28"
                              AutomationProperties.Name="Live channels"
                              TabIndex="2"
                              KeyDown="ChannelList_KeyDown">
                <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal"
                                           ItemWidth="196"
                                           ItemHeight="146"
                                           MaximumRowsOrColumns="6" />
                        </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="186"
                              Height="134"
                              Loaded="RevealCardRoot_Loaded">
                            <ToolTipService.ToolTip>
                                <ToolTip Placement="Mouse">
                                            <Border Background="{StaticResource KroiraSurfaceElevatedBrush}"
                                                    BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                                    BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12,9"
                                            MaxWidth="260">
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="{Binding CurrentProgramTitle}"
                                                       Foreground="{StaticResource KroiraTextPrimaryBrush}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       MaxLines="1"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding CurrentProgramTimeText}"
                                                       Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                                       FontSize="12"
                                                       MaxLines="1"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>
                                </ToolTip>
                            </ToolTipService.ToolTip>

                            <Border CornerRadius="10"
                                    BorderBrush="Transparent"
                                    BorderThickness="0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#1D252C" Offset="0" />
                                        <GradientStop Color="#11161D" Offset="0.56" />
                                        <GradientStop Color="#090B0F" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid Padding="9,8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border Grid.RowSpan="5"
                                            Background="#2AC167FF"
                                            BorderBrush="{StaticResource KroiraAccentBrush}"
                                            BorderThickness="1"
                                            CornerRadius="999"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Padding="6,2"
                                            Visibility="{Binding LastTunedVisibility}">
                                        <TextBlock x:Uid="ChannelsLastBadge" runtime:RuntimeLocalizer.Uid="ChannelsLastBadge" Text="LAST"
                                                   Style="{StaticResource KroiraLabelStyle}"
                                                   FontSize="9"
                                                   Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                                    </Border>
                                    <Button x:Uid="ChannelsFavoriteButton" runtime:RuntimeLocalizer.Uid="ChannelsFavoriteButton"
                                            Grid.RowSpan="5"
                                            Content="{Binding FavoriteIcon}"
                                            Tag="{Binding Id}"
                                            Click="FavoriteToggle_Click"
                                            Style="{StaticResource ChannelFavoriteButtonStyle}"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            Opacity="0.78"
                                            AutomationProperties.Name="Toggle favorite"
                                            ToolTipService.ToolTip="Toggle favorite" />

                                    <Grid Grid.Row="0">
                                        <Border Width="96"
                                                Height="38"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Background="#5810141A"
                                                BorderBrush="#18FFFFFF"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                            <Grid>
                                                <FontIcon Glyph="&#xE714;"
                                                          Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                          FontSize="26"
                                                          Opacity="0.45" />
                                                <Image Source="{Binding LogoUrl, Converter={StaticResource UrlToImageSourceConverter}}"
                                                       Stretch="Uniform" />
                                            </Grid>
                                        </Border>
                                    </Grid>

                                     <TextBlock Grid.Row="1"
                                                Text="{Binding Name}"
                                                Foreground="{StaticResource KroiraTextPrimaryBrush}"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                MaxLines="1"
                                                TextWrapping="Wrap"
                                                TextTrimming="CharacterEllipsis"
                                                VerticalAlignment="Top"
                                                Margin="0,0,0,4" />

                                    <StackPanel Grid.Row="2"
                                                Spacing="1">
                                        <TextBlock Text="{Binding CurrentProgramTitle}"
                                                   Foreground="{StaticResource KroiraTextSecondaryBrush}"
                                                    FontSize="10"
                                                   MaxLines="1"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="{Binding CurrentProgramVisibility}" />
                                         <TextBlock Text="{Binding GuideMetaText}"
                                                    Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                     FontSize="9"
                                                    MaxLines="1"
                                                    TextTrimming="CharacterEllipsis"
                                                    Visibility="{Binding GuideMetaVisibility}" />
                                        <TextBlock Text="{Binding CurrentProgramDescription}"
                                                   Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                   FontSize="9"
                                                   MaxLines="1"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="{Binding DescriptionVisibility}" />
                                        <TextBlock Text="{Binding NextProgramCompactText}"
                                                   Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                   FontSize="9"
                                                   MaxLines="1"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="{Binding NextProgramVisibility}" />
                                        <TextBlock Text="{Binding CatchupBadgeText}"
                                                   Foreground="{StaticResource KroiraAccentBrush}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   MaxLines="1"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="Collapsed" />
                                        <TextBlock Text="{Binding CatchupStatusText}"
                                                   Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                   FontSize="10"
                                                   MaxLines="2"
                                                   TextWrapping="WrapWholeWords"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="Collapsed" />
                                    </StackPanel>

                                    <Grid Grid.Row="4" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <ProgressBar Grid.Column="0"
                                                     Value="{Binding LiveProgressValue}"
                                                     Maximum="100"
                                                     Height="2"
                                                     Foreground="{StaticResource KroiraAccentBrush}"
                                                     Background="{StaticResource KroiraBorderBrush}"
                                                     VerticalAlignment="Center"
                                                     Visibility="{Binding EpgVisibility}" />

                                    </Grid>

                                    <Border Tag="MediaActionOverlay"
                                            Grid.RowSpan="5"
                                            Visibility="Collapsed"
                                            Opacity="0"
                                            IsHitTestVisible="False"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            CornerRadius="13"
                                            Padding="7"
                                            Background="#C805070B">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="6">
                                            <Button Content="●"
                                                    x:Uid="ChannelsScheduleRecordingButton" runtime:RuntimeLocalizer.Uid="ChannelsScheduleRecordingButton"
                                                    Click="RecordChannel_Click"
                                                    Visibility="{Binding ElementName=LiveTvPage, Path=RecordingActionsVisibility}"
                                                    Style="{StaticResource ChannelFavoriteButtonStyle}"
                                                    Foreground="#FF7B6A"
                                                    AutomationProperties.Name="Schedule recording"
                                                    ToolTipService.ToolTip="Schedule recording" />
                                            <Button Content="{Binding CatchupActionLabel}"
                                                    x:Uid="ChannelsStartOverButton" runtime:RuntimeLocalizer.Uid="ChannelsStartOverButton"
                                                    Click="StartCatchup_Click"
                                                    Visibility="{Binding CatchupActionVisibility}"
                                                    Style="{StaticResource LiveQuickOverlayButtonStyle}"
                                                    Foreground="{StaticResource KroiraAccentBrush}"
                                                    AutomationProperties.Name="Start over"
                                                    ToolTipService.ToolTip="{Binding CatchupStatusText}" />
                                            <Button x:Uid="ChannelsDetailsButton" runtime:RuntimeLocalizer.Uid="ChannelsDetailsButton"
                                                    Click="InspectChannel_Click"
                                                    Style="{StaticResource LiveQuickOverlayButtonStyle}"
                                                    Width="28"
                                                    Height="28"
                                                    Padding="0"
                                                    AutomationProperties.Name="Channel details"
                                                    ToolTipService.ToolTip="Details">
                                                <FontIcon Glyph="&#xE946;" FontSize="11" />
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
                </Grid>
        </Grid>
        </Grid>
        </Grid>

        <Grid Visibility="{x:Bind ViewModel.SurfaceState.StateVisibility, Mode=OneWay}"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Margin="32">
            <controls:LoadingStateView Title="{x:Bind ViewModel.SurfaceState.Title, Mode=OneWay}"
                                       Message="{x:Bind ViewModel.SurfaceState.Message, Mode=OneWay}"
                                       Visibility="{x:Bind ViewModel.SurfaceState.LoadingStateVisibility, Mode=OneWay}" />
            <controls:EmptyStateView IconGlyph="{x:Bind ViewModel.SurfaceState.Glyph, Mode=OneWay}"
                                     Title="{x:Bind ViewModel.SurfaceState.Title, Mode=OneWay}"
                                     Message="{x:Bind ViewModel.SurfaceState.Message, Mode=OneWay}"
                                     PrimaryActionLabel="{x:Bind ViewModel.SurfaceState.ActionLabel, Mode=OneWay}"
                                     PrimaryActionVisibility="{x:Bind ViewModel.SurfaceState.ActionVisibility, Mode=OneWay}"
                                     Visibility="{x:Bind ViewModel.SurfaceState.EmptyStateVisibility, Mode=OneWay}"
                                     PrimaryActionClick="OpenSources_Click" />
            <controls:ErrorStateView IconGlyph="{x:Bind ViewModel.SurfaceState.Glyph, Mode=OneWay}"
                                     Title="{x:Bind ViewModel.SurfaceState.Title, Mode=OneWay}"
                                     Message="{x:Bind ViewModel.SurfaceState.Message, Mode=OneWay}"
                                     x:Uid="GeneralRetryErrorState" runtime:RuntimeLocalizer.Uid="GeneralRetryErrorState"
                                     RetryActionLabel="Retry"
                                     DiagnosticsActionLabel="{x:Bind ViewModel.SurfaceState.ActionLabel, Mode=OneWay}"
                                     DiagnosticsActionVisibility="{x:Bind ViewModel.SurfaceState.DiagnosticsActionVisibility, Mode=OneWay}"
                                     Visibility="{x:Bind ViewModel.SurfaceState.ErrorStateVisibility, Mode=OneWay}"
                                     RetryClick="RetrySurface_Click"
                                     DiagnosticsClick="OpenSources_Click" />
        </Grid>
    </Grid>
</Page>
