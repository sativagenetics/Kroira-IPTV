<Page
    x:Class="Kroira.App.Views.ContinueWatchingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Kroira.App.Controls"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Page.Resources>
        <Style x:Key="ResumeColumnStyle" TargetType="Border" BasedOn="{StaticResource KroiraLaneColumnStyle}" />

        <Style x:Key="ResumeItemContainerStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,9" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="QuietManagementButtonStyle" TargetType="Button" BasedOn="{StaticResource KroiraGhostButtonStyle}">
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource KroiraTextTertiaryBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Background" Value="#08000000" />
            <Setter Property="Opacity" Value="0.62" />
        </Style>

        <Style x:Key="QuietIconButtonStyle" TargetType="Button" BasedOn="{StaticResource KroiraGhostButtonStyle}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource KroiraTextTertiaryBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Background" Value="#08000000" />
            <Setter Property="Opacity" Value="0.58" />
        </Style>
    </Page.Resources>

    <Grid XYFocusKeyboardNavigation="Enabled">
        <controls:AmbientPageBackground />

        <Grid Padding="32,26,34,34"
              RowSpacing="18"
              MaxWidth="1480"
              HorizontalAlignment="Center"
              Visibility="{x:Bind ViewModel.SurfaceState.ContentVisibility, Mode=OneWay}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="8">
                <Border Width="54" Height="5" Background="{StaticResource KroiraAccentGradientBrush}" CornerRadius="3" HorizontalAlignment="Left" />
                <TextBlock Text="Continue Watching" Style="{StaticResource KroiraPageTitleStyle}" />
                <TextBlock Text="Resume live sources, movies, and episodes from dedicated queues."
                           Style="{StaticResource KroiraPageSubtitleStyle}"
                           MaxWidth="760" />
            </StackPanel>
            <Border Grid.Column="1"
                    Background="#42111827"
                    BorderBrush="{StaticResource KroiraGhostBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14,10"
                    VerticalAlignment="Bottom"
                    Visibility="Collapsed">
                <TextBlock Text="RESUME HUB"
                           Foreground="{StaticResource KroiraAccentBrush}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           CharacterSpacing="80" />
            </Border>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="1.1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource ResumeColumnStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Style="{StaticResource KroiraLaneHeaderStyle}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="3">
                            <TextBlock Text="Live Resume" Style="{StaticResource KroiraSectionTitleStyle}" />
                            <TextBlock Text="Return to saved live sources" Style="{StaticResource KroiraBodyStyle}" />
                        </StackPanel>
                        <Border Grid.Column="1" Style="{StaticResource KroiraLaneCountBadgeStyle}" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind ViewModel.LiveCountText, Mode=OneWay}" Foreground="{StaticResource KroiraLiveDotBrush}" FontSize="10" FontWeight="SemiBold" />
                        </Border>
                        <Button Grid.Column="2"
                                Content="Clear all"
                                Click="ClearLiveProgress_Click"
                                Style="{StaticResource KroiraLaneClearButtonStyle}"
                                Visibility="{x:Bind ViewModel.ClearLiveVisibility, Mode=OneWay}"
                                VerticalAlignment="Center"
                                Margin="8,0,0,0"
                                AutomationProperties.Name="Clear all live resume items" />
                    </Grid>
                    </Border>

                    <Grid Grid.Row="1" Padding="10,0,10,12">
                        <controls:EmptyStateView IconGlyph="&#xE714;"
                                                 Title="No live resume items"
                                                 Message="Live playback entries appear here when saved progress exists."
                                                 Visibility="{x:Bind ViewModel.LiveEmptyVisibility, Mode=OneWay}"
                                                 VerticalAlignment="Top" />
                        <ListView x:Name="LiveList"
                                  ItemsSource="{x:Bind ViewModel.LiveProgressItems, Mode=OneWay}"
                                  SelectionMode="None"
                                  IsItemClickEnabled="True"
                                  ItemClick="ItemList_ItemClick"
                                  KeyDown="ItemList_KeyDown"
                                  ItemContainerStyle="{StaticResource ResumeItemContainerStyle}"
                                  Padding="0"
                                  ScrollViewer.VerticalScrollMode="Enabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#40111827" BorderBrush="Transparent" BorderThickness="0" CornerRadius="12" Padding="12" MinHeight="78">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="48" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="44" Height="44" CornerRadius="10" Background="{StaticResource KroiraMediaGradientBrush}">
                                                <Grid>
                                                    <FontIcon Glyph="&#xE714;" Foreground="{StaticResource KroiraAccentBrush}" FontSize="16" Opacity="0.55" />
                                                    <Image Source="{Binding LogoUrl, Converter={StaticResource UrlToImageSourceConverter}}" Stretch="Uniform" Margin="6" />
                                                </Grid>
                                            </Border>
                                            <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" Style="{StaticResource KroiraTitleStyle}" MaxLines="2" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding LastWatchedText}" Style="{StaticResource KroiraMetaStyle}" MaxLines="1" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding ResumeContextText}" Style="{StaticResource KroiraBodyStyle}" MaxLines="1" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <Button Grid.Column="2"
                                                    Tag="{Binding ProgressId}"
                                                    Click="RemoveProgress_Click"
                                                    Style="{StaticResource QuietIconButtonStyle}"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding RemoveVisibility}"
                                                    AutomationProperties.Name="Remove from continue watching"
                                                    ToolTipService.ToolTip="Remove">
                                                <FontIcon Glyph="&#xE74D;" FontSize="11" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource ResumeColumnStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Style="{StaticResource KroiraLaneHeaderStyle}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="3">
                            <TextBlock Text="Movie Queue" Style="{StaticResource KroiraSectionTitleStyle}" />
                            <TextBlock Text="Saved film positions" Style="{StaticResource KroiraBodyStyle}" />
                        </StackPanel>
                        <Border Grid.Column="1" Style="{StaticResource KroiraLaneCountBadgeStyle}">
                            <TextBlock Text="{x:Bind ViewModel.MovieCountText, Mode=OneWay}" Foreground="{StaticResource KroiraAccentBrush}" FontSize="10" FontWeight="SemiBold" />
                        </Border>
                        <Button Grid.Column="2"
                                Content="Clear all"
                                Click="ClearMovieProgress_Click"
                                Style="{StaticResource KroiraLaneClearButtonStyle}"
                                Visibility="{x:Bind ViewModel.ClearMovieVisibility, Mode=OneWay}"
                                VerticalAlignment="Center"
                                AutomationProperties.Name="Clear all movie queue items" />
                        <ToggleSwitch x:Name="HideWatchedToggle"
                                      Grid.Column="3"
                                      Header="Hide watched"
                                      IsOn="{x:Bind ViewModel.HideWatchedItems, Mode=TwoWay}"
                                      OnContent=""
                                      OffContent=""
                                      VerticalAlignment="Center"
                                      AutomationProperties.Name="Hide watched continue watching items" />
                    </Grid>
                    </Border>

                    <Grid Grid.Row="1" Padding="10,0,10,12">
                        <controls:EmptyStateView IconGlyph="&#xE8B2;"
                                                 Title="No movies to resume"
                                                 Message="Partially watched movies will collect here."
                                                 Visibility="{x:Bind ViewModel.MovieEmptyVisibility, Mode=OneWay}"
                                                 VerticalAlignment="Top" />
                        <ListView x:Name="MovieList"
                                  ItemsSource="{x:Bind ViewModel.MovieProgressItems, Mode=OneWay}"
                                  SelectionMode="None"
                                  IsItemClickEnabled="True"
                                  ItemClick="ItemList_ItemClick"
                                  KeyDown="ItemList_KeyDown"
                                  ItemContainerStyle="{StaticResource ResumeItemContainerStyle}"
                                  Padding="0"
                                  ScrollViewer.VerticalScrollMode="Enabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#40111827" BorderBrush="Transparent" BorderThickness="0" CornerRadius="12" Padding="11" MinHeight="98">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="54" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="48" Height="68" CornerRadius="8" Background="{StaticResource KroiraPosterPlaceholderBrush}">
                                                <Grid>
                                                    <Image Source="{Binding LogoUrl, Converter={StaticResource UrlToImageSourceConverter}}" Stretch="UniformToFill" />
                                                    <Border Height="21" VerticalAlignment="Bottom" Background="#CC080A0D">
                                                        <TextBlock Text="{Binding ProgressText}" Foreground="{StaticResource KroiraAccentBrush}" FontSize="8" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                </Grid>
                                            </Border>
                                            <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" Style="{StaticResource KroiraTitleStyle}" MaxLines="2" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding LastWatchedText}" Style="{StaticResource KroiraMetaStyle}" MaxLines="1" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding ResumeContextText}" Foreground="{StaticResource KroiraAccentBrush}" FontSize="11" FontWeight="SemiBold" MaxLines="1" TextTrimming="CharacterEllipsis" />
                                                <ProgressBar Value="{Binding ProgressPercent}"
                                                             Maximum="100"
                                                             Height="3"
                                                             Margin="0,3,0,0"
                                                             Foreground="{StaticResource KroiraAccentBrush}"
                                                             Background="{StaticResource KroiraGhostBorderBrush}"
                                                             AutomationProperties.Name="{Binding ProgressText}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Spacing="6" VerticalAlignment="Center" Width="82">
                                                <Button Content="Watched"
                                                        Click="MarkWatched_Click"
                                                        Style="{StaticResource QuietManagementButtonStyle}"
                                                        Visibility="{Binding MarkWatchedVisibility}"
                                                        AutomationProperties.Name="Mark movie watched" />
                                                <Button Content="Unwatched"
                                                        Click="MarkUnwatched_Click"
                                                        Style="{StaticResource QuietManagementButtonStyle}"
                                                        Visibility="{Binding MarkUnwatchedVisibility}"
                                                        AutomationProperties.Name="Mark movie unwatched" />
                                                <Button Tag="{Binding ProgressId}"
                                                        Click="RemoveProgress_Click"
                                                        Style="{StaticResource QuietIconButtonStyle}"
                                                        Visibility="{Binding RemoveVisibility}"
                                                        AutomationProperties.Name="Remove from continue watching"
                                                        ToolTipService.ToolTip="Remove">
                                                    <FontIcon Glyph="&#xE74D;" FontSize="11" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource ResumeColumnStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Style="{StaticResource KroiraLaneHeaderStyle}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="3">
                            <TextBlock Text="Series Queue" Style="{StaticResource KroiraSectionTitleStyle}" />
                            <TextBlock Text="Episode resume items" Style="{StaticResource KroiraBodyStyle}" />
                        </StackPanel>
                        <Border Grid.Column="1" Style="{StaticResource KroiraLaneCountBadgeStyle}">
                            <TextBlock Text="{x:Bind ViewModel.SeriesCountText, Mode=OneWay}" Foreground="{StaticResource KroiraAccentBrush}" FontSize="10" FontWeight="SemiBold" />
                        </Border>
                        <Button Grid.Column="2"
                                Content="Clear all"
                                Click="ClearSeriesProgress_Click"
                                Style="{StaticResource KroiraLaneClearButtonStyle}"
                                Visibility="{x:Bind ViewModel.ClearSeriesVisibility, Mode=OneWay}"
                                VerticalAlignment="Center"
                                Margin="8,0,0,0"
                                AutomationProperties.Name="Clear all series queue items" />
                    </Grid>
                    </Border>

                    <Grid Grid.Row="1" Padding="10,0,10,12">
                        <controls:EmptyStateView IconGlyph="&#xE8A9;"
                                                 Title="No episodes to resume"
                                                 Message="Saved episode progress will appear as a compact queue."
                                                 Visibility="{x:Bind ViewModel.SeriesEmptyVisibility, Mode=OneWay}"
                                                 VerticalAlignment="Top" />
                        <ListView x:Name="SeriesList"
                                  ItemsSource="{x:Bind ViewModel.SeriesProgressItems, Mode=OneWay}"
                                  SelectionMode="None"
                                  IsItemClickEnabled="True"
                                  ItemClick="ItemList_ItemClick"
                                  KeyDown="ItemList_KeyDown"
                                  ItemContainerStyle="{StaticResource ResumeItemContainerStyle}"
                                  Padding="0"
                                  ScrollViewer.VerticalScrollMode="Enabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#40111827" BorderBrush="Transparent" BorderThickness="0" CornerRadius="12" Padding="11" MinHeight="98">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="54" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="48" Height="68" CornerRadius="8" Background="{StaticResource KroiraPosterPlaceholderBrush}">
                                                <Grid>
                                                    <Image Source="{Binding LogoUrl, Converter={StaticResource UrlToImageSourceConverter}}" Stretch="UniformToFill" />
                                                    <Border Height="21" VerticalAlignment="Bottom" Background="#CC080A0D">
                                                        <TextBlock Text="{Binding ProgressText}" Foreground="{StaticResource KroiraAccentBrush}" FontSize="8" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                </Grid>
                                            </Border>
                                            <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" Style="{StaticResource KroiraTitleStyle}" MaxLines="2" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding LastWatchedText}" Style="{StaticResource KroiraMetaStyle}" MaxLines="1" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding ResumeContextText}" Foreground="{StaticResource KroiraAccentBrush}" FontSize="11" FontWeight="SemiBold" MaxLines="1" TextTrimming="CharacterEllipsis" />
                                                <ProgressBar Value="{Binding ProgressPercent}"
                                                             Maximum="100"
                                                             Height="3"
                                                             Margin="0,3,0,0"
                                                             Foreground="{StaticResource KroiraAccentBrush}"
                                                             Background="{StaticResource KroiraGhostBorderBrush}"
                                                             AutomationProperties.Name="{Binding ProgressText}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Spacing="6" VerticalAlignment="Center" Width="82">
                                                <Button Content="Watched"
                                                        Click="MarkWatched_Click"
                                                        Style="{StaticResource QuietManagementButtonStyle}"
                                                        Visibility="{Binding MarkWatchedVisibility}"
                                                        AutomationProperties.Name="Mark episode watched" />
                                                <Button Content="Unwatched"
                                                        Click="MarkUnwatched_Click"
                                                        Style="{StaticResource QuietManagementButtonStyle}"
                                                        Visibility="{Binding MarkUnwatchedVisibility}"
                                                        AutomationProperties.Name="Mark episode unwatched" />
                                                <Button Tag="{Binding ProgressId}"
                                                        Click="RemoveProgress_Click"
                                                        Style="{StaticResource QuietIconButtonStyle}"
                                                        Visibility="{Binding RemoveVisibility}"
                                                        AutomationProperties.Name="Remove from continue watching"
                                                        ToolTipService.ToolTip="Remove">
                                                    <FontIcon Glyph="&#xE74D;" FontSize="11" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
        </Grid>

        <Grid Visibility="{x:Bind ViewModel.SurfaceState.StateVisibility, Mode=OneWay}"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Margin="32">
            <controls:LoadingStateView Title="{x:Bind ViewModel.SurfaceState.Title, Mode=OneWay}"
                                       Message="{x:Bind ViewModel.SurfaceState.Message, Mode=OneWay}"
                                       Visibility="{x:Bind ViewModel.SurfaceState.LoadingStateVisibility, Mode=OneWay}" />
            <controls:EmptyStateView IconGlyph="{x:Bind ViewModel.SurfaceState.Glyph, Mode=OneWay}"
                                     Title="{x:Bind ViewModel.SurfaceState.Title, Mode=OneWay}"
                                     Message="{x:Bind ViewModel.SurfaceState.Message, Mode=OneWay}"
                                     PrimaryActionLabel="{x:Bind ViewModel.SurfaceState.ActionLabel, Mode=OneWay}"
                                     PrimaryActionVisibility="{x:Bind ViewModel.SurfaceState.ActionVisibility, Mode=OneWay}"
                                     Visibility="{x:Bind ViewModel.SurfaceState.EmptyStateVisibility, Mode=OneWay}"
                                     PrimaryActionClick="OpenSources_Click" />
            <controls:ErrorStateView IconGlyph="{x:Bind ViewModel.SurfaceState.Glyph, Mode=OneWay}"
                                     Title="{x:Bind ViewModel.SurfaceState.Title, Mode=OneWay}"
                                     Message="{x:Bind ViewModel.SurfaceState.Message, Mode=OneWay}"
                                     RetryActionLabel="Retry"
                                     DiagnosticsActionLabel="{x:Bind ViewModel.SurfaceState.ActionLabel, Mode=OneWay}"
                                     DiagnosticsActionVisibility="{x:Bind ViewModel.SurfaceState.DiagnosticsActionVisibility, Mode=OneWay}"
                                     Visibility="{x:Bind ViewModel.SurfaceState.ErrorStateVisibility, Mode=OneWay}"
                                     RetryClick="RetrySurface_Click"
                                     DiagnosticsClick="OpenSources_Click" />
        </Grid>
    </Grid>
</Page>
