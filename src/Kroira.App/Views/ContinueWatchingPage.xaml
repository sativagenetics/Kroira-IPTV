<Page
    x:Class="Kroira.App.Views.ContinueWatchingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Grid Padding="28" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource KroiraPanelStyle}">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Continue Watching" Style="{StaticResource KroiraPageTitleStyle}" />
                    <TextBlock Text="Resume saved playback progress across live TV, movies, and episodes." Style="{StaticResource KroiraPageSubtitleStyle}" Margin="0,4,0,0" />
                </StackPanel>
                <Border HorizontalAlignment="Right" VerticalAlignment="Center" Background="#221F42" BorderBrush="{StaticResource KroiraBorderStrongBrush}" BorderThickness="1" CornerRadius="999" Padding="12,5">
                    <TextBlock Text="Fast resume" Foreground="{StaticResource KroiraAccentBrush}" FontSize="12" FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}" Style="{StaticResource KroiraPanelStyle}" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="520">
            <StackPanel Spacing="12">
                <Border Height="130" CornerRadius="22" Background="{StaticResource KroiraMediaGradientBrush}">
                    <Grid>
                        <Border Width="86" Height="86" CornerRadius="30" Background="#55212938" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <FontIcon Glyph="&#xE768;" Foreground="{StaticResource KroiraAccentBrush}" FontSize="36" />
                        <Border Width="190" Height="6" Background="{StaticResource KroiraGoldBrush}" CornerRadius="3" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="24,0,0,24" />
                        <Border Width="310" Height="6" Background="#42FFFFFF" CornerRadius="3" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="24,0,0,24" Opacity="0.18" />
                    </Grid>
                </Border>
                <TextBlock Text="Nothing to resume yet" Style="{StaticResource KroiraSectionTitleStyle}" />
                <TextBlock Text="Start watching content and Kroira will keep your progress ready here." Style="{StaticResource KroiraPageSubtitleStyle}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" ColumnSpacing="18" MaxWidth="1120" HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource KroiraPanelStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Text="Resume queue" Style="{StaticResource KroiraSectionTitleStyle}" />
                    <GridView ItemsSource="{x:Bind ViewModel.ProgressItems, Mode=OneWay}" SelectionMode="Single" SelectionChanged="ItemList_SelectionChanged">
                        <GridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="2" />
                            </ItemsPanelTemplate>
                        </GridView.ItemsPanel>
                        <GridView.ItemContainerStyle>
                            <Style TargetType="GridViewItem">
                                <Setter Property="Margin" Value="0,0,14,14" />
                            </Style>
                        </GridView.ItemContainerStyle>
                        <GridView.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="392" Height="142" Padding="14" BorderBrush="{StaticResource KroiraBorderStrongBrush}" BorderThickness="1" CornerRadius="24" ColumnSpacing="14">
                                    <Grid.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#302E5D" Offset="0" />
                                            <GradientStop Color="#171D30" Offset="0.62" />
                                            <GradientStop Color="#111722" Offset="1" />
                                        </LinearGradientBrush>
                                    </Grid.Background>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="132" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Width="122" Height="92" CornerRadius="22" Background="{StaticResource KroiraMediaGradientBrush}" VerticalAlignment="Center">
                                        <Grid>
                                            <Image Source="{Binding LogoUrl}" Stretch="Uniform" Margin="10" />
                                            <Border Height="6" Background="{StaticResource KroiraGoldBrush}" CornerRadius="3" VerticalAlignment="Bottom" Margin="14,0,54,12" />
                                            <Border Height="6" Background="#4CFFFFFF" CornerRadius="3" VerticalAlignment="Bottom" Margin="14,0,14,12" Opacity="0.18" />
                                            <Border Width="48" Height="24" Background="#44F05BD7" CornerRadius="10" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-8,-10,0" />
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                                        <TextBlock Text="{Binding Title}" TextWrapping="Wrap" MaxLines="2" FontWeight="SemiBold" FontSize="16" Foreground="{StaticResource KroiraTextPrimaryBrush}" />
                                        <TextBlock Text="{Binding ProgressText}" Foreground="{StaticResource KroiraGoldBrush}" FontSize="12" FontWeight="SemiBold" />
                                        <TextBlock Text="Ready to resume" Foreground="{StaticResource KroiraTextSecondaryBrush}" FontSize="11" />
                                    </StackPanel>

                                    <Button Grid.Column="2" Content="Remove" Tag="{Binding Id}" Click="RemoveProgress_Click" Style="{StaticResource KroiraDangerButtonStyle}" FontSize="11" VerticalAlignment="Top" />
                                </Grid>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource KroiraPanelStyle}">
                <StackPanel Spacing="12">
                    <Border Height="118" CornerRadius="22" Background="{StaticResource KroiraMediaGradientBrush}">
                        <Grid>
                            <Border Width="76" Height="76" CornerRadius="28" Background="#55212938" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <FontIcon Glyph="&#xE768;" Foreground="{StaticResource KroiraAccentBrush}" FontSize="32" />
                            <Border Width="146" Height="6" Background="{StaticResource KroiraGoldBrush}" CornerRadius="3" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="22,0,0,22" />
                            <Border Width="240" Height="6" Background="#35FFFFFF" CornerRadius="3" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="22,0,0,22" Opacity="0.2" />
                        </Grid>
                    </Border>
                    <TextBlock Text="Playback continuity" Style="{StaticResource KroiraSectionTitleStyle}" />
                    <TextBlock Text="A small queue should still feel like an active resume hub, with saved progress ready for keyboard or mouse selection." Style="{StaticResource KroiraPageSubtitleStyle}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
