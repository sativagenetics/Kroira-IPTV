<Page
    x:Class="Kroira.App.Views.ContinueWatchingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <Grid Padding="30,28,34,30" RowSpacing="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock Text="Continue Watching" Style="{StaticResource KroiraPageTitleStyle}" />
            <TextBlock
                Text="Resume saved movies and episodes, with live entries kept readable when they exist."
                Style="{StaticResource KroiraPageSubtitleStyle}"
                MaxWidth="720" />
        </StackPanel>

        <Border
            Grid.Row="1"
            Visibility="{x:Bind ViewModel.EmptyVisibility, Mode=OneWay}"
            Background="{StaticResource KroiraSurfaceBrush}"
            CornerRadius="12"
            Padding="24"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            MaxWidth="540">
            <StackPanel Spacing="14">
                <Border
                    Height="110"
                    CornerRadius="10"
                    Background="{StaticResource KroiraMediaGradientBrush}">
                    <Grid>
                        <Border
                            Width="58"
                            Height="58"
                            CornerRadius="10"
                            Background="{StaticResource KroiraSurfaceElevatedBrush}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                        <FontIcon Glyph="&#xE768;" Foreground="{StaticResource KroiraAccentBrush}" FontSize="28" />
                        <Border
                            Width="170"
                            Height="5"
                            Background="{StaticResource KroiraAccentBrush}"
                            CornerRadius="3"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom"
                            Margin="22,0,0,20" />
                        <Border
                            Width="300"
                            Height="5"
                            Background="{StaticResource KroiraSurfaceHighBrush}"
                            CornerRadius="3"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom"
                            Margin="22,0,0,20" />
                    </Grid>
                </Border>
                <TextBlock Text="Nothing to resume yet" Style="{StaticResource KroiraSectionTitleStyle}" />
                <TextBlock
                    Text="When playback progress is saved, the exact title and saved position will be listed here."
                    Style="{StaticResource KroiraPageSubtitleStyle}"
                    MaxWidth="430" />
            </StackPanel>
        </Border>

        <Grid
            Grid.Row="1"
            Visibility="{x:Bind ViewModel.ContentVisibility, Mode=OneWay}"
            ColumnSpacing="22"
            MaxWidth="1080"
            HorizontalAlignment="Left"
            VerticalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource KroiraPanelStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Padding="18,16,18,12" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="3">
                            <TextBlock Text="Resume queue" Style="{StaticResource KroiraSectionTitleStyle}" />
                            <TextBlock
                                Text="Rows use saved playback state only; duration is not estimated when unavailable."
                                Style="{StaticResource KroiraBodyStyle}" />
                        </StackPanel>
                        <TextBlock
                            Grid.Column="1"
                            Text="SAVED"
                            Foreground="{StaticResource KroiraTextTertiaryBrush}"
                            FontSize="11"
                            FontWeight="SemiBold"
                            CharacterSpacing="80"
                            VerticalAlignment="Center" />
                    </Grid>

                    <ListView
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.ProgressItems, Mode=OneWay}"
                        SelectionMode="Single"
                        SelectionChanged="ItemList_SelectionChanged"
                        ItemContainerStyle="{StaticResource KroiraMediaRowContainerStyle}"
                        Padding="10,0,10,10">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Background="{StaticResource KroiraSurfaceSoftBrush}"
                                    BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="12,14">
                                    <Grid ColumnSpacing="14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border
                                            Width="68"
                                            Height="68"
                                            CornerRadius="8"
                                            Background="{StaticResource KroiraMediaGradientBrush}"
                                            VerticalAlignment="Center">
                                            <Grid>
                                                <FontIcon Glyph="&#xE768;" Foreground="{StaticResource KroiraAccentBrush}" FontSize="18" Opacity="0.4" />
                                                <Border CornerRadius="8">
                                                    <Image Source="{Binding LogoUrl, Converter={StaticResource UrlToImageSourceConverter}}" Stretch="UniformToFill" />
                                                </Border>
                                                <Border
                                                    Height="22"
                                                    CornerRadius="0,0,8,8"
                                                    VerticalAlignment="Bottom">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#00000000" Offset="0" />
                                                            <GradientStop Color="#D8080A0D" Offset="1" />
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <TextBlock
                                                        Text="{Binding ProgressText}"
                                                        Foreground="{StaticResource KroiraAccentBrush}"
                                                        FontSize="8"
                                                        FontWeight="SemiBold"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Bottom"
                                                        Margin="0,0,0,3" />
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <Grid Grid.Column="1" RowSpacing="4" VerticalAlignment="Center">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock
                                                    Text="{Binding TypeLabel}"
                                                    Foreground="{StaticResource KroiraAccentBrush}"
                                                    FontSize="11"
                                                    FontWeight="SemiBold" />
                                                <TextBlock
                                                    Text="{Binding LastWatchedText}"
                                                    Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                    FontSize="11" />
                                            </StackPanel>

                                            <TextBlock
                                                Grid.Row="1"
                                                Text="{Binding Title}"
                                                Style="{StaticResource KroiraTitleStyle}"
                                                FontSize="13"
                                                MaxLines="1"
                                                TextTrimming="CharacterEllipsis" />

                                            <TextBlock
                                                Grid.Row="2"
                                                Text="{Binding ResumeContextText}"
                                                Style="{StaticResource KroiraBodyStyle}"
                                                MaxLines="1"
                                                TextTrimming="CharacterEllipsis" />
                                        </Grid>

                                        <Button
                                            Grid.Column="2"
                                            Content="Remove"
                                            Tag="{Binding Id}"
                                            Click="RemoveProgress_Click"
                                            Style="{StaticResource KroiraDangerButtonStyle}"
                                            FontSize="11"
                                            VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1" Spacing="14">
                <Border Style="{StaticResource KroiraPanelStyle}" Padding="18">
                    <StackPanel Spacing="12">
                        <Border
                            Width="48"
                            Height="48"
                            CornerRadius="8"
                            Background="{StaticResource KroiraSurfaceElevatedBrush}"
                            HorizontalAlignment="Left">
                            <FontIcon Glyph="&#xE102;" Foreground="{StaticResource KroiraAccentBrush}" FontSize="20" />
                        </Border>
                        <TextBlock Text="Resume with context" Style="{StaticResource KroiraSectionTitleStyle}" />
                        <TextBlock
                            Text="The list emphasizes type, saved position, and last saved time without inventing a duration or completion percentage."
                            Style="{StaticResource KroiraBodyStyle}" />
                    </StackPanel>
                </Border>

                <Border
                    Background="{StaticResource KroiraSurfaceSoftBrush}"
                    CornerRadius="10"
                    Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Progress policy" Style="{StaticResource KroiraLabelStyle}" />
                        <TextBlock Text="Exact saved position" Style="{StaticResource KroiraTitleStyle}" />
                        <TextBlock
                            Text="Duration-aware progress can be added later if the persistence model stores reliable durations."
                            Style="{StaticResource KroiraBodyStyle}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
