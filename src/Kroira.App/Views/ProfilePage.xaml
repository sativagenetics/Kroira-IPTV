<Page
    x:Class="Kroira.App.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <ScrollViewer>
        <Grid Padding="34,28,34,34"
              RowSpacing="22"
              MaxWidth="920"
              HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="24">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#281D10" Offset="0" />
                        <GradientStop Color="#111722" Offset="0.6" />
                        <GradientStop Color="#090A0D" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="72"
                            Height="72"
                            CornerRadius="18"
                            Background="{StaticResource KroiraSurfaceElevatedBrush}"
                            BorderBrush="{StaticResource KroiraChromeLineBrush}"
                            BorderThickness="1">
                        <FontIcon Glyph="&#xE77B;"
                                  FontSize="30"
                                  Foreground="{StaticResource KroiraAccentBrush}" />
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="Profile" Style="{StaticResource KroiraPageTitleStyle}" />
                        <TextBlock Text="Account tier and license state for this installation."
                                   Style="{StaticResource KroiraPageSubtitleStyle}"
                                   MaxWidth="680" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.35*" />
                    <ColumnDefinition Width="0.85*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource KroiraSettingsGroupStyle}">
                    <StackPanel Spacing="18">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="3">
                            <TextBlock Text="Account" Style="{StaticResource KroiraSectionTitleStyle}" />
                            <TextBlock Text="License state and account-oriented actions."
                                       Style="{StaticResource KroiraBodyStyle}" />
                        </StackPanel>
                        <Border Grid.Column="1"
                                Visibility="{x:Bind ViewModel.ProTierVisibility, Mode=OneWay}"
                                Background="{StaticResource KroiraSurfaceHighBrush}"
                                CornerRadius="8"
                                Padding="10,6"
                                VerticalAlignment="Center">
                            <TextBlock Text="PRO"
                                       Foreground="{StaticResource KroiraGoldBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Border>
                        <Border Grid.Column="1"
                                Visibility="{x:Bind ViewModel.FreeTierVisibility, Mode=OneWay}"
                                Background="{StaticResource KroiraSurfaceHighBrush}"
                                CornerRadius="8"
                                Padding="10,6"
                                VerticalAlignment="Center">
                            <TextBlock Text="FREE"
                                       Foreground="{StaticResource KroiraAccentBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Border>
                    </Grid>

                    <Border Height="1" Background="{StaticResource KroiraBorderBrush}" Opacity="0.45" />

                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="170" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Current tier" Style="{StaticResource KroiraTitleStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.LicenseStatusDescription, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       MaxWidth="560"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="Upgrade to Pro"
                                Command="{x:Bind ViewModel.UpgradeCommand}"
                                Visibility="{x:Bind ViewModel.FreeTierVisibility, Mode=OneWay}"
                                Style="{StaticResource KroiraPrimaryButtonStyle}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center" />
                    </Grid>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1" Spacing="16">
                    <Border Style="{StaticResource KroiraSettingsGroupStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Install state" Style="{StaticResource KroiraSectionTitleStyle}" />
                            <TextBlock Text="Licensing is scoped to this local app installation."
                                       Style="{StaticResource KroiraBodyStyle}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KroiraSettingsGroupStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Account surface" Style="{StaticResource KroiraSectionTitleStyle}" />
                            <TextBlock Text="Profile stays focused on tier state and account-oriented actions."
                                       Style="{StaticResource KroiraBodyStyle}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
