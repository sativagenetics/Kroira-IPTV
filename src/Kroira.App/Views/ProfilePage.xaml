<Page
    x:Class="Kroira.App.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:Kroira.App.ViewModels"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <ScrollViewer>
        <Grid Padding="34,28,34,34"
              RowSpacing="22"
              MaxWidth="1080"
              HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="24">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#281D10" Offset="0" />
                        <GradientStop Color="#111722" Offset="0.6" />
                        <GradientStop Color="#090A0D" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="72"
                            Height="72"
                            CornerRadius="18"
                            Background="{StaticResource KroiraSurfaceElevatedBrush}"
                            BorderBrush="{StaticResource KroiraChromeLineBrush}"
                            BorderThickness="1">
                        <FontIcon Glyph="&#xE77B;"
                                  FontSize="30"
                                  Foreground="{StaticResource KroiraAccentBrush}" />
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="Profiles" Style="{StaticResource KroiraPageTitleStyle}" />
                        <TextBlock Text="Separate library state, favorites, resume data, and family-safe access controls."
                                   Style="{StaticResource KroiraPageSubtitleStyle}"
                                   MaxWidth="760" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="1.15*" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="18">
                    <Border Style="{StaticResource KroiraSettingsGroupStyle}">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Active profile" Style="{StaticResource KroiraSectionTitleStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.ProfileCountText, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}" />

                            <ComboBox Visibility="{x:Bind ViewModel.ProfileSwitcherVisibility, Mode=OneWay}"
                                      Style="{StaticResource KroiraComboBoxStyle}"
                                      ItemsSource="{x:Bind ViewModel.Profiles, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedProfile, Mode=TwoWay}"
                                      DisplayMemberPath="Name"
                                      MinWidth="240" />

                            <TextBox Header="Profile name"
                                     Text="{x:Bind ViewModel.EditableProfileName, Mode=TwoWay}"
                                     PlaceholderText="Profile name" />

                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Button Content="Save name"
                                        Command="{x:Bind ViewModel.SaveProfileNameCommand}"
                                        Style="{StaticResource KroiraPrimaryButtonStyle}" />
                                <Button Content="Add profile"
                                        Command="{x:Bind ViewModel.AddProfileCommand}" />
                                <Button Content="Add kids profile"
                                        Command="{x:Bind ViewModel.AddKidsProfileCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KroiraSettingsGroupStyle}">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Access behavior" Style="{StaticResource KroiraSectionTitleStyle}" />
                            <ToggleSwitch Header="Kids-safe mode"
                                          IsOn="{x:Bind ViewModel.IsKidsSafeMode, Mode=TwoWay}" />
                            <ToggleSwitch Header="Hide locked content until unlocked"
                                          IsOn="{x:Bind ViewModel.HideLockedContent, Mode=TwoWay}" />
                            <TextBlock Text="{x:Bind ViewModel.AccessStatusText, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KroiraSettingsGroupStyle}">
                        <StackPanel Spacing="14">
                            <TextBlock Text="PIN" Style="{StaticResource KroiraSectionTitleStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.PinStatusText, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       TextWrapping="Wrap" />

                            <TextBox Header="Set or replace PIN"
                                     Text="{x:Bind ViewModel.PinDraft, Mode=TwoWay}"
                                     PlaceholderText="Enter PIN digits" />

                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Button Content="Save PIN"
                                        Visibility="{x:Bind ViewModel.SetPinVisibility, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.SetPinCommand}"
                                        Style="{StaticResource KroiraPrimaryButtonStyle}" />
                                <Button Content="Replace PIN"
                                        Visibility="{x:Bind ViewModel.ClearPinVisibility, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.SetPinCommand}"
                                        Style="{StaticResource KroiraPrimaryButtonStyle}" />
                                <Button Content="Clear PIN"
                                        Visibility="{x:Bind ViewModel.ClearPinVisibility, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.ClearPinCommand}" />
                            </StackPanel>

                            <TextBox Header="Unlock locked content"
                                     Text="{x:Bind ViewModel.UnlockPinDraft, Mode=TwoWay}"
                                     PlaceholderText="Enter PIN for this session" />

                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Button Content="Unlock"
                                        Visibility="{x:Bind ViewModel.UnlockVisibility, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.UnlockLockedContentCommand}" />
                                <Button Content="Hide locked content"
                                        Visibility="{x:Bind ViewModel.RelockVisibility, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.RelockContentCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Grid Grid.Column="1" RowSpacing="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource KroiraSettingsGroupStyle}">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Locked sources" Style="{StaticResource KroiraSectionTitleStyle}" />
                            <ItemsControl ItemsSource="{x:Bind ViewModel.SourceLocks, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:ProfileLockOptionViewModel">
                                        <CheckBox IsChecked="{x:Bind IsLocked, Mode=TwoWay}"
                                                  Margin="0,4,0,4">
                                            <StackPanel>
                                                <TextBlock Text="{x:Bind Label}" />
                                                <TextBlock Text="{x:Bind Detail}"
                                                           Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                           FontSize="12" />
                                            </StackPanel>
                                        </CheckBox>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource KroiraSettingsGroupStyle}">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Locked categories" Style="{StaticResource KroiraSectionTitleStyle}" />
                            <ItemsControl ItemsSource="{x:Bind ViewModel.CategoryLocks, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:ProfileLockOptionViewModel">
                                        <CheckBox IsChecked="{x:Bind IsLocked, Mode=TwoWay}"
                                                  Margin="0,4,0,4">
                                            <StackPanel>
                                                <TextBlock Text="{x:Bind Label}" />
                                                <TextBlock Text="{x:Bind Detail}"
                                                           Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                                           FontSize="12" />
                                            </StackPanel>
                                        </CheckBox>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
