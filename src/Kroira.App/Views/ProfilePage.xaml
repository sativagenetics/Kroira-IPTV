<Page
    x:Class="Kroira.App.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <ScrollViewer>
        <Grid Padding="34,28,34,34"
              RowSpacing="22"
              MaxWidth="920"
              HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="6">
                <TextBlock Text="Profile" Style="{StaticResource KroiraPageTitleStyle}" />
                <TextBlock Text="Account tier and license state for this installation."
                           Style="{StaticResource KroiraPageSubtitleStyle}"
                           MaxWidth="680" />
            </StackPanel>

            <Border Grid.Row="1"
                    Style="{StaticResource KroiraSettingsGroupStyle}">
                <StackPanel Spacing="18">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="3">
                            <TextBlock Text="Account" Style="{StaticResource KroiraSectionTitleStyle}" />
                            <TextBlock Text="License state and account-oriented actions."
                                       Style="{StaticResource KroiraBodyStyle}" />
                        </StackPanel>
                        <Border Grid.Column="1"
                                Visibility="{x:Bind ViewModel.ProTierVisibility, Mode=OneWay}"
                                Background="{StaticResource KroiraSurfaceHighBrush}"
                                CornerRadius="8"
                                Padding="10,6"
                                VerticalAlignment="Center">
                            <TextBlock Text="PRO"
                                       Foreground="{StaticResource KroiraGoldBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Border>
                        <Border Grid.Column="1"
                                Visibility="{x:Bind ViewModel.FreeTierVisibility, Mode=OneWay}"
                                Background="{StaticResource KroiraSurfaceHighBrush}"
                                CornerRadius="8"
                                Padding="10,6"
                                VerticalAlignment="Center">
                            <TextBlock Text="FREE"
                                       Foreground="{StaticResource KroiraAccentBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Border>
                    </Grid>

                    <Border Height="1" Background="{StaticResource KroiraBorderBrush}" Opacity="0.45" />

                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="170" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Current tier" Style="{StaticResource KroiraTitleStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.LicenseStatusDescription, Mode=OneWay}"
                                       Style="{StaticResource KroiraBodyStyle}"
                                       MaxWidth="560"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="Upgrade to Pro"
                                Command="{x:Bind ViewModel.UpgradeCommand}"
                                Visibility="{x:Bind ViewModel.FreeTierVisibility, Mode=OneWay}"
                                Style="{StaticResource KroiraPrimaryButtonStyle}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
