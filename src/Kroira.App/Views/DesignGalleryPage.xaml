<Page
    x:Class="Kroira.App.Views.DesignGalleryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Kroira.App.Controls"
    Background="{StaticResource KroiraPageBackgroundBrush}">

    <!--
        Hidden internal design gallery. Not wired into the NavigationView.
        Used to validate tokens, typography, and shared controls in isolation
        before pages adopt them. Navigate to it manually from code if needed:
          ContentFrame.Navigate(typeof(DesignGalleryPage));
    -->

    <ScrollViewer>
        <StackPanel Padding="40,28,40,40"
                    Spacing="32"
                    MaxWidth="1200"
                    HorizontalAlignment="Center">

            <controls:SectionEyebrow
                Eyebrow="INTERNAL"
                Title="Design Gallery"
                Caption="Visual validation surface for tokens, typography, and shared controls. Not part of the shipping navigation." />

            <!-- Typography ramp -->
            <StackPanel Spacing="12">
                <controls:SectionEyebrow Title="Typography" />
                <Border Style="{StaticResource KroiraPanelStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="FEATURED MOVIE" Style="{StaticResource KroiraEyebrowStyle}" />
                        <TextBlock Text="Display XL · hero title" Style="{StaticResource KroiraDisplayXlStyle}" />
                        <TextBlock Text="H1 · page title" Style="{StaticResource KroiraH1Style}" />
                        <TextBlock Text="Section title · rail header" Style="{StaticResource KroiraSectionTitleStyle}" />
                        <TextBlock Text="Title · card title" Style="{StaticResource KroiraTitleStyle}" />
                        <TextBlock Text="Body · paragraph copy sits here, secondary color, 13 px." Style="{StaticResource KroiraBodyStyle}" />
                        <TextBlock Text="Meta · 2023 · 2h 14m · 4K HDR" Style="{StaticResource KroiraMetaStyle}" />
                        <TextBlock Text="14:10:02 · 1.2 s · 44.5 MB" Style="{StaticResource KroiraMonoStyle}" />
                        <TextBlock Text="LABEL · tertiary uppercase" Style="{StaticResource KroiraLabelStyle}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Surfaces -->
            <StackPanel Spacing="12">
                <controls:SectionEyebrow Title="Surfaces" Caption="Layered tonal steps. No borders at rest." />
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Height="96" CornerRadius="10"
                            Background="{StaticResource KroiraSurfaceSoftBrush}">
                        <TextBlock Text="surface soft" Style="{StaticResource KroiraMetaStyle}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Border Grid.Column="1" Height="96" CornerRadius="10"
                            Background="{StaticResource KroiraSurfaceBrush}">
                        <TextBlock Text="surface" Style="{StaticResource KroiraMetaStyle}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Border Grid.Column="2" Height="96" CornerRadius="10"
                            Background="{StaticResource KroiraSurfaceElevatedBrush}">
                        <TextBlock Text="surface elevated" Style="{StaticResource KroiraMetaStyle}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Border Grid.Column="3" Height="96" CornerRadius="10"
                            Background="{StaticResource KroiraSurfaceHighBrush}">
                        <TextBlock Text="surface high" Style="{StaticResource KroiraMetaStyle}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </Grid>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Spacing="12">
                <controls:SectionEyebrow Title="Buttons" />
                <Border Style="{StaticResource KroiraPanelStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="Primary action" Style="{StaticResource KroiraPrimaryButtonStyle}" />
                        <Button Content="Secondary"      Style="{StaticResource KroiraButtonStyle}" />
                        <Button Content="Ghost"          Style="{StaticResource KroiraGhostButtonStyle}" />
                        <Button Content="Delete"         Style="{StaticResource KroiraDangerButtonStyle}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Inputs -->
            <StackPanel Spacing="12">
                <controls:SectionEyebrow Title="Inputs" />
                <Border Style="{StaticResource KroiraPanelStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBox PlaceholderText="Search channels, movies, series…"
                                 Style="{StaticResource KroiraTextBoxStyle}"
                                 Width="320" />
                        <ComboBox PlaceholderText="Sort by"
                                  Style="{StaticResource KroiraComboBoxStyle}"
                                  Width="160">
                            <ComboBoxItem Content="Recently added" />
                            <ComboBoxItem Content="A–Z" />
                            <ComboBoxItem Content="Year" />
                        </ComboBox>
                        <ToggleSwitch OnContent="On" OffContent="Off" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Status pills -->
            <StackPanel Spacing="12">
                <controls:SectionEyebrow Title="Status pills" Caption="One row across all operational states." />
                <Border Style="{StaticResource KroiraPanelStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <controls:StatusPill Label="HEALTHY" Kind="Healthy" />
                        <controls:StatusPill Label="STANDBY" Kind="Standby" />
                        <controls:StatusPill Label="SYNCING" Kind="Syncing" />
                        <controls:StatusPill Label="WARNING" Kind="Warning" />
                        <controls:StatusPill Label="FAILED"  Kind="Failed"  />
                        <controls:StatusPill Label="LIVE"    Kind="Live"    />
                        <controls:StatusPill Label="INFO"    Kind="Info"    />
                    </StackPanel>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
