<Window
    x:Class="Kroira.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Kroira.App"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{StaticResource KroiraPageAtmosphereBrush}">
        <NavigationView x:Name="RootNavView"
                        ItemInvoked="RootNavView_ItemInvoked"
                        PaneOpening="RootNavView_PaneOpening"
                        PaneClosing="RootNavView_PaneClosing"
                        Background="Transparent"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        PaneDisplayMode="LeftCompact"
                        IsPaneOpen="True"
                        OpenPaneLength="214"
                        CompactPaneLength="58">
            <NavigationView.PaneHeader>
                <Grid x:Name="PaneHeaderRoot" Margin="16,26,12,28" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="26"
                            Height="26"
                            CornerRadius="7"
                            Background="{StaticResource KroiraAccentContainerBrush}"
                            BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                            BorderThickness="1">
                        <TextBlock Text="K"
                                   Foreground="{StaticResource KroiraAccentBrush}"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock x:Name="PaneBrandText"
                               Grid.Column="1"
                               Text="KROIRA IPTV"
                               Foreground="{StaticResource KroiraTextPrimaryBrush}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               CharacterSpacing="90"
                               VerticalAlignment="Center" />
                </Grid>
            </NavigationView.PaneHeader>
            <NavigationView.MenuItems>
                <NavigationViewItem Icon="Home" Content="Home" Tag="Home" Margin="8,3" Height="38" />
                <NavigationViewItemSeparator />
                <NavigationViewItem Icon="Video" Content="Live TV" Tag="Channels" Margin="8,3" Height="38" />
                <NavigationViewItem Icon="Video" Content="Movies" Tag="Movies" Margin="8,3" Height="38" />
                <NavigationViewItem Icon="Library" Content="Series" Tag="Series" Margin="8,3" Height="38" />
                <NavigationViewItem Icon="OutlineStar" Content="Favorites" Tag="Favorites" Margin="8,3" Height="38" />
                <NavigationViewItemSeparator />
                <NavigationViewItem Icon="Library" Content="Sources" Tag="Sources" Margin="8,3" Height="38" />
                <NavigationViewItem Icon="Library" Content="Settings" Tag="Settings" Margin="8,3" Height="38" />
                <NavigationViewItemSeparator />
                <NavigationViewItem Icon="Home" Content="Profile" Tag="Profile" Margin="8,3" Height="38" />
            </NavigationView.MenuItems>
            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>
