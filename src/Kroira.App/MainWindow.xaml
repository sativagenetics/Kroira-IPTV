<Window
    x:Class="Kroira.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Kroira.App"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{StaticResource KroiraPageAtmosphereBrush}">
        <Border HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                Height="1"
                Background="{StaticResource KroiraChromeLineBrush}" />
        <NavigationView x:Name="RootNavView"
                        ItemInvoked="RootNavView_ItemInvoked"
                        PaneOpening="RootNavView_PaneOpening"
                        PaneClosing="RootNavView_PaneClosing"
                        Background="Transparent"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        PaneDisplayMode="LeftCompact"
                        IsPaneOpen="True"
                        OpenPaneLength="236"
                        CompactPaneLength="64"
                        UseSystemFocusVisuals="True">
            <NavigationView.PaneHeader>
                <Grid x:Name="PaneHeaderRoot" Margin="18,28,14,30" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="30"
                            Height="30"
                            CornerRadius="8"
                            BorderBrush="{StaticResource KroiraChromeLineBrush}"
                            BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#3A2A17" Offset="0" />
                                <GradientStop Color="#12161D" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="K"
                                   Foreground="{StaticResource KroiraAccentBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <StackPanel x:Name="PaneBrandText"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Spacing="1">
                        <TextBlock Text="KROIRA"
                                   Foreground="{StaticResource KroiraTextPrimaryBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   CharacterSpacing="120" />
                        <TextBlock Text="IPTV STUDIO"
                                   Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   CharacterSpacing="160" />
                    </StackPanel>
                </Grid>
            </NavigationView.PaneHeader>
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Home" Tag="Home" Margin="0,2" Height="42">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" FontSize="16" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Continue Watching" Tag="ContinueWatching" Margin="0,2" Height="42">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE916;" FontSize="16" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Library"
                                    Tag="MediaLibrary"
                                    Margin="0,2"
                                    Height="42"
                                    Visibility="{x:Bind MediaLibraryNavigationVisibility, Mode=OneWay}">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7C3;" FontSize="16" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItemSeparator />
                <NavigationViewItem Content="Live TV" Tag="Channels" Margin="0,2" Height="42">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE714;" FontSize="16" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Movies" Tag="Movies" Margin="0,2" Height="42">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8B2;" FontSize="16" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Series" Tag="Series" Margin="0,2" Height="42">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8A9;" FontSize="16" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Favorites" Tag="Favorites" Margin="0,2" Height="42">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE734;" FontSize="16" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItemSeparator />
                <NavigationViewItem Content="Sources" Tag="Sources" Margin="0,2" Height="42">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8F1;" FontSize="16" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Settings" Tag="Settings" Margin="0,2" Height="42">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" FontSize="16" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItemSeparator />
                <NavigationViewItem Content="Profile" Tag="Profile" Margin="0,2" Height="42">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE77B;" FontSize="16" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <NavigationView.PaneFooter>
                <Border x:Name="PaneFooterRoot"
                        Margin="18,16,16,22"
                        Padding="12,10"
                        Background="#8A10141A"
                        BorderBrush="{StaticResource KroiraGlassBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel Spacing="3">
                        <TextBlock Text="SESSION"
                                   Foreground="{StaticResource KroiraTextTertiaryBrush}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   CharacterSpacing="140" />
                        <TextBlock Text="Ready"
                                   Foreground="{StaticResource KroiraTextPrimaryBrush}"
                                   FontSize="13"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </NavigationView.PaneFooter>
            <Grid Background="Transparent">
                <Border Margin="0,0,0,0"
                        Background="#3305070A"
                        BorderBrush="#14FFFFFF"
                        BorderThickness="1,0,0,0">
                    <Frame x:Name="ContentFrame" />
                </Border>
            </Grid>
        </NavigationView>
    </Grid>
</Window>
