<UserControl
    x:Class="Kroira.App.Controls.SectionEyebrow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Spacing="6">
        <TextBlock x:Name="EyebrowText"
                   Style="{StaticResource KroiraEyebrowStyle}"
                   Visibility="Collapsed" />
        <TextBlock x:Name="TitleText"
                   Style="{StaticResource KroiraSectionTitleStyle}" />
        <TextBlock x:Name="CaptionText"
                   Style="{StaticResource KroiraMetaStyle}"
                   Visibility="Collapsed"
                   MaxWidth="720" />
    </StackPanel>
</UserControl>
