<UserControl
    x:Class="Kroira.App.Controls.AmbientPageBackground"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    IsHitTestVisible="False">

    <Grid Background="{StaticResource KroiraPageAtmosphereBrush}">
        <Rectangle Opacity="0.55"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0.8">
                    <GradientStop Color="#401E0C2F" Offset="0" />
                    <GradientStop Color="#16112A4D" Offset="0.38" />
                    <GradientStop Color="#0005060A" Offset="0.78" />
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle Height="340"
                   VerticalAlignment="Top"
                   Opacity="0.44">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#5A381462" Offset="0" />
                    <GradientStop Color="#24122C52" Offset="0.46" />
                    <GradientStop Color="#0005060A" Offset="1" />
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle Width="520"
                   Height="520"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Opacity="0.18"
                   Margin="0,-170,-140,0">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#7A7AA7FF" Offset="0" />
                    <GradientStop Color="#183B174D" Offset="0.6" />
                    <GradientStop Color="#0005060A" Offset="1" />
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle Opacity="0.74"
                   VerticalAlignment="Bottom"
                   Height="360">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#0005060A" Offset="0" />
                    <GradientStop Color="#F205060A" Offset="1" />
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
    </Grid>
</UserControl>
