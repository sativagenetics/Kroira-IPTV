<UserControl
    x:Class="Kroira.App.Controls.StatusPill"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border x:Name="PillRoot"
            Background="{StaticResource KroiraStateNeutralSoftBrush}"
            CornerRadius="{StaticResource KroiraRadiusChip}"
            Padding="10,4"
            HorizontalAlignment="Left"
            VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Ellipse x:Name="Dot"
                     Width="6" Height="6"
                     Fill="{StaticResource KroiraStateNeutralBrush}"
                     VerticalAlignment="Center" />
            <TextBlock x:Name="LabelText"
                       Text="STATUS"
                       FontFamily="{StaticResource KroiraTextFontFamily}"
                       FontSize="11"
                       FontWeight="SemiBold"
                       CharacterSpacing="80"
                       Foreground="{StaticResource KroiraStateNeutralBrush}"
                       VerticalAlignment="Center" />
        </StackPanel>
    </Border>
</UserControl>
