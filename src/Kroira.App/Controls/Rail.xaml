<UserControl
    x:Class="Kroira.App.Controls.Rail"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RailRoot" Height="130">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Button
            x:Name="PreviousButton"
            Grid.Column="0"
            Width="36"
            Height="36"
            MinWidth="36"
            Padding="0"
            Margin="0,0,12,0"
            VerticalAlignment="Center"
            Click="PreviousButton_Click"
            Style="{StaticResource KroiraGhostButtonStyle}"
            ToolTipService.ToolTip="Previous">
            <FontIcon Glyph="&#xE76B;" FontSize="12" />
        </Button>

        <ScrollViewer
            x:Name="RailScrollViewer"
            Grid.Column="1"
            HorizontalScrollBarVisibility="Hidden"
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Disabled"
            VerticalScrollMode="Disabled"
            BringIntoViewOnFocusChange="False"
            ZoomMode="Disabled"
            ViewChanged="RailScrollViewer_ViewChanged">
            <ItemsRepeater
                x:Name="RailRepeater"
                ItemsSource="{x:Null}">
                <ItemsRepeater.Layout>
                    <StackLayout
                        x:Name="RailStackLayout"
                        Orientation="Horizontal"
                        Spacing="14" />
                </ItemsRepeater.Layout>
            </ItemsRepeater>
        </ScrollViewer>

        <Button
            x:Name="NextButton"
            Grid.Column="2"
            Width="36"
            Height="36"
            MinWidth="36"
            Padding="0"
            Margin="12,0,0,0"
            VerticalAlignment="Center"
            Click="NextButton_Click"
            Style="{StaticResource KroiraGhostButtonStyle}"
            ToolTipService.ToolTip="Next">
            <FontIcon Glyph="&#xE76C;" FontSize="12" />
        </Button>
    </Grid>
</UserControl>
